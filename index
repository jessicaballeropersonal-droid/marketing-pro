    dg.sort(function(a,b){
      if(a.turno!==b.turno)return a.turno==='dia'?-1:1;
      return a.origen==='auto'?-1:1;
    });
    var dayVj=dg.reduce(function(a,g){return a+g.totalVj;},0);
    var dayM3=dg.reduce(function(a,g){return a+g.totalM3;},0);
    html+='<tr><td colspan="8" style="padding:6px 4px 4px"><div style="background:var(--bg3);border-left:3px solid var(--or);border-radius:0 6px 6px 0;padding:5px 12px;display:flex;align-items:center;gap:10px">'
