        +'<div style="font-size:10px;color:#854F0B;margin-top:3px;font-family:var(--M)">⏳ La IA está buscando en internet · puede tardar 30-90 segundos</div>'
        +'<div style="font-size:9px;color:var(--tx3);margin-top:2px;font-family:var(--M)">Tiempo transcurrido: '+seg+'s · No cierres esta ventana</div>'
      +'</div>'
    +'</div>'
    +'<style>@keyframes pulse{0%,100%{opacity:1}50%{opacity:.85}}@keyframes spin{from{transform:rotate(0deg)}to{transform:rotate(360deg)}}</style>';
    // Auto-actualizar contador cada segundo mientras carga
    if(!_RAST._intervalRefresh){_RAST._intervalRefresh=setInterval(function(){if(_RAST.buscandoVentana)renderRastreador();else{clearInterval(_RAST._intervalRefresh);_RAST._intervalRefresh=null;}},1000);}
  }
  html+=_rastRenderConfig();
  html+=_rastRenderFiltros();
  html+=_rastRenderModeTabs();
  if(_RAST.vista==='ventanas'){
    html+=_rastRenderVentanasTabs();
    html+=_rastRenderVentanaContenido();
  }else if(_RAST.vista==='seguimiento'){
    html+=_rastRenderSeguimiento();
  }else if(_RAST.vista==='tareas'){
    html+=_rastRenderTareasFiltradas();
  }else if(_RAST.vista==='historial'){
    html+=_rastRenderHistorial();
  }
  body.innerHTML=html;
}
