  scope:'https://www.googleapis.com/auth/calendar.events',
  tokenClient:null, gapiReady:false, gisReady:false, token:null,
  cur:new Date(), events:[]
};
function _gcalLoadScript(src,cb){
  var s=document.createElement('script');s.src=src;s.async=true;s.defer=true;
  s.onload=cb;s.onerror=function(){_gcalMsg('No se pudo cargar Google ('+src+'). Revisa tu conexión.');};
  document.head.appendChild(s);
}
function _gcalInit(cb){
  // Carga gapi + GIS una sola vez
  function tryReady(){ if(_GCAL.gapiReady&&_GCAL.gisReady&&cb)cb(); }
  if(!window.gapi){
    _gcalLoadScript('https://apis.google.com/js/api.js',function(){
      gapi.load('client',function(){
        gapi.client.init({discoveryDocs:['https://www.googleapis.com/discovery/v1/apis/calendar/v3/rest']})
          .then(function(){_GCAL.gapiReady=true;tryReady();});
      });
    });
  } else if(!_GCAL.gapiReady){ gapi.load('client',function(){gapi.client.init({discoveryDocs:['https://www.googleapis.com/discovery/v1/apis/calendar/v3/rest']}).then(function(){_GCAL.gapiReady=true;tryReady();});}); }
  else _GCAL.gapiReady=true;
  if(!window.google||!window.google.accounts){
    _gcalLoadScript('https://accounts.google.com/gsi/client',function(){
      _GCAL.tokenClient=google.accounts.oauth2.initTokenClient({
        client_id:_GCAL.clientId, scope:_GCAL.scope,
        callback:function(resp){
          if(resp&&resp.access_token){
            _GCAL.token=resp.access_token;
            gapi.client.setToken({access_token:resp.access_token});
            try{localStorage.setItem('gcal_tok',resp.access_token);localStorage.setItem('gcal_tok_exp',Date.now()+3500*1000);}catch(_){}
            _gcalFetchAndRender();
          }
        }
      });
      _GCAL.gisReady=true;tryReady();
    });
  } else { _GCAL.gisReady=true; if(!_GCAL.tokenClient){_GCAL.tokenClient=google.accounts.oauth2.initTokenClient({client_id:_GCAL.clientId,scope:_GCAL.scope,callback:function(resp){if(resp&&resp.access_token){_GCAL.token=resp.access_token;gapi.client.setToken({access_token:resp.access_token});try{localStorage.setItem('gcal_tok',resp.access_token);localStorage.setItem('gcal_tok_exp',Date.now()+3500*1000);}catch(_){}_gcalFetchAndRender();}}});} tryReady(); }
}
function _gcalEnsureToken(){ try{ if(_GCAL.token&&window.gapi&&gapi.client) gapi.client.setToken({access_token:_GCAL.token}); }catch(_){} }
function _gcalSilentReconnect(){
  _gcalInit(function(){ if(_GCAL.tokenClient){ try{_GCAL.tokenClient.requestAccessToken({prompt:''});}catch(_){} } });
}
function _gcalConnected(){
  try{var t=localStorage.getItem('gcal_tok'),e=parseInt(localStorage.getItem('gcal_tok_exp')||'0');
    if(t&&e&&Date.now()<e){_GCAL.token=t;return true;}}catch(_){}
  return !!_GCAL.token;
}
function gcalConnect(){
  try{localStorage.setItem('gcal_auto','1');}catch(_){}
  _gcalInit(function(){
    if(_GCAL.tokenClient)_GCAL.tokenClient.requestAccessToken({prompt:_gcalConnected()?'':'consent'});
  });
}
function gcalDisconnect(){
  try{localStorage.removeItem('gcal_tok');localStorage.removeItem('gcal_tok_exp');localStorage.removeItem('gcal_auto');}catch(_){}
  _GCAL.token=null;_GCAL.events=[];
  try{if(gapi&&gapi.client)gapi.client.setToken(null);}catch(_){}
  renderCalendario();
}
function _gcalMsg(m){var el=G('gcal-msg');if(el)el.textContent=m;}
function _gcalMonthRange(d){
  var first=new Date(d.getFullYear(),d.getMonth(),1);
  var last=new Date(d.getFullYear(),d.getMonth()+1,0,23,59,59);
  return {min:first.toISOString(),max:last.toISOString()};
}
function _gcalFetchAndRender(){
  if(!_gcalConnected()){renderCalendario();return;}
  if(!_GCAL.gapiReady){_gcalInit(_gcalFetchAndRender);return;}
  gapi.client.setToken({access_token:_GCAL.token});
  var r=_gcalMonthRange(_GCAL.cur);
  _gcalMsg('Cargando eventos…');
  gapi.client.calendar.events.list({calendarId:'primary',timeMin:r.min,timeMax:r.max,singleEvents:true,orderBy:'startTime',maxResults:250})
    .then(function(resp){_GCAL.events=(resp.result.items||[]);_gcalMsg('');renderCalendario();})
    .catch(function(err){
      // token expirado → re-pedir
      if(err&&err.status===401){_gcalSilentReconnect();}
      else _gcalMsg('Error al leer Google Calendar: '+((err&&err.result&&err.result.error&&err.result.error.message)||'desconocido'));
    });
}
function _gcalEvDate(ev){var s=ev.start||{};return (s.dateTime||s.date||'').slice(0,10);}
function _gcalEvHora(ev){var s=ev.start||{};if(s.date)return'Todo el día';return (s.dateTime||'').slice(11,16);}
