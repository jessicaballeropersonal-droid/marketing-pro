// === PARTE 7: Seguimiento (kanban) ===
function _rastRenderSeguimiento(){
  var estados=_RAST.modoActivo==='b2b'?S.rastreadorEstadosB2B:S.rastreadorEstadosLicitar;
  var items=_RAST.modoActivo==='b2b'?S.rastreadorLeads:S.rastreadorOportunidades;
  var html='<div style="background:var(--bg3);padding:8px 10px;border-radius:7px;margin-bottom:10px;display:flex;justify-content:space-between;align-items:center;font-size:11px">';
  html+='<span style="font-weight:600;color:var(--tx1)">📊 Seguimiento — '+(_RAST.modoActivo==='b2b'?'Leads B2B':'Oportunidades a Licitar')+'</span>';
  html+='<span style="font-family:var(--M);font-size:10px;color:var(--tx3)">'+items.length+' total</span>';
  html+='</div>';
  if(!items.length){
    html+='<div style="text-align:center;padding:30px 14px;color:var(--tx3);font-size:11px;background:var(--bg3);border-radius:8px;font-style:italic">Sin items aún. Marca ⭐ Interesado en una alerta para que aparezca aquí.</div>';
    return html;
  }
  // Kanban: una fila por estado
  estados.forEach(function(e){
    var its=items.filter(function(x){return (x.estadoId||estados[0].id)===e.id;});
    html+='<div style="margin-bottom:14px"><div style="font-size:11px;font-weight:700;color:var(--tx1);margin-bottom:6px;letter-spacing:.5px;font-family:var(--M);text-transform:uppercase">'+_rastEsc(e.nombre)+' <span style="background:var(--bg3);color:var(--tx2);font-size:9px;padding:1px 6px;border-radius:6px;margin-left:4px">'+its.length+'</span></div>';
    if(!its.length){html+='<div style="background:var(--bg3);border-radius:6px;padding:9px;font-size:10px;color:var(--tx3);text-align:center;font-style:italic;font-family:var(--M)">—</div>';}
    else{
      its.forEach(function(it){
        html+='<div style="background:#fff;border:1px solid var(--bd1);border-left:3px solid var(--ok);border-radius:9px;padding:10px;margin-bottom:6px">';
        html+='<div style="font-size:12px;font-weight:600;color:var(--tx1);line-height:1.3;margin-bottom:3px">'+_rastEsc(it.nombre||it.titulo||'?')+'</div>';
        var meta=[];
        if(it.nit)meta.push('NIT '+it.nit);
        if(it.telefono)meta.push('📞 '+it.telefono);
        if(it.municipio)meta.push(it.municipio);
        if(it.valor)meta.push(_rastFmt$(it.valor));
        if(it.fecha_cierre)meta.push('Cierre: '+it.fecha_cierre);
        if(meta.length)html+='<div style="font-size:9px;color:var(--tx2);line-height:1.4;font-family:var(--M);margin-bottom:5px">'+meta.join(' · ')+'</div>';
        // Selector de estado
        html+='<select onchange="rastItemMover(\''+it.id+'\',this.value)" style="background:var(--bg4);border:1px solid var(--bd2);border-radius:5px;padding:3px 8px;font-size:10px;font-family:var(--M);width:100%">';
        estados.forEach(function(es){html+='<option value="'+es.id+'"'+((it.estadoId||estados[0].id)===es.id?' selected':'')+'>'+_rastEsc(es.nombre)+'</option>';});
        html+='</select>';
        html+='</div>';
      });
    }
    html+='</div>';
  });
  return html;
}

// === PARTE 8: Tareas filtradas ===
function _rastRenderTareasFiltradas(){
  var tareas=(S.tareas||[]).filter(function(t){return t.origen==='rastreador';});
  var html='<div style="background:var(--bg3);padding:8px 10px;border-radius:7px;margin-bottom:10px;font-size:11px;font-weight:600;color:var(--tx1)">✅ Auto-tareas del rastreador <span style="font-family:var(--M);font-size:10px;color:var(--tx3);font-weight:500;margin-left:4px">'+tareas.length+' total</span></div>';
  if(!tareas.length){
    html+='<div style="text-align:center;padding:30px 14px;color:var(--tx3);font-size:11px;background:var(--bg3);border-radius:8px;font-style:italic">Sin auto-tareas aún. Las que crees con ⭐ Interesado aparecerán aquí y también en el módulo Tareas Gerencial.</div>';
    return html;
  }
