function _lubSemaforo(temp,tempMax){
  if(!temp||isNaN(temp))return{cls:'tx3',ico:'⚪',txt:'Sin registro'};
  var diff=tempMax-temp;
  if(temp>tempMax)     return{cls:'er',ico:'🔴',txt:'ALERTA — superó límite'};
  if(diff<=10)         return{cls:'wa',ico:'🟡',txt:'Precaución — '+diff+'°C del límite'};
  return{cls:'ok',ico:'🟢',txt:'Normal'};
}

// Última lubricación de un rodamiento
function _lubUltima(maqId,rodId){
  var hist=(S.lubHistorial||[]).filter(function(r){
    return r.maquinaId===maqId&&r.rodamientoId===rodId;
  }).sort(function(a,b){return b.timestamp-a.timestamp;});
  return hist.length?hist[0]:null;
}

// Horas acumuladas desde Tiempos Op / Bitácora
function _lubHorasAcum(maqId){
  var total=0;
  (S.mantBitacoras||[]).forEach(function(b){
    if(b.equipoId===maqId)total+=parseFloat(b.horas)||0;
  });
  // Also from prod records
  (S.prod.records||[]).forEach(function(r){
    if(r.maqPlantaId===maqId){
      var clasif=r.tiemClasif||{};
      total+=parseFloat(clasif.operado)||0;
    }
  });
  return Math.round(total*10)/10;
}

