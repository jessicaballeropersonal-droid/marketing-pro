function _dashDisp(){
  var hoy=today();
  var recs=(S.prod.records||[]).filter(function(r){return r.fecha===hoy&&r.tiemClasif;});
  var html='';
  if(!recs.length){html='<div style="font-size:12px;color:var(--tx3);padding:16px 0;text-align:center">Sin tiempos registrados hoy</div>';}
  else{
    var dDia=recs.filter(function(r){return r.turno==='dia';});
    var dNoc=recs.filter(function(r){return r.turno==='noche';});
    function calcT(arr){var op=0,mn=0,mu=0;arr.forEach(function(r){op+=parseFloat((r.tiemClasif||{}).operado)||0;mn+=parseFloat((r.tiemClasif||{}).mantenimiento)||0;mu+=(((r.tiemClasif||{}).muertos)||[]).reduce(function(a,m){return a+(parseFloat(m.horas)||0);},0);});var tot=op+mn+mu;return tot>0?Math.round((op/tot)*100):null;}
    var dD=calcT(dDia),dN=calcT(dNoc);
    html='<div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;padding:8px 0">'
      +'<div style="text-align:center"><div style="font-size:20px;font-weight:700;color:'+(dD===null?'var(--tx3)':dD>=80?'var(--ok)':dD>=70?'var(--wa)':'var(--er)')+'\">'+(dD===null?'—':dD+'%')+'</div><div style="font-family:var(--M);font-size:8px;color:var(--tx3)">☀️ TURNO DÍA</div></div>'
      +'<div style="text-align:center"><div style="font-size:20px;font-weight:700;color:'+(dN===null?'var(--tx3)':dN>=80?'var(--ok)':dN>=70?'var(--wa)':'var(--er)')+'\">'+(dN===null?'—':dN+'%')+'</div><div style="font-family:var(--M);font-size:8px;color:var(--tx3)">🌙 TURNO NOCHE</div></div>'
      +'</div>';
  }
  _dashCard('dash-disp-card','⏱️ Disponibilidad Hoy',html);
}

