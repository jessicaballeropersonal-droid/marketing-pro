function saveBackupLocal(){
  var fechaHoy=today();
  var nombreSugerido='crusher-respaldo-'+fechaHoy+'.json';
  var data=JSON.stringify(S,null,2);
  // Usar File System Access API si está disponible (Chrome/Edge): permite elegir carpeta
  if(window.showSaveFilePicker){
    window.showSaveFilePicker({
      suggestedName:nombreSugerido,
      types:[{description:'Crusher Backup JSON',accept:{'application/json':['.json']}}]
    }).then(function(fileHandle){
      return fileHandle.createWritable().then(function(writable){
        return writable.write(data).then(function(){return writable.close();});
      }).then(function(){return fileHandle.name;});
    }).then(function(nombre){
      // Registrar fecha del backup local (Supabase + localStorage como respaldo)
      var nowIso=new Date().toISOString();
      S.lastBackupLocal=nowIso;
      try{supaUpsert('config',{key:'lastBackupLocal',value:JSON.stringify(nowIso)});}catch(_){}
      try{localStorage.setItem('crusherpro_lastBackupLocal',nowIso);}catch(_){}
      try{updBackupBadge();}catch(_){}
      try{logActividad({accion:'crear',modulo:'parametros',descripcion:'Backup Local descargado · '+nombre});}catch(_){}
      // Feedback visual: usa modalAviso (funciona desde cualquier pantalla)
      try{showAlert('param-alert','ok','✅ Backup guardado: '+nombre);}catch(_){}
      try{
        modalAviso({
          tipo:'success',
          titulo:'✅ Backup guardado',
          subtitulo:'Respaldo descargado correctamente',
          contenidoHtml:'<div style="font-size:12px;color:var(--tx2);line-height:1.6">Se guardó el archivo:<br><strong style="color:var(--ok);font-family:var(--M);font-size:11px">'+nombre+'</strong></div>',
          botonSecundario:'Cerrar'
        });
      }catch(_){}
    }).catch(function(e){
      // Si el usuario canceló, no mostrar error
      if(e&&(e.name==='AbortError'||(e.message||'').includes('aborted'))){return;}
      // Error real → fallback al método antiguo
      _saveBackupLocalFallback(data,nombreSugerido,e);
    });
  } else {
    // Navegador sin soporte (Firefox, Safari) → descarga directa a carpeta por defecto
    _saveBackupLocalFallback(data,nombreSugerido,null);
  }
}

function _saveBackupLocalFallback(data,nombreSugerido,errOriginal){
  try{
    var blob=new Blob([data],{type:'application/json'});
    var url=URL.createObjectURL(blob);
    var a=document.createElement('a');
    a.href=url;a.download=nombreSugerido;
    document.body.appendChild(a);a.click();document.body.removeChild(a);
    URL.revokeObjectURL(url);
    // Registrar
    var nowIso=new Date().toISOString();
    S.lastBackupLocal=nowIso;
    try{supaUpsert('config',{key:'lastBackupLocal',value:JSON.stringify(nowIso)});}catch(_){}
    try{localStorage.setItem('crusherpro_lastBackupLocal',nowIso);}catch(_){}
    try{updBackupBadge();}catch(_){}
    try{logActividad({accion:'crear',modulo:'parametros',descripcion:'Backup Local descargado (fallback) · '+nombreSugerido});}catch(_){}
    try{showAlert('param-alert','ok','✅ Backup descargado: '+nombreSugerido);}catch(_){}
    try{
      modalAviso({
        tipo:'success',
        titulo:'✅ Backup descargado',
        subtitulo:'Guardado en carpeta de Descargas',
        contenidoHtml:'<div style="font-size:12px;color:var(--tx2);line-height:1.6">Se descargó el archivo:<br><strong style="color:var(--ok);font-family:var(--M);font-size:11px">'+nombreSugerido+'</strong></div>',
        botonSecundario:'Cerrar'
      });
    }catch(_){}
  }catch(e){
    var msgErr=(errOriginal&&errOriginal.message)||e.message||'Error desconocido';
    modalAviso({tipo:'danger',titulo:'Error al descargar',contenidoHtml:'<div style="font-size:12px;color:var(--tx2);line-height:1.6;margin-bottom:8px">No se pudo descargar el backup.</div><div style="background:var(--bg3);border-radius:6px;padding:8px 10px;font-family:var(--M);font-size:9px;color:var(--er);line-height:1.5">'+msgErr+'</div>',botonSecundario:'Entendido'});
  }
}

function _backupDiasDesde(iso){
  if(!iso)return null;
  try{
    var d=new Date(iso);
    var ahora=new Date();
    var ms=ahora-d;
    return Math.floor(ms/(1000*60*60*24));
  }catch(_){return null;}
}

function updBackupBadge(){
  var badge=G('tb-backup-badge');
  if(!badge)return;
  // Solo admin ve el badge
  if(!SESION||SESION.rol!=='admin'){badge.style.display='none';return;}
  badge.style.display='inline-flex';
  badge.style.alignItems='center';
  badge.style.gap='4px';
  // v171.5: Considerar el más reciente entre local y nube
  var isoCloud=S.lastBackupCloud||null;
  var isoLocal=S.lastBackupLocal||null;
  var iso=null;
  if(isoCloud&&isoLocal)iso=(new Date(isoCloud)>new Date(isoLocal))?isoCloud:isoLocal;
  else iso=isoCloud||isoLocal;
  var dias=_backupDiasDesde(iso);
  if(dias===null){
    // Nunca se ha hecho backup
    badge.innerHTML='💾 Sin backup aún';
    badge.style.background='var(--inA)';
    badge.style.color='var(--in)';
    badge.style.border='1px solid var(--inB)';
  }else if(dias<=2){
    badge.innerHTML='✅ Backup hace '+(dias===0?'hoy':dias+'d');
    badge.style.background='var(--okA)';
    badge.style.color='var(--ok)';
    badge.style.border='1px solid var(--okB)';
  }else if(dias<=6){
    badge.innerHTML='⚠️ Backup hace '+dias+'d';
    badge.style.background='var(--orA)';
    badge.style.color='var(--or)';
    badge.style.border='1px solid var(--or)';
  }else{
    badge.innerHTML='🚨 Backup hace '+dias+'d';
    badge.style.background='var(--erA)';
    badge.style.color='var(--er)';
    badge.style.border='1px solid var(--erB)';
  }
}

function checkBackupRecordatorio(){
  // Solo admin
  if(!SESION||SESION.rol!=='admin')return;
  // v171.5: Considerar el más reciente entre local y nube
  var isoCloud=S.lastBackupCloud||null;
  var isoLocal=S.lastBackupLocal||null;
  var iso=null;
  if(isoCloud&&isoLocal)iso=(new Date(isoCloud)>new Date(isoLocal))?isoCloud:isoLocal;
