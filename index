function _checkDocAlertasConductor(cond){
  var hoy=today();
  var dias=cond.diasAlerta||30;
  var pronto=_addDays(hoy,dias);
  var alertas=[];
  if(cond.soatVence){
    if(cond.soatVence<hoy)alertas.push('⚠️ SOAT VENCIDO — '+cond.nombre+(cond.placa?' ('+cond.placa+')':''));
    else if(cond.soatVence<=pronto)alertas.push('⚠️ SOAT por vencer el '+fd(cond.soatVence)+' — '+cond.nombre+(cond.placa?' ('+cond.placa+')':''));
  }
  if(cond.rtmVence){
    if(cond.rtmVence<hoy)alertas.push('⚠️ TECNOMECÁNICA VENCIDA — '+cond.nombre+(cond.placa?' ('+cond.placa+')':''));
    else if(cond.rtmVence<=pronto)alertas.push('⚠️ Tecnomecánica por vencer el '+fd(cond.rtmVence)+' — '+cond.nombre+(cond.placa?' ('+cond.placa+')':''));
  }
  if(cond.licVence){
    if(cond.licVence<hoy)alertas.push('⚠️ LICENCIA VENCIDA — '+cond.nombre);
    else if(cond.licVence<=pronto)alertas.push('⚠️ Licencia por vencer el '+fd(cond.licVence)+' — '+cond.nombre);
  }
  alertas.forEach(function(msg){
    dispararAlerta('doc_vence','🚛 OPERAX — Documentos vehículo\n'+msg);
  });
}
