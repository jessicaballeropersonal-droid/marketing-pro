// ── Guardar entrada ──

function acpmDelRow(e){var id=e.currentTarget.getAttribute('data-id');delAcpmEntrada(id);}
function delAcpmEntrada(id){
  var e=(S.acpmEntradas||[]).find(function(x){return x.id===id;});
  if(!e){return;}
  var litros=parseFloat(e.litros)||0;
  // Calcular stock actual de ACPM
  var entradasTot=(S.acpmEntradas||[]).reduce(function(s,x){return s+(parseFloat(x.litros)||0);},0);
  var consumosTot=(S.mantBitacoras||[]).reduce(function(s,b){return s+(parseFloat(b.acpm)||0);},0);
  var stockActual=(parseFloat(S.acpmIni)||0)+entradasTot-consumosTot;
  var stockSi=stockActual-litros;
  // NIVEL 1: BLOQUEAR si dejaría stock negativo
  if(stockSi<0){
    var contenido='<div style="background:var(--bg2);border-radius:8px;padding:12px;margin-bottom:11px;border-left:3px solid var(--er)">';
    contenido+='<div style="font-family:var(--M);font-size:10px;color:var(--tx2);margin-bottom:6px">ENTRADA:</div>';
    contenido+='<div style="font-size:13px;color:var(--tx1);font-weight:700">⛽ '+litros.toFixed(2)+' L · '+(e.fecha||'')+'</div>';
    if(e.proveedor)contenido+='<div style="font-family:var(--M);font-size:10px;color:var(--tx3);margin-top:4px">'+e.proveedor+'</div>';
    contenido+='</div>';
    contenido+='<div style="background:var(--erA);border-radius:7px;padding:11px;margin-bottom:11px">';
    contenido+='<div style="font-family:var(--M);font-size:9px;color:var(--er);margin-bottom:6px;font-weight:700">⚠️ STOCK QUEDARÍA NEGATIVO:</div>';
    contenido+='<div style="font-family:var(--M);font-size:10px;color:var(--tx1);line-height:1.6">';
    contenido+='• Stock actual: '+stockActual.toFixed(2)+' L<br>';
    contenido+='• Stock si elimina: <strong style="color:var(--er)">'+stockSi.toFixed(2)+' L</strong><br>';
    contenido+='• Faltarían: '+Math.abs(stockSi).toFixed(2)+' L';
    contenido+='</div></div>';
    contenido+='<div style="background:var(--inA);border-radius:7px;padding:10px">';
    contenido+='<div style="font-family:var(--M);font-size:10px;color:var(--in);line-height:1.6">Esta entrada ya fue consumida en bitácoras posteriores. Si la elimina, el inventario de ACPM quedaría descuadrado.</div>';
    contenido+='</div>';
    modalAviso({tipo:'danger',titulo:'No se puede eliminar',subtitulo:'Stock quedaría negativo',contenidoHtml:contenido,
      botonSecundario:'Entendido'});
    return;
  }
  // NIVEL 3: confirmación con detalle
  var contenido='<div style="background:var(--bg2);border-radius:8px;padding:11px;margin-bottom:11px">';
  contenido+='<div style="font-family:var(--M);font-size:10px;color:var(--tx2);margin-bottom:6px">ENTRADA A ELIMINAR:</div>';
  contenido+='<div style="font-size:13px;color:var(--tx1);font-weight:700">⛽ '+litros.toFixed(2)+' L · '+(e.fecha||'')+'</div>';
  if(e.proveedor)contenido+='<div style="font-family:var(--M);font-size:10px;color:var(--tx3);margin-top:4px">'+e.proveedor+'</div>';
  contenido+='</div>';
  contenido+='<div style="background:var(--okA);border-radius:7px;padding:10px;margin-bottom:11px">';
  contenido+='<div style="font-family:var(--M);font-size:10px;color:var(--ok);line-height:1.6">Stock ACPM bajará de '+stockActual.toFixed(2)+' L a '+stockSi.toFixed(2)+' L</div>';
  contenido+='</div>';
  modalAviso({tipo:'warn',titulo:'Eliminar Entrada ACPM',contenidoHtml:contenido,
    botonPrincipal:'🗑️ Eliminar',onPrincipal:function(){
      S.acpmEntradas=S.acpmEntradas.filter(function(x){return x.id!==id;});
      dbSaveAcpm();
      try{renderAcpmKpis();renderAcpmMov();}catch(e){}
      modalAvisoClose();
    }});
}


// ── Render movimientos (entradas + consumos de bitácoras juntos, cronológico) ──
function renderAcpmMov(){
  renderAcpmKpis();
  var desde=gv('acpm-f-desde'),hasta=gv('acpm-f-hasta'),tipo=gv('acpm-f-tipo');
  var fEquipo=gv('acpm-f-equipo'),fProv=gv('acpm-f-prov');
  if(!S.acpmEntradas)S.acpmEntradas=[];

  var movs=[];

  // Entradas
  if(!tipo||tipo==='entrada'){
    S.acpmEntradas.forEach(function(e){
      if(desde&&e.fecha<desde)return;
      if(hasta&&e.fecha>hasta)return;
      if(fProv&&e.provId!==fProv)return;
      if(fEquipo)return; // entradas no tienen equipo — si filtran por equipo, no incluir
      movs.push({fecha:e.fecha,tipo:'entrada',gal:e.gal,label:e.prov||'Sin proveedor',obs:e.obs,precio:e.precio,id:e.id,deletable:true});
    });
  }

  // Consumos desde bitácoras
  if(!tipo||tipo==='consumo'){
    S.mantBitacoras.forEach(function(b){
      if(!b.acpm||b.acpm<=0)return;
      if(desde&&b.fecha<desde)return;
      if(hasta&&b.fecha>hasta)return;
      if(fEquipo&&b.equipoId!==fEquipo)return;
      if(fProv)return; // consumos no tienen proveedor — si filtran por proveedor, no incluir
      var eq=S.mantEquipos.find(function(e){return e.id===b.equipoId;})||{nombre:'—'};
      var turnoLbl=b.turno==='dia'?'☀️ Día':'🌙 Noche';
      movs.push({fecha:b.fecha,tipo:'consumo',gal:b.acpm,label:eq.nombre,obs:turnoLbl+' · '+b.horas.toFixed(1)+'h',id:b.id,deletable:false});
    });
  }

  // Sort by date desc, then entries before consumos on same day
  movs.sort(function(a,b){
    if(b.fecha!==a.fecha)return b.fecha.localeCompare(a.fecha);
    return a.tipo==='entrada'?-1:1;
  });

  // Calculate running balance (need full history for this, sorted asc)
  var allMovs=[];
  S.acpmEntradas.forEach(function(e){allMovs.push({fecha:e.fecha,tipo:'entrada',gal:e.gal,id:e.id});});
  S.mantBitacoras.forEach(function(b){if(b.acpm>0)allMovs.push({fecha:b.fecha,tipo:'consumo',gal:b.acpm,id:b.id});});
  allMovs.sort(function(a,b){if(a.fecha!==b.fecha)return a.fecha.localeCompare(b.fecha);return a.tipo==='entrada'?-1:1;});
  var saldoMap={};
  var running=(S.acpmIni||0);
  allMovs.forEach(function(m){
    if(m.tipo==='entrada')running+=m.gal;
    else running-=m.gal;
    saldoMap[m.id]=parseFloat(running.toFixed(2));
  });

  var tbody=G('acpm-mov-body');
  if(!movs.length){tbody.innerHTML='<tr class="erow"><td colspan="7">Sin movimientos para los filtros seleccionados.</td></tr>';return;}

  tbody.innerHTML=movs.map(function(m){
    var isEnt=m.tipo==='entrada';
    var saldo=saldoMap[m.id];
    var saldoCol=saldo<0?'var(--er)':saldo<50?'var(--wa)':'var(--ok)';
    var galHtml=isEnt
      ?'<span style="color:var(--ok);font-family:var(--M);font-weight:700">+'+m.gal.toFixed(1)+'</span>'
      :'<span style="color:var(--er);font-family:var(--M);font-weight:700">−'+m.gal.toFixed(1)+'</span>';
    var tipoHtml=isEnt
      ?'<span class="bdg bdg-ok">⬆ Entrada</span>'
      :'<span class="bdg bdg-er">⬇ Consumo</span>';
    var precioInfo=isEnt&&m.precio>0?'<div style="font-family:var(--M);font-size:8px;color:var(--tx3)">$'+m.precio.toFixed(2)+'/gal · Total: $'+(m.gal*m.precio).toFixed(2)+'</div>':'';
    return'<tr>'
      +'<td><span class="mv">'+fd(m.fecha)+'</span></td>'
      +'<td>'+tipoHtml+'</td>'
      +'<td>'+galHtml+'</td>'
      +'<td><span style="font-family:var(--M);font-size:12px;font-weight:700;color:'+saldoCol+'">'+(saldo!=null?saldo.toFixed(1):'—')+'</span></td>'
      +'<td style="font-size:13px">'+m.label+precioInfo+'</td>'
      +'<td style="font-size:11px;color:var(--tx3)">'+(m.obs||'')+'</td>'
      +'<td>'+(m.deletable?'<button class="btn btn-er btn-xs" onclick="acpmDelRow(event)" data-id="'+m.id+'"">🗑️</button>':'')+'</td>'
      +'</tr>';
  }).join('');
}

