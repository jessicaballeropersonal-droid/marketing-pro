// Inicializar plantilla con defaults si está vacía
function _lubEnsurePlantilla(){
  if(!S.lubPlantilla)S.lubPlantilla={};
  if(!S.lubHistorial)S.lubHistorial=[];
  // Para cada máquina de parámetros mant, asegurar que exista en plantilla
  (S.mantMaquinasPlanta||[]).forEach(function(maq){
    if(!S.lubPlantilla[maq.id]){
      // Buscar defaults por nombre
      var defaults=null;
      Object.keys(_LUB_DEFAULTS).forEach(function(k){
        if(maq.nombre&&maq.nombre.toLowerCase().includes(k.toLowerCase().substring(0,6)))
          defaults=_LUB_DEFAULTS[k];
      });
      S.lubPlantilla[maq.id]={
        maquinaId:maq.id,
        maquinaNombre:maq.nombre,
        activa:true,
        rodamientos:defaults?defaults.map(function(r){return Object.assign({},r,{id:uid()});}):[],
      };
    }
  });
  // Agregar defaults hardcoded si no hay máquinas en parámetros
  if(!S.mantMaquinasPlanta||!S.mantMaquinasPlanta.length){
    Object.keys(_LUB_DEFAULTS).forEach(function(nombre){
      var key='def_'+nombre.replace(/\s/g,'_');
      if(!S.lubPlantilla[key]){
        S.lubPlantilla[key]={
          maquinaId:key,maquinaNombre:nombre,activa:true,
          rodamientos:_LUB_DEFAULTS[nombre].map(function(r){return Object.assign({},r,{id:uid()});})
        };
      }
    });
  }
}

