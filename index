    if(a.fecha_adjudicacion)html+='<div style="font-size:10px;color:var(--tx2);margin-bottom:3px"><b>Adjudicado:</b> '+_rastEsc(a.fecha_adjudicacion)+'</div>';
    // Cantidades
    if(a.cantidades_estimadas){
      var q=a.cantidades_estimadas;
      html+='<div style="background:#F0F8F4;border-radius:6px;padding:7px 9px;margin-top:7px;border-left:2px solid var(--ok)">';
      html+='<div style="font-size:8px;color:var(--ok);font-weight:700;letter-spacing:.5px;font-family:var(--M);margin-bottom:3px">📊 CANTIDADES ESTIMADAS</div>';
      html+='<div style="font-size:10px;color:var(--tx1);font-family:var(--M);line-height:1.5">';
      if(q.base_granular_m3)html+='• Base granular: <b style="color:var(--ok)">'+_rastEsc(q.base_granular_m3)+' m³</b><br>';
      if(q.arena_m3)html+='• Arena: <b style="color:var(--ok)">'+_rastEsc(q.arena_m3)+' m³</b><br>';
