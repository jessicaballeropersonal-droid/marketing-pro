    fecha_cierre:a.fecha_cierre||'',
    id_proceso:a.id_proceso||'',
    modalidad:a.modalidad||'',
    estadoId:S.rastreadorEstadosLicitar[0].id,
    notas:'',
    creado_en:(new Date()).toISOString().substring(0,10),
    alertaOrigen:a.id
  };
