// Funciones de reversión de inventario
function revertirExtraccion(r){
  // Saca el registro de exp.records (el getInv() lo recalcula todo)
  S.exp.records=S.exp.records.filter(function(x){return x.id!==r.id;});
  dbDelExp(r.id);
}
function revertirProduccion(r){
  // Saca el registro de prod.records
  S.prod.records=S.prod.records.filter(function(x){return x.id!==r.id;});
  dbDelProd(r.id);
}
function revertirDespacho(r){
  // Saca el registro de desp.records (devuelve los items al inventario)
  S.desp.records=S.desp.records.filter(function(x){return x.id!==r.id;});
  dbDelDesp(r.id);
}

// Resumen visual de cambios de inventario que va a hacer una operación
function resumenRevExtraccion(r){
  if(!r||r.pp)return 'No afecta inventario (Patio a Patio).';
  var alm=r.alm||'';var almNames={patio:'Grava',tolva:'Tolva',zaranda:'Zaranda',arena_rio:'Arena Río',arena:'Arena Río'};
  var almTxt=almNames[alm]||alm;
  var m3=r.tm||0;
  return '<div style="font-size:12px;color:var(--tx1)"><strong style="color:var(--er)">'+almTxt+': −'+m3.toFixed(2)+' m³</strong> (sale del stock)</div>';
}
function resumenRevProduccion(r){
  if(!r)return '';
  var html='<div style="font-family:var(--M);font-size:11px;color:var(--tx2)">';
  // Devuelve la fuente
  if(r.fuentes&&r.fuentes.length){
    r.fuentes.forEach(function(f){
      var almName={patio:'Grava',tolva:'Tolva',zaranda:'Zaranda',arena:'Arena Río',transformacion:'PT origen'}[f.alm]||f.alm;
      html+='<div style="color:var(--ok)">+ '+almName+': '+(f.m3||0).toFixed(2)+' m³ (devuelve)</div>';
    });
  } else if(r.fuenteM3) {
    html+='<div style="color:var(--ok)">+ Fuente: '+(r.fuenteM3||0).toFixed(2)+' m³ (devuelve)</div>';
  }
  // Quita los PT generados
  if(r.dist&&r.dist.length){
    r.dist.forEach(function(d){
      var pt=S.prodTerm.find(function(p){return p.id===d.ptId;});
      var nom=pt?pt.nombre:d.ptId;
      html+='<div style="color:var(--er)">− '+nom+': '+(d.m3||0).toFixed(2)+' m³ (quita)</div>';
    });
  }
  html+='</div>';
  return html;
}
function resumenRevDespacho(r){
  if(!r||!r.items)return '';
  var html='<div style="font-family:var(--M);font-size:11px;color:var(--tx2)">';
  r.items.forEach(function(it){
    var pt=S.prodTerm.find(function(p){return p.id===it.ptId;});
    var nom=pt?pt.nombre:it.ptId;
    html+='<div style="color:var(--ok)">+ '+nom+': '+(it.m3||0).toFixed(2)+' m³ (devuelve al stock)</div>';
  });
  html+='</div>';
  return html;
}

// Cuenta dependencias de una bitácora (para el aviso de cascada)
function bitacoraDependencias(bitId){
  var exps=(S.exp.records||[]).filter(function(r){return r.origenBit&&r.equipoId&&_bitacoraExpMatch(r,bitId);});
  var prods=(S.prod.records||[]).filter(function(r){return r.bitIds&&r.bitIds.indexOf(bitId)>=0;});
  var bit=(S.mantBitacoras||[]).find(function(b){return b.id===bitId;});
  var ots=(S.mantOrdenes||[]).filter(function(o){return bit&&o.fecha===bit.fecha&&o.eqId===bit.equipoId&&o.origen==='auto';});
  return {exps:exps,prods:prods,ots:ots,bit:bit};
}
// Match exp con bitácora: si la bitácora tiene expIds (registros nuevos), empareja por ID
// exacto (preciso, no cruza con otras del mismo día). Si no, cae al método viejo equipo+fecha.
function _bitacoraExpMatch(rExp,bitId){
  var b=(S.mantBitacoras||[]).find(function(x){return x.id===bitId;});
  if(!b)return false;
  if(b.expIds&&b.expIds.length)return b.expIds.indexOf(rExp.id)>=0;
  return rExp.fecha===b.fecha&&rExp.equipoId===b.equipoId;
}

