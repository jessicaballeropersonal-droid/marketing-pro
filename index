    +'</div></div>';

  var hA,hB;
  if(isAdmin){
    hA='<input value="'+esc(cn.a)+'" title="Renombrar columna" onchange="_iadmSetColName(\''+seccion+'\',\'a\',this.value);renderInformeAdm();" style="width:100%;font-family:var(--M);font-size:8px;text-align:right;background:transparent;border:1px dashed var(--bd2);border-radius:3px;color:var(--tx2);padding:2px 4px">';
    hB='<input value="'+esc(cn.b)+'" title="Renombrar columna" onchange="_iadmSetColName(\''+seccion+'\',\'b\',this.value);renderInformeAdm();" style="width:100%;font-family:var(--M);font-size:8px;text-align:right;background:transparent;border:1px dashed var(--bd2);border-radius:3px;color:var(--tx2);padding:2px 4px">';
  }else{
    hA=esc(cn.a);hB=esc(cn.b);
