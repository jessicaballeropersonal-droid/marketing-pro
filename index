function renderCompsMant(){
  var tipos={volqueta:'vol',excavadora:'exc',cargador:'car',planta:'pla'};
  Object.keys(tipos).forEach(function(tipo){
    var cont=G('mcp-'+tipos[tipo]+'-tags');if(!cont)return;
    var comps=S.mantComponentes[tipo]||[];
    cont.innerHTML=comps.length?comps.map(function(c){
      return'<span class="tag">'+c+'<button class="tag-x" data-mant-tipo="'+tipo+'" data-mant-comp="'+c+'">×</button></span>';
    }).join(''):'<span style="color:var(--tx3);font-size:11px;font-style:italic">Sin componentes.</span>';
  });
  // Render maquinas planta
  var maqCont=G('mcp-maq-tags');
