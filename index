    contenido+='<div style="font-size:13px;color:var(--tx1);font-weight:700">👤 '+cond.nombre+(cond.placa?' · '+cond.placa:'')+'</div>';
    contenido+='</div>';
    contenido+='<div style="background:var(--erA);border-radius:7px;padding:11px;margin-bottom:11px">';
    contenido+='<div style="font-family:var(--M);font-size:9px;color:var(--er);margin-bottom:6px;font-weight:700">⚠️ ESTE CONDUCTOR TIENE HISTORIAL:</div>';
    contenido+='<div style="font-family:var(--M);font-size:10px;color:var(--tx1);line-height:1.8">';
    if(viajes.length>0)contenido+='<div>• '+viajes.length+' viaje(s) registrado(s)</div>';
    if(liqs.length>0)contenido+='<div>• '+liqs.length+' liquidación(es) realizada(s)</div>';
    if(bitsAsoc.length>0)contenido+='<div>• '+bitsAsoc.length+' bitácora(s) operacional(es)</div>';
    contenido+='</div></div>';
    contenido+='<div style="background:var(--inA);border-radius:7px;padding:10px">';
    contenido+='<div style="font-family:var(--M);font-size:10px;color:var(--in);line-height:1.6"><strong>Recomendación:</strong> En lugar de eliminar, márquelo como <strong>inactivo</strong> desde Editar. Así conserva el historial sin que aparezca en listas activas.</div>';
    contenido+='</div>';
    modalAviso({tipo:'danger',titulo:'No se puede eliminar el conductor',subtitulo:'Tiene historial registrado',contenidoHtml:contenido,
      botonSecundario:'Entendido'});
