function _iadmConsolSubtotal(yr,t){
  var tC=t.cexpl+t.cplanta+t.cadm;
  var marg=t.ing>0?t.util/t.ing*100:0;
  var m3t=t.mp>0?tC/t.mp:0;
  var semCol=marg>30?'var(--ok)':marg>20?'var(--wa)':'var(--er)';
  var _pa=_iadmCalcPEAnual(yr); // v172.70: PE anual acumulado del año
  return '<tr style="background:var(--bg2);font-weight:700">'
    +'<td style="padding:5px 8px;font-family:var(--M);font-size:8px">Subtotal '+yr+'</td>'
    +'<td style="padding:5px 6px;text-align:right;font-family:var(--M);color:var(--or)">'+(t.trit||0).toLocaleString('es-CO',{maximumFractionDigits:0})+'</td>'
    +'<td style="padding:5px 6px;text-align:right;font-family:var(--M);color:#c084fc">'+(t.zar||0).toLocaleString('es-CO',{maximumFractionDigits:0})+'</td>'
    +'<td style="padding:5px 6px;text-align:right;font-family:var(--M);color:var(--cy)">'+(t.transf||0).toLocaleString('es-CO',{maximumFractionDigits:0})+'</td>'
    +'<td style="padding:5px 6px;text-align:right;font-family:var(--M);color:var(--ok);background:rgba(34,197,94,0.08)">'+t.mp.toLocaleString('es-CO',{maximumFractionDigits:0})+'</td>'
    +'<td style="padding:5px 6px;text-align:right;font-family:var(--M)">'+t.me.toLocaleString('es-CO',{maximumFractionDigits:0})+'</td>'
    +'<td style="padding:5px 6px;text-align:right;font-family:var(--M);color:var(--ok)">'+_fmn(t.ing)+'</td>'
    +'<td style="padding:5px 6px;text-align:right;font-family:var(--M)">'+_fmn(t.cexpl)+'</td>'
    +'<td style="padding:5px 6px;text-align:right;font-family:var(--M)">'+_fmn(t.cplanta)+'</td>'
    +'<td style="padding:5px 6px;text-align:right;font-family:var(--M)">'+_fmn(t.cadm)+'</td>'
    +'<td style="padding:5px 6px;text-align:right;font-family:var(--M);color:var(--er)">'+_fmn(tC)+'</td>'
    +'<td style="padding:5px 6px;text-align:right;font-family:var(--M);color:'+(t.util>=0?'var(--ok)':'var(--er)')+'">'+_fmn(t.util)+'</td>'
    +'<td style="padding:5px 6px;text-align:center;font-family:var(--M);color:'+semCol+'">'+marg.toFixed(1)+'%</td>'
    +'<td style="padding:5px 6px;text-align:right;font-family:var(--M);color:var(--cy)">'+_fcppV(_iadmCppConsol(t.cexpl,t.cplanta,t.cadm,t.me,t.mp))+'</td>'
    +'<td style="padding:5px 6px;text-align:right;font-family:var(--M);color:var(--cy);font-weight:700" title="PE anual acumulado">'+(_pa.mc>0?_pa.pe.toLocaleString():'—')+'</td>'
    +'<td></td>'
    +'</tr>';
}

