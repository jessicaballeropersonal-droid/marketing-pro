function renderOTMant(){
  var estado=gv('mot-f-estado'),area=gv('mot-f-area'),eqId=gv('mot-f-eq'),sev=gv('mot-f-sev');
  var desde=gv('mot-f-desde'),hasta=gv('mot-f-hasta');
  var ots=S.mantOrdenes.filter(function(o){return o.area!=='planta'&&o.estado!=='completada';}).slice().sort(function(a,b){
    var ord={creada:0,en_proceso:1,completada:2};
    if(ord[a.estado]!==ord[b.estado])return ord[a.estado]-ord[b.estado];
    var s={critica:0,media:1,baja:2};if(s[a.sev]!==s[b.sev])return s[a.sev]-s[b.sev];
    return b.fecha.localeCompare(a.fecha);
  });
  if(estado)ots=ots.filter(function(o){return o.estado===estado;});
  if(area)ots=ots.filter(function(o){return o.area===area;});
  if(eqId)ots=ots.filter(function(o){return o.eqId===eqId;});
  if(sev)ots=ots.filter(function(o){return o.sev===sev;});
  if(desde)ots=ots.filter(function(o){return o.fecha>=desde;});
  if(hasta)ots=ots.filter(function(o){return o.fecha<=hasta;});
  var c=G('mant-ot-lista-body');
  if(!ots.length){c.innerHTML='<div style="color:var(--tx3);font-size:13px;font-style:italic;padding:20px;text-align:center">Sin OT con los filtros seleccionados.</div>';return;}
  var sevCls={critica:'er',media:'wa',baja:'ok'};
  var sevLbl={critica:'🔴 Crítica',media:'🟡 Media',baja:'🟢 Baja'};
  var tipoLbl={correctivo:'🔧 Correctivo',preventivo:'🔔 Preventivo',inspeccion:'🔍 Inspección'};
