  var html='<div style="font-size:9px;color:var(--tx2);letter-spacing:.8px;margin:10px 0 6px;font-weight:600;font-family:var(--M)">VENTANAS '+modoLabel+(_rastIsAdmin()?' (editables)':'')+'</div>';
  html+='<div style="display:flex;flex-wrap:wrap;gap:5px;margin-bottom:10px">';
  vts.forEach(function(v){
    if(!v.activa)return;
    var cnt=S.rastreadorAlertas.filter(function(a){return a.ventana===v.id&&a.estado==='nueva';}).length;
    var on=_RAST.ventanaActiva===v.id;
    html+='<div onclick="_RAST.ventanaActiva=\''+v.id+'\';renderRastreador();" style="font-size:11px;padding:5px 11px;border-radius:7px;font-weight:500;cursor:pointer;'+(on?'background:var(--or);color:#fff':'background:var(--bg4);color:var(--tx2)')+'">'+_rastEsc(v.nombre)+(cnt?' <span style="background:var(--er);color:#fff;font-size:8px;padding:0 5px;border-radius:6px;margin-left:4px;font-family:var(--M)">'+cnt+'</span>':'')+'</div>';
  });
  if(_rastIsAdmin())html+='<div onclick="rastVentanaNueva()" style="font-size:11px;padding:5px 11px;border-radius:7px;background:transparent;border:0.5px dashed var(--bd2);color:var(--tx3);cursor:pointer">+ nueva</div>';
  html+='</div>';
  return html;
}

function _rastEsSecop(v){
  if(!v)return false;
  var u=((v.urls||[]).join(' ')||'').toLowerCase();
  if(u.indexOf('mercycorps.org.co')>=0)return false;      // Mercy nunca es SECOP
  if(u.indexOf('datos.gov.co')>=0)return true;             // SECOP = datos.gov.co
  return v.tipo==='secop' || /secop/i.test(v.id||'') || /secop/i.test(v.nombre||'');
}
function _rastRenderVentanaContenido(){
  var vts=_RAST.modoActivo==='b2b'?S.rastreadorVentanasB2B:S.rastreadorVentanasLicitar;
  var v=vts.find(function(x){return x.id===_RAST.ventanaActiva;});
  if(!v)return'<div style="text-align:center;padding:30px;color:var(--tx3);font-size:11px">Selecciona una ventana</div>';

