      var almBds={patio:'var(--orB)',tolva:'rgba(96,165,250,.3)',zaranda:'rgba(192,132,252,.3)',arena_rio:'rgba(6,182,212,.3)'};
      var almLbls={patio:'Patio (Grava)',tolva:'Tolva',zaranda:'Zaranda',arena_rio:'Arena Río'};
      // Recolectar extracción — PREFERIR lo guardado en el propio registro (b.ext).
      // Así dos registros del mismo día/equipo NO se cruzan. Si no hay b.ext (registros
      // viejos), se usa el método anterior por equipo+fecha.
      var extByAlm={};
      if(b.ext){
        ['patio','tolva','zaranda','arena_rio'].forEach(function(alm){
          var e=b.ext[alm];
          if(e&&((parseFloat(e.m3)||0)>0||(parseInt(e.vj)||0)>0)){
            extByAlm[alm]={tv:(parseInt(e.vj)||0),tm:(parseFloat(e.m3)||0)};
          }
        });
      } else {
        var extBit=S.exp.records.filter(function(r){
          if(!r.origenBit||r.pp)return false;
          if(r.fecha!==b.fecha)return false;
          if(r.bitId)return r.bitId===b.id;
          if(r.equipoId&&b.equipoId)return r.equipoId===b.equipoId;
          if(eq&&r.bitEqNombre)return r.bitEqNombre===eq.nombre;
          if(!r.equipoId&&!b.equipoId)return true;
          return false;
        });
        extBit.forEach(function(r){
          if(!extByAlm[r.alm])extByAlm[r.alm]={tv:0,tm:0};
          extByAlm[r.alm].tv+=(r.tv||0);
          extByAlm[r.alm].tm+=(parseFloat(r.tm)||0);
        });
      }
      // Diagnóstico en consola: muestra lo que tiene guardado cada registro
      try{console.log('[BITÁCORA]',b.fecha,(b.turno||'').toUpperCase(),'id='+b.id,{viajes:b.viajes,ext:b.ext||'(registro viejo: por equipo+fecha)',patioAPatioVj:b.ppViajes||0,pgTolvaVj:b.prodVj2||0,prodData:b.prodData});}catch(e){}
      // PP
      var ppVjHist=b.ppViajes||0;
      var ppM3vHist=b.ppM3v||14;
      var ppM3Hist=ppVjHist*ppM3vHist;
      if(!ppVjHist){
        var ppBit=S.exp.records.filter(function(r){return r.pp&&r.origenBit&&r.fecha===b.fecha&&(r.equipoId===b.equipoId||(eq&&r.bitEqNombre===eq.nombre));});
        if(ppBit.length){
          ppVjHist=ppBit.reduce(function(a,r){return a+(r.pp_viajes||r.ppViajes||0);},0);
          ppM3Hist=ppBit.reduce(function(a,r){return a+((r.pp_viajes||r.ppViajes||0)*(r.ppM3v||14));},0);
        }
      }
      // PG→Tolva
      var pgVj=b.prodVj2||0;
      var pgM3=pgVj*(b.prodM3v2||14);
      // Producción — leer de prodVj2/prodM3v2 (donde se guarda)
      var prodTotal=0,prodVjTot=0;
      if(b.prodVj2&&b.prodVj2>0){prodVjTot=b.prodVj2;prodTotal=b.prodVj2*(b.prodM3v2||14);}
      // Fallback: prodData (formato viejo)
      else if(b.prodData&&b.prodData.length){b.prodData.forEach(function(f){prodTotal+=f.vj*(f.m3v||14);prodVjTot+=f.vj;});}
      // Render grid
      var hasAny=Object.keys(extByAlm).length||ppVjHist||pgVj||prodTotal;
      if(hasAny){
        html+='<div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(110px,1fr));gap:7px;margin-bottom:10px">';
        // Extracción — una card por almacenamiento
        ['patio','tolva','zaranda','arena_rio'].forEach(function(alm){
          var d=extByAlm[alm];if(!d||d.tm<=0)return;
          var col=almCols[alm];var bg=almBgs[alm];var bd=almBds[alm];
          html+='<div style="background:'+bg+';border:0.5px solid '+bd+';border-top:3px solid '+col+';border-radius:8px;padding:9px 11px">'
            +'<div style="font-family:var(--M);font-size:7px;color:'+col+';letter-spacing:.5px;margin-bottom:4px">'+almLbls[alm].toUpperCase()+'</div>'
            +'<div style="font-size:20px;font-weight:700;color:'+col+'">'+d.tm.toFixed(1)+'</div>'
            +'<div style="font-family:var(--M);font-size:8px;color:var(--tx3)">m³ · '+d.tv+' vj</div>'
            +'</div>';
        });
        // Producción — KPI card eliminada (visible en Producción → Órdenes del Día)
        // Patio a Patio
        if(ppVjHist>0){
          html+='<div style="background:rgba(192,132,252,.08);border:0.5px solid rgba(192,132,252,.3);border-top:3px solid #c084fc;border-radius:8px;padding:9px 11px">'
            +'<div style="font-family:var(--M);font-size:7px;color:#c084fc;letter-spacing:.5px;margin-bottom:4px">PATIO A PATIO</div>'
            +'<div style="font-size:20px;font-weight:700;color:#c084fc">'+ppM3Hist.toFixed(1)+'</div>'
            +'<div style="font-family:var(--M);font-size:8px;color:var(--tx3)">m³ · '+ppVjHist+' vj</div>'
            +'<div style="font-family:var(--M);font-size:7px;color:var(--tx3);margin-top:2px">Sin efecto inv.</div>'
            +'</div>';
        }
        // PG→Tolva
        if(pgVj>0){
          html+='<div style="background:var(--orA);border:0.5px solid var(--orB);border-top:3px solid var(--or);border-radius:8px;padding:9px 11px">'
            +'<div style="font-family:var(--M);font-size:7px;color:var(--or);letter-spacing:.5px;margin-bottom:4px">PG→TOLVA</div>'
            +'<div style="font-size:20px;font-weight:700;color:var(--or)">'+pgM3.toFixed(1)+'</div>'
            +'<div style="font-family:var(--M);font-size:8px;color:var(--tx3)">m³ · '+pgVj+' vj</div>'
            +'</div>';
        }
        // Transformación
        if(b.transVj>0){
          var transOrigenNombre='';
          if(b.transOrigenId){var tp=S.prodTerm.find(function(p){return p.id===b.transOrigenId;});if(tp)transOrigenNombre=tp.nombre;}
          html+='<div style="background:var(--cyA);border:0.5px solid var(--cyB);border-top:3px solid var(--cy);border-radius:8px;padding:9px 11px">'
            +'<div style="font-family:var(--M);font-size:7px;color:var(--cy);letter-spacing:.5px;margin-bottom:4px">🔀 TRANSFORMACIÓN</div>'
            +'<div style="font-size:20px;font-weight:700;color:var(--cy)">'+(b.transM3||b.transVj*(b.transM3v||14)).toFixed(1)+'</div>'
            +'<div style="font-family:var(--M);font-size:8px;color:var(--tx3)">m³ · '+b.transVj+' vj</div>'
            +(transOrigenNombre?'<div style="font-family:var(--M);font-size:7px;color:var(--tx3);margin-top:3px">Origen: '+transOrigenNombre+'</div>':'')
            +'</div>';
        }
        html+='</div>';
      }
      if(b.conductorTurno){
        var ctNombre=(S.conductores||[]).find(function(cd){return cd.id===b.conductorTurno;})||(S.operadores||[]).find(function(op){return op.id===b.conductorTurno;});
        if(ctNombre)html+='<div style="font-family:var(--M);font-size:9px;color:var(--in);margin-bottom:5px">👷 Conductor: '+ctNombre.nombre+'</div>';
      }
      if(hasA)html+='<div style="margin-top:6px">'+b.anomalias.map(function(a){return'<div style="font-size:11px;color:var(--er);margin-top:2px">⚠️ <strong>'+a.comp+'</strong>: '+a.desc+'</div>';}).join('')+'</div>';
      if(hasT)html+='<div style="margin-top:5px">'+b.trabajos.map(function(t){return'<div style="font-size:11px;color:var(--ok);margin-top:2px">✓ <strong>'+t.comp+'</strong>: '+t.desc+'</div>';}).join('')+'</div>';
      if(b.obs)html+='<div style="margin-top:5px;font-size:11px;color:var(--tx3)">📝 '+b.obs+'</div>';
      html+='</div>';
    });
  });
  c.innerHTML=html;
}
