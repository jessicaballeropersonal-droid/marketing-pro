function initAcpm(){
  if(!S.acpmEntradas)S.acpmEntradas=[];
  if(!S.acpmIni)S.acpmIni=0;
  if(!S.acpmProveedores)S.acpmProveedores=[];
  var t=today();
  sv('acpm-e-fecha',t);
  var desde=new Date();desde.setMonth(desde.getMonth()-1);
  var desdeStr=desde.toISOString().split('T')[0];
  if(G('acpm-f-desde')&&!G('acpm-f-desde').value)sv('acpm-f-desde',desdeStr);
  if(G('acpm-f-hasta')&&!G('acpm-f-hasta').value)sv('acpm-f-hasta',t);
  if(G('acpm-eq-desde')&&!G('acpm-eq-desde').value)sv('acpm-eq-desde',desdeStr);
  if(G('acpm-eq-hasta')&&!G('acpm-eq-hasta').value)sv('acpm-eq-hasta',t);
  // Activate first tab explicitly
  var pgEl=G('pg-acpm');
  if(pgEl){
    pgEl.querySelectorAll('.tp').forEach(function(t2){t2.classList.remove('on');});
    pgEl.querySelectorAll('.tab').forEach(function(t2){t2.classList.remove('on');});
    var firstTp=G('acpm-mov');if(firstTp)firstTp.classList.add('on');
    var firstTab=pgEl.querySelector('.tab');if(firstTab)firstTab.classList.add('on');
  }
  if(G('acpm-ini-val'))G('acpm-ini-val').value=S.acpmIni||0;
  if(G('acpm-ini-fecha'))G('acpm-ini-fecha').value=t;
  _acpmFillSelects();
  renderAcpmKpis();
  renderAcpmMov();
}

// ── Calcular total consumido de bitácoras ──
function acpmTotalConsumido(desde,hasta){
  return S.mantBitacoras.filter(function(b){
    if(desde&&b.fecha<desde)return false;
    if(hasta&&b.fecha>hasta)return false;
    return true;
  }).reduce(function(s,b){return s+(b.acpm||0);},0);
}

// ── KPIs globales (sin filtro de fecha) ──
function renderAcpmKpis(){
  if(!S.acpmEntradas)S.acpmEntradas=[];
  var totalEnt=S.acpmEntradas.reduce(function(s,e){return s+(e.gal||0);},0);
  var totalCons=S.mantBitacoras.reduce(function(s,b){return s+(b.acpm||0);},0);
  var saldo=(S.acpmIni||0)+totalEnt-totalCons;
  var kpiSaldo=G('acpm-kpi-saldo');if(kpiSaldo)kpiSaldo.textContent=saldo.toFixed(1);
  var kpiEnt=G('acpm-kpi-entradas');if(kpiEnt)kpiEnt.textContent=totalEnt.toFixed(1);
  var kpiCons=G('acpm-kpi-consumo');if(kpiCons)kpiCons.textContent=totalCons.toFixed(1);
  var kpiIni=G('acpm-kpi-ini');if(kpiIni)kpiIni.textContent=(S.acpmIni||0).toFixed(1);
  // Color saldo
  var kpiBox=kpiSaldo?kpiSaldo.closest('.kpi'):null;
  if(kpiBox){kpiBox.className='kpi '+(saldo<0?'er':saldo<50?'wa':'ok');}
}

// ── Guardar inventario inicial ──
function saveAcpmIni(){
  var val=parseFloat(G('acpm-ini-val').value)||0;
  S.acpmIni=val;
  dbSaveAcpm();
  cmo('ov-acpm-ini');
  renderAcpmKpis();renderAcpmMov();
  var al=G('acpm-entrada-alert');
  if(al){al.className='alert alert-ok on';al.textContent='✅ Inventario inicial guardado.';setTimeout(function(){al.className='alert';},2500);}
}

// ── Guardar entrada ──
function saveAcpmEntrada(){
  var al=G('acpm-entrada-alert');
  var fecha=gv('acpm-e-fecha');
  var gal=parseFloat(G('acpm-e-gal').value)||0;
  var provId=gv('acpm-e-prov');
  var provObj=(S.acpmProveedores||[]).find(function(p){return p.id===provId;});
  var prov=provObj?provObj.nombre:'';
  var precio=parseFloat(G('acpm-e-precio').value)||0;
  var obs=G('acpm-e-obs').value.trim();
  if(!fecha){al.className='alert alert-er on';al.textContent='⚠️ Seleccione la fecha.';return;}
  if(gal<=0){al.className='alert alert-er on';al.textContent='⚠️ Ingrese la cantidad en galones.';return;}
  if(!S.acpmEntradas)S.acpmEntradas=[];
  var entrada={id:uid(),fecha:fecha,gal:gal,prov:prov,provId:provId,precio:precio,obs:obs};
  S.acpmEntradas.push(entrada);
  dbSaveAcpm();
  al.className='alert alert-ok on';al.textContent='✅ Entrada registrada: '+gal.toFixed(1)+' galones.';
  setTimeout(function(){al.className='alert';},3000);
  sv('acpm-e-gal','');sv('acpm-e-prov','');sv('acpm-e-precio','');sv('acpm-e-obs','');sv('acpm-e-fecha',today());
  _acpmFillSelects();
  renderAcpmKpis();renderAcpmMov();
}

function acpmDelRow(e){var id=e.currentTarget.getAttribute('data-id');delAcpmEntrada(id);}
function calcAcpmSaldo(){
  if(!S.acpmEntradas)S.acpmEntradas=[];
  var totalEnt=S.acpmEntradas.reduce(function(s,e){return s+(e.gal||0);},0);
  var totalCons=S.mantBitacoras.reduce(function(s,b){return s+(b.acpm||0);},0);
  return (S.acpmIni||0)+totalEnt-totalCons;
}
function delAcpmEntrada(id){
  var e=(S.acpmEntradas||[]).find(function(x){return x.id===id;});
  if(!e){return;}
  var litros=parseFloat(e.litros)||0;
  // Calcular stock actual de ACPM
  var entradasTot=(S.acpmEntradas||[]).reduce(function(s,x){return s+(parseFloat(x.litros)||0);},0);
  var consumosTot=(S.mantBitacoras||[]).reduce(function(s,b){return s+(parseFloat(b.acpm)||0);},0);
  var stockActual=(parseFloat(S.acpmIni)||0)+entradasTot-consumosTot;
  var stockSi=stockActual-litros;
  // NIVEL 1: BLOQUEAR si dejaría stock negativo
  if(stockSi<0){
    var contenido='<div style="background:var(--bg2);border-radius:8px;padding:12px;margin-bottom:11px;border-left:3px solid var(--er)">';
    contenido+='<div style="font-family:var(--M);font-size:10px;color:var(--tx2);margin-bottom:6px">ENTRADA:</div>';
    contenido+='<div style="font-size:13px;color:var(--tx1);font-weight:700">⛽ '+litros.toFixed(2)+' L · '+(e.fecha||'')+'</div>';
    if(e.proveedor)contenido+='<div style="font-family:var(--M);font-size:10px;color:var(--tx3);margin-top:4px">'+e.proveedor+'</div>';
    contenido+='</div>';
    contenido+='<div style="background:var(--erA);border-radius:7px;padding:11px;margin-bottom:11px">';
    contenido+='<div style="font-family:var(--M);font-size:9px;color:var(--er);margin-bottom:6px;font-weight:700">⚠️ STOCK QUEDARÍA NEGATIVO:</div>';
    contenido+='<div style="font-family:var(--M);font-size:10px;color:var(--tx1);line-height:1.6">';
    contenido+='• Stock actual: '+stockActual.toFixed(2)+' L<br>';
    contenido+='• Stock si elimina: <strong style="color:var(--er)">'+stockSi.toFixed(2)+' L</strong><br>';
    contenido+='• Faltarían: '+Math.abs(stockSi).toFixed(2)+' L';
    contenido+='</div></div>';
    contenido+='<div style="background:var(--inA);border-radius:7px;padding:10px">';
    contenido+='<div style="font-family:var(--M);font-size:10px;color:var(--in);line-height:1.6">Esta entrada ya fue consumida en bitácoras posteriores. Si la elimina, el inventario de ACPM quedaría descuadrado.</div>';
    contenido+='</div>';
    modalAviso({tipo:'danger',titulo:'No se puede eliminar',subtitulo:'Stock quedaría negativo',contenidoHtml:contenido,
      botonSecundario:'Entendido'});
    return;
  }
  // NIVEL 3: confirmación con detalle
  var contenido='<div style="background:var(--bg2);border-radius:8px;padding:11px;margin-bottom:11px">';
