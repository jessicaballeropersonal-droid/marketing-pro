function guardarMantOT(){
  var ot=S.mantOrdenes.find(function(o){return o.id===_mantOtId;});if(!ot)return;
  var estadoAnterior=ot.estado;
  var nuevoEstado=_mantOtEstadoSel;
  ot.estado=nuevoEstado;
  ot.obsEstado=G('mdet-obs').value.trim();
  if(nuevoEstado==='completada'){
    ot.obs=ot.obsEstado;
    ot.fechaCierre=ot.fechaCierre||today();
  } else {
    ot.fechaCierre=null;
