function _getViajesConductor(condId){
  var viajes={};
  // From exp records
  (S.exp.records||[]).forEach(function(r){
    if(r.conductorId!==condId)return;
    ['dc','dm','dt','vc','vm','vt'].forEach(function(k){
      if(parseFloat(r[k])>0){
        var destNombre=k.startsWith('d')?'Doble Troque':'Volqueta';
        var tipo=k.endsWith('c')?'Patio-Grava':k.endsWith('m')?'Tolva':'Zaranda';
        var key=destNombre+' — '+tipo;
        if(!viajes[key])viajes[key]={destino:key,cantidad:0};
        viajes[key].cantidad+=parseFloat(r[k])||0;
      }
    });
    if(parseFloat(r.pp_viajes)>0){
      if(!viajes['Patio a Patio'])viajes['Patio a Patio']={destino:'Patio a Patio',cantidad:0};
      viajes['Patio a Patio'].cantidad+=parseFloat(r.pp_viajes)||0;
    }
  });
  return Object.values(viajes);
}

