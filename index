      +'<span style="font-size:13px;font-weight:700;flex:1">'+e.nombre+'</span>'
      +'<div style="display:flex;gap:4px">'
      +(i>0?'<button class="btn btn-gh btn-xs" onclick="moverEstado(\''+e.id+'\','+tipo+',-1)">↑</button>':'')
      +(i<estados.length-1?'<button class="btn btn-gh btn-xs" onclick="moverEstado(\''+e.id+'\',\''+tipo+'\',1)">↓</button>':'')
      +'<button class="btn btn-er btn-xs" onclick="delEstado(\''+e.id+'\',\''+tipo+'\')">✕</button>'
      +'</div></div>';
  }).join('');
}
function addEstadoTarea(){
  var nombre=G('gest-estado-nuevo').value.trim();
  var color=G('gest-estado-color').value;
  if(!nombre){showAlert('gest-estados-alert','er','Escribe el nombre del estado.');return;}
  var tipo=G('gest-estados-tipo').value;
  var estados=_getEstados(tipo);
  estados.push({id:uid(),nombre:nombre,color:color});
  _saveEstados(tipo,estados);
  G('gest-estado-nuevo').value='';
