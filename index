  contenido+='<div style="font-family:var(--M);font-size:10px;color:var(--ok);line-height:1.6">✓ Este equipo no tiene registros en bitácora, se puede eliminar sin riesgo de descuadre.</div>';
  contenido+='</div>';
  contenido+='<div style="font-size:12px;color:var(--tx2)">¿Confirma eliminar este equipo?</div>';
