      </div>
      <div id="feq-p-alert" class="alert"></div>
    </div>
    <div class="mo-foot">
      <button class="btn btn-gh btn-sm" onclick="cmo('ov-fung-eq-pieza')">Cancelar</button>
      <button class="btn btn-or btn-sm" onclick="saveFungEqPieza()">💾 Guardar Pieza</button>
    </div>
  </div>
</div>

