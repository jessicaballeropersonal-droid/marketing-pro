          <select class="fs" id="feq-p-unidad">
            <option value="horas">Horas (horómetro)</option>
            <option value="km">Kilómetros (odómetro)</option>
            <option value="ambos">Horas y Km</option>
          </select>
        </div>
        <div class="ff"><div class="fl">Intervalo esperado (opcional)</div>
          <div style="display:flex;gap:6px;align-items:center">
