function gcalGuardarEvento(evId){
  if(!canWrite('calendario'))return;
  var tit=gv('gce-tit'),f=gv('gce-fecha'),hi=gv('gce-ini'),hf=gv('gce-fin'),notas=gv('gce-notas');
  if(!tit){var m=G('gce-msg');if(m)m.textContent='Escribe un título.';return;}
  var resource={summary:tit,description:notas,
    start:{dateTime:f+'T'+(hi||'09:00')+':00',timeZone:'America/Bogota'},
    end:{dateTime:f+'T'+(hf||'10:00')+':00',timeZone:'America/Bogota'}};
  if(_GCAL.saving)return; _GCAL.saving=true;
  _gcalEnsureToken();
  var _bp=G('gce-savebtn'); if(_bp){_bp.disabled=true;_bp.style.opacity='.6';_bp.textContent='Guardando...';}
  var op=evId?gapi.client.calendar.events.patch({calendarId:'primary',eventId:evId,resource:resource})
             :gapi.client.calendar.events.insert({calendarId:'primary',resource:resource});
  op.then(function(){_GCAL.saving=false;modalAvisoClose();_gcalFetchAndRender();})
    .catch(function(err){_GCAL.saving=false;var _b=G('gce-savebtn');if(_b){_b.disabled=false;_b.style.opacity='';_b.textContent='Guardar en Google';}
      if(err&&err.status===401){_gcalSilentReconnect();var m0=G('gce-msg');if(m0)m0.textContent='Reconectando... intenta guardar de nuevo.';return;}
      var m=G('gce-msg');if(m)m.textContent='Error: '+((err&&err.result&&err.result.error&&err.result.error.message)||'no se pudo guardar');});
}
function gcalEliminarEvento(evId){
  if(!canWrite('calendario'))return;
