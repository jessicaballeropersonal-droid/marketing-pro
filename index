// Helper: detecta si registro de extracción vino de bitácora
function esExtDeBitacora(r){return r&&r.origenBit===true;}

// Helper: detecta si registro de producción vino de bitácora
function esProdDeBitacora(r){return r&&(r.origenBit===true||(r.bitIds&&r.bitIds.length>0));}

// Helper: detecta si una bitácora tiene producción YA clasificada
function bitacoraTieneClasificacion(bitId){
  return (S.prod.records||[]).some(function(p){
    return p.bitIds&&p.bitIds.indexOf(bitId)>=0&&!p.pendienteClasif&&p.dist&&p.dist.length>0;
  });
}

// Helper: ¿Una extracción manual generó orden/clasificación?
// Match: prod.records con origenBit=false que comparten fecha+turno con la extracción
function extraccionManualTieneOrdenes(r){
  if(esExtDeBitacora(r))return {ordenes:[],clasificadas:[]};
  var ordenes=(S.prod.records||[]).filter(function(p){
    return !esProdDeBitacora(p) && p.fecha===r.fecha && (p.turno||'dia')===(r.turno||'dia');
  });
  var clasificadas=ordenes.filter(function(p){return !p.pendienteClasif&&p.dist&&p.dist.length>0;});
  return {ordenes:ordenes,clasificadas:clasificadas};
}

// Helper: obtiene fecha de la bitácora origen
function bitacoraFecha(bitId){
  var b=(S.mantBitacoras||[]).find(function(x){return x.id===bitId;});
  return b?b.fecha:'';
}

