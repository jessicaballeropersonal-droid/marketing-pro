  if(_rastEsSecop(v))html+='<span style="background:#EAF3DE;color:#173404;font-size:8px;font-weight:700;letter-spacing:.5px;padding:3px 8px;border-radius:6px;font-family:var(--M)">⚙ AUTOMÁTICO</span>';
  html+='</div>';
  html+='<div style="display:flex;gap:6px">';
  if(_RAST.buscandoVentana===v.id){
    html+='<button class="btn btn-sm" disabled style="background:var(--bg4);color:var(--tx2);cursor:not-allowed;opacity:.7">⏳ Buscando...</button>';
  }else if(_RAST.buscandoVentana){
    html+='<button class="btn btn-sm" disabled style="background:var(--bg4);color:var(--tx3);cursor:not-allowed;opacity:.5">🔍 Buscar ahora</button>';
  }else{
    html+='<button class="btn btn-or btn-sm" onclick="rastBuscarVentana(\''+v.id+'\')">🔍 Buscar ahora</button>';
  }
  if(_rastIsAdmin()){
    html+='<button class="btn btn-gh btn-sm" onclick="rastVentanaEdit(\''+v.id+'\')">⚙</button>';
  }
  html+='</div></div>';

  // URLs + Probar + interruptor (solo admin)
  if(_rastIsAdmin()){
    html+='<div style="background:var(--bg3);border-radius:6px;padding:8px 10px;margin-bottom:10px;font-size:10px">';
    html+='<div style="color:var(--tx2);font-weight:600;margin-bottom:4px;font-family:var(--M);letter-spacing:.5px;font-size:9px">URLS DE ESTA VENTANA</div>';
    (v.urls||[]).forEach(function(u,i){
      html+='<div style="color:var(--tx1);font-family:var(--M);margin-bottom:2px;display:flex;justify-content:space-between"><span>• '+_rastEsc(u)+'</span><span onclick="rastUrlDel(\''+v.id+'\','+i+')" style="cursor:pointer;color:var(--er);font-weight:700">✕</span></div>';
    });
    if(_rastEsSecop(v)){
      html+='<div style="color:var(--tx3);font-family:var(--M);margin-top:4px;font-style:italic">Fuente automática — gestionada por el sistema.</div>';
    }else{
      html+='<div onclick="rastUrlAdd(\''+v.id+'\')" style="color:var(--tx3);font-family:var(--M);cursor:pointer;margin-top:4px">+ agregar URL...</div>';
      var _sa=(v.soloAbiertos!==false);
      html+='<div style="display:flex;align-items:center;gap:7px;margin-top:8px;padding-top:7px;border-top:1px dashed var(--bd2)">';
      html+='<span onclick="rastToggleAbierto(\''+v.id+'\')" style="cursor:pointer;width:30px;height:17px;border-radius:9px;flex:none;position:relative;background:'+(_sa?'var(--ok)':'var(--bd3)')+'"><span style="position:absolute;width:13px;height:13px;background:#fff;border-radius:50%;top:2px;'+(_sa?'right:2px':'left:2px')+'"></span></span>';
      html+='<span style="color:var(--tx2);font-family:var(--M);font-size:9px">Solo avisar si el proceso está ABIERTO</span>';
      html+='</div>';
      html+='<div style="margin-top:8px"><button class="btn btn-gh btn-sm" onclick="rastProbarURL(\''+v.id+'\')" style="font-size:10px;padding:5px 11px">🔍 Probar esta página</button></div>';
    }
    html+='</div>';
  }

  // Lista de alertas de esta ventana
  var alertas=S.rastreadorAlertas.filter(function(a){return a.ventana===v.id&&a.estado!=='descartada';});
  alertas.sort(function(a,b){return new Date(b.encontrada_en||0)-new Date(a.encontrada_en||0);});

  if(!alertas.length){
    html+='<div style="text-align:center;padding:30px 14px;color:var(--tx3);font-size:11px;background:var(--bg3);border-radius:8px;font-style:italic">Sin alertas en esta ventana. Pulsa "🔍 Buscar ahora" para rastrear.</div>';
  }else{
    alertas.forEach(function(a){html+=_rastRenderAlerta(a);});
