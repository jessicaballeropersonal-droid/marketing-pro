function _iadmSetCosto(key,sec,itemId,which,val){
  var mes=_iadmGetMes(key);
  if(!mes.costos[sec])mes.costos[sec]={};
  var cur=mes.costos[sec][itemId];
  if(!cur||typeof cur!=='object'){var n=parseFloat(cur)||0;cur={a:n,b:0};}
  if(which==='a'||which==='b'){cur[which]=parseFloat(val)||0;}
  else{cur={a:parseFloat(val)||0,b:0};}
  mes.costos[sec][itemId]=cur;
  _iadmSave();
  renderInformeAdm();
}

function _iadmSetM3(key,campo,val){
  var mes=_iadmGetMes(key);
  mes[campo]=parseFloat(val)||0;
  // v172.11: marcar m3expl como editado manualmente para que no se sobreescriba con auto
  if(campo==='m3expl')mes.m3explEditado=true;
  _iadmSave();
  renderInformeAdm();
}

function _iadmResetM3Expl(key){
  var mes=_iadmGetMes(key);
  var auto=_iadmAutoM3(key);
  mes.m3expl=auto.me;
  mes.m3explEditado=false;
  _iadmSave();
  renderInformeAdm();
}

// Setear m³ manual por equipo (trit/zar/transf). val vacío o null = volver a auto
function _iadmSetM3Eq(key,equipo,val){
  var mes=_iadmGetMes(key);
  var campo='m3'+equipo; // m3trit, m3zar, m3transf
  if(val===''||val===null||val===undefined){
    mes[campo]=null;
  } else {
    mes[campo]=parseFloat(val);
    if(isNaN(mes[campo]))mes[campo]=null;
  }
  _iadmSave();
  // Re-render solo del tab actual (no recargar todo)
  var tab=document.querySelector('#pg-informe-adm-wrap .insp-tab.on');
  var tabId=tab?tab.id.replace('iadm-tab-',''):'planta';
  _renderIAdmTab(tabId);
}

// Restablecer los 3 m³ del mes a sus valores automáticos
function _iadmResetM3Auto(key){
  cc('¿Restablecer los 3 valores de m³ a auto-calculados? Se perderán las ediciones manuales.',function(){
