function _taskCardHTML(t){
  var today2=today();
  var isLate=t.fecha_vencimiento&&t.fecha_vencimiento<today2&&t.estado!=='archivo';
  var isSoon=t.fecha_vencimiento&&!isLate&&t.fecha_vencimiento<=_addDays(today2,3);
  var tipoCls=t.tipo==='administrativa'?'tipo-adm':'tipo-op';
  var prioOver=t.prioridad==='alta'?'prio-alta':'';
  var tipoTag=t.tipo==='administrativa'
    ?'<span class="tc-tag adm">ADM</span>'
    :'<span class="tc-tag op">OP</span>';
  var prioTag=t.prioridad==='alta'?'<span class="tc-tag alta">ALTA</span>'
    :t.prioridad==='media'?'<span class="tc-tag media">MEDIA</span>'
    :'<span class="tc-tag baja">BAJA</span>';
  // Avatares de responsables
  var avHtml='';
  (t.responsables||[]).slice(0,4).forEach(function(uid,i){
    var u=S.usuarios.find(function(x){return x.id===uid;});
    var name=u?u.nombre:'?';
    avHtml+='<div class="tc-av" style="'+_avStyle(i)+'">'+_initials(name)+'</div>';
  });
  // Supervisores checks para estado revision
  var supHtml='';
  if(t.estado==='revision'){
    var total=(t.responsables||[]).length;
    var gestionadas=(t.gestionadas||[]).length;
    supHtml='<div class="tc-sups">Supervisores: '+gestionadas+'/'+total+' gestionaron</div>'
      +'<div class="tc-checks">'
      +(t.responsables||[]).map(function(uid){
        var done=(t.gestionadas||[]).indexOf(uid)>-1;
        return'<div class="tc-chk'+(done?' done':'')+'">'+( done?'✓':'')+'</div>';
      }).join('')
      +'</div>';
  }
  var dateHtml='';
  if(t.fecha_vencimiento){
    var dcls=isLate?'late':isSoon?'soon':'';
