    +_iadmPEDesglose({varExpl:_pe.varExpl,varPlanta:_pe.varPlanta,varAdm:_pe.varAdm,me:_pe.me,mp:_pe.mp,varM3:_pe.varM3,m3vend:_pe.m3vend,tV:_pe.tV,precioM3:_pe.precioM3,mc:_pe.mc,fijos:_pe.fijos,pe:_pe.pe})
    +'</div>';

  // ── PE ANUAL (acumulado del año) ──
  var _yr=(key||'').split('-')[0];
  var _pa=_iadmCalcPEAnual(_yr);
  html+='<div style="padding:12px 14px;background:var(--bg3);border-top:1px solid var(--bd2)">'
    +'<div style="font-family:var(--M);font-size:8px;color:var(--tx3);margin-bottom:6px">📅 PUNTO DE EQUILIBRIO ANUAL (acumulado '+_yr+') — más confiable</div>'
    +'<div style="display:flex;gap:20px;flex-wrap:wrap;align-items:flex-end">'
    +'<div><div style="font-family:var(--M);font-size:7px;color:var(--tx3)">PE anual</div><div style="font-family:var(--M);font-size:20px;font-weight:900;color:var(--cy)">'+(_pa.mc>0?_pa.pe.toLocaleString()+' m³':'—')+'</div></div>'
    +'<div><div style="font-family:var(--M);font-size:7px;color:var(--tx3)">Precio/m³</div><div style="font-family:var(--M);font-size:12px;font-weight:700">'+_fcppV(_pa.precioM3)+'</div></div>'
    +'<div><div style="font-family:var(--M);font-size:7px;color:var(--tx3)">Costo Var/m³</div><div style="font-family:var(--M);font-size:12px;font-weight:700;color:var(--er)">'+_fcppV(_pa.varM3)+'</div></div>'
    +'<div><div style="font-family:var(--M);font-size:7px;color:var(--tx3)">Margen/m³</div><div style="font-family:var(--M);font-size:12px;font-weight:700;color:'+(_pa.mc>=0?'var(--ok)':'var(--er)')+'">'+_fcppS(_pa.mc)+'</div></div>'
    +'<div><div style="font-family:var(--M);font-size:7px;color:var(--tx3)">Vendido año</div><div style="font-family:var(--M);font-size:12px;font-weight:700">'+_pa.vend.toLocaleString('es-CO',{maximumFractionDigits:0})+' m³</div></div>'
    +'</div>'
    +(_pa.mc<=0&&(_pa.fijos>0||_pa.varM3>0)?'<div style="font-family:var(--M);font-size:8px;color:var(--er);margin-top:6px">⚠️ Margen anual negativo: el costo variable/m³ supera el precio/m³ en el acumulado del año.</div>':'')
    +_iadmPEDesglose({varExpl:_pa.varExpl,varPlanta:_pa.varPlanta,varAdm:_pa.varAdm,me:_pa.me,mp:_pa.mp,varM3:_pa.varM3,m3vend:_pa.vend,tV:_pa.ventas,precioM3:_pa.precioM3,mc:_pa.mc,fijos:_pa.fijos,pe:_pa.pe})
    +'</div>';

  html+='</div></div>';
  html+='</div>';
  c.innerHTML=html;
}

// ── TAB: Ventas ─────────────────────────────────────────────────────
function _iadmRenderVentas(c){
  var key=_iadmMesKey();
  var mes=_iadmGetMes(key);
   var isAdmin=puedeEditar('informe-adm');

  // Calcular m³ auto-distribuidos por cliente desde despachos
  var autoVentas=_iadmAutoVentas(key);

  // Migrar estructura vieja si existe (v.precios={empresaId:{m3,precioU}}) → nueva (v.precios={clienteId:{precioU}})
  if(mes.ventas&&mes.ventas.length){
    mes.ventas.forEach(function(v){
      if(v.precios){
        Object.keys(v.precios).forEach(function(k){
          // Si el valor tiene m3, lo ignoramos (ahora viene auto)
          if(v.precios[k]&&typeof v.precios[k]==='object'&&'m3' in v.precios[k]){
            // Conservar solo precioU
            v.precios[k]={precioU:v.precios[k].precioU||0};
          }
        });
      }
    });
  }

  // Sincronizar ventas con los productos despachados del mes
  if(!mes.ventas)mes.ventas=[];
  autoVentas.forEach(function(a){
    var existing=mes.ventas.find(function(v){return v.ptId===a.ptId;});
    if(!existing){
      mes.ventas.push({ptId:a.ptId,precios:{}});
    }
  });

  // Construir lista de clientes que tuvieron despachos en este mes
  var clientesConVentas={};
  autoVentas.forEach(function(a){
    Object.keys(a.m3PorCliente).forEach(function(clId){clientesConVentas[clId]=true;});
  });
  // Resolver clientes a objetos (con nombre)
  var clientesActivos=Object.keys(clientesConVentas).map(function(clId){
    if(clId==='_sin_cliente')return{id:'_sin_cliente',nombre:'Sin cliente'};
    var c=(S.clientes||[]).find(function(x){return x.id===clId;});
    return c?{id:c.id,nombre:c.nombre}:{id:clId,nombre:'(eliminado)'};
  }).sort(function(a,b){return a.nombre.localeCompare(b.nombre);});

  // Helper: obtener m³ auto-distribuido para un producto+cliente
  function getM3Auto(ptId,clId){
    var a=autoVentas.find(function(x){return x.ptId===ptId;});
    if(!a)return 0;
    return a.m3PorCliente[clId]||0;
  }

  var html='<div style="background:var(--bg2);border:1px solid var(--bd2);border-radius:10px;overflow:hidden">';
  html+='<div style="background:var(--dark);padding:10px 14px;display:flex;justify-content:space-between;align-items:center">'
    +'<div><div style="font-family:var(--M);font-size:9px;font-weight:700;color:#fff;letter-spacing:1px">💰 VENTAS DETALLADAS</div>'
    +'<div style="font-family:var(--M);font-size:8px;color:var(--tx3);margin-top:2px">m³ auto-importados de Despachos · precio manual</div></div>'
    +'<div style="font-family:var(--M);font-size:8px;color:var(--tx3)">'+clientesActivos.length+' cliente(s) · '+mes.ventas.length+' producto(s)</div>'
    +'</div>';

  if(!clientesActivos.length){
    html+='<div style="padding:32px;text-align:center;color:var(--tx3);font-size:12px;font-style:italic">'
      +'No hay despachos registrados para este mes.<br>'
      +'<span style="font-size:10px;color:var(--tx3)">Los m³ vendidos se importan automáticamente desde el módulo Despacho.</span>'
      +'</div>';
    html+='</div>';
    c.innerHTML=html;
    return;
  }

  // Column headers
  var nCols=clientesActivos.length;
  var colsHdr='<div style="display:grid;grid-template-columns:160px repeat('+(nCols*3)+',1fr) 80px 100px;gap:0;padding:6px 12px;background:var(--bg3);font-family:var(--M);font-size:7px;color:var(--tx3);letter-spacing:1px">'
    +'<div>PRODUCTO</div>';
  clientesActivos.forEach(function(cl){
    colsHdr+='<div style="text-align:center;color:var(--in)" title="'+cl.nombre+'">'+cl.nombre+' m³</div>'
      +'<div style="text-align:center;color:var(--in)">Precio U.</div>'
      +'<div style="text-align:center;color:var(--in)">Total $</div>';
  });
  colsHdr+='<div style="text-align:center">TOTAL m³</div><div style="text-align:center">TOTAL $</div></div>';
  html+=colsHdr;

  var totales={m3:0,pesos:0};
  var totCli={};
  clientesActivos.forEach(function(cl){totCli[cl.id]={m3:0,pesos:0};});

  (mes.ventas||[]).forEach(function(v,vi){
    var ptNombre=v.ptId?ptn(v.ptId):(v.nombre||'Externo');
    var rowM3=0,rowPesos=0;
    if(!v.precios)v.precios={};
    var bgRow=vi%2===0?'':'background:var(--bg3)';
    var row='<div style="display:grid;grid-template-columns:160px repeat('+(nCols*3)+',1fr) 80px 100px;gap:0;padding:6px 12px;border-bottom:1px solid var(--bd2);align-items:center;'+bgRow+'">'
      +'<div style="font-size:11px;font-weight:600">'+ptNombre+'</div>';
    clientesActivos.forEach(function(cl){
      var m3v=v.ptId?getM3Auto(v.ptId,cl.id):0; // m³ auto-distribuidos (no editables)
      var pu=v.precios[cl.id]?v.precios[cl.id].precioU:0;
      var sub=(m3v||0)*(pu||0);
      rowM3+=(m3v||0); rowPesos+=sub;
      if(totCli[cl.id]){totCli[cl.id].m3+=(m3v||0);totCli[cl.id].pesos+=sub;}
      // M³ siempre como display (no editable, auto-importado)
      row+='<div style="text-align:right;font-family:var(--M);font-size:10px;color:'+(m3v>0?'var(--tx1)':'var(--tx3)')+';font-weight:'+(m3v>0?'700':'400')+';padding:0 6px">'
        +(m3v>0?m3v.toLocaleString('es-CO',{maximumFractionDigits:2}):'—')+'</div>';
      // Precio manual (admin) o display (otros roles)
      if(isAdmin){
        row+='<div style="padding:2px 4px"><input type="number" class="fi" min="0" value="'+(pu||'')+'" placeholder="$" style="font-size:11px;text-align:right" '
          +(m3v>0?'':'disabled ')
          +'onchange="_iadmSetVenta(\''+key+'\','+vi+',\''+cl.id+'\',\'precioU\',this.value)"></div>';
      } else {
        row+='<div style="text-align:right;font-family:var(--M);font-size:10px;color:var(--tx3)">'+_fmn(pu)+'</div>';
      }
      row+='<div style="text-align:right;font-family:var(--M);font-size:10px;color:var(--ok)">'+_fmn(sub)+'</div>';
    });
    totales.m3+=rowM3; totales.pesos+=rowPesos;
    row+='<div style="text-align:right;font-family:var(--M);font-size:11px;font-weight:700">'+rowM3.toLocaleString('es-CO',{maximumFractionDigits:2})+'</div>'
      +'<div style="text-align:right;font-family:var(--M);font-size:11px;font-weight:700;color:var(--ok)">'+_fmn(rowPesos)+'</div>'
      +'</div>';
    html+=row;
  });

  // Totals row
  html+='<div style="display:grid;grid-template-columns:160px repeat('+(nCols*3)+',1fr) 80px 100px;gap:0;padding:8px 12px;background:var(--dark);align-items:center">'
    +'<div style="font-family:var(--M);font-size:9px;font-weight:700;color:#fff">VENTAS TOTALES</div>';
  clientesActivos.forEach(function(cl){
    var em=totCli[cl.id]||{m3:0,pesos:0};
    var pct=totales.pesos>0?em.pesos/totales.pesos*100:0;
    html+='<div style="text-align:right;font-family:var(--M);font-size:10px;font-weight:700;color:#fff">'+em.m3.toLocaleString('es-CO',{maximumFractionDigits:0})+'</div>'
      +'<div style="text-align:center;font-family:var(--M);font-size:8px;color:var(--tx3)">'+pct.toFixed(1)+'%</div>'
      +'<div style="text-align:right;font-family:var(--M);font-size:10px;font-weight:700;color:var(--ok)">'+_fmn(em.pesos)+'</div>';
  });
  html+='<div style="text-align:right;font-family:var(--M);font-size:11px;font-weight:700;color:#fff">'+totales.m3.toLocaleString('es-CO',{maximumFractionDigits:0})+'</div>'
    +'<div style="text-align:right;font-family:var(--M);font-size:12px;font-weight:900;color:var(--ok)">'+_fmn(totales.pesos)+'</div>'
    +'</div>';

  html+='</div>';
  if(isAdmin){
    html+='<div style="margin-top:8px;padding:8px 12px;background:var(--inA);border:1px solid var(--inB);border-radius:8px;font-family:var(--M);font-size:8px;color:var(--in);line-height:1.6">'
      +'💡 Los m³ se distribuyen automáticamente por cliente desde los despachos registrados en el módulo Despacho. '
      +'Solo necesita ingresar el <strong>precio unitario</strong> por cliente.'
      +'</div>';
  }
  c.innerHTML=html;
}

function _iadmSetVenta(key,vi,clId,campo,val){
  var mes=_iadmGetMes(key);
  if(!mes.ventas[vi].precios)mes.ventas[vi].precios={};
  if(!mes.ventas[vi].precios[clId])mes.ventas[vi].precios[clId]={precioU:0};
  mes.ventas[vi].precios[clId][campo]=parseFloat(val)||0;
  _iadmSave();
  // Update totals without full re-render
  _iadmRenderVentas(G('iadm-content'));
}

function _iadmAddVentaExt(){
  var n=prompt('Nombre del producto externo:');
  if(!n)return;
  var key=_iadmMesKey();
  var mes=_iadmGetMes(key);
  mes.ventas.push({nombre:n,precios:{}});
  _iadmSave();
  _iadmRenderVentas(G('iadm-content'));
}

