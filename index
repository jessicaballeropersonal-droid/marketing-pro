function _inspDelEst(id){
  var estado=(S.inspeccionOTEstados||[]).find(function(e){return e.id===id;});
  if(!estado){return;}
  // Contar Auto-OTs que usan este estado
  var autoOTs=(S.mantOrdenes||[]).filter(function(o){return o.tipo==='inspeccion'&&o.estado===id;}).length;
  // NIVEL 1: BLOQUEAR si tiene Auto-OTs
  if(autoOTs>0){
    var contenido='<div style="background:var(--bg2);border-radius:8px;padding:12px;margin-bottom:11px;border-left:3px solid var(--er)">';
    contenido+='<div style="font-family:var(--M);font-size:10px;color:var(--tx2);margin-bottom:6px">ESTADO AUTO-OT INSPECCIÓN:</div>';
    contenido+='<div style="font-size:13px;color:var(--tx1);font-weight:700">'+(estado.nombre||id)+'</div>';
    contenido+='</div>';
    contenido+='<div style="background:var(--erA);border-radius:7px;padding:11px;margin-bottom:11px">';
    contenido+='<div style="font-family:var(--M);font-size:9px;color:var(--er);margin-bottom:6px;font-weight:700">⚠️ ESTE ESTADO TIENE AUTO-OTs:</div>';
    contenido+='<div style="font-family:var(--M);font-size:10px;color:var(--tx1)">• '+autoOTs+' Auto-OT(s) están en este estado</div>';
    contenido+='</div>';
    contenido+='<div style="background:var(--inA);border-radius:7px;padding:10px">';
    contenido+='<div style="font-family:var(--M);font-size:10px;color:var(--in);line-height:1.6">Mueva esas Auto-OTs a otro estado antes de eliminar.</div>';
    contenido+='</div>';
    modalAviso({tipo:'danger',titulo:'No se puede eliminar el estado',subtitulo:'Tiene Auto-OTs asignadas',contenidoHtml:contenido,botonSecundario:'Entendido'});
    return;
  }
  // NIVEL 3: confirmación simple
  modalAviso({tipo:'warn',titulo:'Eliminar Estado Auto-OT',
    contenidoHtml:'<div style="font-size:13px;color:var(--tx1);font-weight:700;margin-bottom:8px">'+(estado.nombre||id)+'</div><div style="background:var(--okA);border-radius:7px;padding:10px;font-family:var(--M);font-size:10px;color:var(--ok)">✓ Sin Auto-OTs asignadas, se puede eliminar.</div>',
    botonPrincipal:'🗑️ Eliminar',onPrincipal:function(){
      S.inspeccionOTEstados=(S.inspeccionOTEstados||[]).filter(function(e){return e.id!==id;});
      dbSaveInsp();
      try{_renderInspEstLista();}catch(e){}
      modalAvisoClose();
    }});
}
function _inspMoverEst(idx,dir){
  var arr=S.inspeccionOTEstados||[];var ni=idx+dir;
  if(ni<0||ni>=arr.length)return;
  var tmp=arr[idx];arr[idx]=arr[ni];arr[ni]=tmp;
  dbSaveInsp();_renderInspEstLista();
}

