function _renderDestinosLista2(){
  var c=G('destinos-lista');if(!c)return;
  var pf=(S.conductoresConfig&&S.conductoresConfig.preciosFijos)||{};
  c.innerHTML=_DESTINOS_FIJOS.map(function(d){
