  eq.alertaPct=parseInt(gv('emeq-apct'))||15;
  dbSaveMantEquipo(eq);cmo('ov-mant-eq-edit');renderEquiposMant();
}
function delMantEq(id){
  var eq=S.mantEquipos.find(function(e){return e.id===id;});
  if(!eq){return;}
  // Verificar si tiene registros en bitácora
  var bitacoras=(S.mantBitacoras||[]).filter(function(b){return b.equipoId===id;});
  var planes=(S.mantPlanes||[]).filter(function(p){return p.eqId===id;});
  // Contar dependencias en cascada
  var totalExp=0,totalProd=0,totalOTs=0,totalAcpm=0;
  bitacoras.forEach(function(b){
    var exps=(S.exp.records||[]).filter(function(r){return r.origenBit&&r.equipoId===id&&r.fecha===b.fecha;});
    totalExp+=exps.length;
    var prods=(S.prod.records||[]).filter(function(p){return p.bitIds&&p.bitIds.indexOf(b.id)>=0;});
    totalProd+=prods.length;
    var ots=(S.mantOrdenes||[]).filter(function(o){return o.fecha===b.fecha&&o.eqId===id&&o.origen==='auto';});
    totalOTs+=ots.length;
    if(b.acpm&&b.acpm>0)totalAcpm+=b.acpm;
  });
  // NIVEL 1: si tiene bitácoras, BLOQUEAR
  if(bitacoras.length>0){
    var contenido='<div style="background:var(--bg2);border-radius:8px;padding:12px;margin-bottom:11px;border-left:3px solid var(--er)">';
    contenido+='<div style="font-family:var(--M);font-size:10px;color:var(--tx2);margin-bottom:6px">EQUIPO:</div>';
    contenido+='<div style="font-size:13px;color:var(--tx1);font-weight:700">🚛 '+eq.nombre+(eq.placa?' · '+eq.placa:'')+'</div>';
    contenido+='</div>';
    contenido+='<div style="background:var(--erA);border-radius:7px;padding:11px;margin-bottom:11px">';
    contenido+='<div style="font-family:var(--M);font-size:9px;color:var(--er);margin-bottom:8px;font-weight:700">⚠️ ESTE EQUIPO TIENE HISTORIAL — SI ELIMINA, DESCUADRARÍA:</div>';
    contenido+='<div style="font-family:var(--M);font-size:10px;color:var(--tx1);line-height:1.9">';
    contenido+='<div>📓 <strong>'+bitacoras.length+' registro(s) de Bitácora</strong></div>';
    if(totalExp>0)contenido+='<div>🪨 '+totalExp+' registro(s) de Extracción afectando inventario</div>';
    if(totalProd>0)contenido+='<div>🏭 '+totalProd+' registro(s) de Producción</div>';
    if(totalOTs>0)contenido+='<div>🔧 '+totalOTs+' Orden(es) de Trabajo automáticas</div>';
    if(totalAcpm>0)contenido+='<div>⛽ '+totalAcpm.toFixed(2)+' L de consumo ACPM registrado</div>';
    if(planes.length>0)contenido+='<div>📅 '+planes.length+' Plan(es) de mantenimiento preventivo</div>';
