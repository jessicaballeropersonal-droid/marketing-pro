function saveTarea(){
  var titulo=G('tarea-titulo').value.trim();
  if(!titulo){showAlert('tarea-alert','er','El título es obligatorio.');return;}
  var resp=_getSelectedResponsables();
  // FIX: Si es edición, obtener registro original para preservar creado_en/creado_por
  var original=_tareaEditId?S.tareas.find(function(x){return x.id===_tareaEditId;}):null;
  var t={
    id:_tareaEditId||uid(),
    titulo:titulo,
    descripcion:G('tarea-desc').value.trim(),
    tipo:G('tarea-tipo').value,
    prioridad:G('tarea-prio').value,
    fecha_vencimiento:G('tarea-fecha').value,
    estado:G('tarea-estado').value,
    responsables:resp,
    gestionadas:[],
    // FIX: Preservar creado_por y creado_en si es edición
    creado_por:original?original.creado_por:(SESION?SESION.id:''),
    creado_en:original?original.creado_en:new Date().toISOString().split('T')[0],
    comentarios:[]
  };
  var com=G('tarea-comentario').value.trim();
  if(com)t.comentarios.push({id:uid(),texto:com,autor:SESION?SESION.nombre:'',fecha:today()});
  if(_tareaEditId){
    var idx=S.tareas.findIndex(function(x){return x.id===_tareaEditId;});
    if(idx>-1){t.gestionadas=S.tareas[idx].gestionadas||[];t.comentarios=S.tareas[idx].comentarios||[];if(com)t.comentarios.push({id:uid(),texto:com,autor:SESION?SESION.nombre:'',fecha:today()});S.tareas[idx]=t;}
  } else {
    S.tareas.push(t);
  }
  saveTareasDB();
  cmo('ov-tarea');
  _renderKanban();
  _updateTareasBadge();
}

