function _calcLiquidacion(){
  var condId=G('liq-cond-id').value;
  var desde=G('liq-desde').value;var hasta=G('liq-hasta').value;
  var al=G('liq-alert');
  if(!desde||!hasta){al.className='alert alert-er on';al.textContent='Selecciona el período completo.';return;}
  // Check si ya está liquidado
  var liqExist=(S.conductoresLiq||[]).find(function(l){return l.condId===condId&&l.desde===desde&&l.hasta===hasta;});
  if(liqExist){al.className='alert alert-wa on';al.textContent='⚠️ Este período ya fue liquidado el '+fd(liqExist.fechaLiq)+'.';return;}
  al.className='alert';
  // Get viajes from exp records
  var cond=(S.conductores||[]).find(function(c){return c.id===condId;});
  var destinos=((S.ctrlViajesConfig||{}).destinos)||[];
  var grupos={};
  (S.exp.records||[]).forEach(function(r){
    if(r.conductorId!==condId)return;
    if(r.fecha<desde||r.fecha>hasta)return;
    // Each destination type
    destinos.forEach(function(dest){
      var key=dest.id;
      var viajes=parseInt(r['dest_'+dest.id])||0;
      if(viajes>0){
        if(!grupos[key])grupos[key]={nombre:dest.nombre,precio:dest.precio,viajes:0};
        grupos[key].viajes+=viajes;
      }
    });
  });
  var keys=Object.keys(grupos);
  var total=0;
  var html='';
  if(!keys.length){
    G('liq-resultado').innerHTML='<div style="text-align:center;padding:20px;color:var(--tx3)">Sin viajes registrados en este período.</div>';
    var btn=G('liq-confirmar-btn');if(btn)btn.style.display='none';
    return;
  }
  html='<div class="tw"><table><thead><tr><th>Destino / Tipo</th><th style="text-align:center">Viajes</th><th style="text-align:right">Precio/viaje</th><th style="text-align:right">Subtotal</th></tr></thead><tbody>';
  keys.forEach(function(k){
    var g=grupos[k];
    var sub=g.viajes*g.precio;total+=sub;
    html+='<tr><td>'+g.nombre+'</td><td style="text-align:center;font-weight:700">'+g.viajes+'</td>'
      +'<td style="text-align:right">$'+Math.round(g.precio).toLocaleString('es-CO')+'</td>'
      +'<td style="text-align:right;font-weight:700;color:var(--ok)">$'+Math.round(sub).toLocaleString('es-CO')+'</td></tr>';
  });
  // Independiente: add flete %
  if(cond&&cond.tipo==='independiente'&&cond.porc>0){
    var flete=total;var comision=Math.round(flete*cond.porc/100);
    html+='<tr style="background:var(--puA)"><td colspan="3" style="font-weight:700">Comisión ('+cond.porc+'% del flete)</td><td style="text-align:right;font-weight:700;color:var(--pu)">$'+comision.toLocaleString('es-CO')+'</td></tr>';
    total=comision;
  }
  html+='<tr style="background:var(--okA)"><td colspan="3" style="font-weight:700">TOTAL A PAGAR</td><td style="text-align:right;font-weight:900;color:var(--ok);font-size:16px">$'+Math.round(total).toLocaleString('es-CO')+'</td></tr></tbody></table></div>';
  G('liq-resultado').innerHTML=html;
  G('liq-resultado').dataset.total=total;
  G('liq-resultado').dataset.grupos=JSON.stringify(grupos);
  var btn=G('liq-confirmar-btn');if(btn)btn.style.display='inline-flex';
}
