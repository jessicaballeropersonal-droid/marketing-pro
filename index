function gestionarTarea(id){
  var t=S.tareas.find(function(x){return x.id===id;});if(!t||!SESION)return;
  if(!t.gestionadas)t.gestionadas=[];
  if(t.gestionadas.indexOf(SESION.id)===-1)t.gestionadas.push(SESION.id);
  // Si todos gestionaron → aprobado automático
  var todos=(t.responsables||[]).every(function(uid2){return t.gestionadas.indexOf(uid2)>-1;});
  if(todos)t.estado='aprobado';
  saveTareasDB();
  cmo('ov-tarea-det');
  _renderKanban();
  _updateTareasBadge();
}

function archivarTarea(id){
  var t=S.tareas.find(function(x){return x.id===id;});if(!t)return;
  t.estado='archivo';
  saveTareasDB();cmo('ov-tarea-det');_renderKanban();_updateTareasBadge();
}

function editTarea(id){
  var t=S.tareas.find(function(x){return x.id===id;});if(!t)return;
  cmo('ov-tarea-det');
  _tareaEditId=id;
  G('tarea-mo-ttl').textContent='Editar Tarea';
  G('tarea-edit-id').value=id;
  G('tarea-titulo').value=t.titulo;
  G('tarea-desc').value=t.descripcion||'';
  G('tarea-tipo').value=t.tipo||'administrativa';
  G('tarea-prio').value=t.prioridad||'media';
  G('tarea-fecha').value=t.fecha_vencimiento||'';
  G('tarea-estado').value=t.estado||'todo';
  G('tarea-comentario').value='';
  G('tarea-alert').className='alert';
  _renderResponsablesCheck(t.responsables||[]);
  openMo('ov-tarea');
}

function delTarea(id){
  cc('¿Eliminar esta tarea permanentemente?',function(){
    S.tareas=S.tareas.filter(function(t){return t.id!==id;});
    saveTareasDB();cmo('ov-tarea-det');_renderKanban();_updateTareasBadge();
  });
}

function addComentarioTarea(id){
  var t=S.tareas.find(function(x){return x.id===id;});if(!t)return;
  var txt=G('tdet-comentario').value.trim();if(!txt)return;
  if(!t.comentarios)t.comentarios=[];
  t.comentarios.push({id:uid(),texto:txt,autor:SESION?SESION.nombre:'',fecha:today()});
  saveTareasDB();
  openTareaDetalle(id);
}

