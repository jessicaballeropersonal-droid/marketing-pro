function xCalc(){if(!G('xdc'))return;var dc=+gv('xdc')||0,dm=+gv('xdm')||0,vc=+gv('xvc')||0,vm=+gv('xvm')||0;sv('xdt',(dc*dm).toFixed(2));sv('xvt',(vc*vm).toFixed(2));var tv=G('x-tv');if(tv)tv.textContent=(dc+vc).toFixed(0);var tm=G('x-tm');if(tm)tm.textContent=((dc*dm)+(vc*vm)).toFixed(2);}
function saveExp(){
  // v172.1: Esta función ya no se usa (panel "Nuevo Registro" eliminado)
  // Se mantiene defensiva por si algún script externo la llama
  if(!G('xf')){console.log('[saveExp] Panel deprecado, ignorado');return;}
  if(!canWrite("exp"))return;
  var f=gv('xf'),pv=gv('xp'),al=gv('xal');
  var dc=+gv('xdc')||0,dm=+gv('xdm')||0,vc=+gv('xvc')||0,vm=+gv('xvm')||0;
  if(!f){showAlert('xa','er','Seleccione la fecha.');return;}
  if(!pv){showAlert('xa','er','Seleccione un proveedor.');return;}
  if(dc+vc===0){showAlert('xa','er','Ingrese al menos un viaje.');return;}
  ensureSysPT();
  var ptId=ptIdBySrc(al);
  var tot=(dc*dm)+(vc*vm);
  var rec={id:uid(),fecha:f,provId:pv,alm:al,dc:dc,dm:dm,dt:dc*dm,vc:vc,vm:vm,vt:vc*vm,tv:dc+vc,tm:tot,ptId:ptId};
  S.exp.records.push(rec);saveS();dbSaveExp(rec);
  logActividad({accion:'crear',modulo:'extraccion',descripcion:'Extracción '+f+' · '+ptn(ptId)+' '+tot.toFixed(2)+' m³ · '+(dc+vc)+' viajes',registroId:rec.id,despues:{fecha:f,proveedor:pn(pv),alm:al,m3:tot,viajes:dc+vc}});
  saveS();
  showAlert('xa','ok','✓ Guardado. Inventario "'+ptn(ptId)+'" +'+tot.toFixed(2)+' m³.');
  sv('xdc','0');sv('xdm','0');sv('xdt','');sv('xvc','0');sv('xvm','0');sv('xvt','');
  G('x-tv').textContent='0';G('x-tm').textContent='0.00';sv('xp','');
  updXKPI();
}
function updXKPI(){
  var recs=S.exp.records.filter(function(r){return r.provId!=='sys_ini';});
  var B={patio:{m3:0,v:0},tolva:{m3:0,v:0},zaranda:{m3:0,v:0},arena_rio:{m3:0,v:0}};
  recs.forEach(function(r){if(B[r.alm]){B[r.alm].m3+=r.tm;B[r.alm].v+=r.tv;}});
  G('kx-p').textContent=B.patio.m3.toFixed(1);G('kx-pv').textContent=B.patio.v+' viajes';
  G('kx-t').textContent=B.tolva.m3.toFixed(1);G('kx-tv2').textContent=B.tolva.v+' viajes';
  G('kx-z').textContent=B.zaranda.m3.toFixed(1);G('kx-zv').textContent=B.zaranda.v+' viajes';
  G('kx-a').textContent=B.arena_rio.m3.toFixed(1);G('kx-av').textContent=B.arena_rio.v+' viajes';
  var tm=B.patio.m3+B.tolva.m3+B.zaranda.m3+B.arena_rio.m3;
  var tv=B.patio.v+B.tolva.v+B.zaranda.v+B.arena_rio.v;
  G('kx-tot').textContent=tm.toFixed(1);G('kx-totv').textContent=tv+' viajes';
}
function applyXF(){
  var d=gv('xfd'),h=gv('xfh'),pr=gv('xfp'),met=gv('xfmet');
  var recs=S.exp.records.slice();
  if(d)recs=recs.filter(function(r){return r.fecha>=d;});
  if(h)recs=recs.filter(function(r){return r.fecha<=h;});
  if(pr)recs=recs.filter(function(r){return r.provId===pr;});
  var datesMap={};recs.sort(function(a,b){return a.fecha.localeCompare(b.fecha);}).forEach(function(r){datesMap[r.fecha]=1;});
  var dates=Object.keys(datesMap);
  var alms=['patio','tolva','zaranda','arena_rio'];
  var almNames={patio:'Patio/Grava',tolva:'Tolva',zaranda:'Zaranda',arena_rio:'Arena Río'};
  var datasets=[];
  var totals={patio:{m3:0,v:0},tolva:{m3:0,v:0},zaranda:{m3:0,v:0},arena_rio:{m3:0,v:0}};
  alms.forEach(function(alm,ai){
    var data=dates.map(function(dt){
      var s=0,sv2=0;
      recs.filter(function(r){return r.alm===alm&&r.fecha===dt;}).forEach(function(r){s+=r.tm;sv2+=r.tv;});
      totals[alm].m3+=s;totals[alm].v+=sv2;
      return met==='m3'?+s.toFixed(2):sv2;
    });
    datasets.push(mkDs(almNames[alm],data,COLS[ai]));
  });
  G('xf-kpi').innerHTML=alms.map(function(alm,ai){var v=totals[alm];return'<div class="kpi" style="border-top-color:'+COLS[ai]+'!important"><div class="kpi-lbl">'+almNames[alm]+'</div><div class="kpi-val" style="color:'+COLS[ai]+'">'+(met==='m3'?v.m3.toFixed(1):v.v)+'</div><div class="kpi-unit">'+(met==='m3'?'m³':'viajes')+'</div></div>';}).join('');
  mkLine('xch',dates.map(fd),datasets);
}
function renderXH(){
  var q=(gv('xsq')||'').toLowerCase();
  var recs=S.exp.records.filter(function(r){
    return r.provId!=='sys_ini'&&!r.pp&&(r.tm||0)>=0&&r.alm;
  }).sort(function(a,b){return b.fecha.localeCompare(a.fecha);});
  if(q)recs=recs.filter(function(r){
    return pn(r.provId).toLowerCase().includes(q)||(r.fecha||'').includes(q)||(r.alm||'').includes(q)||(r.bitEqNombre||'').toLowerCase().includes(q);
  });
  var tb=G('xhb');
  if(!recs.length){tb.innerHTML='<tr class="erow"><td colspan="8">Sin registros</td></tr>';return;}
  var almCols={patio:'var(--or)',tolva:'#60a5fa',zaranda:'#c084fc',arena_rio:'var(--cy)'};
  var almBgs={patio:'var(--orA)',tolva:'rgba(96,165,250,.08)',zaranda:'rgba(192,132,252,.08)',arena_rio:'rgba(6,182,212,.08)'};
  var almBds={patio:'var(--orB)',tolva:'rgba(96,165,250,.3)',zaranda:'rgba(192,132,252,.3)',arena_rio:'rgba(6,182,212,.3)'};
  var almLbls={patio:'Patio (Grava)',tolva:'Tolva',zaranda:'Zaranda',arena_rio:'Arena Rio'};
  var isAdmin=puedeEditar('exp');
  // NUEVA AGRUPACIÓN: Día + Turno + Origen (AUTO/MANUAL)
  var grupos={};
  recs.forEach(function(r){
    var origen=r.origenBit?'auto':'manual';
    var turno=r.turno||'dia';
    var key=r.fecha+'|'+turno+'|'+origen;
    if(!grupos[key]){
      grupos[key]={fecha:r.fecha,turno:turno,origen:origen,alms:{},totalVj:0,totalM3:0,ids:[],
        provIds:{},equipos:{}};
    }
    var g=grupos[key];
    if(!g.alms[r.alm])g.alms[r.alm]={tv:0,tm:0};
    g.alms[r.alm].tv+=(r.tv||0);g.alms[r.alm].tm+=(parseFloat(r.tm)||0);
    g.totalVj+=(r.tv||0);g.totalM3+=(parseFloat(r.tm)||0);g.ids.push(r.id);
    // Coleccionar proveedores y equipos del grupo (para mostrar)
    if(r.provId)g.provIds[r.provId]=(g.provIds[r.provId]||0)+1;
    var eqKey=r.bitEqNombre||r.equipoId||'';
    if(eqKey)g.equipos[eqKey]=(g.equipos[eqKey]||0)+1;
  });
  // Agrupar grupos por fecha (para mostrar header del día)
  var porFecha={};
  Object.keys(grupos).forEach(function(k){var g=grupos[k];if(!porFecha[g.fecha])porFecha[g.fecha]=[];porFecha[g.fecha].push(g);});
  var html='';
  Object.keys(porFecha).sort(function(a,b){return b.localeCompare(a);}).forEach(function(fecha){
    var dg=porFecha[fecha];
    // Ordenar dentro del día: turno (día primero), origen (auto primero)
    dg.sort(function(a,b){
      if(a.turno!==b.turno)return a.turno==='dia'?-1:1;
      return a.origen==='auto'?-1:1;
    });
    var dayVj=dg.reduce(function(a,g){return a+g.totalVj;},0);
    var dayM3=dg.reduce(function(a,g){return a+g.totalM3;},0);
    html+='<tr><td colspan="8" style="padding:6px 4px 4px"><div style="background:var(--bg3);border-left:3px solid var(--or);border-radius:0 6px 6px 0;padding:5px 12px;display:flex;align-items:center;gap:10px">'
      +'<span style="font-family:var(--M);font-size:9px;font-weight:700;color:var(--or)">'+fd(fecha)+'</span>'
      +'<span style="font-family:var(--M);font-size:9px;color:var(--tx3)">🚛 '+dayVj+' viajes</span>'
      +'<span style="font-family:var(--M);font-size:9px;color:var(--ok);font-weight:700">'+dayM3.toFixed(2)+' m³</span>'
      +'</div></td></tr>';
    dg.forEach(function(g){
      var turnoLbl=g.turno==='noche'?'🌙 NOCHE':'☀️ DÍA';
      var origenLbl=g.origen==='auto'?'🟦 AUTO':'📋 MANUAL';
      var origenColor=g.origen==='auto'?'var(--in)':'var(--or)';
      var origenBg=g.origen==='auto'?'var(--inA)':'var(--orA)';
      var origenBd=g.origen==='auto'?'var(--inB)':'var(--orB)';
      // Resumen de proveedores y equipos del grupo
      var provNombres=Object.keys(g.provIds).map(function(pid){return pn(pid);}).filter(function(n){return n;}).slice(0,3).join(' · ');
      var eqNombres=Object.keys(g.equipos).filter(function(e){return e;}).slice(0,2).map(function(e){
        if(S.mantEquipos){var found=S.mantEquipos.find(function(x){return x.id===e;});if(found)return found.nombre;}
        return e;
      }).join(' · ');
      html+='<tr><td colspan="8" style="padding:0 0 8px"><div style="background:var(--bg2);border:1px solid '+origenBd+';border-radius:10px;padding:12px 14px">';
      html+='<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:10px;padding-bottom:8px;border-bottom:1px solid var(--bd2)">';
      html+='<div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap">';
      html+='<span style="font-family:var(--M);font-size:11px;font-weight:700;color:var(--tx2)">'+turnoLbl+'</span>';
      html+='<span style="font-family:var(--M);font-size:9px;font-weight:700;color:'+origenColor+';background:'+origenBg+';padding:3px 9px;border-radius:10px;border:1px solid '+origenBd+'">'+origenLbl+'</span>';
      if(provNombres)html+='<span style="font-size:12px;color:var(--tx2);font-weight:700">'+provNombres+'</span>';
      if(eqNombres)html+='<span class="bdg bdg-in" style="font-size:10px">🚛 '+eqNombres+'</span>';
      html+='</div><div style="display:flex;align-items:center;gap:8px">';
      html+='<span style="font-family:var(--M);font-size:9px;color:var(--ok);font-weight:700;background:var(--okA);padding:3px 9px;border-radius:20px;border:1px solid var(--okB)">'+g.totalVj+' vj · '+g.totalM3.toFixed(1)+' m³</span>';
      if(isAdmin)html+='<button class="btn btn-gh btn-xs" onclick="editXGrupo(this)" data-ids="'+g.ids.join(',')+'" title="Editar">✏️</button> ';
      if(isAdmin)html+='<button class="btn btn-er btn-xs" onclick="delXGrupo(this)" data-ids="'+g.ids.join(',')+'">🗑️</button>';
      html+='</div></div>';
      html+='<div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(110px,1fr));gap:7px">';
      Object.keys(g.alms).forEach(function(alm){
        var d=g.alms[alm];
        var col=almCols[alm]||'var(--or)';var bg=almBgs[alm]||'var(--orA)';var bd=almBds[alm]||'var(--orB)';
        html+='<div style="background:'+bg+';border:1px solid '+bd+';border-top:3px solid '+col+';border-radius:8px;padding:9px 11px">'
          +'<div style="font-family:var(--M);font-size:7.5px;color:'+col+';letter-spacing:.5px;margin-bottom:4px">'+(almLbls[alm]||alm).toUpperCase()+'</div>'
          +'<div style="font-size:20px;font-weight:700;color:'+col+'">'+d.tm.toFixed(1)+'</div>'
          +'<div style="font-family:var(--M);font-size:8px;color:var(--tx3)">m³</div>'
          +'<div style="font-family:var(--M);font-size:8px;color:var(--tx3);margin-top:3px">'+d.tv+' viajes</div>'
          +'<div style="font-family:var(--M);font-size:8px;color:var(--tx3)">→ '+ptn(ptIdBySrc(alm))+'</div>'
          +'</div>';
      });
      html+='</div></div></td></tr>';
    });
  });
  tb.innerHTML=html;
}
function editXGrupo(btn){
  var ids=btn.getAttribute('data-ids').split(',');
  if(!ids.length){return;}
  // Verificar si algún registro del grupo vino de bitácora
  var algunoBit=ids.some(function(rid){
    var r=S.exp.records.find(function(x){return x.id===rid;});
    return r&&esExtDeBitacora(r);
  });
  if(algunoBit){
    // openEX ya tiene el bloqueo con aviso "Ir a Bitácora", lo reutilizamos
    openEX(ids[0]);
    return;
  }
  // Si tiene múltiples registros (múltiples almacenamientos), avisar
  if(ids.length>1){
    var contenido='<div style="background:var(--bg2);border-radius:8px;padding:11px;margin-bottom:11px">';
    contenido+='<div style="font-family:var(--M);font-size:10px;color:var(--tx2);margin-bottom:6px">Este grupo tiene '+ids.length+' registros (varios almacenamientos).</div>';
    contenido+='<div style="font-family:var(--M);font-size:10px;color:var(--tx3);line-height:1.6">Solo se editará el primero. Para editar los demás, abra cada uno individualmente desde Producción Histórica.</div>';
    contenido+='</div>';
    modalAviso({tipo:'info',titulo:'Editar grupo de extracción',contenidoHtml:contenido,
      botonPrincipal:'✏️ Editar primero',onPrincipal:function(){
        modalAvisoClose();
        openEX(ids[0]);
      }});
    return;
  }
  // 1 solo registro → abrir directo
  openEX(ids[0]);
}
function delXGrupo(btn){
  var ids=btn.getAttribute('data-ids').split(',');
  // Verificar si algún registro vino de bitácora
  var algunoBit=ids.some(function(rid){
    var r=S.exp.records.find(function(x){return x.id===rid;});
    return r&&esExtDeBitacora(r);
  });
  if(algunoBit){
    var primero=S.exp.records.find(function(x){return x.id===ids[0];});
    var fecha=primero?primero.fecha:'';
    var contenido='<div style="background:var(--bg2);border-radius:8px;padding:12px;margin-bottom:11px;border-left:3px solid var(--er)">';
    contenido+='<div style="font-family:var(--M);font-size:10px;color:var(--tx2);margin-bottom:6px">Uno o más registros de este grupo vienen de:</div>';
    contenido+='<div style="font-size:13px;color:var(--in)">🔗 <strong>Bitácora Operacional del '+fecha+'</strong></div>';
    contenido+='</div>';
    contenido+='<div style="background:var(--inA);border-radius:7px;padding:10px">';
    contenido+='<div style="font-family:var(--M);font-size:10px;color:var(--in);line-height:1.6">Para eliminar correctamente, vaya a <strong>Bitácora Operacional</strong> y elimine el registro completo (cascada total).</div>';
    contenido+='</div>';
    modalAviso({tipo:'danger',titulo:'No se puede eliminar el grupo',subtitulo:'Registros vinculados a Bitácora',contenidoHtml:contenido,
      botonPrincipal:'🔗 Ir a Bitácora',onPrincipal:function(){irABitacoraDia(fecha);},botonSecundario:'Entendido'});
    return;
  }
  // Todos manuales → AUDITORÍA COMPLETA DE CASCADA (v170)
  var totalM3=0;
  var registrosGrupo=[];
  var ordenesAfectadasMap={};
  var clasificacionesAfectadasMap={};
  ids.forEach(function(rid){
    var r=S.exp.records.find(function(x){return x.id===rid;});
    if(!r)return;
    totalM3+=(r.tm||0);
    registrosGrupo.push(r);
    // Detectar órdenes/clasificaciones asociadas a cada extracción del grupo
    var info=extraccionManualTieneOrdenes(r);
    info.ordenes.forEach(function(p){
      if(!ordenesAfectadasMap[p.id])ordenesAfectadasMap[p.id]=p;
    });
    info.clasificadas.forEach(function(c){
      if(!clasificacionesAfectadasMap[c.id])clasificacionesAfectadasMap[c.id]=c;
    });
  });
  var ordenesAfectadas=Object.values(ordenesAfectadasMap);
  var clasificacionesAfectadas=Object.values(clasificacionesAfectadasMap);
  var tieneClasif=clasificacionesAfectadas.length>0;
  var tieneOrdenes=ordenesAfectadas.length>0;

  // Construir contenido del modal
  var contenido='<div style="background:var(--bg2);border-radius:8px;padding:11px;margin-bottom:11px">';
  contenido+='<div style="font-family:var(--M);font-size:10px;color:var(--tx2);margin-bottom:6px">REVERTIRÁ:</div>';
  contenido+='<div style="font-size:12px;color:var(--er)"><strong>'+ids.length+' registro(s) manuales</strong> · '+totalM3.toFixed(2)+' m³ totales</div>';
  // Detalle por registro
  contenido+='<div style="font-family:var(--M);font-size:9px;color:var(--tx3);margin-top:6px;line-height:1.6">';
  registrosGrupo.forEach(function(r){
    var almName={patio:'Patio',tolva:'Tolva',zaranda:'Zaranda',arena_rio:'Arena Río'}[r.alm]||r.alm;
    contenido+='• '+almName+': '+(r.tm||0).toFixed(2)+' m³ ('+(r.tv||0)+' vj)<br>';
  });
  contenido+='</div></div>';

  // CASCADA con clasificación
  if(tieneClasif){
    var totalClasifM3=clasificacionesAfectadas.reduce(function(s,p){return s+(p.tm||0);},0);
    contenido+='<div style="background:var(--erA);border-radius:7px;padding:11px;margin-bottom:11px;border:1px solid var(--er)">';
    contenido+='<div style="font-family:var(--M);font-size:9px;color:var(--er);margin-bottom:8px;font-weight:700">⚠️ TAMBIÉN SE PERDERÁ EN CASCADA:</div>';
    contenido+='<div style="font-family:var(--M);font-size:10px;color:var(--tx1);line-height:1.7">';
    contenido+='• <strong>'+clasificacionesAfectadas.length+' clasificación(es) ya hechas</strong> en Historial Producción<br>';
    contenido+='• Total clasificado: <strong>'+totalClasifM3.toFixed(2)+' m³</strong><br>';
    contenido+='• Los Productos Terminados volverán al stock';
    contenido+='</div></div>';
  } else if(tieneOrdenes){
    contenido+='<div style="background:var(--waA);border-radius:7px;padding:10px;margin-bottom:11px;border:1px solid var(--wa)">';
    contenido+='<div style="font-family:var(--M);font-size:9px;color:var(--wa);margin-bottom:6px;font-weight:700">⚠️ También se cancelarán:</div>';
    contenido+='<div style="font-family:var(--M);font-size:10px;color:var(--tx1);line-height:1.6">';
    contenido+='• '+ordenesAfectadas.length+' Orden(es) pendiente(s) en Producción';
    contenido+='</div></div>';
  }
  contenido+='<div style="font-size:12px;color:var(--tx2)">¿Confirma eliminar este grupo de extracción manual?</div>';

  modalAviso({tipo:tieneClasif?'danger':'warn',titulo:'Eliminar Grupo de Extracción',contenidoHtml:contenido,
    botonPrincipal:'🗑️ Eliminar todo en cascada',onPrincipal:function(){
      // Capturar info antes
      var registrosEliminados=registrosGrupo.map(function(r){
        return {id:r.id,fecha:r.fecha,proveedor:pn(r.provId),alm:r.alm,m3:r.tm,viajes:r.tv};
      });
      // CASCADA 1: Revertir cada extracción del grupo
      registrosGrupo.forEach(function(r){
        try{revertirExtraccion(r);}catch(e){}
      });
      // CASCADA 2: Eliminar órdenes y clasificaciones asociadas
      ordenesAfectadas.forEach(function(p){
        if(!p.pendienteClasif&&p.dist&&p.dist.length){
          try{revertirProduccion(p);}catch(e){}
        }
        S.prod.records=S.prod.records.filter(function(x){return x.id!==p.id;});
        try{dbDelProd(p.id);}catch(e){}
      });
      // CASCADA 3: Eliminar las extracciones de la lista local y BD
      S.exp.records=S.exp.records.filter(function(r){return ids.indexOf(r.id)===-1;});
      ids.forEach(function(id){try{dbDelExp(id);}catch(e){}});
      // Log actividad
      logActividad({
        accion:'eliminar',
        modulo:'extraccion',
        descripcion:'Eliminó grupo de '+ids.length+' registro(s) Extracción · '+totalM3.toFixed(2)+' m³ (+ '+ordenesAfectadas.length+' órdenes en cascada, '+clasificacionesAfectadas.length+' clasificaciones)',
        antes:{registros:registrosEliminados,ordenesAfectadas:ordenesAfectadas.length,clasificacionesAfectadas:clasificacionesAfectadas.length}
      });
      // Refresh completo
      saveS();
      try{updXKPI();updPKPI();updDKPI();}catch(e){}
      try{renderXH();renderPH();}catch(e){}
      try{renderProdOrdenes();}catch(e){}
      modalAvisoClose();
    }});
}
