  // Mostrar/ocultar bloque de totales
  var totWrap=G('cot-totales-wrap');
  if(totWrap)totWrap.style.display=G('cot-cant-activo').checked?'block':'none';
}
// v172.14: Recalcula subtotales por fila y totales globales en vivo
function onCotCantChange(){
  // Actualizar subtotales por fila
  var i=0;
  while(G('cot-fila-'+i)){
    var cant=G('cf-cant-'+i);
    var prec=G('cf-precio-'+i);
    var subt=G('cf-subt-'+i);
    if(cant&&prec&&subt){
      var c=parseFloat(cant.value)||0;
      var p=parseFloat(prec.value)||0;
      subt.value=c&&p?(c*p).toLocaleString('es-CO'):'';
    }
    i++;
  }
  _cotRecalcTotales();
}
// v172.14: Recalcula y muestra los totales (Subtotal + IVA = Total) en el bloque inferior
function _cotRecalcTotales(){
  var det=G('cot-totales-detalle');
  if(!det)return;
  var cantActivo=G('cot-cant-activo')&&G('cot-cant-activo').checked;
  if(!cantActivo){det.innerHTML='';return;}
  var ivaMode=G('cot-iva')?G('cot-iva').value:'con_iva';
  var rate=(S.preciosRefIva||19)/100;
  // Sumar subtotales (cantidad × precio) de todas las filas con material
  var subtotal=0;
  var i=0;
  while(G('cot-fila-'+i)){
    var cant=parseFloat(G('cf-cant-'+i)?G('cf-cant-'+i).value:0)||0;
    var prec=parseFloat(G('cf-precio-'+i)?G('cf-precio-'+i).value:0)||0;
    subtotal+=cant*prec;
    i++;
  }
  var fmt=function(n){return'$ '+Math.round(n).toLocaleString('es-CO');};
  if(ivaMode==='con_iva'){
    // Modo CON IVA: el precio unitario en tabla es SIN IVA; al final se suma IVA
    var ivaVal=subtotal*rate;
    var total=subtotal+ivaVal;
    det.innerHTML=
      '<div style="display:flex;justify-content:space-between;padding:4px 0;color:var(--tx2)">'
      +'<span>Subtotal sin IVA</span><span style="font-weight:600">'+fmt(subtotal)+'</span></div>'
      +'<div style="display:flex;justify-content:space-between;padding:4px 0;color:var(--tx2)">'
      +'<span>IVA ('+(S.preciosRefIva||19)+'%)</span><span style="font-weight:600">'+fmt(ivaVal)+'</span></div>'
      +'<div style="display:flex;justify-content:space-between;padding:7px 0 2px 0;border-top:1px solid var(--bd2);margin-top:4px;align-items:center">'
      +'<span style="font-weight:700;color:var(--ok);font-size:13px">TOTAL CON IVA</span>'
      +'<span style="font-weight:700;color:var(--ok);font-size:15px">'+fmt(total)+'</span></div>';
  } else {
    // Modo SIN IVA: solo total
    det.innerHTML=
      '<div style="display:flex;justify-content:space-between;padding:4px 0;color:var(--tx2)">'
      +'<span>Subtotal</span><span style="font-weight:600">'+fmt(subtotal)+'</span></div>'
      +'<div style="display:flex;justify-content:space-between;padding:7px 0 2px 0;border-top:1px solid var(--bd2);margin-top:4px;align-items:center">'
      +'<span style="font-weight:700;color:var(--ok);font-size:13px">TOTAL</span>'
      +'<span style="font-weight:700;color:var(--ok);font-size:15px">'+fmt(subtotal)+'</span></div>';
  }
}
function addCotFila(){
  var filas=_getCotFilas();
