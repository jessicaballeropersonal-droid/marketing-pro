}

function renderFungEqHist(){
  var eqF=gv('feq-h-eq');var pF=gv('feq-h-pieza');var caF=gv('feq-h-causa');
  var dF=gv('feq-h-desde');var hF=gv('feq-h-hasta');
  var rows=S.fungCambiosEq.filter(function(c){
    if(eqF&&c.eqId!==eqF)return false;
    if(pF&&c.piezaId!==pF)return false;
    if(caF&&c.causa!==caF)return false;
    if(dF&&c.fecha<dF)return false;
    if(hF&&c.fecha>hF)return false;
    return true;
  });
  rows.sort(function(a,b){return b.fecha.localeCompare(a.fecha);});
  // KPIs
  var kpiEl=G('feq-h-kpis');
  if(kpiEl){
    var totalCambios=rows.length;
    var costoTotal=rows.reduce(function(s,r){return s+(r.precio||0);},0);
    var avgDurH=rows.filter(function(r){return r.durHoras!=null;}).map(function(r){return r.durHoras;});
    var avgH=avgDurH.length?Math.round(avgDurH.reduce(function(a,b){return a+b;},0)/avgDurH.length):null;
    kpiEl.innerHTML='<div class="kpi in"><div class="kpi-lbl">Total Cambios</div><div class="kpi-val">'+totalCambios+'</div><div class="kpi-unit">registros</div></div>'
      +'<div class="kpi wa"><div class="kpi-lbl">Costo Total</div><div class="kpi-val">$'+costoTotal.toLocaleString()+'</div><div class="kpi-unit">en piezas</div></div>'
      +(avgH!=null?'<div class="kpi ok"><div class="kpi-lbl">Duración Prom.</div><div class="kpi-val">'+avgH+'</div><div class="kpi-unit">horas/pieza</div></div>':'');
  }
  var tbody=G('feq-h-body');if(!tbody)return;
  if(!rows.length){tbody.innerHTML='<tr class="erow"><td colspan="13">Sin registros para los filtros seleccionados.</td></tr>';return;}
  tbody.innerHTML=rows.map(function(r){
    var pieza=(S.fungPiezasEq.find(function(p){return p.id===r.piezaId;})||{nombre:'—'});
    var eq=(S.mantEquipos.find(function(e){return e.id===r.eqId;})||{nombre:'—'});
    var costH=r.durHoras&&r.precio?'$'+(r.precio/r.durHoras).toFixed(2):r.durHoras!=null&&r.durHoras>0?'—':'';
    var costKm=r.durKm&&r.precio?'$'+(r.precio/r.durKm).toFixed(2):r.durKm!=null&&r.durKm>0?'—':'';
    var durH=r.durHoras!=null?r.durHoras+'h':'<span style="color:var(--tx3)">En curso</span>';
    var durKm=r.durKm!=null?r.durKm+' km':'';
    var causaBdg={desgaste:'bdg-ok',rotura:'bdg-er',preventivo:'bdg-in'};
    return'<tr>'
      +'<td>'+r.fecha+'</td>'
      +'<td>'+eq.nombre+'</td>'
      +'<td><strong>'+pieza.nombre+'</strong></td>'
      +'<td><span class="bdg bdg-gy">'+pieza.unidad+'</span></td>'
      +'<td>'+durH+(durKm?' / '+durKm:'')+'</td>'
      +'<td>'+(r.horom!=null?r.horom+'h':'—')+'</td>'
      +'<td>'+(r.odo!=null?r.odo+' km':'—')+'</td>'
      +'<td style="color:var(--ok)">$'+(r.precio||0).toLocaleString()+'</td>'
      +'<td>'+(costH||'—')+'</td>'
      +'<td>'+(costKm||'—')+'</td>'
      +'<td><span class="bdg '+(causaBdg[r.causa]||'bdg-gy')+'">'+r.causa+'</span></td>'
      +'<td style="color:var(--tx3);font-size:11px">'+(r.obs||'')+'</td>'
      +'<td><button class="btn btn-er btn-xs" onclick="delFungEqCambio(\''+r.id+'\')">🗑️</button></td>'
      +'</tr>';
  }).join('');
}

