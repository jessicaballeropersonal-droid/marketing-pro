  // Marketing Pro: TODO vive como claves dentro de la tabla config_marketing.
  supaGet('config_marketing').then(function(d){
    if(!Array.isArray(d))d=[];
    function cfgGet(k){var r=d.find(function(c){return c.key===k;});if(!r)return null;try{return JSON.parse(r.value);}catch(e){return r.value;}}
    var us=cfgGet('usuarios');if(Array.isArray(us))S.usuarios=us;
    var perm=cfgGet('permisos');if(perm&&typeof perm==='object')S.permisos=perm;
    var hf=cfgGet('hfmt');if(hf)S.hfmt=hf;
    var kg=cfgGet('kanbanGeneral');if(Array.isArray(kg))S.kanbanGeneral=kg;
    var kge=cfgGet('kanbanGeneralEstados');if(Array.isArray(kge))S.kanbanGeneralEstados=kge;
    var rolMap=cfgGet('rolMap');
    if(rolMap&&typeof rolMap==='object'){window._rolMapCache=JSON.stringify(rolMap);(S.usuarios||[]).forEach(function(u){if(rolMap[u.id])u.rol=rolMap[u.id];});}
    if(cb)cb();
  }).catch(function(){if(cb)cb(true);});
}

