  html+=_diagKpi('Producciones',R.nProd,'reg','var(--tx2)');
  html+=_diagKpi('· Trans. (esTransformacion)',R.nTransf,'reg','var(--cy)');
  html+=_diagKpi('· Pendientes clasif',R.nPend,'reg','var(--wa)');
  html+=_diagKpi('Despachos',R.nDesp,'reg','var(--tx2)');
  html+='</div>';

  // Botón exportar + migración catálogos (v171.9)
