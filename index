    lista.innerHTML='<div style="padding:30px;text-align:center;color:var(--tx3);font-family:var(--M);font-size:10px;font-style:italic">Sin eventos que mostrar.<br><br>Si recién activaste la auditoría, comienza a usar el sistema y los eventos aparecerán aquí.</div>';
    return;
  }
  // Mostrar máximo 200 más recientes
  var mostrar=eventos.slice(0,200);
  var html='';
  var iconos={crear:'➕',editar:'✏️',eliminar:'🗑️'};
  var colorAccion={crear:{bg:'var(--okA)',col:'var(--ok)'},editar:{bg:'var(--orA)',col:'var(--or)'},eliminar:{bg:'var(--erA)',col:'var(--er)'}};
  var modLbl={extraccion:'EXTRACCIÓN',produccion:'PRODUCCIÓN',despacho:'DESPACHO',bitacora:'BITÁCORA',mantenimiento:'MANTENIMIENTO',sesion:'SESIÓN',parametros:'PARÁMETROS',general:'GENERAL'};
  var modCol={extraccion:'var(--or)',produccion:'var(--in)',despacho:'var(--pu)',bitacora:'var(--cy)',mantenimiento:'var(--wa)',sesion:'var(--tx3)',parametros:'var(--ok)',general:'var(--tx2)'};
  mostrar.forEach(function(e,idx){
    var ic=iconos[e.accion]||'•';
    var clr=colorAccion[e.accion]||{bg:'var(--bg3)',col:'var(--tx2)'};
    var modL=modLbl[e.modulo]||(e.modulo||'').toUpperCase();
    var mCol=modCol[e.modulo]||'var(--tx2)';
    var fechaTs='';
    if(e.ts){
      try{
        var dt=new Date(e.ts);
        fechaTs=dt.toLocaleString('es-CO',{year:'numeric',month:'2-digit',day:'2-digit',hour:'2-digit',minute:'2-digit'});
      }catch(_){fechaTs=e.ts;}
    }
    var bgRow=idx%2===0?'var(--bg2)':'var(--bg1)';
    html+='<div style="padding:11px 14px;border-bottom:1px solid var(--bd2);background:'+bgRow+'">';
    html+='<div style="display:flex;align-items:flex-start;gap:11px">';
    html+='<div style="width:30px;height:30px;background:'+clr.bg+';border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:14px;flex-shrink:0">'+ic+'</div>';
    html+='<div style="flex:1;min-width:0">';
    html+='<div style="display:flex;flex-wrap:wrap;gap:6px;align-items:center;margin-bottom:4px">';
    html+='<span style="font-size:12px;font-weight:700;color:var(--tx1)">'+(e.usuarioNombre||'?')+'</span>';
    html+='<span style="background:'+clr.bg+';color:'+clr.col+';font-family:var(--M);font-size:8px;padding:2px 7px;border-radius:8px;font-weight:700;letter-spacing:.5px">'+(e.accion||'').toUpperCase()+'</span>';
    html+='<span style="background:var(--bg3);color:'+mCol+';font-family:var(--M);font-size:8px;padding:2px 7px;border-radius:8px;font-weight:700;letter-spacing:.5px;border:1px solid '+mCol+'">'+modL+'</span>';
    html+='</div>';
    html+='<div style="font-size:11px;color:var(--tx2);line-height:1.5;margin-bottom:4px">'+(e.descripcion||'(sin descripción)')+'</div>';
    // Mostrar antes/después si existen
    if(e.antes||e.despues){
      var cambios=[];
      if(e.accion==='editar'&&e.antes&&e.despues){
        // Comparar campos
        Object.keys(e.despues).forEach(function(k){
          var a=e.antes[k],n=e.despues[k];
          if(JSON.stringify(a)!==JSON.stringify(n)){
            cambios.push('<strong>'+k+':</strong> <s style="color:var(--er)">'+JSON.stringify(a)+'</s> → <span style="color:var(--ok)">'+JSON.stringify(n)+'</span>');
          }
        });
      } else if(e.accion==='crear'&&e.despues){
        Object.keys(e.despues).forEach(function(k){
          cambios.push('<strong>'+k+':</strong> '+JSON.stringify(e.despues[k]));
