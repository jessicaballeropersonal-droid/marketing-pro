function renderFungEqPiezas(){
  var el=G('fung-eq-piezas-lista');if(!el)return;
  if(!S.fungPiezasEq||!S.fungPiezasEq.length){el.innerHTML='<div style="color:var(--tx3);font-size:12px;padding:16px;text-align:center;font-style:italic">Sin piezas registradas. Agregue la primera pieza con el botón ＋.</div>';return;}
  el.innerHTML=S.fungPiezasEq.map(function(p){
    var eqNom=p.eqId?(S.mantEquipos.find(function(e){return e.id===p.eqId;})||{nombre:'Todos'}).nombre:'Todos los equipos';
