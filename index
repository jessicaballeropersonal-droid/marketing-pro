// Auto-populate m3 from app data for the selected month
function _iadmAutoM3(key){
  if(!key)return{mp:0,me:0,trit:0,zar:0,transf:0};
  var parts=key.split('-'); // e.g. '2026-04'
  var fecha_prefix=parts[0]+'-'+parts[1];
  var trit=0, zar=0, transf=0, me=0;
  // Misma lógica que updPKPI() del panel de Producción
  (S.prod.records||[]).forEach(function(r){
    if(r.pendienteClasif||!r.fecha||!r.fecha.startsWith(fecha_prefix))return;
    var esTransf=r.esTransformacion||(r.fuenteId&&!isSysId(r.fuenteId)&&r.origenBit);
    if(esTransf){
      transf+=r.fuenteM3||r.tm||0;
      return; // No entra en Trituración ni Zaranda
    }
    var fuentes=r.fuentes&&r.fuentes.length?r.fuentes:(r.fuenteId?[{alm:'patio',m3:r.fuenteM3||0}]:[]);
    if(!fuentes.length){
      var totM3=0;(r.dist||[]).forEach(function(d){if(d.ptId&&d.m3>0)totM3+=d.m3;});
      trit+=totM3;
    }else{
      fuentes.forEach(function(fu){
        if(fu.alm==='zaranda')zar+=fu.m3||0;
        else trit+=fu.m3||0;
      });
    }
  });
  // M³ explotados — v172.65: contar SOLO los almacenes de extracción real
  // (patio/tolva/zaranda/arena_rio), igual que _iadmAutoExp. Antes sumaba todos los
  // registros no-pp e incluía cosas que no son extracción (ej. inventario inicial alm='manual'),
  // por lo que el "auto" de costos no cuadraba con el Total extraído del panel.
  (S.exp.records||[]).forEach(function(r){
    if(!r.fecha||!r.fecha.startsWith(fecha_prefix)||r.pp)return;
    if(r.alm==='patio'||r.alm==='tolva'||r.alm==='zaranda'||r.alm==='arena_rio')me+=(r.tm||0);
  });
  // Round
  trit=Math.round(trit*100)/100;
  zar=Math.round(zar*100)/100;
  transf=Math.round(transf*100)/100;
  me=Math.round(me*100)/100;
  // mp (legacy) = trit + zar para compatibilidad con código viejo
  return{trit:trit,zar:zar,transf:transf,me:me,mp:Math.round(trit+zar)};
}

// v172.12: Calcular m³ extraídos por almacén para el panel de Explotación
function _iadmAutoExp(key){
  if(!key)return{patio:0,tolva:0,zaranda:0,arena_rio:0,total:0};
  var parts=key.split('-');
  var fecha_prefix=parts[0]+'-'+parts[1];
  var patio=0,tolva=0,zaranda=0,arena_rio=0;
  (S.exp.records||[]).forEach(function(r){
    if(!r.fecha||!r.fecha.startsWith(fecha_prefix)||r.pp)return;
    var m=r.tm||0;
    if(r.alm==='patio')patio+=m;
    else if(r.alm==='tolva')tolva+=m;
    else if(r.alm==='zaranda')zaranda+=m;
    else if(r.alm==='arena_rio')arena_rio+=m;
  });
  patio=Math.round(patio*100)/100;
  tolva=Math.round(tolva*100)/100;
  zaranda=Math.round(zaranda*100)/100;
  arena_rio=Math.round(arena_rio*100)/100;
  return{patio:patio,tolva:tolva,zaranda:zaranda,arena_rio:arena_rio,total:Math.round((patio+tolva+zaranda+arena_rio)*100)/100};
}

// Helper: obtiene los m³ del mes resolviendo auto vs manual
// Devuelve {trit:{auto,manual,usado}, zar:{...}, transf:{...}, total, me}
function _iadmGetM3(mes,key){
  var auto=_iadmAutoM3(key);
  function resolve(autoVal,manualVal){
    var usado=(manualVal!==null&&manualVal!==undefined)?manualVal:autoVal;
    return{auto:autoVal,manual:manualVal,usado:usado,editado:(manualVal!==null&&manualVal!==undefined&&manualVal!==autoVal)};
  }
  // Si no existe estructura nueva, intentar migrar desde m3prod viejo
  if(mes.m3trit===undefined&&mes.m3zar===undefined&&mes.m3transf===undefined){
    // Primera vez con el nuevo modelo: dejar todo en null (usará auto)
    mes.m3trit=null;
    mes.m3zar=null;
    mes.m3transf=null;
  }
  var t=resolve(auto.trit,mes.m3trit);
  var z=resolve(auto.zar,mes.m3zar);
  var tr=resolve(auto.transf,mes.m3transf);
  return{
    trit:t,
    zar:z,
    transf:tr,
    total:Math.round((t.usado+z.usado)*100)/100, // Total = Trit + Zar (Transf NO suma)
    me:mes.m3expl||auto.me
  };
}

// Auto-populate ventas from despachos — agrupa por producto Y cliente
function _iadmAutoVentas(key){
  if(!key)return[];
  var parts=key.split('-');
  var fecha_prefix=parts[0]+'-'+parts[1];
  // Estructura: {ptId: {clienteId: m3total}}
  var byPt={};
  (S.desp.records||[]).forEach(function(r){
    if(!r.fecha||!r.fecha.startsWith(fecha_prefix))return;
    // Resolver clienteId (puede venir como r.clienteId o como r.cliente nombre)
    var clId=r.clienteId||'';
    if(!clId&&r.cliente){
      var cObj=(S.clientes||[]).find(function(c){return c.nombre===r.cliente;});
      if(cObj)clId=cObj.id;
    }
    if(!clId)clId='_sin_cliente';
    (r.items||[]).forEach(function(it){
      if(!it.ptId||!(it.m3>0))return;
      if(!byPt[it.ptId])byPt[it.ptId]={};
      if(!byPt[it.ptId][clId])byPt[it.ptId][clId]=0;
      byPt[it.ptId][clId]+=it.m3;
    });
  });
  // Convertir a array
  return Object.keys(byPt).map(function(ptId){
    var m3PorCliente={};
    Object.keys(byPt[ptId]).forEach(function(clId){
      m3PorCliente[clId]=Math.round(byPt[ptId][clId]*100)/100;
    });
    return{ptId:ptId,m3PorCliente:m3PorCliente};
  });
}

// v172.71: último mes (YYYY-MM) que tiene datos reales, para abrir el Informe ahí
// (antes abría en el mes actual, normalmente vacío, y parecía que no había información)
function _iadmLatestMonthWithData(){
  var keys={};
  function add(f){if(f&&f.length>=7)keys[f.slice(0,7)]=1;}
  (S.exp.records||[]).forEach(function(r){add(r.fecha);});
  (S.prod.records||[]).forEach(function(r){add(r.fecha);});
  (S.desp.records||[]).forEach(function(r){add(r.fecha);});
  var meses=(S.informeAdm&&S.informeAdm.meses)||{};
  Object.keys(meses).forEach(function(k){
    var m=meses[k];if(!m)return;
    var hasCost=['planta','expl','adm'].some(function(s){return m.costos&&m.costos[s]&&Object.keys(m.costos[s]).length;});
    var hasVent=m.ventas&&m.ventas.length;
    if(hasCost||hasVent||(m.m3expl>0))keys[k]=1;
  });
  var arr=Object.keys(keys).filter(function(k){return /^\d{4}-\d{2}$/.test(k);}).sort();
  return arr.length?arr[arr.length-1]:'';
}

