function fplUpdPiezaInfo(){
  var pid=gv('fpl-c-pieza');
  var pInfo=G('fpl-pieza-info');var sInfo=G('fpl-stock-info');var caraWrap=G('fpl-c-cara-wrap');
  if(!pid){pInfo.style.display='none';sInfo.style.display='none';caraWrap.style.display='none';return;}
  var pieza=(S.fungPiezasPl||[]).find(function(p){return p.id===pid;});
  if(!pieza){pInfo.style.display='none';return;}
  // Cara select
  // Show ncaras selector based on pieza capability
  var ncWrap=G('fpl-c-ncaras-wrap');
  if(ncWrap){
    if(pieza.caras==2){ncWrap.style.display='block';if(G('fpl-c-ncaras'))G('fpl-c-ncaras').value='2';}
    else{ncWrap.style.display='none';}
  }
  // Stock FIFO price
  var stocks=fplGetStockFIFO(pid);
  var precioEl=G('fpl-c-precio');
  if(stocks.lotes.length&&precioEl&&!precioEl.value)precioEl.value=stocks.lotes[0].precio||'';
