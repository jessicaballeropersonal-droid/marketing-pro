function logActividad(opts){
  // opts: {accion: 'crear'|'editar'|'eliminar', modulo: 'extraccion'|'produccion'|..., descripcion, registroId, antes, despues}
  try{
    if(!SESION)return; // No registrar acciones sin sesión activa
    var evt={
      id:uid(),
      ts:new Date().toISOString(),
      usuarioId:SESION.id||'',
      usuarioNombre:SESION.nombre||'?',
      usuarioRol:SESION.rol||'',
      accion:opts.accion||'crear',
      modulo:opts.modulo||'general',
      descripcion:opts.descripcion||'',
      registroId:opts.registroId||'',
      antes:opts.antes||null,
      despues:opts.despues||null
    };
    if(!S.actividad)S.actividad=[];
    S.actividad.unshift(evt); // Más reciente primero
    // Mantener máximo 5000 eventos en memoria (suficiente para varios meses)
    if(S.actividad.length>5000)S.actividad=S.actividad.slice(0,5000);
    // Guardar en Supabase (tabla actividad, con fallback a config)
    try{
      supaUpsert('actividad',{
        id:evt.id,ts:evt.ts,usuario_id:evt.usuarioId,usuario_nombre:evt.usuarioNombre,usuario_rol:evt.usuarioRol,
        accion:evt.accion,modulo:evt.modulo,descripcion:evt.descripcion,registro_id:evt.registroId,
        antes:evt.antes?JSON.stringify(evt.antes):null,
        despues:evt.despues?JSON.stringify(evt.despues):null
      });
    }catch(e){
      // Si falla Supabase (tabla no existe), guardar últimos 500 en config como fallback
      try{_dbSaveCfg('actividad',S.actividad.slice(0,500));}catch(e2){}
    }
    saveS();
  }catch(e){console.warn('logActividad error:',e);}
}

