    var origen=r.origenBit?'auto':'manual';
    var turno=r.turno||'dia';
    var key=r.fecha+'|'+turno+'|'+origen;
    if(!grupos[key]){
      grupos[key]={fecha:r.fecha,turno:turno,origen:origen,alms:{},totalVj:0,totalM3:0,ids:[],
        provIds:{},equipos:{}};
    }
    var g=grupos[key];
    if(!g.alms[r.alm])g.alms[r.alm]={tv:0,tm:0};
    g.alms[r.alm].tv+=(r.tv||0);g.alms[r.alm].tm+=(parseFloat(r.tm)||0);
    g.totalVj+=(r.tv||0);g.totalM3+=(parseFloat(r.tm)||0);g.ids.push(r.id);
