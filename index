    html+='<div style="margin-top:11px;border-top:1px solid var(--bd2);padding-top:9px">'
      +'<div style="font-family:var(--M);font-size:8px;color:var(--tx3);margin-bottom:7px">📋 HISTORIAL DE CAMBIOS</div>'
