function _lubGetMaquinasActivas(){
  if(!S.lubPlantilla)return[];
  return Object.values(S.lubPlantilla).filter(function(m){return m.activa!==false;});
}

function saveLubMaquina(maqId,rodIdsStr){
  var maq=S.lubPlantilla[maqId];if(!maq)return;
  var rodEntries=rodIdsStr.split(',');
  var saved=0;var errors=[];
  rodEntries.forEach(function(entry){
    var parts=entry.split('|');
    var rodId=parts[0];var tempMax=parseFloat(parts[1])||70;
    var kid=maqId+'-'+rodId;
    var tempEl=G('lub-t-'+kid);
    if(!tempEl||!tempEl.value)return; // skip empty rows
    var temp=parseFloat(tempEl.value);
    if(isNaN(temp)||temp<=0){errors.push(rodId);return;}
    var medicion=G('lub-med-'+maqId)?G('lub-med-'+maqId).value:'mediodia';
    var lubrico=G('lub-l-'+kid).value;
    var cantidad=parseFloat(G('lub-c-'+kid).value)||0;
    var obs=G('lub-o-'+kid).value.trim();
    var rod=(maq.rodamientos||[]).find(function(r){return r.id===rodId;});
    var sem=_lubSemaforo(temp,tempMax);
    var now=new Date();
    var hora=now.toLocaleTimeString('es-CO',{hour:'2-digit',minute:'2-digit'});
    var registro={
      id:uid(),fecha:today(),hora:hora,timestamp:Date.now(),
      maquinaId:maqId,maquinaNombre:maq.maquinaNombre,
      rodamientoId:rodId,rodamientoNombre:rod?rod.nombre:'',
      temp:temp,tempMax:tempMax,semaforo:sem.cls,medicion:medicion,
      lubrico:lubrico==='si',cantidad:lubrico==='si'?cantidad:0,obs:obs
    };
    if(!S.lubHistorial)S.lubHistorial=[];
    S.lubHistorial.push(registro);
    if(sem.cls==='er')_lubDispararAlerta(maq.maquinaNombre,rod?rod.nombre:'',temp,tempMax);
    saved++;
  });
  _dbSaveCfg('lubHistorial',S.lubHistorial);
  _updateLubBadge();
  if(errors.length){
    modalAviso({tipo:'warn',titulo:'Temperatura inválida',contenidoHtml:'<div style="font-size:12px;color:var(--tx2);line-height:1.6">Algunos rodamientos tenían temperatura inválida. Los demás fueron guardados correctamente.</div>',botonSecundario:'Entendido'});
  }
  else if(saved===0){
    modalAviso({tipo:'warn',titulo:'Sin temperaturas',contenidoHtml:'<div style="font-size:12px;color:var(--tx2);line-height:1.6">Ingrese al menos una temperatura para guardar.</div>',botonSecundario:'Entendido'});
  }
  _renderLubRegistro(G('lub-content'));
}

