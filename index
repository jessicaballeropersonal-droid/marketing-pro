function guardarInspOTEstado(id){
  var ot=(S.mantOrdenes||[]).find(function(o){return o.id===id;});if(!ot)return;
  var nuevoEst=G('insp-ot-est-sel')?G('insp-ot-est-sel').value:ot.estado;
  var obs=G('insp-ot-obs')?G('insp-ot-obs').value.trim():'';
  var now=new Date();
  ot.estado=nuevoEst;
  if(!ot.historialEstados)ot.historialEstados=[];
  ot.historialEstados.push({
    fecha:today(),hora:now.toLocaleTimeString('es-CO',{hour:'2-digit',minute:'2-digit'}),
    estadoNuevo:nuevoEst,obs:obs,usuario:SESION?SESION.nombre:'—'
  });
  supaUpsert('config',{key:'mantOrdenes',value:JSON.stringify(S.mantOrdenes)});
  cmo('ov-insp-ot');_renderInspTab('auto-ot');_updateInspBadge();
}
