// ── Alertas preventivas ──
function getMantAlertasPrev(){
  var alertas=[];
  S.mantPlanes.forEach(function(plan){
    var eq=S.mantEquipos.find(function(e){return e.id===plan.eqId;});if(!eq)return;
    var horasFaltantes=(plan.ultimoHoro+plan.intervalo)-eq.horoActual;
    if(horasFaltantes<=0){
      alertas.push({tipo:'er',ico:'🔴',titulo:'MANTENIMIENTO VENCIDO',
        desc:eq.nombre+' — '+plan.comp+': venció hace '+Math.abs(Math.round(horasFaltantes))+'h',plan:plan,eq:eq,horas:horasFaltantes});
    } else if(horasFaltantes<=(plan.anticipo||20)){
      alertas.push({tipo:'wa',ico:'🟡',titulo:'MANTENIMIENTO PRÓXIMO',
        desc:eq.nombre+' — '+plan.comp+': faltan '+Math.round(horasFaltantes)+'h',plan:plan,eq:eq,horas:horasFaltantes});
    }
  });
  return alertas;
}

