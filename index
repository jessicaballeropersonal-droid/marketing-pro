// === PARTE 10: Acciones ===
function rastAccion(alertaId,accion){
  var a=S.rastreadorAlertas.find(function(x){return x.id===alertaId;});
  if(!a)return;
  if(accion==='revisada'){a.estado='revisada';renderRastreador();saveRastreadorDB();return;}
  if(accion==='descartada'){a.estado='descartada';renderRastreador();saveRastreadorDB();return;}
  if(accion==='interesado'){
    a.estado='interesado';
    // Crear lead u oportunidad según modo
    if(a.modo==='b2b')_rastCrearLead(a);else _rastCrearOportunidad(a);
    // Crear auto-tarea en Tareas Gerencial
    _rastCrearAutoTarea(a);
    if(typeof toast==='function')toast('⭐ Lead creado + auto-tarea en Tareas Gerencial','ok');
    renderRastreador();
    saveRastreadorDB();
    if(typeof saveTareasDB==='function')saveTareasDB();
    if(typeof _updateTareasBadge==='function')_updateTareasBadge();
  }
}
function _rastCrearLead(a){
  if(!a.adjudicatario||!a.adjudicatario.nombre)return;
  var existe=S.rastreadorLeads.find(function(x){return x.nit&&a.adjudicatario.nit&&x.nit===a.adjudicatario.nit;});
  if(existe){
    if(existe.alertasOrigen.indexOf(a.id)<0)existe.alertasOrigen.push(a.id);
    return;
  }
  var lead={
    id:(typeof uid==='function'?uid():'lead_'+Date.now()),
    nit:a.adjudicatario.nit||'',
    nombre:a.adjudicatario.nombre,
    representante:a.adjudicatario.representante||'',
    telefono:(a.contacto&&a.contacto.telefono)||'',
    correo:(a.contacto&&a.contacto.correo)||'',
    direccion:(a.contacto&&a.contacto.direccion)||'',
    estadoId:S.rastreadorEstadosB2B[0].id,
    municipio:a.municipio||'',
    valor:a.valor||0,
    notas:'',
    creado_en:(new Date()).toISOString().substring(0,10),
    alertasOrigen:[a.id]
  };
  S.rastreadorLeads.push(lead);
}
function _rastCrearOportunidad(a){
