      ? '<div class="ff"><div class="fl" style="'+(i>0?'display:none':'')+'">Subt. $</div>'
        +'<input type="text" class="fi fi-xs" id="cf-subt-'+i+'" readonly style="text-align:right;font-weight:700;color:var(--ok);background:var(--bg3)" value="'+(f.cantidad&&f.precio?(f.cantidad*f.precio).toLocaleString('es-CO'):'')+'">'
        +'</div>'
      : '';
    var delBtn='<div style="display:flex;align-items:'+(i===0?'flex-end':'center')+'">'
      +'<button class="btn btn-er btn-xs" onclick="removeCotFila('+i+')" style="width:28px;height:28px;padding:0;justify-content:center">✕</button>'
      +'</div>';
    return'<div class="fg" style="'+gridTpl+';margin-bottom:7px" id="cot-fila-'+i+'">'
      +matSelector+cantField+precioField+subtotalField+delBtn
      +'</div>';
  }).join('');
  // Set select values
  filas.forEach(function(f,i){
    var sel=G('cf-mat-'+i);if(!sel)return;
    var found=S.prodTerm.find(function(p){return p.nombre===f.material;});
    if(found){sel.value=f.material;}
    else if(f.material){var cust=G('cf-matcustom-'+i);if(cust){cust.style.display='block';cust.value=f.material;}}
  });
  // Recalcular totales
  _cotRecalcTotales();
}
function onCotMatChange(i){
  var sel=G('cf-mat-'+i);var cust=G('cf-matcustom-'+i);if(!sel||!cust)return;
  cust.style.display=sel.value===''?'block':'none';
  // v172.13: Auto-rellenar precio desde preciosRef según modo IVA
  _cotAutofillPrecio(i);
}
// v172.13: Cuando cambia el material en una fila, buscar el PT y poner el precio correspondiente
function _cotAutofillPrecio(i){
  var sel=G('cf-mat-'+i);var precInp=G('cf-precio-'+i);
  if(!sel||!precInp)return;
  var nombreMat=sel.value;
  if(!nombreMat)return; // material custom o vacío → no tocar
  var pt=S.prodTerm.find(function(p){return p.nombre===nombreMat;});
  if(!pt)return;
  var ivaMode=G('cot-iva')?G('cot-iva').value:'con_iva';
  var pref=S.preciosRef||{};
  var precio=ivaMode==='sin_iva'
    ? (pref[pt.id+'_sin']||0)
    : (pref[pt.id+'_con']||pref[pt.id]||0);
  if(precio>0)precInp.value=precio;
  // v172.14: recalcular subtotal y totales después de actualizar precio
  onCotCantChange();
}
// v172.13: Cuando cambia el modo IVA, recalcular precios de TODAS las filas
// que tengan material seleccionado (preserva precios custom de filas sin material PT)
function onCotIvaChange(){
  var i=0;
  while(G('cot-fila-'+i)){
    var sel=G('cf-mat-'+i);
    if(sel&&sel.value){
      // Es material PT — recalcular precio según nuevo modo IVA
      _cotAutofillPrecio(i);
    }
    // Si es custom (sel.value vacío), no tocar el precio escrito manualmente
    i++;
  }
  // v172.14: Recalcular totales (cambia rótulo según IVA y suma IVA)
  _cotRecalcTotales();
}
// v172.14: Toggle "Cotizar por cantidades (m³)"
function onCotCantToggle(){
  var filas=_getCotFilas();
