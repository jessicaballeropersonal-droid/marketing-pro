function feqGetLastHoroOdo(eqId, fecha){
  // Get latest bitacora up to given date for this equipo
  var bits=S.mantBitacoras.filter(function(b){return b.equipoId===eqId&&b.fecha<=fecha;});
  bits.sort(function(a,b){return b.fecha.localeCompare(a.fecha)||(b.turno||'').localeCompare(a.turno||'');});
  if(!bits.length)return{horom:null,odo:null};
  var last=bits[0];
  return{horom:last.horoFin!=null?last.horoFin:(last.horoIni||null),odo:last.odoFin!=null?last.odoFin:(last.odoIni||null)};
}




