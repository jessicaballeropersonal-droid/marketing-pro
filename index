function kgMoverColumna(id,dir){
  if(!canWrite('kanban'))return;
  var arr=S.kanbanGeneralEstados,i=arr.findIndex(function(x){return x.id===id;});
  if(i<0)return;var j=i+dir;if(j<0||j>=arr.length)return;
  var tmp=arr[i];arr[i]=arr[j];arr[j]=tmp;_kgSave();_kgRenderColumnasLista();_kgRenderBoard();
}
function kgDelColumna(id){
  if(!canWrite('kanban'))return;
  if(S.kanbanGeneralEstados.length<=1){modalAviso({tipo:'warn',titulo:'No permitido',contenidoHtml:'<div style="font-size:12px;color:var(--tx2)">Debe quedar al menos una columna.</div>',botonSecundario:'Entendido'});return;}
  var conTarjetas=S.kanbanGeneral.filter(function(c){return c.estado===id;}).length;
  modalAvisoClose();
  cc('Eliminar esta columna?'+(conTarjetas?' Las '+conTarjetas+' tarjeta(s) pasaran a la primera columna.':''),function(){
    S.kanbanGeneralEstados=S.kanbanGeneralEstados.filter(function(x){return x.id!==id;});
    var primera=S.kanbanGeneralEstados[0]?S.kanbanGeneralEstados[0].id:'pend';
    S.kanbanGeneral.forEach(function(c){if(c.estado===id)c.estado=primera;});
    _kgSave();_kgRenderBoard();openKgColumnas();
  });
}
