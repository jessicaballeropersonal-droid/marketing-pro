  else if(a.estado==='interesado')html+='<span style="background:#EAF3DE;color:#173404;font-size:8px;font-weight:700;padding:3px 7px;border-radius:5px;letter-spacing:.8px;font-family:var(--M)">⭐ INTERESADO</span>';
  html+='<span style="background:'+bgsoft+';color:'+txsoft+';font-size:8px;font-weight:700;padding:3px 7px;border-radius:5px;letter-spacing:.8px;font-family:var(--M)">'+(esB2B?'🤝 B2B':'📋 LICITAR')+'</span>';
  html+='<span style="font-family:var(--M);font-size:9px;color:var(--tx3)">'+(a.encontrada_en?a.encontrada_en.substring(0,10):'—')+'</span>';
  html+='</div>';

  // Cuerpo distinto según modo
  if(esB2B){
    if(a.adjudicatario){
      html+='<div style="background:linear-gradient(135deg,#FFF8F3,#FFEDD9);border:1px solid #F0A867;border-radius:7px;padding:9px 10px;margin-bottom:8px">';
      html+='<div style="font-size:8px;color:var(--wa);font-weight:700;letter-spacing:1px;font-family:var(--M);margin-bottom:3px">🏆 GANÓ EL CONTRATO</div>';
      html+='<div style="font-size:14px;font-weight:700;color:var(--or-dark);line-height:1.2">'+_rastEsc(a.adjudicatario.nombre||'?')+'</div>';
