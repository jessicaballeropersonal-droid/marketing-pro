  html+='<button class="btn btn-or btn-sm" onclick="diagFixAccion(\'migrar-catalogos\')" title="Recuperar PT/equipos/clientes perdidos en config">🩹 Recuperar catálogos perdidos</button>';
  html+='<button class="btn btn-gh btn-sm" onclick="diagExportar()">📥 Exportar diagnóstico (JSON)</button>';
