function _getCotFilas(){
  var filas=[];var i=0;
  while(G('cot-fila-'+i)){
    var sel=G('cf-mat-'+i);var cust=G('cf-matcustom-'+i);var prec=G('cf-precio-'+i);
    var cant=G('cf-cant-'+i);
    var mat=sel&&sel.value?sel.value:(cust?cust.value.trim():'');
    filas.push({
      material:mat,
      precio:prec?parseFloat(prec.value)||0:0,
      cantidad:cant?parseFloat(cant.value)||0:0
    });
    i++;
  }
  return filas;
}
