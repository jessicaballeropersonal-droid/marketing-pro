function _lubApplyFiltros(){
  var maq=G('lhf-maq')?G('lhf-maq').value:'';
  var desde=G('lhf-desde')?G('lhf-desde').value:'';
  var hasta=G('lhf-hasta')?G('lhf-hasta').value:'';
  var sem=G('lhf-sem')?G('lhf-sem').value:'';
  _lubFiltros={maq,desde,hasta,sem};
  var hist=(S.lubHistorial||[]).filter(function(r){
    if(maq&&r.maquinaId!==maq)return false;
    if(desde&&r.fecha<desde)return false;
    if(hasta&&r.fecha>hasta)return false;
    if(sem&&r.semaforo!==sem)return false;
    return true;
  }).sort(function(a,b){return b.timestamp-a.timestamp;});
  _lubRenderHistTbl(hist);
}
function _lubLimpiarFiltros(){
  _lubFiltros={maq:'',desde:'',hasta:'',sem:''};
