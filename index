function saveMantEqEdit(){
  var eq=S.mantEquipos.find(function(e){return e.id===_mantEditEqId;});if(!eq)return;
  var tipoNew=gv('emeq-tipo')||eq.tipo;
  var nombreNew=G('emeq-nombre').value.trim()||eq.nombre;
  // Validar duplicados (excepto él mismo)
  var dup=S.mantEquipos.find(function(e){return e.id!==eq.id&&e.nombre&&e.nombre.toLowerCase()===nombreNew.toLowerCase();});
  if(dup){showAlert('mant-eq-edit-alert','er','Ya existe otro equipo con ese nombre.');return;}
  eq.tipo=tipoNew;
  eq.nombre=nombreNew;
  eq.placa=G('emeq-placa').value.trim();
  eq.marca=G('emeq-marca').value.trim();
  eq.modelo=G('emeq-modelo').value.trim();
  eq.anio=parseInt(gv('emeq-anio'))||eq.anio||0;
  eq.estado=gv('emeq-estado')||eq.estado;
  // Instrumentos
  var hEl2=G('emeq-tiene-horo');if(hEl2)eq.tieneHoro=hEl2.checked;
  var oEl2=G('emeq-tiene-odo');if(oEl2)eq.tieneOdo=oEl2.checked;
  // Horómetro: actualizar inicial; el actual también si cambia el inicial (preservar diff acumulado)
  var horoNew=parseFloat(gv('emeq-horo'));
  if(!isNaN(horoNew)){
    var diff=horoNew-(eq.horoInicial||0);
    eq.horoInicial=horoNew;
    eq.horoActual=(eq.horoActual||0)+diff;
  }
  var odoNew=parseFloat(gv('emeq-odo'));
  if(!isNaN(odoNew)){
    var diffO=odoNew-(eq.odoInicial||0);
    eq.odoInicial=odoNew;
    eq.odoActual=(eq.odoActual||0)+diffO;
  }
  // Volqueta
  if(eq.tipo==='volqueta'){
    eq.subtipoVolqueta=gv('emeq-subtipo')||eq.subtipoVolqueta||'doble_troque';
    eq.m3Viaje=parseFloat(gv('emeq-m3viaje'))||eq.m3Viaje||14;
    if(G('emeq-soat-venc'))eq.soatVenc=G('emeq-soat-venc').value||'';
