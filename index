  }

  var html='';
  // Banner global de loading (cuando hay búsqueda en curso)
  if(_RAST.buscandoVentana){
    var seg=Math.round((Date.now()-(_RAST.buscandoDesde||Date.now()))/1000);
    html+='<div style="background:linear-gradient(135deg,#FFF8DC,#FFE0B2);border:2px solid #9C0F9C;border-radius:10px;padding:14px 16px;margin-bottom:14px;display:flex;align-items:center;gap:12px;animation:pulse 1.5s ease-in-out infinite">'
