  var box=G('diag-inv-result');if(!box)return;
  box.style.display='block';
  box.innerHTML='<div style="padding:18px;text-align:center;font-family:var(--M);font-size:10px;color:var(--tx3);letter-spacing:1px">⏳ EJECUTANDO DIAGNÓSTICO...</div>';
  setTimeout(function(){renderDiagInv();},100);
}

