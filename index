  var gravaIng=0,gravaCons=0;
  S.exp.records.forEach(function(r){if(r.alm==='patio'||r.alm==='tolva'||r.alm==='zaranda')gravaIng+=r.tm;});
  S.prod.records.forEach(function(r){
    if(r.pendienteClasif)return;
    var esT=r.esTransformacion||(r.fuenteId&&!isSysId(r.fuenteId)&&r.origenBit);
    if(esT){
      // Transformación: solo descuenta de Grava si el origen es sys_patio
      if(r.fuentes&&r.fuentes.length){
        r.fuentes.forEach(function(f){
          if(f.alm==='transformacion'&&f.origenId==='sys_patio')gravaCons+=f.m3||0;
        });
      } else if(r.fuenteId==='sys_patio'){
        gravaCons+=r.fuenteM3||0;
      }
      return;
    }
    if(r.fuentes&&r.fuentes.length){
      r.fuentes.forEach(function(f){
        if(f.alm==='patio'||f.alm==='tolva'||f.alm==='zaranda')gravaCons+=f.m3||0;
      });
    } else if(r.fuenteId==='sys_patio'||r.fuenteId==='sys_tolva'||r.fuenteId==='sys_zaranda'){
      var safeM3=Math.min(r.fuenteM3||0,r.tm||r.fuenteM3||0);
      gravaCons+=safeM3;
    }
  });
  // Descontar despachos de Grava (sys_patio)
  var gravaDesp=0;
  S.desp.records.forEach(function(r){
    (r.items||[]).forEach(function(it){
      var pt=S.prodTerm.find(function(p){return p.id===it.ptId;});
      if(pt&&pt.src==='patio')gravaDesp+=it.m3||0;
    });
  });
  var gravaStock=gravaIng-gravaCons-gravaDesp;
  if(G('ki-grava'))G('ki-grava').textContent=gravaStock.toFixed(1);
  if(G('ki-grava-ing'))G('ki-grava-ing').textContent=gravaIng.toFixed(1);
  if(G('ki-grava-cons'))G('ki-grava-cons').textContent=gravaCons.toFixed(1);
  // Total transformado
  var totalTransf=0;
  S.prod.records.forEach(function(r){
    if(r.pendienteClasif)return;
    var esT=r.esTransformacion||(r.fuenteId&&!isSysId(r.fuenteId)&&r.origenBit);
    if(!esT)return;
    if(r.fuentes&&r.fuentes.length){r.fuentes.forEach(function(f){if(f.alm==='transformacion')totalTransf+=f.m3||0;});}
    else totalTransf+=r.fuenteM3||0;
  });
  if(G('ki-transformado'))G('ki-transformado').textContent=totalTransf.toFixed(1);
  var maxV=Math.max.apply(null,Object.values(inv).map(function(v){return Math.max(0,v);}).concat([1]));
  var c=G('inv-body');
  if(!S.prodTerm.length){c.innerHTML='<div style="text-align:center;color:var(--tx3);padding:36px;font-size:12px">Sin productos terminados.</div>';return;}
  var sysPTs=S.prodTerm.filter(function(p){return isSysId(p.id);});
  var manPTs=S.prodTerm.filter(function(p){return !isSysId(p.id);});
  function cardHTML(p){
    var val=inv[p.id]||0;var cls=val>0?'ok':val===0?'wa':'er';
    var pct=Math.max(0,Math.min(100,val/maxV*100));
    var pc=ptColor(p.id);
    var barCol=val>0?pc.col:val===0?'var(--wa)':'var(--er)';
    var chip=val>0?'<span class="ic-pos">'+val.toFixed(2)+' m³</span>':val===0?'<span class="ic-zer">Sin stock</span>':'<span class="ic-neg">Déf. '+Math.abs(val).toFixed(2)+'</span>';
    // +Explotación: lo que entró desde extracción directamente
    var entExpl=0;
    S.exp.records.forEach(function(r){if((r.ptId||ptIdBySrc(r.alm))===p.id)entExpl+=r.tm||0;});
    // Para Grava (sys_patio): también sumar Tolva+Zaranda extraídos (son parte de Grava Cruda)
    var entFuentes=0;
    if(p.src==='patio'){
      S.exp.records.forEach(function(r){if(r.alm==='tolva'||r.alm==='zaranda')entFuentes+=r.tm||0;});
    }
    // +Producido: m3 de productos terminados generados en dist[] (para manuales)
    var entProd=0;
    S.prod.records.forEach(function(r){(r.dist||[]).forEach(function(d){if(d.ptId===p.id)entProd+=d.m3||0;});});
    // -Transformado/Producido: m3 consumidos de ESTA fuente hacia producción
    var salFuente=0;
    var salTransf=0;
    if(p.src==='patio'){
      // Grava: sumar dist[] de registros NO transformacion
      S.prod.records.forEach(function(r){
        if(r.pendienteClasif)return;
        var esT=r.esTransformacion||(r.fuenteId&&!isSysId(r.fuenteId)&&r.origenBit);
        if(!esT)(r.dist||[]).forEach(function(d){salFuente+=d.m3||0;});
      });
    } else {
      // Tolva/Zaranda: solo lo que salió de esa fuente específica
      S.prod.records.forEach(function(r){
        if(r.pendienteClasif)return;
        if(r.fuentes&&r.fuentes.length){
          r.fuentes.forEach(function(f){
            var fid=ptIdBySrc(f.alm);
            if(fid===p.id)salFuente+=f.m3||0;
          });
        } else if(r.fuenteId===p.id&&!r.origenBit){
          salFuente+=r.fuenteM3||0;
        }
      });
    }
    // -Transformado: m3 de este producto terminado consumidos como origen
    S.prod.records.forEach(function(r){
      if(r.pendienteClasif)return;
      var esT=r.esTransformacion||(r.fuenteId&&!isSysId(r.fuenteId)&&r.origenBit);
      if(!esT)return;
      // Usar fuentes[] si existe, sino fuenteId/fuenteM3
      var contado=false;
      if(r.fuentes&&r.fuentes.length){
        r.fuentes.forEach(function(f){if(f.origenId===p.id){salTransf+=f.m3||0;contado=true;}});
      }
      if(!contado&&r.fuenteId===p.id)salTransf+=r.fuenteM3||0;
    });
    // -Despacho
    var salDesp=0;
    S.desp.records.forEach(function(r){(r.items||[]).forEach(function(it){if(it.ptId===p.id)salDesp+=it.m3||0;});});
    var isSystem=isSysId(p.id);
    return'<div class="icard" style="border-left:3px solid '+pc.col+'"><div>'+
      '<div class="icard-name" style="color:'+pc.col+'">'+p.nombre+'</div>'+
      '<div class="icard-src">'+(isSystem?'🏭 Explotación':'🔧 Producción manual')+'</div>'+
      '<div class="icard-stats">'+
      '<div class="istat"><div class="istat-lbl">Stock Neto</div><div class="istat-val '+cls+'">'+val.toFixed(2)+' m³</div></div>'+
      (entExpl>0?'<div class="istat"><div class="istat-lbl">+Explotación</div><div class="istat-val">'+entExpl.toFixed(2)+'m³</div></div>':'')+
      (entFuentes>0?'<div class="istat"><div class="istat-lbl">+Tolva+Zaranda</div><div class="istat-val">'+entFuentes.toFixed(2)+'m³</div></div>':'')+
      (entProd>0?'<div class="istat"><div class="istat-lbl">+Producido</div><div class="istat-val ok">'+entProd.toFixed(2)+'m³</div></div>':'')+
      (salFuente>0?'<div class="istat"><div class="istat-lbl">'+(p.src==='patio'?'-Producido':'-Consumido como fuente')+'</div><div class="istat-val er">'+salFuente.toFixed(2)+'m³</div></div>':'')+
      (salTransf>0?'<div class="istat"><div class="istat-lbl">-Transformado</div><div class="istat-val er">'+salTransf.toFixed(2)+'m³</div></div>':'')+
      (salDesp>0?'<div class="istat"><div class="istat-lbl">-Despacho</div><div class="istat-val er">'+salDesp.toFixed(2)+'m³</div></div>':'')+
      '</div><div class="ibar-w" style="margin-top:8px"><div class="ibar" style="width:'+pct+'%;background:'+barCol+'"></div></div></div>'+chip+'</div>';
  }
  var html='';
  if(sysPTs.length){html+='<div class="slbl" style="margin-top:4px">Productos del Sistema — Explotación</div>';sysPTs.forEach(function(p){html+=cardHTML(p);});}
  if(manPTs.length){html+='<div class="slbl">Producción Manual</div>';manPTs.forEach(function(p){html+=cardHTML(p);});}
  c.innerHTML=html||'<div style="text-align:center;color:var(--tx3);padding:30px;font-size:12px">Sin productos.</div>';
}

