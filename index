function _initFirmaCanvasNew(){
  var canvas=G('not-firma-canvas');if(!canvas)return;
  // Set actual pixel dimensions based on display size
  var rect=canvas.getBoundingClientRect();
  canvas.width=rect.width||500;canvas.height=120;
  var ctx=canvas.getContext('2d');
  ctx.clearRect(0,0,canvas.width,canvas.height);
  var drawing=false;
  // Remove old listeners by cloning
  var newCanvas=canvas.cloneNode(true);
  canvas.parentNode.replaceChild(newCanvas,canvas);
  var c=G('not-firma-canvas');
  var cx=c.getContext('2d');
  function getPos(e){
    var r=c.getBoundingClientRect();
    var src=e.touches?e.touches[0]:e;
    return{x:(src.clientX-r.left)*(c.width/r.width),y:(src.clientY-r.top)*(c.height/r.height)};
  }
  function start(e){e.preventDefault();drawing=true;var p=getPos(e);cx.beginPath();cx.moveTo(p.x,p.y);}
  function draw(e){e.preventDefault();if(!drawing)return;var p=getPos(e);cx.lineTo(p.x,p.y);cx.strokeStyle='#1565C0';cx.lineWidth=2.5;cx.lineCap='round';cx.lineJoin='round';cx.stroke();}
  function stop(e){drawing=false;}
  c.addEventListener('mousedown',start);c.addEventListener('mousemove',draw);
  c.addEventListener('mouseup',stop);c.addEventListener('mouseleave',stop);
  c.addEventListener('touchstart',start,{passive:false});
  c.addEventListener('touchmove',draw,{passive:false});
  c.addEventListener('touchend',stop);
}
function limpiarFirmaNew(){
  var c=G('not-firma-canvas');
