function addInvIni(){
  if(!puedeEditar('inv')){showAlert('inv-ini-alert','er','Solo el Administrador puede editar el inventario inicial.');return;}
  var ptId=gv('ini-pt'),m3=parseFloat(gv('ini-m3'))||0,fecha=gv('ini-fecha')||today();
  if(!ptId){showAlert('inv-ini-alert','er','Seleccione un producto terminado. Si no aparece, créelo primero en "Productos Terminados (Manual)".');return;}
  if(m3<=0){showAlert('inv-ini-alert','er','Ingrese una cantidad mayor a 0.');return;}
  // Verificar que no haya stock inicial duplicado para ese producto
  var existe=S.exp.records.some(function(r){return r.provId==='sys_ini'&&r.ptId===ptId;});
  if(existe){showAlert('inv-ini-alert','er','Ya existe stock inicial para este producto. Elimínelo primero para modificarlo.');return;}
  var iniRec={id:uid(),fecha:fecha,provId:'sys_ini',alm:'manual',matId:'',dc:0,dm:0,dt:0,vc:1,vm:m3,vt:m3,tv:1,tm:m3,ptId:ptId};
  S.exp.records.push(iniRec);
  dbSaveExp(iniRec); // v172.61: persistir en Supabase (antes solo quedaba en memoria y se perdía al recargar)
  saveS();sv('ini-m3','');sv('ini-pt','');
  showAlert('inv-ini-alert','ok','✓ Stock inicial de '+ptn(ptId)+' registrado: '+m3.toFixed(2)+' m³');
  renderInvIni();updXKPI();
}
function delInvIni(id){
  var r=S.exp.records.find(function(x){return x.id===id;});
  if(!r){return;}
  var pt=S.prodTerm.find(function(p){return p.id===r.ptId;});
  var nomPT=pt?pt.nombre:'Inv. inicial';
  var contenido='<div style="background:var(--erA);border-radius:7px;padding:10px;margin-bottom:11px">';
  contenido+='<div style="font-family:var(--M);font-size:9px;color:var(--er);margin-bottom:6px;font-weight:700">⚠️ EL INVENTARIO BAJARÁ:</div>';
  contenido+='<div style="font-family:var(--M);font-size:11px;color:var(--tx1)"><strong>'+nomPT+': −'+(r.tm||0).toFixed(2)+' m³</strong></div>';
  contenido+='<div style="font-family:var(--M);font-size:9px;color:var(--tx3);margin-top:6px;line-height:1.5">Si este inv. inicial ya fue usado por despachos posteriores, el stock podría quedar negativo.</div>';
  contenido+='</div>';
  contenido+='<div style="font-size:12px;color:var(--tx2)">¿Confirma eliminar este stock inicial?</div>';
