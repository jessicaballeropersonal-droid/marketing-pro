// v171.9 FIX CRÍTICO: Migración de catálogos perdidos en config
// ═══════════════════════════════════════════════════════════════
// El bug histórico: durante import masivo, se guardaba en config.{coleccion}
// pero la app lee de las tablas dedicadas. Esta función detecta el caso
// y migra automáticamente los datos al lugar correcto.
function migrarCatalogosDesdeConfig(){
  console.log('[Migración] Iniciando...');
  if(!SESION){console.log('[Migración] Sin SESION, abortando');return;}
  if(SESION.rol!=='admin'){console.log('[Migración] No es admin, abortando');return;}
  console.log('[Migración] Usuario admin OK, ejecutando...');

  // ═══ PARTE 1: Recuperar nombres de productos desde TODAS las fuentes posibles ═══
  // Recolectar IDs de productos terminados usados en cualquier registro
  var ptIdsUsados={};
  S.prod.records.forEach(function(r){
    (r.dist||[]).forEach(function(d){if(d.ptId)ptIdsUsados[d.ptId]=true;});
  });
  S.desp.records.forEach(function(r){
    (r.items||[]).forEach(function(it){if(it.ptId)ptIdsUsados[it.ptId]=true;});
  });
  console.log('[Migración] IDs de PT usados en registros:',Object.keys(ptIdsUsados).length);

  // IDs que ya están en S.prodTerm (con nombre conocido)
  var idsActualesPT={};
  (S.prodTerm||[]).forEach(function(p){idsActualesPT[p.id]=p;});

  // IDs USADOS que NO están en prodTerm (productos huérfanos)
  var ptHuerfanos=Object.keys(ptIdsUsados).filter(function(id){return !idsActualesPT[id];});
  console.log('[Migración] PT huérfanos (en registros pero no en S.prodTerm):',ptHuerfanos.length,ptHuerfanos);

  supaFetch('GET','config',null,'select=key,value').then(function(cfgs){
    console.log('[Migración] config rows recibidas:',cfgs?cfgs.length:0);

    // Mapeo: cfgKey → (tablaSupabase, arrayEnS, idGenerator)
    var migraciones=[
      {cfgKey:'prodTerm', tabla:'prod_term', arr:'prodTerm', mapper:function(p){return {id:p.id,nombre:p.nombre,src:p.src||'manual'};}, filtrarSys:true},
      {cfgKey:'equipos', tabla:'equipos', arr:'equipos', mapper:function(o){return {id:o.id,nombre:o.nombre};}},
      {cfgKey:'operadores', tabla:'operadores', arr:'operadores', mapper:function(o){return {id:o.id,nombre:o.nombre};}},
      {cfgKey:'clientes', tabla:'clientes', arr:'clientes', mapper:function(o){return {id:o.id,nombre:o.nombre};}},
      {cfgKey:'proveedores', tabla:'proveedores', arr:'proveedores', mapper:function(o){return {id:o.id,nombre:o.nombre};}},
      {cfgKey:'causasMuerto', tabla:'causas_muerto', arr:'causasMuerto', mapper:function(o){return {id:o.id,nombre:o.nombre};}}
    ];
    var nMigrados=0;
    var ptRecuperadosDesdeConfig=[];

    if(cfgs&&cfgs.length){
      migraciones.forEach(function(m){
        var cfgRow=cfgs.find(function(c){return c.key===m.cfgKey;});
        if(!cfgRow||!cfgRow.value){console.log('[Migración] '+m.cfgKey+': no hay fila en config');return;}
        var cfgData;
        try{cfgData=JSON.parse(cfgRow.value);}catch(e){console.warn('[Migración] '+m.cfgKey+': error parse',e);return;}
        if(!Array.isArray(cfgData)||!cfgData.length){console.log('[Migración] '+m.cfgKey+': config vacío');return;}
        console.log('[Migración] '+m.cfgKey+': '+cfgData.length+' items en config');

        // Verificar si la tabla dedicada YA tiene esos items
        var arrActual=S[m.arr]||[];
        var idsActuales={};
        arrActual.forEach(function(x){if(x.id)idsActuales[x.id]=true;});

        // Items en config que NO están en la tabla
        var faltantes=cfgData.filter(function(x){
          if(!x||!x.id||!x.nombre)return false;
          if(m.filtrarSys&&isSysId(x.id))return false;
          return !idsActuales[x.id];
        });
        if(!faltantes.length){console.log('[Migración] '+m.cfgKey+': nada que migrar');return;}
        console.log('[Migración] '+m.cfgKey+': '+faltantes.length+' items faltan en tabla '+m.tabla);

        // Migrar cada item faltante
        faltantes.forEach(function(item){
          try{
            supaUpsert(m.tabla, m.mapper(item));
            if(!arrActual.find(function(x){return x.id===item.id;})){
              arrActual.push(item);
            }
            nMigrados++;
            if(m.arr==='prodTerm')ptRecuperadosDesdeConfig.push(item.id);
          }catch(e){console.warn('Error migrando item',item,e);}
        });
        S[m.arr]=arrActual;
      });
    } else {
      console.log('[Migración] config está vacío, salteo migración tabla→tabla');
    }

    // ═══ PARTE 2: Recuperar PT huérfanos usando nombres conocidos ═══
    // Si después de la migración de config, AÚN hay PT huérfanos, intentamos inferirlos
    var nombresConocidos={
      // Nombres comunes en operación de Terranorte
      // (estos nombres se intentarán para huérfanos basados en patrón)
    };

    // Recolectar PT huérfanos remanentes
    var idsActualesPT2={};
    (S.prodTerm||[]).forEach(function(p){idsActualesPT2[p.id]=p;});
    var huerfanosRemanentes=ptHuerfanos.filter(function(id){return !idsActualesPT2[id];});

    if(huerfanosRemanentes.length>0){
      console.log('[Migración] PT aún huérfanos después de config:',huerfanosRemanentes.length);
      // Crear placeholders con nombre genérico
      huerfanosRemanentes.forEach(function(id){
        var nuevoPT={id:id, nombre:'Producto recuperado '+id.substring(id.length-4), src:'manual'};
        try{
          supaUpsert('prod_term', nuevoPT);
          S.prodTerm.push(nuevoPT);
          nMigrados++;
          console.log('[Migración] Creado PT placeholder:',id);
        }catch(e){console.warn('Error creando PT placeholder',id,e);}
      });
    }

    if(nMigrados>0){
      console.log('[Migración] TOTAL: '+nMigrados+' items recuperados');
      try{logActividad({accion:'editar',modulo:'sistema',descripcion:'Migración automática: '+nMigrados+' items recuperados (cfg='+ptRecuperadosDesdeConfig.length+', huerfanos='+huerfanosRemanentes.length+')'});}catch(_){}
      // Refrescar UI
      setTimeout(function(){
        try{if(typeof renderInv==='function')renderInv();}catch(_){}
        try{if(typeof renderTags==='function')renderTags();}catch(_){}
        try{if(typeof renderPTAll==='function')renderPTAll();}catch(_){}
      },500);
    } else {
      console.log('[Migración] Nada que migrar');
    }
  }).catch(function(e){console.warn('[Migración] Error fetching config:',e);});
}

