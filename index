function toggleLubMaquina(maqId){
  if(!S.lubPlantilla[maqId])return;
  var activa=S.lubPlantilla[maqId].activa!==false;
  var msg=activa?'¿Desactivar esta máquina? No aparecerá en el check list mientras esté desactivada.':'¿Activar esta máquina?';
  cc(msg,function(){
    S.lubPlantilla[maqId].activa=!activa;
    dbSaveLub();
    _renderLubConfig(G('lub-content'));
    _updateLubBadge();
  });
}

function openLubAddRod(maqId){
  G('lub-rod-ttl').textContent='Agregar Rodamiento';
  G('lub-rod-maq-id').value=maqId;
  G('lub-rod-id').value='';
  G('lub-rod-nombre').value='';
  G('lub-rod-temp').value='65';
  G('lub-rod-horas').value='250';
  G('lub-rod-lubricante').value='';
  G('lub-rod-cantidad').value='30';
  G('lub-rod-alert').className='alert';
  openMo('ov-lub-rod');
}
function openLubEditRod(maqId,rodId){
  var maq=S.lubPlantilla[maqId];if(!maq)return;
  var rod=(maq.rodamientos||[]).find(function(r){return r.id===rodId;});if(!rod)return;
  G('lub-rod-ttl').textContent='Editar Rodamiento';
  G('lub-rod-maq-id').value=maqId;
  G('lub-rod-id').value=rodId;
  G('lub-rod-nombre').value=rod.nombre;
  G('lub-rod-temp').value=rod.tempMax;
  G('lub-rod-horas').value=rod.horas;
  G('lub-rod-lubricante').value=rod.lubricante;
  G('lub-rod-cantidad').value=rod.cantidad;
  G('lub-rod-alert').className='alert';
  openMo('ov-lub-rod');
}
function saveLubRodamiento(){
  var maqId=G('lub-rod-maq-id').value;
  var rodId=G('lub-rod-id').value;
  var nombre=G('lub-rod-nombre').value.trim();
  var tempMax=parseFloat(G('lub-rod-temp').value)||65;
  var horas=parseFloat(G('lub-rod-horas').value)||250;
  var lubricante=G('lub-rod-lubricante').value.trim();
  var cantidad=parseFloat(G('lub-rod-cantidad').value)||0;
  var al=G('lub-rod-alert');
  if(!nombre){al.className='alert alert-er on';al.textContent='Escribe el nombre del rodamiento.';return;}
  var maq=S.lubPlantilla[maqId];if(!maq)return;
  if(!maq.rodamientos)maq.rodamientos=[];
  if(rodId){
    var idx=maq.rodamientos.findIndex(function(r){return r.id===rodId;});
    if(idx>-1)maq.rodamientos[idx]={id:rodId,nombre,tempMax,horas,lubricante,cantidad};
  } else {
    maq.rodamientos.push({id:uid(),nombre,tempMax,horas,lubricante,cantidad});
  }
  dbSaveLub();
  cmo('ov-lub-rod');
  _renderLubConfig(G('lub-content'));
}
function delLubRod(maqId,rodId){
  var maq=S.lubPlantilla[maqId];if(!maq){return;}
  var rod=(maq.rodamientos||[]).find(function(r){return r.id===rodId;});
  if(!rod){return;}
  // Verificar uso en historial
  var usos=(S.lubHistorial||[]).filter(function(h){return h.maqId===maqId&&h.rodId===rodId;}).length;
  // NIVEL 1: BLOQUEAR si tiene historial
  if(usos>0){
    var contenido='<div style="background:var(--bg2);border-radius:8px;padding:12px;margin-bottom:11px;border-left:3px solid var(--er)">';
    contenido+='<div style="font-family:var(--M);font-size:10px;color:var(--tx2);margin-bottom:6px">RODAMIENTO:</div>';
    contenido+='<div style="font-size:13px;color:var(--tx1);font-weight:700">⚙️ '+(rod.nombre||rodId)+'</div>';
    contenido+='</div>';
    contenido+='<div style="background:var(--erA);border-radius:7px;padding:11px;margin-bottom:11px">';
    contenido+='<div style="font-family:var(--M);font-size:9px;color:var(--er);margin-bottom:6px;font-weight:700">⚠️ TIENE HISTORIAL DE LUBRICACIÓN:</div>';
    contenido+='<div style="font-family:var(--M);font-size:10px;color:var(--tx1)">• '+usos+' registro(s) en historial</div>';
    contenido+='</div>';
    modalAviso({tipo:'danger',titulo:'No se puede eliminar el rodamiento',subtitulo:'Tiene historial',contenidoHtml:contenido,botonSecundario:'Entendido'});
    return;
  }
  // NIVEL 3: confirmación simple
  modalAviso({tipo:'warn',titulo:'Eliminar Rodamiento',
    contenidoHtml:'<div style="font-size:13px;color:var(--tx1);font-weight:700;margin-bottom:8px">⚙️ '+(rod.nombre||rodId)+'</div><div style="background:var(--okA);border-radius:7px;padding:10px;font-family:var(--M);font-size:10px;color:var(--ok)">✓ Sin historial, se puede eliminar.</div>',
    botonPrincipal:'🗑️ Eliminar',onPrincipal:function(){
      maq.rodamientos=(maq.rodamientos||[]).filter(function(r){return r.id!==rodId;});
      dbSaveLub();
      try{_renderLubConfig(G('lub-content'));}catch(e){}
      modalAvisoClose();
    }});
}

