// Calcula horas/km acumulados solo en períodos ACTIVOS del registro
function feqCalcAcum(cambio){
  var today2=new Date().toISOString().slice(0,10);
  var pausas=cambio.pausas||[];
  // Build active intervals
  var intervals=[];
  var cursor=cambio.fecha;
  for(var i=0;i<pausas.length;i++){
    var p=pausas[i];
    if(p.inicio>cursor)intervals.push({desde:cursor,hasta:p.inicio});
    if(p.fin)cursor=p.fin;
    else cursor=null; // still paused
  }
  if(cursor)intervals.push({desde:cursor,hasta:today2});
  // Sum horas and km from bitacoras within active intervals for this equipo
  var totalH=0,totalKm=0;
  var eqId=cambio.eqId;
  intervals.forEach(function(iv){
    var bits=S.mantBitacoras.filter(function(b){return b.equipoId===eqId&&b.fecha>=iv.desde&&b.fecha<=iv.hasta;});
    bits.forEach(function(b){totalH+=(b.horas||0);totalKm+=(b.km||0);});
  });
  return{horas:parseFloat(totalH.toFixed(1)),km:Math.round(totalKm)};
}

function feqEsActivo(cambio){
  var pausas=cambio.pausas||[];
  if(!pausas.length)return true;
  var last=pausas[pausas.length-1];
  return !!last.fin; // if last pause has a fin, it's active again
}

function feqToggleActivo(id){
  var c=(S.fungCambiosEq||[]).find(function(x){return x.id===id;});
  if(!c)return;
  if(!c.pausas)c.pausas=[];
  var today2=new Date().toISOString().slice(0,10);
  var activo=feqEsActivo(c);
  if(activo){
    // Pause it
    c.pausas.push({inicio:today2,fin:null});
    c.estadoPieza='inactivo';
  }else{
    // Reactivate
    var last=c.pausas[c.pausas.length-1];
    if(last&&!last.fin)last.fin=today2;
    c.estadoPieza='activo';
  }
  dbSaveFungCambioEq(c);
  renderFungEqActivos();
}

function abrirCerrarFungEq(id){
  var c=(S.fungCambiosEq||[]).find(function(x){return x.id===id;});
