  window._diagInvResultado=R;
}

function _diagKpi(label,val,unit,color){
  return '<div style="background:var(--bg2);border:1px solid var(--bd2);border-radius:7px;padding:9px 11px;border-top:2px solid '+color+'">'
    +'<div style="font-family:var(--M);font-size:8px;letter-spacing:1.5px;text-transform:uppercase;color:var(--tx3);margin-bottom:4px">'+label+'</div>'
    +'<div style="font-family:var(--M);font-size:16px;font-weight:700;color:'+color+';line-height:1">'+(typeof val==='number'?val.toFixed(1):val)+'</div>'
    +'<div style="font-family:var(--M);font-size:9px;color:var(--tx3);margin-top:2px">'+unit+'</div>'
  +'</div>';
}

function collectDiagData(){
  var R={
    totExt:0,extPatio:0,extTolva:0,extZaranda:0,extArenaRio:0,
    prodConsumo:0,transfTotal:0,transfDesdeGrava:0,transfDesdeOtros:0,
    despDirectos:0,despTransf:0,despGravaDirecta:0,
    nExp:0,nProd:0,nTransf:0,nPend:0,nDesp:0,
    anomalias:[]
  };
  // Extracciones
  S.exp.records.forEach(function(r){
    if(r.pp)return;
    if(r.provId==='sys_ini')return;
    R.nExp++;
    R.totExt+=r.tm||0;
    if(r.alm==='patio')R.extPatio+=r.tm||0;
    else if(r.alm==='tolva')R.extTolva+=r.tm||0;
    else if(r.alm==='zaranda')R.extZaranda+=r.tm||0;
    else if(r.alm==='arena_rio')R.extArenaRio+=r.tm||0;
  });
  // Producciones (consumo + transformaciones)
  var transfSinOrigen=[];
  var prodPatioSinMarca=[];
  var prodSinFuentes=[];
  S.prod.records.forEach(function(r){
    R.nProd++;
    if(r.pendienteClasif){R.nPend++;return;}
    var esT=r.esTransformacion||(r.fuenteId&&!isSysId(r.fuenteId)&&r.origenBit);
    if(esT){
      R.nTransf++;
      var totalEsteRec=0;
      var origenes={};
      if(r.fuentes&&r.fuentes.length){
        r.fuentes.forEach(function(f){
          if(f.alm==='transformacion'){
            totalEsteRec+=f.m3||0;
            var ori=f.origenId||'(sin origen)';
            origenes[ori]=(origenes[ori]||0)+(f.m3||0);
            if(!f.origenId){
              transfSinOrigen.push({fecha:r.fecha,detalle:'transformación sin origenId',m3:f.m3||0});
            } else if(ori==='sys_patio'){
              R.transfDesdeGrava+=f.m3||0;
            } else {
              R.transfDesdeOtros+=f.m3||0;
            }
          }
        });
      } else if(r.fuenteId&&r.fuenteM3){
        totalEsteRec=r.fuenteM3;
        if(r.fuenteId==='sys_patio')R.transfDesdeGrava+=r.fuenteM3;
        else R.transfDesdeOtros+=r.fuenteM3;
      }
      R.transfTotal+=totalEsteRec;
    } else {
      // Producción normal
      if(r.fuentes&&r.fuentes.length){
        r.fuentes.forEach(function(f){
          if(f.alm==='patio'||f.alm==='tolva'||f.alm==='zaranda'){
            R.prodConsumo+=f.m3||0;
          }
        });
      } else if(r.fuenteId==='sys_patio'||r.fuenteId==='sys_tolva'||r.fuenteId==='sys_zaranda'){
        var safeM3=Math.min(r.fuenteM3||0,r.tm||r.fuenteM3||0);
        R.prodConsumo+=safeM3;
        // Si tiene fuenteId='sys_patio' pero no está marcado como esTransformacion → sospechoso
        if(r.fuenteId==='sys_patio'&&!r.esTransformacion&&!r.origenBit){
          prodPatioSinMarca.push({fecha:r.fecha,detalle:'fuente=sys_patio sin marca transformación',m3:r.fuenteM3||0});
        }
      } else if(!r.fuentes&&!r.fuenteId&&(r.dist||[]).some(function(d){return d.ptId&&d.m3;})){
        prodSinFuentes.push({fecha:r.fecha,detalle:'distribución sin fuentes definidas',m3:(r.dist||[]).reduce(function(s,d){return s+(d.m3||0);},0)});
      }
    }
  });
  // Despachos
  S.desp.records.forEach(function(r){
    R.nDesp++;
    (r.items||[]).forEach(function(it){
      var pt=S.prodTerm.find(function(p){return p.id===it.ptId;});
      var m3=it.m3||0;
      if(pt&&pt.src==='patio'){
        R.despGravaDirecta+=m3;
        R.despDirectos+=m3;
      } else if(pt&&isSysId(pt.id)){
        R.despDirectos+=m3;
      } else {
        R.despTransf+=m3;
      }
    });
  });
  // ═══ Detectar IDs duplicados ═══
  var idsExp={},idsProd={},idsDesp={};
  var dupExp=[],dupProd=[],dupDesp=[];
  S.exp.records.forEach(function(r){
    if(idsExp[r.id])dupExp.push({fecha:r.fecha,detalle:'ID duplicado: '+r.id,m3:r.tm});
    idsExp[r.id]=true;
  });
  S.prod.records.forEach(function(r){
    if(idsProd[r.id])dupProd.push({fecha:r.fecha,detalle:'ID duplicado: '+r.id,m3:r.tm||0});
    idsProd[r.id]=true;
  });
  S.desp.records.forEach(function(r){
    if(idsDesp[r.id])dupDesp.push({fecha:r.fecha,detalle:'ID duplicado: '+r.id,m3:r.tm||0});
    idsDesp[r.id]=true;
  });
  // ═══ Anomalías ═══
  if(transfSinOrigen.length){
    R.anomalias.push({
      severidad:'er',
      titulo:'Transformaciones sin origenId',
      descripcion:transfSinOrigen.length+' registro(s) de transformación NO tienen el campo origenId. Eso impide descontar la grava correctamente del KPI.',
      detalle:transfSinOrigen,
      accion:'fix-transf-origen',
      accionLabel:'🔧 Reparar (asignar sys_patio)'
    });
  }
  if(prodPatioSinMarca.length){
    R.anomalias.push({
      severidad:'wa',
      titulo:'Producciones con fuenteId=sys_patio sin marca de transformación',
      descripcion:prodPatioSinMarca.length+' registro(s) consumen Grava directamente pero no están marcados como transformación. Si son trituraciones normales, está correcto. Si son transformaciones, deberían marcarse.',
      detalle:prodPatioSinMarca
    });
  }
  if(prodSinFuentes.length){
    R.anomalias.push({
      severidad:'wa',
      titulo:'Producciones sin fuentes definidas',
      descripcion:prodSinFuentes.length+' registro(s) tienen distribución a PT pero no fuente declarada (legacy). Inventario asume Grava como origen.',
      detalle:prodSinFuentes
    });
  }
  if(dupExp.length||dupProd.length||dupDesp.length){
    var total=dupExp.length+dupProd.length+dupDesp.length;
    R.anomalias.push({
      severidad:'er',
      titulo:'IDs duplicados detectados',
      descripcion:total+' registro(s) tienen el mismo ID que otro. Esto rompe la integridad referencial.',
      detalle:dupExp.concat(dupProd).concat(dupDesp)
    });
  }
  return R;
}

