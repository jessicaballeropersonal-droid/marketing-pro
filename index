function importValidar(){
  var raw=gv('import-json').trim();
  if(!raw){
    modalAviso({tipo:'info',titulo:'JSON vacío',contenidoHtml:'<div style="font-size:12px;color:var(--tx2);line-height:1.6">Pegue el JSON en el área de texto antes de validar.</div>',botonSecundario:'Entendido'});
    return;
  }
  var data;
  try{data=JSON.parse(raw);}
  catch(e){
    modalAviso({
      tipo:'danger',
      titulo:'JSON inválido',
      subtitulo:'Revisa el formato del texto pegado',
      contenidoHtml:'<div style="font-size:12px;color:var(--tx2);line-height:1.6;margin-bottom:8px">El texto pegado no es un JSON válido.</div>'+
        '<div style="background:var(--bg3);border-radius:6px;padding:8px 10px;font-family:var(--M);font-size:9px;color:var(--er);line-height:1.5;word-break:break-word">'+e.message+'</div>',
      botonSecundario:'Entendido'
    });
    return;
  }
  // Verificar estructura — soportar v1.6 (despachos_directos + despachos_transformados) y v1.7 (despachos unificado + parametros)
  var esV17 = !!data.parametros || (Array.isArray(data.despachos) && !data.despachos_directos);
  // Normalizar: si es v1.7, partir despachos en directos+transformados internamente
  if(esV17){
    // Aceptamos: despachos unificado (cada uno con cliente y items[])
    if(!data.extracciones || !data.producciones){
      modalAviso({
        tipo:'danger',
        titulo:'Estructura inválida (v1.7)',
        subtitulo:'Faltan claves requeridas',
        contenidoHtml:'<div style="font-size:12px;color:var(--tx2);line-height:1.6;margin-bottom:8px">El JSON v1.7 debe contener:</div>'+
          '<div style="background:var(--bg3);border-radius:6px;padding:8px 10px;font-family:var(--M);font-size:9.5px;color:var(--tx1);line-height:1.7">• parametros (opcional)<br>• extracciones<br>• producciones<br>• despachos</div>',
        botonSecundario:'Entendido'
      });
      return;
    }
    if(!Array.isArray(data.despachos)){
      modalAviso({tipo:'danger',titulo:'Despachos inválidos',subtitulo:'La clave "despachos" debe ser un array',contenidoHtml:'<div style="font-size:12px;color:var(--tx2)">El JSON v1.7 usa una clave única "despachos" en lugar de despachos_directos/transformados.</div>',botonSecundario:'Entendido'});
      return;
    }
    // Generar arrays vacíos para retrocompatibilidad — los despachos van todos en despachos_directos
    data.despachos_directos = data.despachos;
    data.despachos_transformados = [];
  } else {
    // Formato v1.6
    if(!data.extracciones||!data.producciones||!data.despachos_directos||!data.despachos_transformados){
      modalAviso({
        tipo:'danger',
        titulo:'Estructura inválida',
        subtitulo:'Faltan claves requeridas',
        contenidoHtml:'<div style="font-size:12px;color:var(--tx2);line-height:1.6;margin-bottom:8px">El JSON debe contener las 4 claves siguientes:</div>'+
          '<div style="background:var(--bg3);border-radius:6px;padding:8px 10px;font-family:var(--M);font-size:9.5px;color:var(--tx1);line-height:1.7">• extracciones<br>• producciones<br>• despachos_directos<br>• despachos_transformados</div>',
        botonSecundario:'Entendido'
      });
      return;
    }
  }
  // Calcular totales
  var totExtM3=data.extracciones.reduce(function(s,e){return s+(parseFloat(e.m3)||0);},0);
  var totProdM3=data.producciones.reduce(function(s,p){return s+(parseFloat(p.fuente_m3_tolva)||0)+(parseFloat(p.fuente_m3_zaranda)||0)+(parseFloat(p.fuente_m3_arena_rio)||0);},0);
  var totDirM3=data.despachos_directos.reduce(function(s,d){return s+(d.items||[]).reduce(function(a,it){return a+(parseFloat(it.m3)||0);},0);},0);
  var totTransM3=data.despachos_transformados.reduce(function(s,d){return s+(d.items||[]).reduce(function(a,it){return a+(parseFloat(it.m3)||0);},0);},0);
  // Verificar que existan proveedor/equipo/operador
  // En v1.7 los nombres vienen del JSON.parametros, en v1.6 son hard-coded
  var nomProv = (esV17 && data.parametros && data.parametros.proveedores && data.parametros.proveedores[0]) ? (data.parametros.proveedores[0].nombre || data.parametros.proveedores[0]) : 'CAMILO';
  var nomEq = (esV17 && data.parametros && data.parametros.equipos && data.parametros.equipos[0]) ? (data.parametros.equipos[0].nombre || data.parametros.equipos[0]) : 'PLANTA 1';
  var nomOp = (esV17 && data.parametros && data.parametros.operadores && data.parametros.operadores[0]) ? (data.parametros.operadores[0].nombre || data.parametros.operadores[0]) : 'PRODUCCION INICIAL';
  var avisos=[];
  var provExiste=(S.proveedores||[]).find(function(p){return p.nombre&&p.nombre.toUpperCase()===nomProv.toUpperCase();});
  if(!provExiste)avisos.push('⚙️ Se creará proveedor "'+nomProv+'"');
  var eqExiste=(S.mantEquipos||[]).find(function(e){return e.nombre&&e.nombre.toUpperCase()===nomEq.toUpperCase();});
  if(!eqExiste)avisos.push('⚙️ Se creará equipo "'+nomEq+'"');
  var opExiste=(S.operadores||[]).find(function(o){return o.nombre&&o.nombre.toUpperCase()===nomOp.toUpperCase();});
  if(!opExiste)avisos.push('⚙️ Se creará operador "'+nomOp+'"');
  // v1.7: avisos por clientes nuevos del JSON
  if(esV17 && data.parametros && Array.isArray(data.parametros.clientes)){
    var cliFaltantes=[];
    data.parametros.clientes.forEach(function(c){
      var n=c.nombre||c;
      var ex=(S.clientes||[]).find(function(x){return x.nombre&&x.nombre.toUpperCase()===n.toUpperCase();});
      if(!ex)cliFaltantes.push(n);
    });
    if(cliFaltantes.length)avisos.push('⚙️ Se crearán '+cliFaltantes.length+' cliente(s): '+cliFaltantes.join(', '));
  }
  // Verificar productos terminados que faltan
  var ptFaltantes={};
  data.producciones.forEach(function(p){
    Object.keys(p.clasificacion_tolva||{}).concat(Object.keys(p.clasificacion_zaranda||{})).concat(Object.keys(p.clasificacion_arena_rio||{})).forEach(function(pt){
      var existe=(S.prodTerm||[]).find(function(x){return x.nombre&&x.nombre.toUpperCase()===pt.toUpperCase();});
      if(!existe)ptFaltantes[pt]=1;
    });
  });
  data.despachos_directos.concat(data.despachos_transformados).forEach(function(d){
    (d.items||[]).forEach(function(it){
      var existe=(S.prodTerm||[]).find(function(x){return x.nombre&&x.nombre.toUpperCase()===(it.producto||'').toUpperCase();});
      if(!existe)ptFaltantes[it.producto]=1;
    });
  });
  if(Object.keys(ptFaltantes).length){
    avisos.push('⚠️ Productos terminados faltantes: '+Object.keys(ptFaltantes).join(', '));
  }
  // Mostrar preview
  var html='<div style="display:flex;flex-direction:column;gap:5px">';
  html+='<div>📊 Se importarán:</div>';
  html+='<div style="padding-left:14px">• <strong>'+data.extracciones.length+' extracciones</strong> ('+totExtM3.toFixed(0)+' m³)</div>';
  html+='<div style="padding-left:14px">• <strong>'+data.producciones.length+' meses de producción</strong> ('+totProdM3.toFixed(0)+' m³)</div>';
  html+='<div style="padding-left:14px">• <strong>'+data.despachos_directos.length+' despachos directos</strong> ('+totDirM3.toFixed(0)+' m³)</div>';
  html+='<div style="padding-left:14px">• <strong>'+data.despachos_transformados.length+' despachos transformados</strong> ('+totTransM3.toFixed(0)+' m³)</div>';
  if(avisos.length){
    html+='<div style="margin-top:6px;padding-top:6px;border-top:1px solid var(--bd2)">';
    avisos.forEach(function(a){html+='<div>'+a+'</div>';});
    html+='</div>';
  }
  // Detectar producciones con 5+ PT (necesitan 2 órdenes)
  var con2ordenes=data.producciones.filter(function(p){return Object.keys(p.clasificacion_tolva||{}).length>4;}).length;
  if(con2ordenes>0){
    html+='<div style="margin-top:6px;padding-top:6px;border-top:1px solid var(--bd2);color:var(--in)">ℹ️ '+con2ordenes+' meses generarán <strong>2 órdenes</strong> en Tolva (más de 4 PT)</div>';
  }
  html+='</div>';
  G('import-preview-content').innerHTML=html;
  G('import-preview').style.display='block';
  G('import-confirm').style.display='block';
  _importDataParsed=data;
  importCheckConfirm();
}

function _importGetOrCreate(coleccion,nombre,extra){
  var lista=S[coleccion]||(S[coleccion]=[]);
  var found=lista.find(function(x){return x.nombre&&x.nombre.toUpperCase()===nombre.toUpperCase();});
  if(found)return found;
  var n={id:uid(),nombre:nombre};
  if(extra)Object.assign(n,extra);
  lista.push(n);
  // v171.9 FIX: Guardar en tabla dedicada de Supabase (snake_case), no en config
  var tableMap={
    equipos:'equipos',
    operadores:'operadores',
    clientes:'clientes',
    proveedores:'proveedores',
    causasMuerto:'causas_muerto',
    materiales:'causas_muerto'
  };
  try{
    if(tableMap[coleccion]){
      // Tabla dedicada (snake_case) — se lee al cargar
      supaUpsert(tableMap[coleccion],{id:n.id,nombre:n.nombre});
    } else {
      // Catálogos que sí van a config (mantEquipos, etc.)
      _dbSaveCfg(coleccion,lista);
    }
  }catch(e){console.warn('Error guardando',coleccion,e);}
  return n;
}

function _importGetOrCreatePT(nombre){
  var lista=S.prodTerm||(S.prodTerm=[]);
  var found=lista.find(function(x){return x.nombre&&x.nombre.toUpperCase()===nombre.toUpperCase();});
  if(found)return found;
  var pt={id:uid(),nombre:nombre,src:'manual'};
  lista.push(pt);
  // v171.9 FIX CRÍTICO: Guardar en tabla 'prod_term' (no en config)
  try{dbSaveProdTerm(pt);}catch(e){console.warn('Error guardando PT en prod_term',e);}
  return pt;
}

function importEjecutar(){
  if(!_importDataParsed){
    modalAviso({tipo:'info',titulo:'Validación pendiente',contenidoHtml:'<div style="font-size:12px;color:var(--tx2);line-height:1.6">Primero debe validar el JSON con el botón 🔍 Validar antes de importar.</div>',botonSecundario:'Entendido'});
    return;
  }
  if(gv('import-confirm-txt').trim()!=='IMPORTAR'){
    modalAviso({tipo:'warn',titulo:'Confirmación requerida',contenidoHtml:'<div style="font-size:12px;color:var(--tx2);line-height:1.6">Escriba la palabra <strong>IMPORTAR</strong> en mayúsculas en el campo de confirmación antes de continuar.</div>',botonSecundario:'Entendido'});
    return;
  }
  var data=_importDataParsed;
  G('import-progress').style.display='block';
  var totalSteps=data.extracciones.length+data.producciones.length*2+data.despachos_directos.length+data.despachos_transformados.length;
  var step=0;
  function tick(msg){
    step++;
    var pct=Math.round(step/totalSteps*100);
    G('import-progress-txt').textContent=msg+' ('+step+'/'+totalSteps+')';
    G('import-progress-bar').style.width=pct+'%';
  }

  // 1) Crear proveedor, equipo, operador (desde parametros del v1.7 o defaults del v1.6)
  var esV17 = !!data.parametros;
  var nomProv = (esV17 && data.parametros.proveedores && data.parametros.proveedores[0]) ? (data.parametros.proveedores[0].nombre || data.parametros.proveedores[0]) : 'CAMILO';
  var nomOp = (esV17 && data.parametros.operadores && data.parametros.operadores[0]) ? (data.parametros.operadores[0].nombre || data.parametros.operadores[0]) : 'PRODUCCION INICIAL';
  // Equipo: usar nombre + tipo del JSON v1.7. Si no, defaults seguros.
  var eqObj = (esV17 && data.parametros.equipos && data.parametros.equipos[0]) ? data.parametros.equipos[0] : null;
  var nomEq = eqObj ? (eqObj.nombre || eqObj) : 'PLANTA 1';
  // ⚠️ tipo del equipo: si no se especifica o es 'planta'/'trituradora' (no soportado por mantEquipos), usar 'cargador' como default neutro y permitir al user reconfigurarlo
  var tipoEq = (eqObj && eqObj.tipo) ? eqObj.tipo : 'volqueta';
  if(['planta','trituradora','zaranda'].indexOf((tipoEq||'').toLowerCase())>=0){
    // Tipos no soportados por mantEquipos (que solo acepta volqueta/excavadora/cargador) → marcar como cargador (genérico)
    // Pero conservamos un campo 'tipoOriginal' para que la app pueda reconocerlo
    var tipoOrig=tipoEq;
    tipoEq='cargador';
  }
  var prov=_importGetOrCreate('proveedores',nomProv);
  // Para equipo: si ya existe con ese nombre lo respeta; si no, lo crea con tipo seguro
  var equipo=_importGetOrCreate('mantEquipos',nomEq,{tipo:tipoEq,estado:'operativo',horoActual:0,horoInicial:0,viajes:0,m3:0});
  // Sanear si el equipo ya existía pero estaba mal armado (campos undefined que causan crashes)
  if(equipo){
    if(equipo.estado===undefined)equipo.estado='operativo';
    if(equipo.horoActual===undefined)equipo.horoActual=0;
    if(equipo.horoInicial===undefined)equipo.horoInicial=0;
    if(!equipo.tipo||['planta','trituradora','zaranda'].indexOf(String(equipo.tipo).toLowerCase())>=0)equipo.tipo='cargador';
    try{_dbSaveCfg('mantEquipos',S.mantEquipos);}catch(_){}
  }
  // ═══ v172.10 FIX: SINCRONIZAR con S.equipos (lista usada por Producción) ═══
  // El módulo de Gestión de Activos lee de S.mantEquipos
  // Pero el módulo de Producción lee de S.equipos
  // Sin esta sincronización, las producciones mostrarían un equipo "fantasma"
  // y "Mis Equipos" estaría vacía.
  if(equipo){
    var equipoEnEquipos=(S.equipos||[]).find(function(x){return x.nombre&&x.nombre.toUpperCase()===equipo.nombre.toUpperCase();});
    if(!equipoEnEquipos){
      // No existe en S.equipos → crearlo con el MISMO ID que tiene en mantEquipos
      if(!S.equipos)S.equipos=[];
      var nuevoEq={id:equipo.id,nombre:equipo.nombre};
      S.equipos.push(nuevoEq);
      try{supaUpsert('equipos',{id:nuevoEq.id,nombre:nuevoEq.nombre});}catch(_){}
      // Usar este como referencia para producciones
      equipo=Object.assign(equipo,{id:nuevoEq.id});
    } else if(equipoEnEquipos.id!==equipo.id){
      // Existe pero con ID distinto → unificar IDs (usar el de S.equipos como master)
      equipo.id=equipoEnEquipos.id;
      try{_dbSaveCfg('mantEquipos',S.mantEquipos);}catch(_){}
    }
  }
  var operador=_importGetOrCreate('operadores',nomOp);
  // Crear clientes del bloque parametros (v1.7)
  if(esV17 && Array.isArray(data.parametros.clientes)){
    data.parametros.clientes.forEach(function(c){
      var n=c.nombre||c;
      _importGetOrCreate('clientes',n);
    });
  }
  // Crear PT del bloque parametros (v1.7)
  if(esV17 && Array.isArray(data.parametros.productos_terminados)){
    data.parametros.productos_terminados.forEach(function(pt){
      _importGetOrCreatePT(typeof pt==='string'?pt:(pt.nombre||''));
    });
  }
  // Inventario inicial (v1.7)
  if(esV17 && Array.isArray(data.inventario_inicial)){
    data.inventario_inicial.forEach(function(inv){
      if(!inv.producto||!(inv.m3>0))return;
      var pt=_importGetOrCreatePT(inv.producto);
      // Registrar como una "extracción virtual" al inventario para que el stock arranque correcto
      // En realidad lo más limpio es registrarlo como un movimiento de producción que clasifica 100% a ese PT
      // Pero como es complejo y depende del módulo, lo dejamos como bandera para mostrarlo al usuario
      // -> Por ahora solo lo logueamos. El usuario lo ingresará manualmente si lo necesita.
      console.log('Inv. inicial detectado en JSON:',inv);
    });
  }

  // 2) Importar extracciones
  data.extracciones.forEach(function(e){
    var almReal=e.alm;
    var ptIdMap={patio:'sys_patio',tolva:'sys_tolva',zaranda:'sys_zaranda',arena_rio:'sys_arena_rio'};
    var rec={id:uid(),fecha:e.fecha,provId:prov.id,alm:almReal,turno:e.turno||'dia',
      dc:0,dm:0,dt:0,vc:e.viajes||0,vm:14,vt:e.m3,tv:e.viajes||0,tm:e.m3,
      ptId:ptIdMap[almReal]||'sys_patio',origenBit:false};
    S.exp.records.push(rec);
    try{dbSaveExp(rec);}catch(_){}
    tick('Importando extracciones');
  });

  // 3) Importar producciones (con 1 o 2 órdenes según PT)
  data.producciones.forEach(function(p){
    var fechaProd=p.fecha;
    var turno=p.turno||'dia';
    
    // ═══ NUEVO v1.6: Soporte para Transformación desde Grava ═══
    // Si la producción tiene tipo='transformacion', crear orden de Transformación
    // que descuenta de Grava (sys_patio) sin tocar Tolva
    if(p.tipo==='transformacion' && p.fuente_m3_tolva>0){
      var ptsT=Object.keys(p.clasificacion_tolva||{});
      if(ptsT.length){
        var distT=ptsT.map(function(pt){
          var pto=_importGetOrCreatePT(pt);
          var pctT=p.clasificacion_tolva[pt]||0;
          return {key:'trans-'+pto.id,alm:'transformacion',ptId:pto.id,pct:pctT,m3:p.fuente_m3_tolva*pctT/100};
        });
        var transRec={id:uid(),fecha:fechaProd,turno:turno,equipoId:equipo.id,operadorId:operador.id,
          fuentes:[{alm:'transformacion',vj:Math.round(p.fuente_m3_tolva/14),m3v:14,m3:p.fuente_m3_tolva,origenId:'sys_patio'}],
          fuenteM3:p.fuente_m3_tolva,fuenteId:'sys_patio',
          dc:0,dm:0,dt:0,vc:0,vm:0,vt:0,tv:0,
          tm:distT.reduce(function(s,d){return s+d.m3;},0),
          ini:'',des:'00:00',fin:'',netMin:0,netas:'',dist:distT,sinHorario:true,
          esTransformacion:true,origenBit:false,pendienteClasif:false};
        S.prod.records.push(transRec);
        try{dbSaveProd(transRec);}catch(_){}
        tick('Importando transformación ('+p.mes+')');
      }
      // Si la transformación tiene Zaranda también, continuar al bloque normal
      // pero solo para Zaranda
      var zPtsT=Object.keys(p.clasificacion_zaranda||{});
      if(zPtsT.length&&p.fuente_m3_zaranda>0){
        var distZT=zPtsT.map(function(pt){
          var pto=_importGetOrCreatePT(pt);
          return {key:'zaranda-'+pto.id,alm:'zaranda',ptId:pto.id,pct:p.clasificacion_zaranda[pt],m3:p.fuente_m3_zaranda*p.clasificacion_zaranda[pt]/100};
        });
        var recZT={id:uid(),fecha:fechaProd,turno:turno,equipoId:equipo.id,operadorId:operador.id,
          fuentes:[{alm:'zaranda',vj:Math.round(p.fuente_m3_zaranda/14),m3v:14,m3:p.fuente_m3_zaranda}],
          fuenteM3:p.fuente_m3_zaranda,fuenteId:'sys_zaranda',
          dc:0,dm:0,dt:0,vc:Math.round(p.fuente_m3_zaranda/14),vm:14,vt:0,
          tv:Math.round(p.fuente_m3_zaranda/14),tm:distZT.reduce(function(s,d){return s+d.m3;},0),
          ini:'',des:'00:00',fin:'',netMin:0,netas:'',dist:distZT,sinHorario:true,
          esTransformacion:false,origenBit:false,pendienteClasif:false};
        S.prod.records.push(recZT);
        try{dbSaveProd(recZT);}catch(_){}
      }
      return; // No procesar este registro como producción Tolva normal
    }
    // ═══ FIN bloque transformación ═══
    
    // Determinar si Tolva necesita 1 o 2 órdenes
    var pts=Object.keys(p.clasificacion_tolva||{});
    
    // ═══ NUEVO v172.9: soporte para fuente_m3_pgtolva (Card VERDE Patio→Tolva) ═══
    // Si la producción tiene fuente_m3_pgtolva, agregar una orden adicional
    // con fuente alm:'patio' que descuenta Patio Y suma al producido mensual (porque pasa por Tolva)
    var fuentePgTolva = p.fuente_m3_pgtolva || 0;
    if(fuentePgTolva > 0 && pts.length){
      // Crear orden PG→Tolva con misma clasificación que Tolva normal
      var distPg = pts.map(function(pt){
        var pctPg = p.clasificacion_tolva[pt]||0;
        var pto = _importGetOrCreatePT(pt);
        return {key:'pgtolva-'+pto.id,alm:'patio',ptId:pto.id,pct:pctPg,m3:fuentePgTolva*pctPg/100};
      });
      var recPg = {id:uid(),fecha:fechaProd,turno:turno,equipoId:equipo.id,operadorId:operador.id,
        fuentes:[{alm:'patio',vj:Math.round(fuentePgTolva/14),m3v:14,m3:fuentePgTolva}],
        fuenteM3:fuentePgTolva,fuenteId:'sys_patio',
        dc:0,dm:0,dt:0,vc:Math.round(fuentePgTolva/14),vm:14,vt:0,
        tv:Math.round(fuentePgTolva/14),
        tm:distPg.reduce(function(s,d){return s+d.m3;},0),
        ini:'',des:'00:00',fin:'',netMin:0,netas:'',dist:distPg,sinHorario:true,
        esTransformacion:false,origenBit:false,pendienteClasif:false};
      S.prod.records.push(recPg);
      try{dbSaveProd(recPg);}catch(_){}
      tick('Importando PG→Tolva ('+p.mes+')');
    }
    // ═══ FIN bloque PG→Tolva ═══
    
    var grupos=[];
    if(pts.length<=4){
      grupos.push(pts);
    }else{
      // Partir en 2 grupos
      var mid=Math.ceil(pts.length/2);
      grupos.push(pts.slice(0,mid));
      grupos.push(pts.slice(mid));
    }
    // Crear órdenes Tolva
    grupos.forEach(function(grupoPts,idx){
      if(!grupoPts.length)return;
      var pctTotal=grupoPts.reduce(function(s,pt){return s+(p.clasificacion_tolva[pt]||0);},0);
      var fuenteM3=p.fuente_m3_tolva*pctTotal/100;
      var dist=grupoPts.map(function(pt){
        var pctNormalizado=(p.clasificacion_tolva[pt]||0)/pctTotal*100;
        var pto=_importGetOrCreatePT(pt);
        return {key:'tolva-'+pto.id,alm:'tolva',ptId:pto.id,pct:pctNormalizado,m3:fuenteM3*pctNormalizado/100};
      });
      var rec={id:uid(),fecha:fechaProd,turno:turno,equipoId:equipo.id,operadorId:operador.id,
        fuentes:[{alm:'tolva',vj:Math.round(fuenteM3/14),m3v:14,m3:fuenteM3}],
        fuenteM3:fuenteM3,fuenteId:'sys_patio',
        dc:0,dm:0,dt:0,vc:Math.round(fuenteM3/14),vm:14,vt:0,tv:Math.round(fuenteM3/14),
        tm:dist.reduce(function(s,d){return s+d.m3;},0),
        ini:'',des:'00:00',fin:'',netMin:0,netas:'',dist:dist,sinHorario:true,
        esTransformacion:false,origenBit:false,pendienteClasif:false};
      S.prod.records.push(rec);
      try{dbSaveProd(rec);}catch(_){}
    });
    tick('Importando órdenes Tolva ('+p.mes+')');
    // Crear orden Zaranda si tiene
    var zPts=Object.keys(p.clasificacion_zaranda||{});
    if(zPts.length&&p.fuente_m3_zaranda>0){
      var distZ=zPts.map(function(pt){
        var pto=_importGetOrCreatePT(pt);
        return {key:'zaranda-'+pto.id,alm:'zaranda',ptId:pto.id,pct:p.clasificacion_zaranda[pt],m3:p.fuente_m3_zaranda*p.clasificacion_zaranda[pt]/100};
      });
      var recZ={id:uid(),fecha:fechaProd,turno:turno,equipoId:equipo.id,operadorId:operador.id,
        fuentes:[{alm:'zaranda',vj:Math.round(p.fuente_m3_zaranda/14),m3v:14,m3:p.fuente_m3_zaranda}],
        fuenteM3:p.fuente_m3_zaranda,fuenteId:'sys_zaranda',
        dc:0,dm:0,dt:0,vc:Math.round(p.fuente_m3_zaranda/14),vm:14,vt:0,
        tv:Math.round(p.fuente_m3_zaranda/14),tm:distZ.reduce(function(s,d){return s+d.m3;},0),
        ini:'',des:'00:00',fin:'',netMin:0,netas:'',dist:distZ,sinHorario:true,
        esTransformacion:false,origenBit:false,pendienteClasif:false};
      S.prod.records.push(recZ);
      try{dbSaveProd(recZ);}catch(_){}
    }
    // Crear orden Arena Río si tiene
    if(p.fuente_m3_arena_rio>0){
      var pto=_importGetOrCreatePT('Arena Río');
      var distA=[{key:'arena_rio-'+pto.id,alm:'arena_rio',ptId:pto.id,pct:100,m3:p.fuente_m3_arena_rio}];
      var recA={id:uid(),fecha:fechaProd,turno:turno,equipoId:equipo.id,operadorId:operador.id,
        fuentes:[{alm:'arena_rio',vj:Math.round(p.fuente_m3_arena_rio/14),m3v:14,m3:p.fuente_m3_arena_rio}],
        fuenteM3:p.fuente_m3_arena_rio,fuenteId:'sys_arena_rio',
        dc:0,dm:0,dt:0,vc:Math.round(p.fuente_m3_arena_rio/14),vm:14,vt:0,
        tv:Math.round(p.fuente_m3_arena_rio/14),tm:p.fuente_m3_arena_rio,
        ini:'',des:'00:00',fin:'',netMin:0,netas:'',dist:distA,sinHorario:true,
        esTransformacion:false,origenBit:false,pendienteClasif:false};
      S.prod.records.push(recA);
      try{dbSaveProd(recA);}catch(_){}
    }
    tick('Importando órdenes adicionales ('+p.mes+')');
  });

  // 4) Importar despachos directos
  data.despachos_directos.forEach(function(d){
    var items=(d.items||[]).map(function(it){
      var pto=_importGetOrCreatePT(it.producto);
      return {ptId:pto.id,m3:parseFloat(it.m3)||0};
    }).filter(function(it){return it.m3>0;});
    if(items.length){
      var rec={id:uid(),fecha:d.fecha,cliente:d.cliente||'',items:items,
        tm:items.reduce(function(s,it){return s+it.m3;},0)};
      S.desp.records.push(rec);
      try{dbSaveDesp(rec);}catch(_){}
    }
    tick('Importando desp. directo '+d.mes);
  });

  // 5) Importar despachos transformados
  data.despachos_transformados.forEach(function(d){
    var items=(d.items||[]).map(function(it){
      var pto=_importGetOrCreatePT(it.producto);
      return {ptId:pto.id,m3:parseFloat(it.m3)||0};
    }).filter(function(it){return it.m3>0;});
    if(items.length){
      var rec={id:uid(),fecha:d.fecha,cliente:d.cliente||'',items:items,
        tm:items.reduce(function(s,it){return s+it.m3;},0)};
      S.desp.records.push(rec);
      try{dbSaveDesp(rec);}catch(_){}
    }
    tick('Importando desp. transformado '+d.mes);
  });

  // 6) Log actividad
  try{
    logActividad({accion:'crear',modulo:'parametros',descripcion:'Importación masiva: '+data.extracciones.length+' ext, '+data.producciones.length+' meses prod, '+(data.despachos_directos.length+data.despachos_transformados.length)+' despachos',despues:data.metadata||{}});
  }catch(_){}

  // 7) Guardar todo y refrescar
  saveS();
  try{updXKPI();updPKPI();updDKPI();}catch(_){}
  try{renderXH();renderPH();renderDH();}catch(_){}

  G('import-progress-txt').textContent='✅ Importación completada — '+step+' registros creados';
  G('import-progress-bar').style.width='100%';
  G('import-progress-bar').style.background='var(--ok)';
  modalAviso({tipo:'success',titulo:'Importación completada',
    contenidoHtml:'<div style="font-size:12px;color:var(--tx2);line-height:1.6">Se crearon <strong>'+step+'</strong> registros correctamente.<br><br>Revisa los KPIs y los historiales para verificar.</div>',
    botonSecundario:'Cerrar'});
  importLimpiar();
}
