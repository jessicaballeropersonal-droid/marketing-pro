  } else {
    R.anomalias.forEach(function(a){
      var sev=a.severidad||'wa';
      var cls=sev==='er'?'er':(sev==='ok'?'ok':'wa');
      var bg=sev==='er'?'var(--erA)':(sev==='ok'?'var(--okA)':'var(--waA)');
      var bd=sev==='er'?'var(--erB)':(sev==='ok'?'var(--okB)':'var(--waB)');
