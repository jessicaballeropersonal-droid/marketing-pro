function openEditLiq(liqId){
  var liq=(S.conductoresLiq||[]).find(function(l){return l.id===liqId;});if(!liq)return;
  if(!puedeEditar('conductores')){
    modalAviso({tipo:'danger',titulo:'Sin permisos',subtitulo:'Acción restringida',contenidoHtml:'<div style="font-size:12px;color:var(--tx2);line-height:1.6">Solo el <strong>administrador</strong> puede editar liquidaciones.</div>',botonSecundario:'Entendido'});
