function saveConductor(){
  var id=G('cond-edit-id').value;
  var nombre=G('cond-nombre').value.trim();
  var al=G('cond-alert');
  if(!nombre){al.className='alert alert-er on';al.textContent='El nombre es obligatorio.';return;}
  // FIX: Si es edición, preservar campo activo original
  var original=id&&S.conductores?S.conductores.find(function(c){return c.id===id;}):null;
  var cond={
    id:id||uid(),nombre:nombre,cedula:G('cond-cedula').value.trim(),
    tel:G('cond-tel').value.trim(),tipo:G('cond-tipo').value,
    porc:parseFloat(G('cond-porc').value)||0,
    licVence:G('cond-lic-vence')?G('cond-lic-vence').value:'',
    soatVence:G('cond-soat-vence')?G('cond-soat-vence').value:'',
    rtmVence:G('cond-rtm-vence')?G('cond-rtm-vence').value:'',
    placa:G('cond-placa')?(G('cond-placa').value.trim().toUpperCase()):'',
    diasAlerta:G('cond-dias-alerta')?parseInt(G('cond-dias-alerta').value)||30:30,
    obs:G('cond-obs-field')?G('cond-obs-field').value.trim():'',
    // FIX: Preservar estado activo original (no reactivar al editar)
    activo:original?(original.activo!==false):true
