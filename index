  if(typeof toast==='function')toast(esUrl?('🌐 Leyendo '+v.nombre+'...'):('🔍 Rastreando '+v.nombre+'... espera 30-60 segundos'),'info');
  // Marcar estado global de búsqueda + rerender
  _RAST.buscandoVentana=vid;
  _RAST.buscandoNombre=v.nombre;
  _RAST.buscandoDesde=Date.now();
  renderRastreador();

  fetch('/api/rastreo',{
    method:'POST',
    headers:{'Content-Type':'application/json'},
    body:JSON.stringify({
      prompt:prompt,
      departamento:S.rastreadorFiltros.depto,
      entidades:S.rastreadorFiltros.entidades,
      municipios:S.rastreadorFiltros.municipios,
      palabrasClave:S.rastreadorFiltros.palabras,
      ventana:v.nombre,
      urls:v.urls,
      tipo:(_rastEsSecop(v)?'secop':'url'),
      soloAbiertos:(v.soloAbiertos!==false),
      modo:modo,
      modelo:'claude-sonnet-4-6'
    })
  })
  .then(function(r){return r.json().then(function(d){return{status:r.status,data:d};});})
  .then(function(res){
    _RAST.buscandoVentana=null;_RAST.buscandoNombre=null;_RAST.buscandoDesde=null;
    if(res.status!==200){
      var _raw=(res.data&&(res.data.detalle||res.data.error));
      var msg=(typeof _raw==='string')?_raw:(_raw?JSON.stringify(_raw):'Error desconocido (status '+res.status+')');
      if(typeof toast==='function')toast('⚠ '+String(msg).substring(0,120),'err');
      else alert('Error rastreo: '+String(msg).substring(0,300));
      renderRastreador();
      return;
    }
    var resultados=(res.data&&res.data.resultados)||[];
    var _avisos=(res.data&&res.data.avisos)||[];
    if(!resultados.length&&_avisos.length){
      if(typeof toast==='function')toast('⚠ '+String(_avisos[0]).substring(0,170),'warn');
    }
    if(res.data&&res.data.warning){
      if(typeof toast==='function')toast('⚠ '+res.data.warning,'warn');
    }
    _rastProcesarResultados(resultados,vid,modo);
  })
  .catch(function(err){
    _RAST.buscandoVentana=null;_RAST.buscandoNombre=null;_RAST.buscandoDesde=null;
    if(typeof toast==='function')toast('⚠ Error de red: '+err.message,'err');
    else alert('Error de red: '+err.message);
    renderRastreador();
  });
}
