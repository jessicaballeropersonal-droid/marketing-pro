// ════ CAMBIO DE CARA — PLANTA ════
function abrirCambioCara(id){
  var c=(S.fungCambiosPl||[]).find(function(x){return x.id===id;});
  if(!c)return;
  if((c.ncaras||1)<2){
    modalAviso({tipo:'warn',titulo:'Pieza con 1 sola cara',contenidoHtml:'<div style="font-size:12px;color:var(--tx2);line-height:1.6">Esta pieza tiene solo 1 cara configurada, no se puede voltear.</div>',botonSecundario:'Entendido'});
    return;
  }
  // Bloquear si ya se usaron las 2 caras (cambiosCara ya tiene 1 entrada = Cara A cerrada, Cara B es la última)
  var cambiosCara=c.cambiosCara||[];
  if(cambiosCara.length>=(c.ncaras||2)-1){
    modalAviso({tipo:'warn',titulo:'Caras agotadas',contenidoHtml:'<div style="font-size:12px;color:var(--tx2);line-height:1.6">Esta pieza ya usó sus 2 caras. Para terminar use el botón <strong>Cerrar</strong>.</div>',botonSecundario:'Entendido'});
    return;
  }
  window._cambioCara_Id=id;
  var pieza=((S.fungPiezasPl||[]).find(function(p){return p.id===c.piezaId;})||{nombre:'—'});
  var acum=fplCalcAcum(c);
  var caraActual=c.cara||'A';
  var caraNueva='B'; // siempre A→B, solo se permite una vez
  var ttl=G('fpl-cc-ttl');if(ttl)ttl.textContent='🔄 Cambio de Cara — '+c.maq+' · '+pieza.nombre;
  var res=G('fpl-cc-resumen');
  if(res)res.innerHTML='<span style="color:var(--tx3)">Máquina:</span> <strong>'+c.maq+'</strong><br>'
    +'<span style="color:var(--tx3)">Pieza:</span> <strong>'+pieza.nombre+'</strong><br>'
    +'<span style="color:var(--tx3)">Cara actual:</span> <span class="bdg bdg-in">Cara A</span> → <span class="bdg bdg-pu">Cara B</span><br>'
    +'<span style="color:var(--tx3)">Acumulado Cara A:</span> <strong style="color:var(--or)">'+acum.viajes+' viajes / '+acum.m3+' m³</strong>';
  var cn=G('fpl-cc-cara-nueva');if(cn)cn.value='Cara B';
  var fd=G('fpl-cc-fecha');if(fd)fd.value=new Date().toISOString().slice(0,10);
  if(G('fpl-cc-alert'))G('fpl-cc-alert').className='alert';
  openMo('ov-fpl-cambio-cara');
}

function confirmarCambioCara(){
  var id=window._cambioCara_Id;
  var c=(S.fungCambiosPl||[]).find(function(x){return x.id===id;});
  if(!c)return;
  var fecha=G('fpl-cc-fecha').value;
  var causa=gv('fpl-cc-causa')||'desgaste';
  var obs=G('fpl-cc-obs')?G('fpl-cc-obs').value.trim():'';
  if(!fecha){var al=G('fpl-cc-alert');al.className='alert alert-er on';al.textContent='⚠️ Ingrese la fecha del cambio.';return;}
  var acum=fplCalcAcum(c);
  var caraActual=c.cara||'A';
  var caraNueva='B'; // solo se permite A→B una vez
  // Save cara log
  if(!c.cambiosCara)c.cambiosCara=[];
  c.cambiosCara.push({cara:caraActual,fechaIni:c.caraIni||c.fecha,fechaFin:fecha,viajes:acum.viajes,m3:acum.m3,causa:causa,obs:obs});
  // Switch to Cara B
  c.cara=caraNueva;
  c.caraIni=fecha;
  // Reset pausas for new cara tracking
  c.pausas=[];
  c.estadoPieza='activo';
  dbSaveFungCambioPl(c);
  cmo('ov-fpl-cambio-cara');
  renderFungPlActivos();
}

