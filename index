function saveTiemClasif(rid){
  var r=S.prod.records.find(function(x){return x.id===rid;});if(!r)return;
  var tipo=gv('tc-tipo-'+rid);
  var h=parseInt(gv('tc-h-'+rid))||0;
  var m=parseInt(gv('tc-m-'+rid))||0;
  var minutos=h*60+m;
  // Save viajes molidos
  var vjInput=G('tc-vj-'+rid);
  if(vjInput){r.viajesMolidos=parseInt(vjInput.value)||0;}
  if(minutos<=0&&tipo!=='viajes_only'){showAlert('tiem-alerta-'+rid,'er','Ingrese horas o minutos mayores a 0.');return;}
  var saldo=tiemSaldo(r);
  if(minutos>saldo){showAlert('tiem-alerta-'+rid,'er','El tiempo ingresado ('+mToHM(minutos)+') supera el saldo disponible ('+mToHM(saldo)+').');return;}
  if(!r.tiemClasif) r.tiemClasif={operado:0,mantenimiento:0,muertos:[]};
  if(tipo==='operado'){
    r.tiemClasif.operado=(r.tiemClasif.operado||0)+minutos;
  } else if(tipo==='mantenimiento'){
    r.tiemClasif.mantenimiento=(r.tiemClasif.mantenimiento||0)+minutos;
  } else {
    var causaSel=G('tc-causa-'+rid);
    var causaId=causaSel?causaSel.value:'';
    var causaNombre=causaId?(S.causasMuerto.find(function(c){return c.id===causaId;})||{nombre:'Sin causa'}).nombre:'Sin causa';
    r.tiemClasif.muertos.push({causaId:causaId,causaNombre:causaNombre,min:minutos});
  }
  saveS();dbSaveTiemClasif(r);updTiemKPI();renderTiemLista();renderTiemHis();
}

var _tiemPeriodDias=7;

function updTiemKPI(){
  var y=new Date().getFullYear(),f=y+'-01-01',t=y+'-12-31';
  var tot={op:0,mu:0,ma:0,vj:0};
  var dia={op:0,mu:0,ma:0,vj:0};
  var noc={op:0,mu:0,ma:0,vj:0};
  // Anual (para KPIs globales)
  S.prod.records.forEach(function(r){
    if(r.fecha<f||r.fecha>t)return;
    var cl=r.tiemClasif;if(!cl)return;
    var bucket=r.turno==='dia'?dia:noc;
    var op=cl.operado||0,ma=cl.mantenimiento||0,mu=0,vj=r.viajesMolidos||0;
    (cl.muertos||[]).forEach(function(m){mu+=m.min||0;});
    tot.op+=op;tot.ma+=ma;tot.mu+=mu;tot.vj+=vj;
    bucket.op+=op;bucket.ma+=ma;bucket.mu+=mu;bucket.vj+=vj;
  });
  G('kt-op').textContent=mToHM(tot.op);
  G('kt-mu').textContent=mToHM(tot.mu);
  G('kt-ma').textContent=mToHM(tot.ma);
  var base=tot.op+tot.ma;
  G('kt-di').textContent=base>0?Math.round(tot.op/base*100)+'%':'—';
  G('kt-vj').textContent=tot.vj;
  G('kt-tv').textContent=tot.vj>0&&tot.op>0?Math.round(tot.op/tot.vj)+' min':'—';
  // Por período y turno
  var periodoFin=new Date();var periodoIni=new Date();
  periodoIni.setDate(periodoIni.getDate()-(_tiemPeriodDias-1));
  var pf=periodoFin.toISOString().split('T')[0];
  var pi=periodoIni.toISOString().split('T')[0];
  var pDia={op:0,mu:0,ma:0,vj:0};var pNoc={op:0,mu:0,ma:0,vj:0};
  S.prod.records.forEach(function(r){
    if(r.fecha<pi||r.fecha>pf)return;
    var cl=r.tiemClasif;if(!cl)return;
    var bucket=r.turno==='dia'?pDia:pNoc;
    var op=cl.operado||0,ma=cl.mantenimiento||0,mu=0,vj=r.viajesMolidos||0;
    (cl.muertos||[]).forEach(function(m){mu+=m.min||0;});
    bucket.op+=op;bucket.ma+=ma;bucket.mu+=mu;bucket.vj+=vj;
  });
  var setT=function(pref,d){
    var el=G('kt-'+pref+'-op');if(el)el.textContent=mToHM(d.op);
    var el2=G('kt-'+pref+'-mu');if(el2)el2.textContent=mToHM(d.mu);
    var el3=G('kt-'+pref+'-ma');if(el3)el3.textContent=mToHM(d.ma);
    var b=d.op+d.ma;
    var el4=G('kt-'+pref+'-di');if(el4)el4.textContent=b>0?Math.round(d.op/b*100)+'%':'—';
    var el5=G('kt-'+pref+'-vj');if(el5)el5.textContent=d.vj;
    var el6=G('kt-'+pref+'-tv');if(el6)el6.textContent=d.vj>0&&d.op>0?Math.round(d.op/d.vj)+' min':'—';
  };
  setT('dia',pDia);setT('noc',pNoc);
}

