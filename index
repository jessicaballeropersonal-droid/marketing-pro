function delItem(arr,id){
  if(isSysId(id)){
    modalAviso({tipo:'danger',titulo:'No se puede eliminar',
      contenidoHtml:'<div style="font-size:12px;color:var(--tx2);line-height:1.6">Este producto es del sistema (Explotación) y no se puede eliminar.</div>',
      botonSecundario:'Entendido'});
    return;
  }
  var item=(S[arr]||[]).find(function(x){return x.id===id;});
  if(!item){return;}
  var nombre=item.nombre||id;
  // Detectar usos según el tipo
  var usos={};var totalUsos=0;
  if(arr==='proveedores'){
    usos.extracciones=(S.exp.records||[]).filter(function(r){return r.provId===id;}).length;
    totalUsos=usos.extracciones;
  } else if(arr==='equipos'){
    usos.producciones=(S.prod.records||[]).filter(function(r){return r.equipoId===id;}).length;
    totalUsos=usos.producciones;
  } else if(arr==='operadores'){
    usos.producciones=(S.prod.records||[]).filter(function(r){return r.operadorId===id;}).length;
    totalUsos=usos.producciones;
  } else if(arr==='clientes'){
    // Despachos usan el nombre del cliente, no el id
    usos.despachos=(S.desp.records||[]).filter(function(r){return r.cliente===nombre;}).length;
    usos.cotizaciones=(S.cotizaciones||[]).filter(function(c){return c.cliente===nombre;}).length;
    totalUsos=usos.despachos+usos.cotizaciones;
  } else if(arr==='prodTerm'){
    // Producto Terminado: el más crítico
    usos.produccion=0;
    (S.prod.records||[]).forEach(function(r){
      (r.dist||[]).forEach(function(d){if(d.ptId===id)usos.produccion++;});
    });
    usos.despachos=0;
    (S.desp.records||[]).forEach(function(r){
      (r.items||[]).forEach(function(it){if(it.ptId===id)usos.despachos++;});
    });
    usos.invInicial=(S.exp.records||[]).filter(function(r){return r.ptId===id&&r.provId==='sys_ini';}).length;
    usos.transformaciones=(S.prod.records||[]).filter(function(r){return r.fuenteId===id;}).length;
    var stockActual=invStock(id);
    totalUsos=usos.produccion+usos.despachos+usos.invInicial+usos.transformaciones;
    if(stockActual>0.01)totalUsos++; // si tiene stock, no eliminar
    usos.stock=stockActual;
  } else if(arr==='causasMuerto'){
    usos.tiemposMuertos=0;
    (S.prod.records||[]).forEach(function(r){
      if(r.tiemClasif&&r.tiemClasif.muertos){
        r.tiemClasif.muertos.forEach(function(m){if(m.causa===nombre||m.causaId===id)usos.tiemposMuertos++;});
      }
    });
    totalUsos=usos.tiemposMuertos;
  }
  var tipoLbl={proveedores:'Proveedor',equipos:'Equipo de Trituración',operadores:'Operador',
    clientes:'Cliente',prodTerm:'Producto Terminado',causasMuerto:'Causa de Tiempo Muerto'}[arr]||arr;
  // NIVEL 1: BLOQUEAR si tiene uso
  if(totalUsos>0){
    var contenido='<div style="background:var(--bg2);border-radius:8px;padding:12px;margin-bottom:11px;border-left:3px solid var(--er)">';
    contenido+='<div style="font-family:var(--M);font-size:10px;color:var(--tx2);margin-bottom:6px">'+tipoLbl.toUpperCase()+':</div>';
    contenido+='<div style="font-size:13px;color:var(--tx1);font-weight:700">📦 '+nombre+'</div>';
    contenido+='</div>';
    contenido+='<div style="background:var(--erA);border-radius:7px;padding:11px;margin-bottom:11px">';
    contenido+='<div style="font-family:var(--M);font-size:9px;color:var(--er);margin-bottom:6px;font-weight:700">⚠️ USOS DETECTADOS:</div>';
    contenido+='<div style="font-family:var(--M);font-size:10px;color:var(--tx1);line-height:1.8">';
    if(usos.extracciones)contenido+='<div>• '+usos.extracciones+' registro(s) de Extracción</div>';
    if(usos.producciones)contenido+='<div>• '+usos.producciones+' registro(s) de Producción</div>';
    if(usos.despachos)contenido+='<div>• '+usos.despachos+' Despacho(s)</div>';
    if(usos.cotizaciones)contenido+='<div>• '+usos.cotizaciones+' Cotización(es)</div>';
    if(usos.produccion)contenido+='<div>• '+usos.produccion+' usos en clasificaciones de producción</div>';
    if(usos.invInicial)contenido+='<div>• '+usos.invInicial+' registro(s) de Inventario Inicial</div>';
    if(usos.transformaciones)contenido+='<div>• '+usos.transformaciones+' transformación(es) como origen</div>';
    if(usos.tiemposMuertos)contenido+='<div>• '+usos.tiemposMuertos+' Tiempo(s) Muerto(s)</div>';
    if(usos.stock&&usos.stock>0.01)contenido+='<div>• Stock actual: <strong>'+usos.stock.toFixed(2)+' m³</strong></div>';
    contenido+='</div></div>';
    contenido+='<div style="background:var(--inA);border-radius:7px;padding:10px">';
    contenido+='<div style="font-family:var(--M);font-size:10px;color:var(--in);line-height:1.6">Si elimina este '+tipoLbl.toLowerCase()+', los registros relacionados quedarían con referencias rotas. Mejor renómbrelo o déjelo como está.</div>';
    contenido+='</div>';
    modalAviso({tipo:'danger',titulo:'No se puede eliminar',subtitulo:tipoLbl+' en uso',contenidoHtml:contenido,botonSecundario:'Entendido'});
    return;
  }
  // NIVEL 3: confirmación simple
  var contenido='<div style="background:var(--bg2);border-radius:8px;padding:11px;margin-bottom:11px">';
  contenido+='<div style="font-family:var(--M);font-size:10px;color:var(--tx2);margin-bottom:6px">'+tipoLbl.toUpperCase()+' A ELIMINAR:</div>';
  contenido+='<div style="font-size:13px;color:var(--tx1);font-weight:700">📦 '+nombre+'</div>';
