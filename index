function renderCtrlViajesTabla(){
  var desde=G('cv-desde').value,hasta=G('cv-hasta').value;
  var condId=G('cv-conductor').value,volqId=G('cv-volqueta').value;
  // Verificar si el período está liquidado
  var liqExist=(S.ctrlViajesLiq||[]).find(function(l){
    return l.desde===desde&&l.hasta===hasta&&(!condId||l.conductorId===condId);
  });
  var res=G('cv-resumen');var bar=G('cv-liquidar-bar');
  if(liqExist){
    res.innerHTML='<div style="background:var(--okA);border:1px solid var(--okB);border-radius:8px;padding:14px;text-align:center"><div style="font-family:var(--M);font-size:9px;color:var(--ok);font-weight:700;margin-bottom:4px">PERÍODO YA LIQUIDADO</div><div style="font-size:12px;color:var(--tx2)">Liquidado el '+fd(liqExist.fechaLiq)+' · Total: $'+Math.round(liqExist.total).toLocaleString('es-CO')+'</div></div>';
    if(bar)bar.style.display='none';return;
  }
  // Agrupar viajes de bitácoras por conductor
  var viajes={};
  (S.mantBitacoras||[]).forEach(function(b){
    if(desde&&b.fecha<desde)return;
    if(hasta&&b.fecha>hasta)return;
    var eq=S.mantEquipos.find(function(e){return e.id===b.equipoId;});
    if(!eq||eq.tipo!=='volqueta')return;
    if(volqId&&b.equipoId!==volqId)return;
    var condN=b.conductorId||b.operadorId||'Sin conductor';
    if(condId&&condN!==condId)return;
    if(!viajes[condN])viajes[condN]={nombre:condN,ext:0,tri:0,pp:0,equipo:eq.nombre};
    viajes[condN].ext+=(b.dc||0)+(b.dm||0)+(b.dt||0)+(b.vc||0)+(b.vm||0)+(b.vt||0);
  });
  // Sumar patio a patio de explotación
  (S.exp.records||[]).forEach(function(r){
    if(desde&&r.fecha<desde)return;
    if(hasta&&r.fecha>hasta)return;
    if(!r.pp_viajes||r.pp_viajes<=0)return;
    var condN=r.conductorId||'Sin conductor';
    if(!viajes[condN])viajes[condN]={nombre:condN,ext:0,tri:0,pp:0,equipo:'—'};
    viajes[condN].pp+=(r.pp_viajes||0);
  });
  var cfg=S.ctrlViajesConfig||{ext:0,tri:0,pp:0};
  var keys=Object.keys(viajes);
  if(!keys.length){
    res.innerHTML='<div style="text-align:center;padding:32px;color:var(--tx3);font-size:13px">Sin viajes en el período seleccionado.</div>';
    if(bar)bar.style.display='none';return;
  }
  var totalGeneral=0;
  res.innerHTML='<div class="tw"><table><thead><tr><th>Conductor</th><th>Veh.</th><th style="text-align:center">Ext.</th><th style="text-align:center">Tri.</th><th style="text-align:center">P-P</th><th style="text-align:right">Total Viajes</th><th style="text-align:right">Valor a Pagar</th></tr></thead><tbody>'
    +keys.map(function(k){
      var v=viajes[k];
      var total=v.ext*cfg.ext+v.tri*cfg.tri+v.pp*cfg.pp;
      totalGeneral+=total;
      return'<tr><td style="font-weight:700">'+v.nombre+'</td><td style="color:var(--tx3)">'+v.equipo+'</td>'
        +'<td style="text-align:center">'+v.ext+'</td>'
        +'<td style="text-align:center">'+v.tri+'</td>'
        +'<td style="text-align:center">'+v.pp+'</td>'
        +'<td style="text-align:right;font-family:var(--M);font-weight:700">'+(v.ext+v.tri+v.pp)+'</td>'
        +'<td style="text-align:right;font-family:var(--M);font-weight:700;color:var(--ok)">$'+Math.round(total).toLocaleString('es-CO')+'</td>'
        +'</tr>';
    }).join('')
    +'<tr style="background:var(--orA)"><td colspan="5" style="font-weight:700">TOTAL GENERAL</td><td></td><td style="text-align:right;font-family:var(--M);font-weight:700;color:var(--or);font-size:14px">$'+Math.round(totalGeneral).toLocaleString('es-CO')+'</td></tr>'
    +'</tbody></table></div>';
  if(bar){
    bar.style.display='flex';
    var desc=G('cv-liq-desc');
    if(desc)desc.textContent='Período '+fd(desde)+' al '+fd(hasta)+' · Total: $'+Math.round(totalGeneral).toLocaleString('es-CO');
    bar._total=totalGeneral;bar._viajes=viajes;
  }
}
