// v172.14: Recalcula subtotales por fila y totales globales en vivo
function onCotCantChange(){
  // Actualizar subtotales por fila
  var i=0;
  while(G('cot-fila-'+i)){
    var cant=G('cf-cant-'+i);
    var prec=G('cf-precio-'+i);
    var subt=G('cf-subt-'+i);
    if(cant&&prec&&subt){
      var c=parseFloat(cant.value)||0;
      var p=parseFloat(prec.value)||0;
      subt.value=c&&p?(c*p).toLocaleString('es-CO'):'';
    }
    i++;
  }
  _cotRecalcTotales();
}
// v172.14: Recalcula y muestra los totales (Subtotal + IVA = Total) en el bloque inferior
function _cotRecalcTotales(){
  var det=G('cot-totales-detalle');
  if(!det)return;
  var cantActivo=G('cot-cant-activo')&&G('cot-cant-activo').checked;
  if(!cantActivo){det.innerHTML='';return;}
  var ivaMode=G('cot-iva')?G('cot-iva').value:'con_iva';
  var rate=(S.preciosRefIva||19)/100;
  // Sumar subtotales (cantidad × precio) de todas las filas con material
  var subtotal=0;
  var i=0;
  while(G('cot-fila-'+i)){
    var cant=parseFloat(G('cf-cant-'+i)?G('cf-cant-'+i).value:0)||0;
    var prec=parseFloat(G('cf-precio-'+i)?G('cf-precio-'+i).value:0)||0;
    subtotal+=cant*prec;
    i++;
  }
  var fmt=function(n){return'$ '+Math.round(n).toLocaleString('es-CO');};
  if(ivaMode==='con_iva'){
    // Modo CON IVA: el precio unitario en tabla es SIN IVA; al final se suma IVA
    var ivaVal=subtotal*rate;
    var total=subtotal+ivaVal;
    det.innerHTML=
      '<div style="display:flex;justify-content:space-between;padding:4px 0;color:var(--tx2)">'
      +'<span>Subtotal sin IVA</span><span style="font-weight:600">'+fmt(subtotal)+'</span></div>'
      +'<div style="display:flex;justify-content:space-between;padding:4px 0;color:var(--tx2)">'
      +'<span>IVA ('+(S.preciosRefIva||19)+'%)</span><span style="font-weight:600">'+fmt(ivaVal)+'</span></div>'
      +'<div style="display:flex;justify-content:space-between;padding:7px 0 2px 0;border-top:1px solid var(--bd2);margin-top:4px;align-items:center">'
      +'<span style="font-weight:700;color:var(--ok);font-size:13px">TOTAL CON IVA</span>'
      +'<span style="font-weight:700;color:var(--ok);font-size:15px">'+fmt(total)+'</span></div>';
  } else {
    // Modo SIN IVA: solo total
    det.innerHTML=
      '<div style="display:flex;justify-content:space-between;padding:4px 0;color:var(--tx2)">'
      +'<span>Subtotal</span><span style="font-weight:600">'+fmt(subtotal)+'</span></div>'
      +'<div style="display:flex;justify-content:space-between;padding:7px 0 2px 0;border-top:1px solid var(--bd2);margin-top:4px;align-items:center">'
      +'<span style="font-weight:700;color:var(--ok);font-size:13px">TOTAL</span>'
      +'<span style="font-weight:700;color:var(--ok);font-size:15px">'+fmt(subtotal)+'</span></div>';
  }
}
function addCotFila(){
  var filas=_getCotFilas();
  filas.push({material:'',precio:''});
  _buildCotFilas(filas);
}
function removeCotFila(i){
  var filas=_getCotFilas();
  if(filas.length<=1)return;
  filas.splice(i,1);
  _buildCotFilas(filas);
}
function _getCotFilas(){
  var filas=[];var i=0;
  while(G('cot-fila-'+i)){
    var sel=G('cf-mat-'+i);var cust=G('cf-matcustom-'+i);var prec=G('cf-precio-'+i);
    var cant=G('cf-cant-'+i);
    var mat=sel&&sel.value?sel.value:(cust?cust.value.trim():'');
    filas.push({
      material:mat,
      precio:prec?parseFloat(prec.value)||0:0,
      cantidad:cant?parseFloat(cant.value)||0:0
    });
    i++;
  }
  return filas;
}
function saveCotizacion(){
  var cliente=G('cot-cliente').value.trim();
  if(!cliente){showAlert('cot-alert','er','El nombre del cliente es obligatorio.');return;}
  var filas=_getCotFilas().filter(function(f){return f.material;});
  if(!filas.length){showAlert('cot-alert','er','Agrega al menos un material.');return;}
  var transp=G('cot-transp-activo').checked;
  // FIX: Buscar registro original si es edición
  var original=_cotEditId?S.cotizaciones.find(function(x){return x.id===_cotEditId;}):null;
  var c={
    id:_cotEditId||uid(),
    cliente:cliente,
    fecha:G('cot-fecha').value||today(),
    iva:G('cot-iva').value,
    cantidades:G('cot-cant-activo')?G('cot-cant-activo').checked:false,
    filas:filas,
    transporte:transp,
    transp_sitio:transp?G('cot-transp-sitio').value.trim():'',
    transp_m3:transp?parseFloat(G('cot-transp-m3').value)||7:0,
    transp_precio:transp?parseFloat(G('cot-transp-precio').value)||0:0,
    estado:'pendiente',
    estrellas:0,
    // FIX: Preservar creado_en si es edición
    creado_en:original?original.creado_en:today()
  };
  if(_cotEditId){
    var idx=S.cotizaciones.findIndex(function(x){return x.id===_cotEditId;});
    if(idx>-1){c.estado=S.cotizaciones[idx].estado;c.estrellas=S.cotizaciones[idx].estrellas;S.cotizaciones[idx]=c;}
  } else {
    S.cotizaciones.push(c);
  }
  saveCotizacionesDB();
  cmo('ov-cotizacion');
  _renderCotKPIs();_renderCotTabla();
}
