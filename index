function renderFungEqPiezas(){
  var el=G('fung-eq-piezas-lista');if(!el)return;
  if(!S.fungPiezasEq||!S.fungPiezasEq.length){el.innerHTML='<div style="color:var(--tx3);font-size:12px;padding:16px;text-align:center;font-style:italic">Sin piezas registradas. Agregue la primera pieza con el botón ＋.</div>';return;}
  el.innerHTML=S.fungPiezasEq.map(function(p){
    var eqNom=p.eqId?(S.mantEquipos.find(function(e){return e.id===p.eqId;})||{nombre:'Todos'}).nombre:'Todos los equipos';
    var cambios=S.fungCambiosEq.filter(function(c){return c.piezaId===p.id;});
    cambios.sort(function(a,b){return b.fecha.localeCompare(a.fecha);});
    var lastC=cambios[0];
    var alerta='';
    if(p.intervalo&&lastC&&lastC.horom!=null&&(p.unidad==='horas'||p.unidad==='ambos')){
      var bits=S.mantBitacoras.filter(function(b){return(!p.eqId||b.equipoId===p.eqId)&&b.fecha>=lastC.fecha;});
      var horasAcum=bits.reduce(function(s,b){return s+(b.horas||0);},0);
      var pct=p.intervalo>0?Math.round(horasAcum/p.intervalo*100):0;
      if(pct>=80)alerta='<span class="bdg '+(pct>=100?'bdg-er':'bdg-wa')+'" style="margin-left:6px">'+(pct>=100?'⚠️ VENCIDO':'🔔 '+pct+'%')+'</span>';
    }
    return'<div style="display:flex;align-items:center;justify-content:space-between;padding:10px 13px;background:var(--bg3);border:1px solid var(--bd2);border-radius:7px;margin-bottom:6px">'
      +'<div>'
      +'<span style="font-size:14px;font-weight:700;color:var(--tx1)">'+p.nombre+'</span>'+alerta
      +'<div style="font-family:var(--M);font-size:8px;color:var(--tx3);margin-top:3px">'+eqNom+' · '+p.unidad+(p.intervalo?' · Intervalo: '+p.intervalo+' '+p.unidad:' · Sin intervalo definido')+'</div>'
      +'<div style="font-family:var(--M);font-size:8px;color:var(--tx3);margin-top:2px">Cambios registrados: '+cambios.length+(lastC?' · Último: '+lastC.fecha:'')+'</div>'
      +'</div>'
      +'<div style="display:flex;gap:6px">'
      +'<button class="btn btn-gh btn-xs" onclick="openEditFungEqPieza(\''+p.id+'\')">✏️</button>'
      +'<button class="btn btn-er btn-xs" onclick="delFungEqPieza(\''+p.id+'\')">🗑️</button>'
      +'</div></div>';
  }).join('');
}

