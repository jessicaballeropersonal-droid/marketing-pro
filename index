}
function saveAlertaUmbral(id){
  if(!S.alertasCfg)S.alertasCfg={};
  var def=_ALERTAS_DEF.find(function(a){return a.id===id;})||{};
  if(!S.alertasCfg[id])S.alertasCfg[id]={activa:def.defActiva,umbral:def.defUmbral,destinatarios:[]};
  var el=G('alt-umb-'+id);
  if(el)S.alertasCfg[id].umbral=parseFloat(el.value)||0;
  dbSaveAlertasCfg();
}
function toggleAlertaDest(alertaId,userId){
  if(!S.alertasCfg)S.alertasCfg={};
  var def=_ALERTAS_DEF.find(function(a){return a.id===alertaId;})||{};
  if(!S.alertasCfg[alertaId])S.alertasCfg[alertaId]={activa:def.defActiva,umbral:def.defUmbral,destinatarios:[]};
  var dests=S.alertasCfg[alertaId].destinatarios||[];
  var idx=dests.indexOf(userId);
  if(idx>-1)dests.splice(idx,1);else dests.push(userId);
  S.alertasCfg[alertaId].destinatarios=dests;
  dbSaveAlertasCfg();
}
function testWAAlert(){
  var cfg=S.alertasCfg&&S.alertasCfg._api;
  if(!cfg||!cfg.token||!cfg.instancia){
    modalAviso({tipo:'danger',titulo:'WhatsApp sin configurar',subtitulo:'Falta configuración',contenidoHtml:'<div style="font-size:12px;color:var(--tx2);line-height:1.6">Configure el <strong>Token</strong> y el <strong>Instance ID</strong> de UltraMsg primero.</div>',botonSecundario:'Entendido'});
    return;
  }
  var numero=SESION&&(S.usuarios||[]).find(function(u){return u.id===SESION.id;});
  var tel=numero&&numero.whatsapp;
  if(!tel){
    modalAviso({tipo:'danger',titulo:'Sin número WhatsApp',subtitulo:'Configuración pendiente',contenidoHtml:'<div style="font-size:12px;color:var(--tx2);line-height:1.6">Agrega tu número de WhatsApp en el perfil de usuario primero.</div>',botonSecundario:'Entendido'});
    return;
  }
  _enviarAlertaWA(tel,'🧪 Prueba de alerta OPERAX\nSi recibes este mensaje, las alertas están configuradas correctamente.\n\n'+new Date().toLocaleString('es-CO'));
}
function _enviarAlertaWA(telefono,mensaje){
  var cfg=S.alertasCfg&&S.alertasCfg._api;
  if(!cfg||!cfg.activa||!cfg.token||!cfg.instancia)return;
  var tel=telefono.replace(/\D/g,'');
  if(!tel.startsWith('57'))tel='57'+tel;
  fetch('https://api.ultramsg.com/'+cfg.instancia+'/messages/chat',{
    method:'POST',
    headers:{'Content-Type':'application/x-www-form-urlencoded'},
    body:'token='+encodeURIComponent(cfg.token)+'&to='+encodeURIComponent(tel)+'&body='+encodeURIComponent(mensaje)
  }).then(function(r){return r.json();}).then(function(d){
    if(d.sent)console.log('WhatsApp enviado a '+tel);
  }).catch(function(e){console.log('WA error:',e);});
}
function dispararAlerta(alertaId,mensaje){
  if(!S.alertasCfg)return;
  var cfg=S.alertasCfg[alertaId];
  if(!cfg||!cfg.activa)return;
  var dests=cfg.destinatarios||[];
  dests.forEach(function(uid2){
    var u=(S.usuarios||[]).find(function(x){return x.id===uid2;});
    if(u&&u.whatsapp)_enviarAlertaWA(u.whatsapp,mensaje);
  });
}

