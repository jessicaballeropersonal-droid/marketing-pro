// Calcula viajes molidos del turno: tolva + pg-tolva + transformacion
function _calcViajesMolidos(prodRec){
  if(!prodRec||!prodRec.fecha)return 0;
  var fecha=prodRec.fecha;var turno=prodRec.turno||'dia';
  // Sumar viajes de tolva + patio (pg-tolva) del mismo día/turno desde fuentes del prod_record
  var vjProd=0;
  S.prod.records.forEach(function(r){
    if(r.fecha!==fecha||r.turno!==turno)return;
    if(r.esTransformacion||(r.fuenteId&&!isSysId(r.fuenteId)&&r.origenBit))return;
    if(r.pendienteClasif)return;
    (r.fuentes||[]).forEach(function(f){if(f.alm==='tolva'||f.alm==='patio')vjProd+=(f.vj||0);});
  });
  // Sumar viajes de transformacion del mismo día/turno
  var vjTransf=0;
  S.mantBitacoras.forEach(function(b){
    if(b.fecha===fecha&&(b.turno||'dia')===turno)vjTransf+=(b.transVj||0);
  });
  if(vjProd>0||vjTransf>0)return vjProd+vjTransf;
  // Fallback: bitácora del día
  return (S.mantBitacoras||[]).filter(function(b){
    return b.fecha===fecha&&(b.viajes||0)>0;
  }).reduce(function(a,b){return a+(b.viajes||0);},0)||0;
}

