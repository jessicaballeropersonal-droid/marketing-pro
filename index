function saveInspFila(){
  var tipo=G('insp-fila-tipo').value;
  var filaId=G('insp-fila-idx').value;
  var equipo=G('insp-fila-equipo').value.trim();
  var punto=G('insp-fila-punto').value.trim();
  var desc=G('insp-fila-desc').value.trim();
  var al=G('insp-fila-alert');
  if(!equipo||!punto){al.className='alert alert-er on';al.textContent='Equipo y punto son obligatorios.';return;}
  if(!S.inspeccionPlantillas[tipo])S.inspeccionPlantillas[tipo]=[];
  if(filaId){
    var idx=S.inspeccionPlantillas[tipo].findIndex(function(f){return f.id===filaId;});
    if(idx>-1)S.inspeccionPlantillas[tipo][idx]={id:filaId,equipo,punto,desc};
  } else {
    S.inspeccionPlantillas[tipo].push({id:uid(),equipo,punto,desc});
  }
  dbSaveInsp();cmo('ov-insp-fila');_renderInspTab(tipo);
}
function delInspFila(tipo,filaId){
  var fila=(S.inspeccionPlantillas[tipo]||[]).find(function(f){return f.id===filaId;});
  if(!fila){return;}
  // Verificar uso en historial de inspecciones
  var usos=0;
  (S.inspeccionHistorial||[]).forEach(function(h){
    if(h.tipo===tipo&&h.resultados){
      h.resultados.forEach(function(r){if(r.filaId===filaId)usos++;});
    }
  });
  // NIVEL 1: BLOQUEAR si tiene historial
  if(usos>0){
    var contenido='<div style="background:var(--bg2);border-radius:8px;padding:12px;margin-bottom:11px;border-left:3px solid var(--er)">';
    contenido+='<div style="font-family:var(--M);font-size:10px;color:var(--tx2);margin-bottom:6px">PUNTO DE INSPECCIÓN:</div>';
    contenido+='<div style="font-size:13px;color:var(--tx1);font-weight:700">📋 '+(fila.equipo||'')+' · '+(fila.punto||filaId)+'</div>';
    contenido+='</div>';
    contenido+='<div style="background:var(--erA);border-radius:7px;padding:11px;margin-bottom:11px">';
    contenido+='<div style="font-family:var(--M);font-size:9px;color:var(--er);margin-bottom:6px;font-weight:700">⚠️ TIENE HISTORIAL DE INSPECCIONES:</div>';
    contenido+='<div style="font-family:var(--M);font-size:10px;color:var(--tx1)">• '+usos+' inspección(es) registrada(s)</div>';
    contenido+='</div>';
    modalAviso({tipo:'danger',titulo:'No se puede eliminar el punto',subtitulo:'Tiene historial',contenidoHtml:contenido,botonSecundario:'Entendido'});
    return;
  }
  // NIVEL 3: confirmación simple
  modalAviso({tipo:'warn',titulo:'Eliminar Punto de Inspección',
    contenidoHtml:'<div style="font-size:13px;color:var(--tx1);font-weight:700;margin-bottom:8px">📋 '+(fila.equipo||'')+' · '+(fila.punto||filaId)+'</div><div style="background:var(--okA);border-radius:7px;padding:10px;font-family:var(--M);font-size:10px;color:var(--ok)">✓ Sin historial, se puede eliminar.</div>',
    botonPrincipal:'🗑️ Eliminar',onPrincipal:function(){
      S.inspeccionPlantillas[tipo]=(S.inspeccionPlantillas[tipo]||[]).filter(function(f){return f.id!==filaId;});
      dbSaveInsp();
      try{_renderInspTab(tipo);}catch(e){}
      modalAvisoClose();
    }});
}

// ── Historial ────────────────────────────────────────────────────────────────
function _renderInspHistorial(c){
  var hist=(S.inspeccionHistorial||[]).slice().sort(function(a,b){return b.timestamp-a.timestamp;});
  var tipoOpts='<option value="">Todos</option>'+_INSP_TIPOS.map(function(t){return'<option value="'+t+'">'+t.charAt(0).toUpperCase()+t.slice(1)+'</option>';}).join('');
  var html='<div class="fbar" style="margin-bottom:12px">'
    +'<div class="ff"><div class="fl">Tipo</div><select class="fs fi-xs" id="ihf-tipo" onchange="_inspFiltrarHist()">'+tipoOpts+'</select></div>'
    +'<div class="ff"><div class="fl">Técnico</div><select class="fs fi-xs" id="ihf-tec" onchange="_inspFiltrarHist()"><option value="">Todos</option></select></div>'
    +'<div class="ff"><div class="fl">Desde</div><input type="date" class="fi fi-xs" id="ihf-desde" onchange="_inspFiltrarHist()"></div>'
    +'<div class="ff"><div class="fl">Hasta</div><input type="date" class="fi fi-xs" id="ihf-hasta" onchange="_inspFiltrarHist()"></div>'
    +'<div class="ff"><div class="fl">Estado</div><select class="fs fi-xs" id="ihf-sem" onchange="_inspFiltrarHist()"><option value="">Todos</option><option value="ok">🟢 Verde</option><option value="wa">🟡 Amarillo</option><option value="er">🔴 Rojo</option></select></div>'
    +'<button class="btn btn-gh btn-sm" onclick="_inspLimpiarHist()">✕ Limpiar</button>'
    +'</div><div id="insp-hist-tabla"></div>';
  c.innerHTML=html;
  // Fill tecnicos
  var tecs=[...new Set((S.inspeccionHistorial||[]).map(function(r){return r.tecnico;}))];
  var tecSel=G('ihf-tec');
  tecs.forEach(function(t){if(t)tecSel.innerHTML+='<option value="'+t+'">'+t+'</option>';});
  _inspRenderHistTbl(hist);
}
function _inspFiltrarHist(){
  var tipo=G('ihf-tipo')?G('ihf-tipo').value:'';
  var tec=G('ihf-tec')?G('ihf-tec').value:'';
  var desde=G('ihf-desde')?G('ihf-desde').value:'';
  var hasta=G('ihf-hasta')?G('ihf-hasta').value:'';
  var sem=G('ihf-sem')?G('ihf-sem').value:'';
  var hist=(S.inspeccionHistorial||[]).filter(function(r){
    if(tipo&&r.tipo!==tipo)return false;
    if(tec&&r.tecnico!==tec)return false;
    if(desde&&r.fecha<desde)return false;
    if(hasta&&r.fecha>hasta)return false;
    if(sem&&!(r.puntos||[]).some(function(p){return p.sem===sem;}))return false;
    return true;
  }).sort(function(a,b){return b.timestamp-a.timestamp;});
  _inspRenderHistTbl(hist);
}
function _inspLimpiarHist(){
  ['ihf-tipo','ihf-tec','ihf-desde','ihf-hasta','ihf-sem'].forEach(function(id){var el=G(id);if(el)el.value='';});
  _inspRenderHistTbl((S.inspeccionHistorial||[]).slice().sort(function(a,b){return b.timestamp-a.timestamp;}));
}
function _inspRenderHistTbl(hist){
  var c=G('insp-hist-tabla');if(!c)return;
  if(!hist.length){c.innerHTML='<div style="text-align:center;padding:32px;color:var(--tx3)">Sin registros para los filtros seleccionados.</div>';return;}
  var tipoLbl={diario:'📋 Diario',semanal:'📅 Semanal',quincenal:'📆 Quincenal',mensual:'🗓 Mensual',trimestral:'📊 Trimestral'};
  c.innerHTML=hist.map(function(r){
    var verdes=(r.puntos||[]).filter(function(p){return p.sem==='ok';}).length;
    var amarillos=(r.puntos||[]).filter(function(p){return p.sem==='wa';}).length;
    var rojos=(r.puntos||[]).filter(function(p){return p.sem==='er';}).length;
    var total=(r.puntos||[]).length;
    var brdCol=rojos>0?'var(--er)':amarillos>0?'var(--wa)':'var(--ok)';
    return'<div style="border:1px solid var(--bd2);border-left:4px solid '+brdCol+';border-radius:8px;padding:11px 14px;margin-bottom:8px;background:var(--bg1);cursor:pointer" onclick="openInspDetalle(\''+r.id+'\')">'
      +'<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:6px">'
      +'<div style="display:flex;align-items:center;gap:8px">'
      +'<span style="font-size:13px">'+(tipoLbl[r.tipo]||r.tipo)+'</span>'
      +'<span style="font-family:var(--M);font-size:8px;color:var(--tx3)">'+fd(r.fecha)+' · '+r.hora+'</span>'
      +'</div>'
      +'<div style="display:flex;gap:5px">'
      +(rojos>0?'<span class="bdg bdg-er">🔴 '+rojos+'</span>':'')
      +(amarillos>0?'<span class="bdg bdg-wa">🟡 '+amarillos+'</span>':'')
      +(verdes>0?'<span class="bdg bdg-ok">🟢 '+verdes+'</span>':'')
      +'</div></div>'
      +'<div style="font-size:12px;color:var(--tx2)">'+total+' puntos · Técnico: '+r.tecnico+'</div>'
      +'</div>';
  }).join('');
}
