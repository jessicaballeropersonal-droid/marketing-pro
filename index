  {id:'todo',nombre:'Por hacer',color:'tx2'},
  {id:'revision',nombre:'En revisión',color:'in'},
  {id:'aprobado',nombre:'Aprobado',color:'ok'},
  {id:'archivo',nombre:'Archivo',color:'tx3'}
];
function _getEstados(tipo){
  var arr=tipo==='oficina'?S.tareasOficinaEstados:tipo==='mant'?S.tareasMantenimientoEstados:S.tareasEstados;
  return(arr&&arr.length)?arr:_DEFAULT_ESTADOS.map(function(e){return Object.assign({},e,{id:uid()});});
}
function _saveEstados(tipo,arr){
  if(tipo==='oficina'){S.tareasOficinaEstados=arr;supaUpsert('config',{key:'tareasOficinaEstados',value:JSON.stringify(arr)});}
  else if(tipo==='mant'){S.tareasMantenimientoEstados=arr;supaUpsert('config',{key:'tareasMantenimientoEstados',value:JSON.stringify(arr)});}
  else{S.tareasEstados=arr;supaUpsert('config',{key:'tareasEstados',value:JSON.stringify(arr)});}
}
function _renderGestEstadosLista(){
  var c=G('gest-estados-lista');if(!c)return;
  var tipo=G('gest-estados-tipo').value;
  var estados=_getEstados(tipo);
  if(!estados.length){c.innerHTML='<div style="font-size:12px;color:var(--tx3);text-align:center;padding:12px">Sin estados. Agrega el primero.</div>';return;}
  c.innerHTML=estados.map(function(e,i){
    return'<div style="display:flex;align-items:center;gap:8px;padding:8px 11px;background:var(--bg2);border:1px solid var(--bd2);border-radius:7px">'
      +'<span style="width:10px;height:10px;border-radius:50%;background:var(--'+e.color+');display:inline-block;flex-shrink:0"></span>'
      +'<span style="font-size:13px;font-weight:700;flex:1">'+e.nombre+'</span>'
      +'<div style="display:flex;gap:4px">'
      +(i>0?'<button class="btn btn-gh btn-xs" onclick="moverEstado(\''+e.id+'\','+tipo+',-1)">↑</button>':'')
      +(i<estados.length-1?'<button class="btn btn-gh btn-xs" onclick="moverEstado(\''+e.id+'\',\''+tipo+'\',1)">↓</button>':'')
      +'<button class="btn btn-er btn-xs" onclick="delEstado(\''+e.id+'\',\''+tipo+'\')">✕</button>'
      +'</div></div>';
  }).join('');
}
function addEstadoTarea(){
  var nombre=G('gest-estado-nuevo').value.trim();
  var color=G('gest-estado-color').value;
  if(!nombre){showAlert('gest-estados-alert','er','Escribe el nombre del estado.');return;}
  var tipo=G('gest-estados-tipo').value;
  var estados=_getEstados(tipo);
  estados.push({id:uid(),nombre:nombre,color:color});
  _saveEstados(tipo,estados);
  G('gest-estado-nuevo').value='';
  _renderGestEstadosLista();
  if(tipo==='oficina')_renderKanban('oficina');else if(tipo==='mant')_renderKanban('mant');else _renderKanban('gerencial');
}
function delEstado(id,tipo){
  var estados=_getEstados(tipo);
  var estado=estados.find(function(e){return e.id===id;});
  if(!estado){return;}
  // Contar tareas que usan este estado
  var lista=tipo==='oficina'?S.tareasOficina:(tipo==='mant'?S.tareasMantenimiento:S.tareas);
  var tareasUsan=(lista||[]).filter(function(t){return t.estado===id;}).length;
  // NIVEL 1: BLOQUEAR si tiene tareas usándolo
  if(tareasUsan>0){
    var contenido='<div style="background:var(--bg2);border-radius:8px;padding:12px;margin-bottom:11px;border-left:3px solid var(--er)">';
    contenido+='<div style="font-family:var(--M);font-size:10px;color:var(--tx2);margin-bottom:6px">ESTADO KANBAN:</div>';
    contenido+='<div style="font-size:13px;color:var(--tx1);font-weight:700">'+(estado.nombre||id)+'</div>';
    contenido+='</div>';
    contenido+='<div style="background:var(--erA);border-radius:7px;padding:11px;margin-bottom:11px">';
    contenido+='<div style="font-family:var(--M);font-size:9px;color:var(--er);margin-bottom:6px;font-weight:700">⚠️ ESTE ESTADO TIENE TAREAS:</div>';
    contenido+='<div style="font-family:var(--M);font-size:10px;color:var(--tx1)">• '+tareasUsan+' tarea(s) están en este estado</div>';
    contenido+='</div>';
    contenido+='<div style="background:var(--inA);border-radius:7px;padding:10px">';
    contenido+='<div style="font-family:var(--M);font-size:10px;color:var(--in);line-height:1.6">Mueva esas tareas a otro estado antes de eliminar.</div>';
    contenido+='</div>';
    modalAviso({tipo:'danger',titulo:'No se puede eliminar el estado',subtitulo:'Tiene tareas asignadas',contenidoHtml:contenido,botonSecundario:'Entendido'});
    return;
  }
  // NIVEL 3: confirmación simple
  var contenido='<div style="background:var(--bg2);border-radius:8px;padding:11px;margin-bottom:11px">';
  contenido+='<div style="font-size:13px;color:var(--tx1);font-weight:700">'+(estado.nombre||id)+'</div>';
  contenido+='</div>';
  contenido+='<div style="background:var(--okA);border-radius:7px;padding:10px;margin-bottom:11px">';
  contenido+='<div style="font-family:var(--M);font-size:10px;color:var(--ok);line-height:1.6">✓ Sin tareas asignadas, se puede eliminar.</div>';
  contenido+='</div>';
  modalAviso({tipo:'warn',titulo:'Eliminar Estado Kanban',contenidoHtml:contenido,
    botonPrincipal:'🗑️ Eliminar',onPrincipal:function(){
      var nuevos=_getEstados(tipo).filter(function(e){return e.id!==id;});
      _saveEstados(tipo,nuevos);
      try{_renderGestEstadosLista();}catch(e){}
      modalAvisoClose();
    }});
}
function moverEstado(id,tipo,dir){
  var estados=_getEstados(tipo);
  var idx=estados.findIndex(function(e){return e.id===id;});
  if(idx<0)return;
  var newIdx=idx+dir;
  if(newIdx<0||newIdx>=estados.length)return;
  var tmp=estados[idx];estados[idx]=estados[newIdx];estados[newIdx]=tmp;
  _saveEstados(tipo,estados);
  _renderGestEstadosLista();
}

// ══ TAREAS — ACTUALIZAR PARA ESTADOS PERSONALIZADOS ════════════════════
var _tareaFilterOf='all';
var _tareaFilterMant='all';
function _getListaTareas(tipo){return tipo==='oficina'?S.tareasOficina:tipo==='mant'?S.tareasMantenimiento:S.tareas;}
function _getFilteredTareas(tipo){
  var f=tipo==='oficina'?_tareaFilterOf:tipo==='mant'?_tareaFilterMant:_tareaFilter;
  return _getListaTareas(tipo).filter(function(t){
    if(f==='all')return true;
    if(f==='administrativa')return t.tipo==='administrativa';
    if(f==='operativa')return t.tipo==='operativa';
    if(f==='alta')return t.prioridad==='alta';
    if(f==='mine')return SESION&&(t.responsables||[]).indexOf(SESION.id)>-1;
    return true;
  });
}
function _renderKanban(tipo){
  tipo=tipo||'gerencial';
  var boardId=tipo==='oficina'?'kanban-board-oficina':tipo==='mant'?'kanban-board-mant':'kanban-board';
  var board=G(boardId);if(!board)return;
  var estados=_getEstados(tipo);
  var cols={};estados.forEach(function(e){cols[e.id]=[];});
  _getFilteredTareas(tipo).forEach(function(t){
    // Buscar estado por ID o por nombre legacy
    var estadoId=t.estado;
    var found=estados.find(function(e){return e.id===estadoId;});
    if(!found){
      // fallback: buscar por nombre
      found=estados.find(function(e){return e.nombre.toLowerCase()===String(estadoId).toLowerCase();});
      if(!found&&estados.length)found=estados[0];
    }
    if(found&&cols[found.id])cols[found.id].push(t);
    else if(estados.length&&cols[estados[0].id])cols[estados[0].id].push(t);
  });
  board.style.gridTemplateColumns='repeat('+Math.max(estados.length,1)+',1fr)';
  board.innerHTML=estados.map(function(est){
    var tasks=cols[est.id]||[];
    var cards=tasks.map(function(t){return _taskCardHTML(t,tipo);}).join('');
    return'<div class="kb-col">'
      +'<div class="kb-col-hd" style="color:var(--'+est.color+')">'+est.nombre.toUpperCase()
      +'<span class="kb-count" style="background:var(--'+est.color+'A,rgba(0,0,0,.08));color:var(--'+est.color+')">'+tasks.length+'</span></div>'
      +'<div class="kb-body">'+cards+'</div>'
      +'</div>';
  }).join('');
}
function _taskCardHTML(t,tipo){
  var today2=today();
  var isLate=t.fecha_vencimiento&&t.fecha_vencimiento<today2;
  var tipoCls=t.tipo==='administrativa'?'tipo-adm':'tipo-op';
  var prioOver=t.prioridad==='alta'?'prio-alta':'';
  var tipoTag=t.tipo==='administrativa'?'<span class="tc-tag adm">ADM</span>':'<span class="tc-tag op">OP</span>';
  var prioTag=t.prioridad==='alta'?'<span class="tc-tag alta">ALTA</span>':t.prioridad==='media'?'<span class="tc-tag media">MEDIA</span>':'<span class="tc-tag baja">BAJA</span>';
  var avHtml='';
  (t.responsables||[]).slice(0,4).forEach(function(uid2,i){
    var u=S.usuarios.find(function(x){return x.id===uid2;});
    avHtml+='<div class="tc-av" style="'+_avStyle(i)+'">'+_initials(u?u.nombre:'?')+'</div>';
  });
  var dateHtml=t.fecha_vencimiento?'<div class="tc-date'+(isLate?' late':'')+'">'+( isLate?'⚠️':'📅')+' '+fd(t.fecha_vencimiento)+'</div>':'';
  var tipoParam=tipo||'gerencial';
  return'<div class="tarea-card '+tipoCls+' '+prioOver+'" onclick="openTareaDetalle(\''+t.id+'\',\''+tipoParam+'\')">'
    +'<div class="tc-title">'+t.titulo+'</div>'
    +'<div class="tc-tags">'+tipoTag+prioTag+'</div>'
    +(avHtml?'<div class="tc-avatars">'+avHtml+'</div>':'')
    +dateHtml+'</div>';
}
var _tareaTipo='gerencial';
function saveTarea(){
  var titulo=G('tarea-titulo').value.trim();
  if(!titulo){showAlert('tarea-alert','er','El título es obligatorio.');return;}
  var resp=_getSelectedResponsables();
  var tipo=_tareaTipo||'gerencial';
  // FIX: Buscar registro original si es edición
  var lista=tipo==='oficina'?S.tareasOficina:(tipo==='mant'?S.tareasMantenimiento:S.tareas);
  var original=_tareaEditId?lista.find(function(x){return x.id===_tareaEditId;}):null;
  var t={
    id:_tareaEditId||uid(),titulo:titulo,descripcion:G('tarea-desc').value.trim(),
    tipo:G('tarea-tipo').value,prioridad:G('tarea-prio').value,
    fecha_vencimiento:G('tarea-fecha').value,estado:G('tarea-estado').value,
    responsables:resp,gestionadas:[],
    // FIX: Preservar creado_por y creado_en si es edición
    creado_por:original?original.creado_por:(SESION?SESION.id:''),
    creado_en:original?original.creado_en:today(),
    comentarios:[]
  };
  var com=G('tarea-comentario').value.trim();
  if(com)t.comentarios.push({id:uid(),texto:com,autor:SESION?SESION.nombre:'',fecha:today()});
  if(_tareaEditId){
    var idx=lista.findIndex(function(x){return x.id===_tareaEditId;});
    if(idx>-1){t.gestionadas=lista[idx].gestionadas||[];t.comentarios=lista[idx].comentarios||[];if(com)t.comentarios.push({id:uid(),texto:com,autor:SESION?SESION.nombre:'',fecha:today()});lista[idx]=t;}
  } else {lista.push(t);}
  if(tipo==='oficina'){S.tareasOficina=lista;supaUpsert('config',{key:'tareasOficina',value:JSON.stringify(lista)});}
  else if(tipo==='mant'){S.tareasMantenimiento=lista;supaUpsert('config',{key:'tareasMantenimiento',value:JSON.stringify(lista)});}
  else{S.tareas=lista;saveTareasDB();}
  cmo('ov-tarea');_renderKanban(tipo);_updateTareasBadge();
}
function openTareaDetalle(id,tipo){
  tipo=tipo||'gerencial';
  var lista=tipo==='oficina'?S.tareasOficina:S.tareas;
  var t=lista.find(function(x){return x.id===id;});if(!t)return;
  var estados=_getEstados(tipo);
  var estadoObj=estados.find(function(e){return e.id===t.estado;})||{nombre:t.estado,color:'tx2'};
  G('tdet-ttl').textContent='✅ '+t.titulo;
  var isAdmin=puedeEditar('tareas');
  var html='<div style="display:flex;gap:6px;flex-wrap:wrap;margin-bottom:13px">'
    +'<span class="bdg" style="background:var(--'+estadoObj.color+'A,var(--bg3));color:var(--'+estadoObj.color+');border:1px solid var(--'+estadoObj.color+'B,var(--bd2))">'+estadoObj.nombre+'</span>'
    +'<span class="bdg '+(t.tipo==='administrativa'?'bdg-pu':'bdg-in')+'">'+t.tipo.toUpperCase()+'</span>'
    +'<span class="bdg '+(t.prioridad==='alta'?'bdg-er':t.prioridad==='media'?'bdg-wa':'bdg-ok')+'">'+t.prioridad.toUpperCase()+'</span>'
    +(t.fecha_vencimiento?'<span class="bdg bdg-gy">📅 '+fd(t.fecha_vencimiento)+'</span>':'')
    +'</div>';
  if(t.descripcion)html+='<div style="background:var(--bg3);border:1px solid var(--bd2);border-radius:7px;padding:11px;margin-bottom:13px;font-size:12px;color:var(--tx2);line-height:1.6">'+t.descripcion+'</div>';
  html+='<div class="vblk-hd" style="margin-bottom:7px">RESPONSABLES</div><div style="display:flex;flex-wrap:wrap;gap:6px;margin-bottom:13px">';
  (t.responsables||[]).forEach(function(uid2,i){
    var u=S.usuarios.find(function(x){return x.id===uid2;});
    html+='<div style="padding:4px 9px;border-radius:20px;background:var(--bg3);border:1px solid var(--bd2);font-size:11px">'+_initials(u?u.nombre:'?')+' '+(u?u.nombre:uid2)+'</div>';
  });
  if(!(t.responsables||[]).length)html+='<span style="font-size:11px;color:var(--tx3)">Sin responsables</span>';
  html+='</div>';
  if((t.comentarios||[]).length){
    html+='<div class="vblk-hd" style="margin-bottom:7px">COMENTARIOS</div><div style="display:flex;flex-direction:column;gap:6px;margin-bottom:13px">';
    t.comentarios.forEach(function(cm){
      html+='<div style="background:var(--bg3);border:1px solid var(--bd2);border-radius:6px;padding:8px 10px">'
        +'<div style="font-family:var(--M);font-size:8px;color:var(--or);margin-bottom:3px">'+cm.autor+' · '+fd(cm.fecha)+'</div>'
        +'<div style="font-size:12px">'+cm.texto+'</div></div>';
    });
    html+='</div>';
  }
  html+='<div class="ff"><div class="fl">Agregar comentario</div><div style="display:flex;gap:6px">'
    +'<input type="text" class="fi" id="tdet-comentario" placeholder="Escribe..." style="flex:1">'
    +'<button class="btn btn-gh btn-sm" onclick="addComentarioTarea(\''+t.id+'\',\''+tipo+'\')">Enviar</button>'
    +'</div></div>';
  G('tdet-body').innerHTML=html;
  var footHtml='';
  if(isAdmin){
    footHtml+='<button class="btn btn-gh btn-sm" onclick="editTarea(\''+t.id+'\',\''+tipo+'\')">✏️ Editar</button>';
    footHtml+='<button class="btn btn-er btn-sm" onclick="delTarea(\''+t.id+'\',\''+tipo+'\')">🗑️ Eliminar registro</button>';
  } else {
    footHtml='<button class="btn btn-gh btn-sm" onclick="cmo(\'ov-tarea-det\')">Cerrar</button>';
  }
  G('tdet-foot').innerHTML=footHtml;
  openMo('ov-tarea-det');
}
function editTarea(id,tipo){
  var lista=tipo==='oficina'?S.tareasOficina:S.tareas;
  var t=lista.find(function(x){return x.id===id;});if(!t)return;
  cmo('ov-tarea-det');
  _tareaEditId=id;_tareaTipo=tipo;
  G('tarea-mo-ttl').textContent='Editar Tarea';
  G('tarea-edit-id').value=id;G('tarea-titulo').value=t.titulo;G('tarea-desc').value=t.descripcion||'';
  G('tarea-tipo').value=t.tipo||'administrativa';G('tarea-prio').value=t.prioridad||'media';
  G('tarea-fecha').value=t.fecha_vencimiento||'';
  var estados=_getEstados(tipo);
  var sel=G('tarea-estado');
  sel.innerHTML=estados.map(function(e){return'<option value="'+e.id+'" '+(e.id===t.estado?'selected':'')+'>'+e.nombre+'</option>';}).join('');
  G('tarea-comentario').value='';G('tarea-alert').className='alert';
  _renderResponsablesCheck(t.responsables||[]);
  openMo('ov-tarea');
}
function delTarea(id,tipo){
  cc('¿Eliminar esta tarea?',function(){
    if(tipo==='oficina'){S.tareasOficina=S.tareasOficina.filter(function(t){return t.id!==id;});supaUpsert('config',{key:'tareasOficina',value:JSON.stringify(S.tareasOficina)});}
    else if(tipo==='mant'){S.tareasMantenimiento=S.tareasMantenimiento.filter(function(t){return t.id!==id;});supaUpsert('config',{key:'tareasMantenimiento',value:JSON.stringify(S.tareasMantenimiento)});}
    else{S.tareas=S.tareas.filter(function(t){return t.id!==id;});saveTareasDB();}
    cmo('ov-tarea-det');_renderKanban(tipo);_updateTareasBadge();
  });
}
function addComentarioTarea(id,tipo){
  var lista=tipo==='oficina'?S.tareasOficina:S.tareas;
  var t=lista.find(function(x){return x.id===id;});if(!t)return;
  var txt=G('tdet-comentario').value.trim();if(!txt)return;
  if(!t.comentarios)t.comentarios=[];
  t.comentarios.push({id:uid(),texto:txt,autor:SESION?SESION.nombre:'',fecha:today()});
  if(tipo==='oficina'){supaUpsert('config',{key:'tareasOficina',value:JSON.stringify(S.tareasOficina)});}
  else if(tipo==='mant'){supaUpsert('config',{key:'tareasMantenimiento',value:JSON.stringify(S.tareasMantenimiento)});}
  else{saveTareasDB();}
  openTareaDetalle(id,tipo);
}

