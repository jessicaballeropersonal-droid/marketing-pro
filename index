function pordCalcH(rid){
  var ini=gv('pord-hi-'+rid),fin=gv('pord-hf-'+rid);
  var dh=parseInt(gv('pord-dh-'+rid))||0,dm=parseInt(gv('pord-dm-'+rid))||0;
