// ══ TIEMPOS DE OPERACIÓN ══
// Cada registro de producción con horas netas (netMin > 0) aparece aquí para clasificar.
// La clasificación se guarda en r.tiemClasif = { operado, mantenimiento, muertos:[] }
// muertos: [{causaId, causaNombre, min}] — puede haber múltiples hasta agotar el tiempo.

function mToHM(min){var h=Math.floor(min/60),m=min%60;return h+'h '+m+'m';}

function applyTiemF(){
  var d=gv('tfd'),h=gv('tfh'),eq=gv('tfeq'),tu=gv('tftu');
  // Obtener registros de producción con clasificación y filtros aplicados
  var recs=S.prod.records.filter(function(r){
    if(r.sinHorario)return false; // Excluir registros sin horario activado
    if(!r.netMin||r.netMin<=0) return false;
    if(d&&r.fecha<d) return false;
    if(h&&r.fecha>h) return false;
    if(eq&&r.equipoId!==eq) return false;
    if(tu&&r.turno!==tu) return false;
    return true;
  }).sort(function(a,b){return a.fecha.localeCompare(b.fecha);});

  // Calcular totales del período
  var totOp=0,totMu=0,totMa=0,totNeto=0;
  recs.forEach(function(r){
    totNeto+=r.netMin||0;
    var c=r.tiemClasif;if(!c)return;
    totOp+=c.operado||0;
    totMa+=c.mantenimiento||0;
    (c.muertos||[]).forEach(function(m){totMu+=m.min||0;});
  });
  var totBase=totOp+totMa;
  var disp=totBase>0?Math.round(totOp/totBase*100):0;
  var sinClasif=Math.max(0,totNeto-totOp-totMu-totMa);

  // Renderizar KPIs del período
  var kpiHtml=''
    +'<div class="kpi ok"><div class="kpi-lbl">Operado</div><div class="kpi-val">'+mToHM(totOp)+'</div><div class="kpi-unit">en el período</div></div>'
    +'<div class="kpi er"><div class="kpi-lbl">Tiempo Muerto</div><div class="kpi-val">'+mToHM(totMu)+'</div><div class="kpi-unit">en el período</div></div>'
    +'<div class="kpi wa"><div class="kpi-lbl">Mantenimiento</div><div class="kpi-val">'+mToHM(totMa)+'</div><div class="kpi-unit">en el período</div></div>'
    +'<div class="kpi in"><div class="kpi-lbl">Disponibilidad</div><div class="kpi-val">'+(totBase>0?disp+'%':'—')+'</div><div class="kpi-unit">Operado / (Op+Mant)</div></div>'
    +(sinClasif>0?'<div class="kpi"><div class="kpi-lbl">Sin Clasificar</div><div class="kpi-val" style="color:var(--tx2)">'+mToHM(sinClasif)+'</div><div class="kpi-unit">pendiente</div></div>':'');
  G('tf-kpi').innerHTML=kpiHtml;

  if(!recs.length){mkLine('tch',[],[]);return;}

  // Agrupar por fecha para la gráfica (minutos por día)
  var dm={};
  recs.forEach(function(r){
    if(!dm[r.fecha])dm[r.fecha]={op:0,mu:0,ma:0};
    var c=r.tiemClasif;if(!c)return;
    dm[r.fecha].op+=(c.operado||0)/60;
    dm[r.fecha].ma+=(c.mantenimiento||0)/60;
    (c.muertos||[]).forEach(function(m){dm[r.fecha].mu+=m.min/60;});
  });
  var labels=Object.keys(dm).map(fd);
  var vals=Object.values(dm);
  mkLine('tch',labels,[
    mkDs('Operado',     vals.map(function(v){return+v.op.toFixed(2);}), '#22c55e'),
    mkDs('Tiempo Muerto',vals.map(function(v){return+v.mu.toFixed(2);}), '#ef4444'),
    mkDs('Mantenimiento',vals.map(function(v){return+v.ma.toFixed(2);}), '#f59e0b')
  ]);
}

function updTiemKPI(){
  var y=new Date().getFullYear(),f=y+'-01-01',t=y+'-12-31';
  var tot={op:0,mu:0,ma:0};
  var dia={op:0,mu:0,ma:0};
  var noc={op:0,mu:0,ma:0};
  S.prod.records.forEach(function(r){
    if(r.fecha<f||r.fecha>t)return;
    var cl=r.tiemClasif;if(!cl)return;
    var bucket=r.turno==='dia'?dia:noc;
    var op=cl.operado||0,ma=cl.mantenimiento||0,mu=0;
    (cl.muertos||[]).forEach(function(m){mu+=m.min||0;});
    tot.op+=op;tot.ma+=ma;tot.mu+=mu;
    bucket.op+=op;bucket.ma+=ma;bucket.mu+=mu;
  });
  // Global
  G('kt-op').textContent=mToHM(tot.op);
  G('kt-mu').textContent=mToHM(tot.mu);
  G('kt-ma').textContent=mToHM(tot.ma);
  var base=tot.op+tot.ma;
  G('kt-di').textContent=base>0?Math.round(tot.op/base*100)+'%':'—';
  // Por turno
  var setT=function(pref,d){
    var el=G('kt-'+pref+'-op');if(el)el.textContent=mToHM(d.op);
    var el2=G('kt-'+pref+'-mu');if(el2)el2.textContent=mToHM(d.mu);
    var el3=G('kt-'+pref+'-ma');if(el3)el3.textContent=mToHM(d.ma);
    var b=d.op+d.ma;
    var el4=G('kt-'+pref+'-di');if(el4)el4.textContent=b>0?Math.round(d.op/b*100)+'%':'—';
  };
  setT('dia',dia);
  setT('noc',noc);
}

function tiemSaldo(r){
  // Devuelve minutos no clasificados del turno
  if(!r.netMin) return 0;
  var c=r.tiemClasif;if(!c)return r.netMin;
  var used=(c.operado||0)+(c.mantenimiento||0);
  (c.muertos||[]).forEach(function(m){used+=m.min||0;});
  return Math.max(0,r.netMin-used);
}

