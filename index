// ═══ Helper: Opción A — Cascada total ═══
function _delBitacoraOpcionA(id,deps){
  var bitLog=deps.bit||{};
  var eqLog=bitLog.equipoId?(S.mantEquipos.find(function(e){return e.id===bitLog.equipoId;})||{}):{};
  var antes={fecha:bitLog.fecha,turno:bitLog.turno,equipo:eqLog.nombre||'',viajes:bitLog.viajes,extracciones:deps.exps.length,producciones:deps.prods.length,ots:deps.ots.length};
  S.mantBitacoras=S.mantBitacoras.filter(function(b){return b.id!==id;});
  _dbSaveCfg('mantBitacoras',S.mantBitacoras);
  deps.exps.forEach(function(r){
    S.exp.records=S.exp.records.filter(function(x){return x.id!==r.id;});
    dbDelExp(r.id);
  });
  deps.prods.forEach(function(r){
    S.prod.records=S.prod.records.filter(function(x){return x.id!==r.id;});
    dbDelProd(r.id);
  });
  deps.ots.forEach(function(o){
    S.mantOrdenes=S.mantOrdenes.filter(function(x){return x.id!==o.id;});
  });
  _dbSaveCfg('mantOrdenes',S.mantOrdenes);
  logActividad({accion:'eliminar',modulo:'bitacora',descripcion:'Eliminó Bitácora en cascada total · '+bitLog.fecha+' '+(bitLog.turno==='dia'?'DÍA':'NOCHE')+' ('+deps.exps.length+' ext, '+deps.prods.length+' prod, '+deps.ots.length+' OT)',registroId:id,antes:antes});
  saveS();
  updXKPI();updPKPI();updDKPI();
  try{renderMantBitHoy();}catch(e){}
  try{renderXH();}catch(e){}
  try{renderPH();}catch(e){}
  modalAviso({tipo:'success',titulo:'Eliminación completada',contenidoHtml:'<div style="font-size:12px;color:var(--tx2)">Se eliminó la bitácora y sus dependencias en cascada total.</div>',botonSecundario:'Cerrar'});
}

// ═══ Helper: Opción B — Proporcional (solo esta bitácora, recalcular el resto) ═══
function _delBitacoraOpcionB(id,bit,deps,prodCompartidas){
  // Pedir confirmación con palabra
  modalConfirmEscriba({
    titulo:'Confirmar Opción B — Proporcional',
    subtitulo:'Recalculo proporcional de clasificaciones',
    contenidoHtml:'<div style="font-size:12px;color:var(--tx2);line-height:1.6">Se eliminará solo esta bitácora y sus extracciones. Las producciones del grupo se recalcularán proporcionalmente manteniendo los %.</div>',
    palabra:'ELIMINAR',
    onConfirm:function(){
      // 1. Calcular m³ que esta bitácora aportaba
      var m3EstaBit=deps.exps.reduce(function(s,r){return s+(parseFloat(r.tm)||0);},0);
      // m³ del grupo (esta + otras del mismo día+turno) para repartir según el aporte REAL
      var _otrasGrupo=(S.mantBitacoras||[]).filter(function(b){return b.id!==id&&b.fecha===bit.fecha&&(b.turno||'dia')===(bit.turno||'dia');});
      var _m3Otras=0;
      _otrasGrupo.forEach(function(ob){bitacoraDependencias(ob.id).exps.forEach(function(r){_m3Otras+=parseFloat(r.tm)||0;});});
      var _m3Grupo=m3EstaBit+_m3Otras;
      var _propElim=_m3Grupo>0?(m3EstaBit/_m3Grupo):0;
      // 2. Eliminar esta bitácora
      S.mantBitacoras=S.mantBitacoras.filter(function(b){return b.id!==id;});
      _dbSaveCfg('mantBitacoras',S.mantBitacoras);
      // 3. Eliminar SUS extracciones (las que vinieron de ESTA bitácora)
      deps.exps.forEach(function(r){
        S.exp.records=S.exp.records.filter(function(x){return x.id!==r.id;});
        dbDelExp(r.id);
      });
      // 4. Eliminar OTs SOLO de esta bitácora
      deps.ots.forEach(function(o){
        S.mantOrdenes=S.mantOrdenes.filter(function(x){return x.id!==o.id;});
      });
      _dbSaveCfg('mantOrdenes',S.mantOrdenes);
      // 5. RECALCULAR proporcionalmente cada producción compartida
      prodCompartidas.forEach(function(r){
        // Quitar este bitId del array
        r.bitIds=(r.bitIds||[]).filter(function(b){return b!==id;});
        // Reducir fuentes proporcionalmente
        if(r.fuentes&&r.fuentes.length){
          var fuenteTotalAntes=r.fuentes.reduce(function(s,f){return s+(f.m3||0);},0);
          if(fuenteTotalAntes>0){
            // Reducir según el aporte REAL de m³ de esta bitácora vs el grupo.
            // Si no se pudo calcular, repartir uniforme como respaldo.
            var proporcionEliminar=_propElim>0?_propElim:(1/(r.bitIds.length+1));
            r.fuentes.forEach(function(f){
              f.m3=f.m3*(1-proporcionEliminar);
              if(f.vj)f.vj=Math.round(f.vj*(1-proporcionEliminar));
            });
          }
          r.fuenteM3=r.fuentes.reduce(function(s,f){return s+(f.m3||0);},0);
        }
        // Recalcular dist proporcionalmente (% se mantienen, m³ baja)
        if(r.dist&&r.dist.length){
          r.dist.forEach(function(d){
