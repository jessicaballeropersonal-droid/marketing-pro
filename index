// ══ TIEMPOS DE OPERACIÓN ══
// Cada registro de producción con horas netas (netMin > 0) aparece aquí para clasificar.
// La clasificación se guarda en r.tiemClasif = { operado, mantenimiento, muertos:[] }
// muertos: [{causaId, causaNombre, min}] — puede haber múltiples hasta agotar el tiempo.

function mToHM(min){var h=Math.floor(min/60),m=min%60;return h+'h '+m+'m';}


function updTiemKPI(){
  var y=new Date().getFullYear(),f=y+'-01-01',t=y+'-12-31';
  var tot={op:0,mu:0,ma:0};
  var dia={op:0,mu:0,ma:0};
  var noc={op:0,mu:0,ma:0};
  S.prod.records.forEach(function(r){
    if(r.fecha<f||r.fecha>t)return;
    var cl=r.tiemClasif;if(!cl)return;
    var bucket=r.turno==='dia'?dia:noc;
    var op=cl.operado||0,ma=cl.mantenimiento||0,mu=0;
    (cl.muertos||[]).forEach(function(m){mu+=m.min||0;});
    tot.op+=op;tot.ma+=ma;tot.mu+=mu;
    bucket.op+=op;bucket.ma+=ma;bucket.mu+=mu;
  });
  // Global
  G('kt-op').textContent=mToHM(tot.op);
  G('kt-mu').textContent=mToHM(tot.mu);
  G('kt-ma').textContent=mToHM(tot.ma);
  var base=tot.op+tot.ma;
  G('kt-di').textContent=base>0?Math.round(tot.op/base*100)+'%':'—';
  // Por turno
  var setT=function(pref,d){
    var el=G('kt-'+pref+'-op');if(el)el.textContent=mToHM(d.op);
    var el2=G('kt-'+pref+'-mu');if(el2)el2.textContent=mToHM(d.mu);
    var el3=G('kt-'+pref+'-ma');if(el3)el3.textContent=mToHM(d.ma);
    var b=d.op+d.ma;
    var el4=G('kt-'+pref+'-di');if(el4)el4.textContent=b>0?Math.round(d.op/b*100)+'%':'—';
  };
  setT('dia',dia);
  setT('noc',noc);
}

function tiemSaldo(r){
  // Devuelve minutos no clasificados del turno
  if(!r.netMin) return 0;
  var c=r.tiemClasif;if(!c)return r.netMin;
  var used=(c.operado||0)+(c.mantenimiento||0);
  (c.muertos||[]).forEach(function(m){used+=m.min||0;});
  return Math.max(0,r.netMin-used);
}

function renderTiemLista(){
  var c=G('tiem-lista');c.innerHTML='';
  // Solo mostrar registros pendientes de clasificar (no completamente clasificados)
  var recs=S.prod.records.filter(function(r){
    if(r.sinHorario)return false; // Excluir registros sin horario activado
    if(!r.netMin||r.netMin<=0)return false;
    if(r.esTransformacion||(r.fuenteId&&!isSysId(r.fuenteId)&&r.origenBit))return false; // Transformacion no tiene tiempos
    var cl=r.tiemClasif||{operado:0,mantenimiento:0,muertos:[]};
    var totMu=(cl.muertos||[]).reduce(function(a,m){return a+m.min;},0);
    var totalUsado=(cl.operado||0)+(cl.mantenimiento||0)+totMu;
    var completo=totalUsado>=r.netMin&&totalUsado>0;
    return !completo; // Solo pendientes
  }).slice().sort(function(a,b){return b.fecha.localeCompare(a.fecha);});
  if(!recs.length){
    c.innerHTML='<div style="text-align:center;color:var(--ok);font-size:13px;padding:32px">✅ Todos los turnos están clasificados. Ver el historial para consultar registros anteriores.</div>';
    return;
  }
  recs.forEach(function(r){
    var cl=r.tiemClasif||{operado:0,mantenimiento:0,muertos:[]};
    var saldo=tiemSaldo(r);
    var totMu=(cl.muertos||[]).reduce(function(a,m){return a+m.min;},0);
    var totalUsado=(cl.operado||0)+(cl.mantenimiento||0)+totMu;
    var completo=saldo===0&&totalUsado>0;
    var pctOp=r.netMin>0?Math.round((cl.operado||0)/r.netMin*100):0;
    var pctMa=r.netMin>0?Math.round((cl.mantenimiento||0)/r.netMin*100):0;
    var pctMu=r.netMin>0?Math.round(totMu/r.netMin*100):0;
    var html='<div class="card" style="border-left:3px solid '+(completo?'var(--ok)':saldo<r.netMin&&totalUsado>0?'var(--wa)':'var(--bd2)')+'">';
    // Header del turno
    html+='<div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:8px;margin-bottom:13px;padding-bottom:11px;border-bottom:1px solid var(--bd1)">';
    html+='<div style="display:flex;align-items:center;gap:10px">';
    html+='<span class="mv" style="font-size:13px">'+fd(r.fecha)+'</span>';
    html+='<span class="'+(r.turno==='dia'?'trn-d':'trn-n')+'">'+(r.turno==='dia'?'☀️ DÍA':'🌙 NOCHE')+'</span>';
    html+='<span style="font-size:13px;color:var(--tx2)">'+eqn(r.equipoId)+'</span>';
    html+='</div>';
    html+='<div style="display:flex;align-items:center;gap:10px">';
    html+='<span style="font-family:var(--M);font-size:10px;color:var(--tx3)">Horas netas: <strong style="color:var(--or)">'+r.netas+'</strong></span>';
    html+='<span class="'+(completo?'ic-pos':saldo<r.netMin&&totalUsado>0?'ic-zer':'ic-neg')+'">'+(completo?'✓ Clasificado':'Saldo: '+mToHM(saldo))+'</span>';
    // Disponibilidad
    var dispPct=((cl.operado||0)+(cl.mantenimiento||0))>0?Math.round((cl.operado||0)/((cl.operado||0)+(cl.mantenimiento||0))*100):null;
    if(dispPct!==null){
      var dispCol=dispPct>=85?'var(--ok)':dispPct>=70?'var(--wa)':'var(--er)';
      html+='<div style="background:var(--bg3);border:1px solid var(--bd2);border-radius:8px;padding:6px 12px;text-align:center;min-width:80px"><div style="font-family:var(--M);font-size:8px;color:var(--tx3);letter-spacing:1px;margin-bottom:2px">DISPONIB.</div><div style="font-family:var(--M);font-size:20px;font-weight:700;color:'+dispCol+'">'+dispPct+'%</div></div>';
