function bitProdCalc(){
  var vj=parseFloat(gv('prod-bit-patio-vj'))||0;
  var m3v=parseFloat(gv('prod-bit-patio-m3v'))||0;
  var tot=vj*m3v;
  var totEl=G('prod-bit-patio-tot');if(totEl)totEl.value=vj>0&&m3v>0?tot.toFixed(2):'';
  var tvEl=G('prod-bit-total-vj');if(tvEl)tvEl.textContent=vj;
  var tmEl=G('prod-bit-total-m3');if(tmEl)tmEl.textContent=tot.toFixed(2);
  // Stock Grava actual (Patio+Tolva+Zaranda - producido)
  var gravaPtId=ptIdBySrc('patio');
  var stockActual=gravaPtId?(getInv()[gravaPtId]||0):0;
  // Add extraccion from current form (not yet saved)
  var extPatio=(parseFloat(gv('ext-patio-vj'))||0)*(parseFloat(gv('ext-patio-m3v'))||0);
  var extTolva=(parseFloat(gv('ext-tolva-vj'))||0)*(parseFloat(gv('ext-tolva-m3v'))||0);
  var extZaranda=(parseFloat(gv('ext-zaranda-vj'))||0)*(parseFloat(gv('ext-zaranda-m3v'))||0);
  var stockConExt=stockActual+extPatio+extTolva+extZaranda;
  var stockDespues=stockConExt-tot;
  var valEl=G('prod-bit-stock-val');
  var afterEl=G('prod-bit-stock-after');
  var barEl=G('prod-bit-stock-bar-fill');
  var warnEl=G('prod-bit-stock-warn');
  if(valEl){
    valEl.textContent=stockConExt.toFixed(1)+' m³';
    valEl.style.color=stockConExt<=0?'var(--er)':stockConExt<50?'var(--wa)':'var(--ok)';

  }
  if(afterEl){
    afterEl.textContent=stockDespues.toFixed(1)+' m³';
    afterEl.style.color=stockDespues<0?'var(--er)':stockDespues<20?'var(--wa)':'var(--ok)';
  }
  if(barEl&&stockConExt>0){
    var pct=Math.max(0,Math.min(100,stockDespues/stockConExt*100));
    barEl.style.width=pct+'%';
    barEl.style.background=stockDespues<0?'var(--er)':stockDespues<20?'var(--wa)':'var(--ok)';
  }
  if(warnEl){
    if(stockConExt<=0){
      warnEl.className='alert alert-er on';
      warnEl.textContent='⛔ Sin stock de Grava disponible. No se puede registrar producción.';
    } else if(tot>stockConExt){
      warnEl.className='alert alert-er on';
      warnEl.textContent='⛔ Los viajes ('+tot.toFixed(1)+'m³) superan el stock disponible ('+stockConExt.toFixed(1)+'m³).';
    } else if(stockDespues<20&&tot>0){
      warnEl.className='alert alert-wa on';
      warnEl.textContent='⚠️ Stock quedará bajo: '+stockDespues.toFixed(1)+'m³ restantes.';
    } else {
      warnEl.className='alert';
    }
  }
}
