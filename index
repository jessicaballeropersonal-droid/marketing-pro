  var net=toMin(fin)-toMin(ini)-(dh*60+dm);
  if(net<0)net+=1440;
  var el=G('pord-hn-'+rid);if(el)el.value=mFmt(net);
}

function pordCalcCol(rid,alm,maxT,fuenteM3){
  fuenteM3=parseFloat(fuenteM3)||0;maxT=parseInt(maxT)||4;
  var tot=0;
  for(var i=1;i<=maxT;i++){
    var pct=parseFloat(gv('pord-pct-'+rid+'-'+alm+'-'+i))||0;
    tot+=pct;
    var m3El=G('pord-m3-'+rid+'-'+alm+'-'+i);
    if(m3El)m3El.value=pct>0?(fuenteM3*pct/100).toFixed(2):'';
  }
  var totEl=G('pord-tot-'+rid+'-'+alm);
  var barEl=G('pord-bar-'+rid+'-'+alm);
  if(totEl){totEl.textContent=tot+'%';totEl.style.color=tot===100?'var(--ok)':tot>100?'var(--er)':'var(--tx2)';}
  if(barEl){barEl.style.width=Math.min(tot,100)+'%';barEl.style.background=tot===100?'var(--ok)':tot>100?'var(--er)':'var(--or)';}
}


