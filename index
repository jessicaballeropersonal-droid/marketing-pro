function updPKPI(){
  var y=new Date().getFullYear(),f=y+'-01-01',t=y+'-12-31';
  var recs=S.prod.records.filter(function(r){
    return r.fecha>=f && r.fecha<=t && !r.pendienteClasif;
  });
  // Separar por tipo: Trituración (patio/tolva) vs Zaranda vs Transformación
  var trit={m3:0,v:0}, zar={m3:0,v:0}, transf={m3:0,v:0};
  recs.forEach(function(r){
    // ¿Es una transformación desde bitácora?
    var esTransf=r.esTransformacion||(r.fuenteId&&!isSysId(r.fuenteId)&&r.origenBit);
    if(esTransf){
      // KPI Transformado: suma fuenteM3 (lo que se re-procesó)
      transf.m3+=r.fuenteM3||r.tm||0;
      transf.v+=r.tv||0;
      return; // No entra en Trituración ni Zaranda
    }
    // Si no es transformación, separar por fuente: Patio/Tolva = Trituración, Zaranda aparte
    var fuentes=r.fuentes&&r.fuentes.length?r.fuentes:(r.fuenteId?[{alm:'patio',m3:r.fuenteM3||0,vj:r.tv||0}]:[]);
    if(!fuentes.length){
      // Sin fuentes definidas: tomar dist (producto terminado) y asumir Trituración
      var totM3=0;(r.dist||[]).forEach(function(d){if(d.ptId&&d.m3>0)totM3+=d.m3;});
      trit.m3+=totM3;trit.v+=r.tv||0;
    }else{
      fuentes.forEach(function(fu){
        if(fu.alm==='zaranda'){zar.m3+=fu.m3||0;zar.v+=fu.vj||0;}
        else{trit.m3+=fu.m3||0;trit.v+=fu.vj||0;}
      });
    }
  });
  // Total Producido = Trituración + Zaranda (NO incluye Transformado)
  var totM3=trit.m3+zar.m3, totV=trit.v+zar.v;
  // Pintar los 4 KPIs
  if(G('kp-trit'))G('kp-trit').textContent=trit.m3.toFixed(1);
  if(G('kp-trit-v'))G('kp-trit-v').textContent=trit.v+' viajes';
  if(G('kp-zar'))G('kp-zar').textContent=zar.m3.toFixed(1);
  if(G('kp-zar-v'))G('kp-zar-v').textContent=zar.v+' viajes';
  if(G('kp-transf'))G('kp-transf').textContent=transf.m3.toFixed(1);
  if(G('kp-transf-v'))G('kp-transf-v').textContent=transf.v+' viajes';
  G('kp-tot').textContent=totM3.toFixed(1);
  G('kp-totv').textContent=totV+' viajes';
  // KPI por equipo (sigue igual)
  var byEq={};
  recs.forEach(function(r){
    if(!byEq[r.equipoId])byEq[r.equipoId]={m3:0,v:0};
    (r.dist||[]).forEach(function(d){if(d.ptId&&d.m3>0)byEq[r.equipoId].m3+=d.m3;});
    byEq[r.equipoId].v+=r.tv||0;
  });
  var eqCols=['wa','in','pu','cy','or'];
  G('kp-eq').innerHTML=Object.keys(byEq).map(function(eid,i){var d=byEq[eid];var cls=eqCols[i%eqCols.length];return'<div class="kpi '+cls+'"><div class="kpi-lbl">'+eqn(eid)+'</div><div class="kpi-val">'+d.m3.toFixed(1)+'</div><div class="kpi-unit">m³ transformados</div><div class="kpi-sub">'+d.v+' viajes</div></div>';}).join('');
}
