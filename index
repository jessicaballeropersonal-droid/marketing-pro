  return'<div style="background:var(--bg1);border:1px solid var(--bd2);border-radius:9px;padding:11px 14px;border-left:3px solid '+(activa?'var(--ok)':'var(--bd2)')+'">'
    // Header
    +'<div style="display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:8px">'
    +'<div style="flex:1">'
    +'<div style="font-weight:700;font-size:12px">'+nombre+'</div>'
    +'<div style="font-size:11px;color:var(--tx2);margin-top:2px">'+desc+'</div>'
    +'</div>'
    +'<div style="display:flex;align-items:center;gap:8px;margin-left:12px;flex-shrink:0">'
    +(esCustom&&isAdmin?'<button class="btn btn-gh btn-xs" onclick="editAlertaCustom(\''+id+'\')">✏️</button>'
      +'<button class="btn btn-er btn-xs" onclick="delAlertaCustom(\''+id+'\')">🗑️</button>':'')
