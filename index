    html+='<div style="background:var(--waA);border:1px solid var(--waB);border-radius:8px;padding:10px 14px;font-size:11px;color:var(--wa)">'
      +'⚠️ '+sinWA+' usuario(s) sin número de WhatsApp registrado. '
      +'<span style="cursor:pointer;text-decoration:underline" onclick="goTo(\'usuarios\')">Ir a Usuarios →</span>'
      +'</div>';
  }

  c.innerHTML=html;
}

function _renderAlertaCard(id,nombre,desc,defUmbral,unidad,defActiva,esCustom,isAdmin){
