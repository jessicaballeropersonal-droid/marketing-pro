function fplGetAcumProd(maq, fechaIni){
  // Sum viajes and m3 from prod records from fechaIni to today
  // prod records have date and prodTerm entries with m3 and viajes
  var totalViajes=0,totalM3=0;
  (S.prod.records||[]).filter(function(r){return r.fecha>=fechaIni;}).forEach(function(r){
    // each record has tv (total viajes) and tm (total m3)
    totalViajes+=(r.tv||0);
    totalM3+=(r.tm||0);
  });
  return{viajes:totalViajes,m3:parseFloat(totalM3.toFixed(2))};
}


function fplGetStockFIFO(piezaId){
  // Get all entradas sorted oldest first
  var entradas=(S.fungStockPl||[]).filter(function(e){return e.piezaId===piezaId;});
  entradas.sort(function(a,b){return a.fecha.localeCompare(b.fecha);});
  // Count cambios (each cambio uses 1 unit)
  var cambios=(S.fungCambiosPl||[]).filter(function(c){return c.piezaId===piezaId;}).length;
  var totalIn=entradas.reduce(function(s,e){return s+e.cantidad;},0);
  var totalOut=cambios;
  var total=Math.max(0,totalIn-totalOut);
  // FIFO: find oldest lote with remaining stock
  var lotes=[];var consumed=totalOut;
  for(var i=0;i<entradas.length;i++){
    var e=entradas[i];
    if(consumed>=e.cantidad){consumed-=e.cantidad;}
    else{lotes.push({precio:e.precio,disponible:e.cantidad-consumed,fecha:e.fecha,prov:e.prov});consumed=0;}
  }
  return{total:total,lotes:lotes};
}

