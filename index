    {key:'tolva',  alm:'tolva',   vj:+gv('rm-tolva-vj')||0,   m3v:+gv('rm-tolva-m3v')||14,   tipo:'extraccion',clasif:true},
    {key:'zaranda',alm:'zaranda', vj:+gv('rm-zaranda-vj')||0, m3v:+gv('rm-zaranda-m3v')||14, tipo:'extraccion',clasif:true},
    {key:'arena',  alm:'arena',   vj:+gv('rm-arena-vj')||0,   m3v:+gv('rm-arena-m3v')||14,   tipo:'extraccion',clasif:false},
    {key:'pp',     alm:'pp',      vj:+gv('rm-pp-vj')||0,      m3v:+gv('rm-pp-m3v')||14,      tipo:'movimiento',clasif:false},
