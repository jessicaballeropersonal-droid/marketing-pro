  if(fq)eventos=eventos.filter(function(e){
    var txt=(e.descripcion||'')+' '+(e.usuarioNombre||'')+' '+(e.modulo||'');
    return txt.toLowerCase().indexOf(fq)>=0;
  });
  // Resumen
  var resumen=G('act-resumen');
  if(resumen){
    var usuariosUnicos={};eventos.forEach(function(e){usuariosUnicos[e.usuarioId]=1;});
    var nUsuarios=Object.keys(usuariosUnicos).length;
    resumen.innerHTML='📊 <strong>'+eventos.length+'</strong> eventos · 👥 <strong>'+nUsuarios+'</strong> usuario(s) distintos';
  }
