function rmCalc(){
  var cards=rmCardData();
  // Pintar subtotales en cada card
  sv('rm-patio-tot',  cards[0].m3.toFixed(2));
  sv('rm-tolva-tot',  cards[1].m3.toFixed(2));
  sv('rm-zaranda-tot',cards[2].m3.toFixed(2));
  sv('rm-arena-tot',  cards[3].m3.toFixed(2));
  sv('rm-pp-tot',     cards[4].m3.toFixed(2));
  sv('rm-pgtolva-tot',cards[5].m3.toFixed(2));
  sv('rm-trans-tot',  cards[6].m3.toFixed(2));
  // Stock disponible para Transformación
  var transEl=G('rm-trans-stock');
  if(transEl){
    var oId=cards[6].origenId;
    if(oId){var st=invStock(oId);transEl.value=st.toFixed(2)+' m³';transEl.style.color=cards[6].m3>st?'var(--er)':'var(--ok)';}
    else{transEl.value='—';transEl.style.color='var(--tx3)';}
  }
  // Stock disponible para PG→Tolva
  var pgStockEl=G('rm-pgtolva-stock');
  if(pgStockEl){
    var stG=invStock('sys_patio');
    pgStockEl.textContent=stG.toFixed(2)+' m³';
    pgStockEl.style.color=cards[5].m3>stG?'var(--er)':'var(--ok)';
  }
  // Calcular totales
  var totVj=cards.reduce(function(s,c){return s+c.vj;},0);
  var totM3=cards.reduce(function(s,c){return s+c.m3;},0);
  if(G('p-tv'))G('p-tv').textContent=(totVj%1===0?totVj.toFixed(0):totVj.toFixed(1));
  if(G('p-tm'))G('p-tm').textContent=totM3.toFixed(2);
  // Pendiente de clasif: suma de Tolva + Zaranda + PG→Tolva + Transformación
  var pendClasif=cards[1].m3+cards[2].m3+cards[5].m3+cards[6].m3;
  if(G('p-tc'))G('p-tc').textContent=pendClasif.toFixed(2);
}

