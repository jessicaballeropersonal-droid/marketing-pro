function _lubGetAlertas(){
  var alertas=[];
  _lubGetMaquinasActivas().forEach(function(maq){
    var horas=_lubHorasAcum(maq.maquinaId);
    (maq.rodamientos||[]).forEach(function(rod){
      var ult=_lubUltima(maq.maquinaId,rod.id);
      if(ult){
        var sem=_lubSemaforo(ult.temp,rod.tempMax);
        if(sem.cls==='er'||sem.cls==='wa'){
          alertas.push({tipo:sem.cls,maq:maq.maquinaNombre,rod:rod.nombre,
            msg:sem.ico+' Temperatura: '+ult.temp+'°C / Límite: '+rod.tempMax+'°C — '+sem.txt,
            fecha:fd(ult.fecha)+' '+ult.hora});
        }
      }
      // Horas alert
      if(rod.horas&&horas>rod.horas){
        alertas.push({tipo:'er',maq:maq.maquinaNombre,rod:rod.nombre,
          msg:'⏱️ Superó intervalo de horas: '+horas+'h / '+rod.horas+'h configuradas',
          fecha:'Horas acum. desde producción'});
      } else if(rod.horas&&(rod.horas-horas)<50&&horas>0){
        alertas.push({tipo:'wa',maq:maq.maquinaNombre,rod:rod.nombre,
          msg:'⏱️ Próximo a intervalo: '+horas+'h / '+rod.horas+'h — faltan '+(rod.horas-horas).toFixed(0)+'h',
          fecha:'Horas acum. desde producción'});
      }
    });
  });
  return alertas;
}
function _updateLubBadge(){
  var b=G('sb-lub-badge');if(!b)return;
  var n=_lubGetAlertas().filter(function(a){return a.tipo==='er';}).length;
  b.textContent='!';b.style.display=n>0?'inline-block':'none';
  var bc=G('lub-alert-count');if(bc){bc.textContent=n;bc.style.display=n>0?'inline':'none';}
}

