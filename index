  var nuevoTm=(dc*dm)+(vc*vm);
  // FIX CRÍTICO: Si el registro tiene dist[], recalcular m3 de cada transformación con los nuevos pct
  if(r.dist&&r.dist.length>0&&nuevoTm>0){
    r.dist.forEach(function(d){
      if(d.pct){d.m3=nuevoTm*d.pct/100;}
    });
    // r.tm debe ser la suma del dist[] (no los viajes), para que cuadre el inventario
    r.tm=r.dist.reduce(function(s,d){return s+(d.m3||0);},0);
  } else {
    r.tm=nuevoTm;
  }
  // FIX: También actualizar r.fuentes[] si existen
  if(r.fuentes&&r.fuentes.length>0&&nuevoTm>0){
    var totFuentesPrev=r.fuentes.reduce(function(s,f){return s+(f.m3||0);},0);
    if(totFuentesPrev>0){
      var factor=nuevoTm/totFuentesPrev;
      r.fuentes.forEach(function(f){f.m3=(f.m3||0)*factor;});
    }
  }
  var mdesH=parseInt(gv('mphd-h'))||0,mdesM=parseInt(gv('mphd-m'))||0;
  r.ini=gv('mphi');r.des=pad(mdesH)+':'+pad(mdesM);r.fin=gv('mphf');
  var mnet=r.ini&&r.fin?toMin(r.fin)-toMin(r.ini)-(mdesH*60+mdesM):0;if(mnet<0)mnet+=1440;r.netMin=mnet;r.netas=mFmt(mnet);
  saveS();dbSaveProd(r);cmo('ov-prod');updPKPI();updDKPI();renderPH();
}

