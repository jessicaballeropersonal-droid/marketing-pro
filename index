      +'<span style="font-family:var(--M);font-size:9px;color:var(--tx3)">🚛 '+dayVj+' viajes</span>'
      +'<span style="font-family:var(--M);font-size:9px;color:var(--ok);font-weight:700">'+dayM3.toFixed(2)+' m³</span>'
      +'</div></td></tr>';
