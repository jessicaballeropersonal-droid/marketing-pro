var _KG_OVERLAYS=['calendario','kanban','tareas','tareas-oficina','tareas-mant'];
function volverAlMenu(){
  // Ocultar todas las pantallas completas (overlays)
  ['pg-calendario-wrap','pg-kanban-wrap','pg-tareas-wrap','pg-tareas-oficina-wrap','pg-tareas-mant-wrap'].forEach(function(idw){var w=G(idw);if(w)w.style.display='none';});
  // Admin: comportamiento normal (Extracción)
  if(!SESION||SESION.rol==='admin'){goTo('kanban');return;}
  // No-admin: abrir el primer módulo NORMAL permitido (no-overlay), para que el sidebar quede visible
  var perms=(S.permisos&&S.permisos[SESION.id])||{};
  for(var i=0;i<MODULOS_PERMISOS.length;i++){
    var mid=MODULOS_PERMISOS[i].id,p=perms[mid];
    if((p==='ver'||p==='todo'||p===true)&&_KG_OVERLAYS.indexOf(mid)<0){goTo(mid);return;}
  }
  // Solo tiene módulos de pantalla completa (ej. Calendario+Kanban): abrir el primero permitido
  for(var j=0;j<MODULOS_PERMISOS.length;j++){
    var oid=MODULOS_PERMISOS[j].id,po=perms[oid];
    if((po==='ver'||po==='todo'||po===true)&&_KG_OVERLAYS.indexOf(oid)>=0){goTo(oid);return;}
  }
  // Sin nada permitido: dejar el menú visible
  document.querySelectorAll('.nl').forEach(function(n){n.classList.remove('on');});
  document.querySelectorAll('.nl-m').forEach(function(n){n.classList.remove('on');});
}
function closeCalendario(){var w=G('pg-calendario-wrap');if(w)w.style.display='none';volverAlMenu();}
function gcalOpenEvento(evId,fecha){
  if(!_gcalConnected()){gcalConnect();return;}
  var ev=evId?_GCAL.events.find(function(x){return x.id===evId;}):null;
  var f=ev?_gcalEvDate(ev):(fecha||new Date().toISOString().slice(0,10));
  var hIni=ev&&ev.start&&ev.start.dateTime?ev.start.dateTime.slice(11,16):'09:00';
  var hFin=ev&&ev.end&&ev.end.dateTime?ev.end.dateTime.slice(11,16):'10:00';
  var titulo=ev?(ev.summary||''):'';var notas=ev?(ev.description||''):'';
  var body='<div style="display:flex;flex-direction:column;gap:9px">'
    +'<div><div class="fl">Título</div><input class="fi" id="gce-tit" value="'+titulo.replace(/"/g,'&quot;')+'" placeholder="Título del evento"></div>'
    +'<div style="display:flex;gap:8px"><div style="flex:1"><div class="fl">Fecha</div><input type="date" class="fi" id="gce-fecha" value="'+f+'"></div>'
    +'<div style="flex:1"><div class="fl">Inicio</div><input type="time" class="fi" id="gce-ini" value="'+hIni+'"></div>'
    +'<div style="flex:1"><div class="fl">Fin</div><input type="time" class="fi" id="gce-fin" value="'+hFin+'"></div></div>'
    +'<div><div class="fl">Notas</div><textarea class="fi" id="gce-notas" rows="3" style="resize:vertical">'+notas+'</textarea></div>'
    +'<div style="display:flex;gap:8px;margin-top:4px">'
    +'<button class="btn btn-gh" onclick="modalAvisoClose()">Cerrar</button>'
    +'<button class="btn btn-or" id="gce-savebtn" onclick="gcalGuardarEvento(\''+(evId||'')+'\')" style="flex:1">💾 Guardar en Google</button>'
    +(evId?'<button class="btn btn-er" onclick="gcalEliminarEvento(\''+evId+'\')">🗑️</button>':'')
    +'</div>'
    +(evId?'<button class="btn btn-gh btn-sm" onclick="kgCrearDesdeEvento(\''+evId+'\')" style="margin-top:2px">Crear tarjeta en Kanban</button>':'<div style="font-family:var(--M);font-size:8px;color:var(--tx3)">Guarda el evento para crear tarjeta en Kanban.</div>')
    +'<div id="gce-msg" style="font-family:var(--M);font-size:9px;color:var(--er)"></div></div>';
  modalAviso({tipo:'info',titulo:evId?'✏️ Editar evento':'➕ Nuevo evento',subtitulo:'Se guarda en tu Google Calendar',contenidoHtml:body,sinBotones:true});
}
function gcalGuardarEvento(evId){
  if(!canWrite('calendario'))return;
  var tit=gv('gce-tit'),f=gv('gce-fecha'),hi=gv('gce-ini'),hf=gv('gce-fin'),notas=gv('gce-notas');
  if(!tit){var m=G('gce-msg');if(m)m.textContent='Escribe un título.';return;}
  var resource={summary:tit,description:notas,
    start:{dateTime:f+'T'+(hi||'09:00')+':00',timeZone:'America/Bogota'},
    end:{dateTime:f+'T'+(hf||'10:00')+':00',timeZone:'America/Bogota'}};
  if(_GCAL.saving)return; _GCAL.saving=true;
  _gcalEnsureToken();
  var _bp=G('gce-savebtn'); if(_bp){_bp.disabled=true;_bp.style.opacity='.6';_bp.textContent='Guardando...';}
  var op=evId?gapi.client.calendar.events.patch({calendarId:'primary',eventId:evId,resource:resource})
             :gapi.client.calendar.events.insert({calendarId:'primary',resource:resource});
  op.then(function(){_GCAL.saving=false;modalAvisoClose();_gcalFetchAndRender();})
    .catch(function(err){_GCAL.saving=false;var _b=G('gce-savebtn');if(_b){_b.disabled=false;_b.style.opacity='';_b.textContent='Guardar en Google';}
      if(err&&err.status===401){_gcalSilentReconnect();var m0=G('gce-msg');if(m0)m0.textContent='Reconectando... intenta guardar de nuevo.';return;}
      var m=G('gce-msg');if(m)m.textContent='Error: '+((err&&err.result&&err.result.error&&err.result.error.message)||'no se pudo guardar');});
}
function gcalEliminarEvento(evId){
  if(!canWrite('calendario'))return;
  _gcalEnsureToken();
  gapi.client.calendar.events.delete({calendarId:'primary',eventId:evId})
    .then(function(){modalAvisoClose();_gcalFetchAndRender();})
    .catch(function(err){
      if(err&&err.status===401){_gcalSilentReconnect();var m0=G('gce-msg');if(m0)m0.textContent='Reconectando... intenta eliminar de nuevo.';return;}
      var m=G('gce-msg');if(m)m.textContent='Error al eliminar: '+((err&&err.result&&err.result.error&&err.result.error.message)||'reintenta');});
}
