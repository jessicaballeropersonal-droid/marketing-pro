function auditCheckPalabra(palabra){
  var val=(G('audit-confirm-input').value||'').trim().toUpperCase();
  var btn=G('audit-confirm-btn');if(!btn)return;
  if(val===palabra.toUpperCase()){btn.disabled=false;btn.style.opacity='1';btn.style.cursor='pointer';}
  else{btn.disabled=true;btn.style.opacity='.4';btn.style.cursor='not-allowed';}
}

// Navegar a Bitácora del día
function irABitacoraDia(fecha){
  modalAvisoClose();
  goTo('mant');
  setTimeout(function(){
    // Cambiar a sub-tab de bitácora
    var pgMant=G('pg-mant');
    if(pgMant){
      pgMant.querySelectorAll('.tab').forEach(function(t){
        if(t.textContent.indexOf('Bitácora')>=0){t.click();}
      });
    }
    var f=G('bit-h-desde');if(f&&fecha)f.value=fecha;
    var f2=G('bit-h-hasta');if(f2&&fecha)f2.value=fecha;
  },200);
