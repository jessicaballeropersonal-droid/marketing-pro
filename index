function _renderCondLiquidaciones(c){
  var isAdmin=puedeEditar('conductores');
  var liqs=(S.conductoresLiq||[]).slice().sort(function(a,b){return b.fechaLiq.localeCompare(a.fechaLiq);});
  var html='<div style="font-size:15px;font-weight:700;margin-bottom:12px">Historial de Liquidaciones</div>';
  if(!liqs.length){html+='<div style="text-align:center;padding:40px;color:var(--tx3)">Sin liquidaciones registradas.</div>';c.innerHTML=html;return;}
  html+='<div class="tw"><table><thead><tr>'
    +'<th>Conductor</th><th>Período</th><th>Fecha Liq.</th><th style="text-align:right">Viajes</th>'
    +'<th style="text-align:right">Total</th><th></th></tr></thead><tbody>';
  liqs.forEach(function(l){
    var cond=(S.conductores||[]).find(function(c){return c.id===l.conductorId;})||{nombre:'—'};
    html+='<tr>'
      +'<td style="font-weight:700">'+cond.nombre+'</td>'
      +'<td>'+fd(l.desde)+' al '+fd(l.hasta)+'</td>'
      +'<td style="font-family:var(--M);font-size:9px">'+fd(l.fechaLiq)+'</td>'
      +'<td style="text-align:right">'+l.totalViajes+'</td>'
      +'<td style="text-align:right;font-weight:700;color:var(--ok)">$'+Math.round(l.total).toLocaleString('es-CO')+'</td>'
      +'<td>'
      +'<button class="btn btn-gh btn-xs" onclick="openCondLiqDetalle(\''+l.id+'\')">Ver</button>'
      +(isAdmin?'<button class="btn btn-gh btn-xs" onclick="openEditLiq(\''+l.id+'\')">✏️</button>':'')
      +'</td></tr>';
  });
  html+='</tbody></table></div>';
  c.innerHTML=html;
}

function _renderCondHistorial(c){
  var html='<div style="font-size:15px;font-weight:700;margin-bottom:12px">Historial de Viajes por Conductor</div>';
  var conds=S.conductores||[];
  if(!conds.length){html+='<div style="color:var(--tx3);text-align:center;padding:30px">Sin conductores.</div>';c.innerHTML=html;return;}
  html+='<div class="tw"><table><thead><tr><th>Conductor</th><th>Tipo</th><th>Destino</th><th style="text-align:center">Viajes</th><th style="text-align:right">Valor est.</th></tr></thead><tbody>';
  conds.forEach(function(cond){
    var viajes=_getViajesConductor(cond.id);
    if(!viajes.length)return;
    var dests=S.conductoresConfig&&S.conductoresConfig.destinos||[];
    viajes.forEach(function(v){
      var dest=dests.find(function(d){return v.destino.includes(d.nombre)||d.nombre.includes(v.destino);});
      var valor=dest?(v.cantidad*dest.precio):0;
      html+='<tr><td style="font-weight:700">'+cond.nombre+'</td><td style="color:var(--tx3)">'+(cond.tipo==='empleado'?'Empleado':'Independiente')+'</td><td>'+v.destino+'</td><td style="text-align:center;font-weight:700">'+v.cantidad+'</td><td style="text-align:right;color:var(--ok)">'+( valor>0?'$'+Math.round(valor).toLocaleString('es-CO'):'—')+'</td></tr>';
    });
  });
  html+='</tbody></table></div>';
  c.innerHTML=html;
}

function openCondLiqModal(condId){
  var cond=(S.conductores||[]).find(function(c){return c.id===condId;});if(!cond)return;
  var viajes=_getViajesConductor(condId);
  var dests=(S.conductoresConfig&&S.conductoresConfig.destinos)||[];
  var total=0;var totalViajes=0;
  G('cond-liq-ttl').textContent='💰 Liquidar — '+cond.nombre;
  var rows=viajes.map(function(v){
    var dest=dests.find(function(d){return v.destino.toLowerCase().includes(d.nombre.toLowerCase())||d.nombre.toLowerCase().includes(v.destino.split('—')[0].toLowerCase().trim());});
    var precio=dest?dest.precio:0;
    var subtotal=0;
    if(cond.tipo==='empleado')subtotal=v.cantidad*precio;
    else subtotal=v.cantidad*precio*(cond.pct/100);
    total+=subtotal;totalViajes+=v.cantidad;
    return{destino:v.destino,cantidad:v.cantidad,precio:precio,subtotal:subtotal};
  });
  var html='<div style="background:var(--bg3);border-radius:7px;padding:10px 13px;margin-bottom:13px">'
    +'<div style="font-family:var(--M);font-size:8px;color:var(--tx3);margin-bottom:3px">CONDUCTOR</div>'
    +'<div style="font-weight:700;font-size:14px">'+cond.nombre+'</div>'
    +'<div style="font-size:11px;color:var(--tx3)">'+cond.cedula+' · '+(cond.tipo==='empleado'?'Empleado propio':'Independiente — '+cond.pct+'% del flete')+'</div>'
    +'</div>'
    +'<div style="display:flex;gap:8px;margin-bottom:11px">'
    +'<div class="ff"><div class="fl">Desde</div><input type="date" class="fi" id="liq-desde" value="'+_addDays(today(),-30)+'"></div>'
    +'<div class="ff"><div class="fl">Hasta</div><input type="date" class="fi" id="liq-hasta" value="'+today()+'"></div>'
    +'</div>'
    +'<div class="tw"><table style="width:100%;border-collapse:collapse;font-size:12px">'
    +'<thead><tr style="background:var(--or)"><th style="padding:7px 10px;color:#fff;text-align:left">Destino</th><th style="padding:7px 10px;color:#fff;text-align:center">Viajes</th><th style="padding:7px 10px;color:#fff;text-align:right">Precio/viaje</th><th style="padding:7px 10px;color:#fff;text-align:right">Subtotal</th></tr></thead><tbody>'
    +rows.map(function(r,i){
      return'<tr style="border-bottom:1px solid var(--bd2);'+(i%2===0?'':'background:var(--bg3)')+'">'
        +'<td style="padding:7px 10px;font-weight:700">'+r.destino+'</td>'
        +'<td style="padding:7px 10px;text-align:center">'+r.cantidad+'</td>'
        +'<td style="padding:7px 10px;text-align:right;color:var(--tx2)">'+( r.precio>0?'$'+Math.round(r.precio).toLocaleString('es-CO'):'Sin precio')+'</td>'
        +'<td style="padding:7px 10px;text-align:right;font-weight:700;color:var(--ok)">'+( r.subtotal>0?'$'+Math.round(r.subtotal).toLocaleString('es-CO'):'—')+'</td>'
        +'</tr>';
    }).join('')
    +'<tr style="background:var(--okA);border-top:2px solid var(--ok)">'
    +'<td style="padding:9px 10px;font-weight:700;font-family:var(--M)">TOTAL</td>'
    +'<td style="padding:9px 10px;text-align:center;font-weight:700">'+totalViajes+'</td>'
    +'<td></td>'
    +'<td style="padding:9px 10px;text-align:right;font-weight:900;font-size:16px;color:var(--ok)">$'+Math.round(total).toLocaleString('es-CO')+'</td>'
    +'</tr>'
    +'</tbody></table></div>';
  G('cond-liq-body').innerHTML=html;
