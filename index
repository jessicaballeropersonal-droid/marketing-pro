function bitMExtCalcAll(){bitProdCalc();
  var alms=[
    {id:'patio',   vjId:'ext-patio-vj',   m3Id:'ext-patio-m3v',   totId:'ext-patio-tot',   svj:'ext-patio-sum-vj',   sm3:'ext-patio-sum-m3'},
