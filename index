function saveMantBit(){
  var fecha=gv('bit-m-fecha'),turno=gv('bit-m-turno'),eqId=gv('bit-m-equipo');
  var acpm=parseFloat(gv('bit-m-acpm'))||0;
  if(acpm>0){
    var saldoDisp=calcAcpmSaldo();
    if(saldoDisp<=0){showAlert('mant-bit-alert','er','⛽ Saldo ACPM en 0. Registre una entrada de combustible antes de continuar.');return;}
    if(acpm>saldoDisp){showAlert('mant-bit-alert','wa','⚠️ Los galones superan el saldo disponible ('+saldoDisp.toFixed(1)+' gal). Verifique la cantidad.');return;}
  }
  // Validar stock de grava antes de guardar producción
  if(prodBitVj>0&&prodBitM3v>0){
    var gravaPtId2=ptIdBySrc('patio');
    var stockGrava=gravaPtId2?(getInv()[gravaPtId2]||0):0;
    var extP=(parseFloat(gv('ext-patio-vj'))||0)*(parseFloat(gv('ext-patio-m3v'))||0);
    var extT=(parseFloat(gv('ext-tolva-vj'))||0)*(parseFloat(gv('ext-tolva-m3v'))||0);
    var extZ=(parseFloat(gv('ext-zaranda-vj'))||0)*(parseFloat(gv('ext-zaranda-m3v'))||0);
    var stockDisp=stockGrava+extP+extT+extZ;
    if(prodBitTot>stockDisp){
      showAlert('mant-bit-alert','er','⛔ Sin stock suficiente de Grava. Disponible: '+stockDisp.toFixed(1)+'m³, solicitado: '+prodBitTot.toFixed(1)+'m³.');return;
    }
  }
  if(!fecha){showAlert('mant-bit-alert','er','Seleccione la fecha.');return;}
  if(!eqId){showAlert('mant-bit-alert','er','Seleccione el equipo.');return;}
  // Conductor obligatorio
  var conductorTurno=gv('bit-conductor-turno')||'';
  if(!conductorTurno){showAlert('mant-bit-alert','er','⚠️ Debe seleccionar el Conductor del Turno para guardar.');return;}
  // Validar proveedor si hay viajes de extracción
