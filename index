function _rastProcesarResultados(arr,vid,modo){
  var nuevas=0,duplicadas=0,sinId=0,descartadasPalabra=0,descartadasMunicipio=0;
  var f=S.rastreadorFiltros;
  arr.forEach(function(r){
    var key=r.id_proceso||r.url;
    if(!key){sinId++;return;}
    if(S.rastreadorAlertas.find(function(x){return x.id===key;})){duplicadas++;return;}

    // Búsqueda de palabras: en titulo + entidad + objeto + cualquier texto disponible
    var textoCompleto=_rastNorm([r.titulo,r.entidad,r.objeto,r.descripcion,(r.adjudicatario&&r.adjudicatario.nombre)||'',(r.coincidencias||[]).join(' ')].join(' '));
    var palOK=!f.palabras||!f.palabras.length||f.palabras.some(function(p){return textoCompleto.indexOf(_rastNorm(p))>=0;});

    // Filtro de municipio MÁS permisivo:
    // - Si municipio coincide con alguno de la lista → OK
    // - Si municipio dice "Norte de Santander" o variante (depto) → OK
    // - Si el resultado NO tiene municipio definido → OK (mejor traer que perder)
    var muniNorm=_rastNorm(r.municipio||'');
    var muniOK=true;
    if(f.municipios&&f.municipios.length&&muniNorm){
      muniOK=f.municipios.some(function(m){
        var mn=_rastNorm(m);
        return muniNorm.indexOf(mn)>=0||mn.indexOf(muniNorm)>=0;
      });
      // Aceptar también si dice el depto general
      var deptoNorm=_rastNorm(f.depto||'norte de santander');
      if(!muniOK&&(muniNorm.indexOf(deptoNorm)>=0||muniNorm.indexOf('norte de santander')>=0||muniNorm.indexOf('n. de santander')>=0||muniNorm.indexOf('nte santander')>=0)){
        muniOK=true;
      }
    }

    if(!palOK){descartadasPalabra++;return;}
    if(!muniOK){descartadasMunicipio++;return;}

    r.id=key;
    r.ventana=vid;
    r.modo=modo;
    r.estado='nueva';
    r.encontrada_en=(new Date()).toISOString();
    S.rastreadorAlertas.push(r);
    nuevas++;
  });
  renderRastreador();
  saveRastreadorDB();
  // Toast detallado: muestra DESGLOSE para saber por qué se descartó
  if(typeof toast==='function'){
    var msg='';
    if(arr.length===0){
      msg='⚠ La IA no encontró NADA. Posibles razones: web search no indexó esta fuente, o no hay licitaciones nuevas.';
    }else{
      msg='📊 '+arr.length+' encontradas · ✅ '+nuevas+' nuevas';
      var desc=[];
      if(duplicadas)desc.push(duplicadas+' duplicadas');
      if(sinId)desc.push(sinId+' sin ID');
      if(descartadasPalabra)desc.push(descartadasPalabra+' sin palabras clave');
      if(descartadasMunicipio)desc.push(descartadasMunicipio+' fuera de municipios');
      if(desc.length)msg+=' · descartadas: '+desc.join(', ');
    }
    toast(msg,nuevas>0?'ok':(arr.length===0?'warn':'info'));
  }
  // Log a consola para diagnóstico admin
  console.log('[Rastreador]',{ventana:vid,modo:modo,encontradas:arr.length,nuevas:nuevas,duplicadas:duplicadas,sinId:sinId,descartadasPalabra:descartadasPalabra,descartadasMunicipio:descartadasMunicipio,sample:arr.slice(0,2)});
}

