function _inspEnsureData(){
  if(!S.inspeccionPlantillas)S.inspeccionPlantillas={};
  if(!S.inspeccionHistorial)S.inspeccionHistorial=[];
  if(!S.inspeccionOTEstados||!S.inspeccionOTEstados.length)
    S.inspeccionOTEstados=_INSP_OT_EST_DEFAULT.map(function(e){return Object.assign({},e);});
  // Ensure plantillas for each tipo
  _INSP_TIPOS.forEach(function(tipo){
    if(!S.inspeccionPlantillas[tipo]){
      S.inspeccionPlantillas[tipo]=(_INSP_DEFAULTS[tipo]||[]).map(function(r){
        return Object.assign({},r,{id:uid()});
      });
    }
  });
}

