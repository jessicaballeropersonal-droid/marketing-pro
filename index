function volverAlMenu(){
  // Ocultar todas las pantallas completas (overlays)
  ['pg-calendario-wrap','pg-kanban-wrap','pg-tareas-wrap','pg-tareas-oficina-wrap','pg-tareas-mant-wrap'].forEach(function(idw){var w=G(idw);if(w)w.style.display='none';});
