  gapi.client.calendar.events.delete({calendarId:'primary',eventId:evId})
    .then(function(){modalAvisoClose();_gcalFetchAndRender();})
    .catch(function(err){
      if(err&&err.status===401){_gcalSilentReconnect();var m0=G('gce-msg');if(m0)m0.textContent='Reconectando... intenta eliminar de nuevo.';return;}
      var m=G('gce-msg');if(m)m.textContent='Error al eliminar: '+((err&&err.result&&err.result.error&&err.result.error.message)||'reintenta');});
}
