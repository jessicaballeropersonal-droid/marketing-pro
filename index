function syncBackupConfigFromSupa(){
  // v172.2: Leer también de localStorage como respaldo robusto
  try{
    var lsLocal=localStorage.getItem('crusherpro_lastBackupLocal');
    if(lsLocal)S.lastBackupLocal=lsLocal;
  }catch(_){}
  // Cargar timestamps últimos backups desde config (local y nube)
  return Promise.all([
    supaFetch('GET','config',null,'key=eq.lastBackupCloud').then(function(r){
      if(r&&r.length){
        try{S.lastBackupCloud=JSON.parse(r[0].value);}catch(_){S.lastBackupCloud=r[0].value;}
      }
    }).catch(function(){}),
    supaFetch('GET','config',null,'key=eq.lastBackupLocal').then(function(r){
      if(r&&r.length){
        var supaIso;
        try{supaIso=JSON.parse(r[0].value);}catch(_){supaIso=r[0].value;}
        // Si Supabase tiene fecha más reciente que localStorage, usar la de Supabase
        if(supaIso){
          if(!S.lastBackupLocal||new Date(supaIso)>new Date(S.lastBackupLocal)){
            S.lastBackupLocal=supaIso;
          }
        }
      }
    }).catch(function(){})
  ]).then(function(){updBackupBadge();});
}
