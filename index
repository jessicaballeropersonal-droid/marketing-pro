function saveTiemClasif(rid){
  var r=S.prod.records.find(function(x){return x.id===rid;});if(!r)return;
  var tipo=gv('tc-tipo-'+rid);
  var h=parseInt(gv('tc-h-'+rid))||0;
  var m=parseInt(gv('tc-m-'+rid))||0;
  var minutos=h*60+m;
  // Save viajes molidos
  var vjInput=G('tc-vj-'+rid);
  if(vjInput){r.viajesMolidos=parseInt(vjInput.value)||0;}
  if(minutos<=0&&tipo!=='viajes_only'){showAlert('tiem-alerta-'+rid,'er','Ingrese horas o minutos mayores a 0.');return;}
  var saldo=tiemSaldo(r);
  if(minutos>saldo){showAlert('tiem-alerta-'+rid,'er','El tiempo ingresado ('+mToHM(minutos)+') supera el saldo disponible ('+mToHM(saldo)+').');return;}
  if(!r.tiemClasif) r.tiemClasif={operado:0,mantenimiento:0,muertos:[]};
  if(tipo==='operado'){
    r.tiemClasif.operado=(r.tiemClasif.operado||0)+minutos;
  } else if(tipo==='mantenimiento'){
    r.tiemClasif.mantenimiento=(r.tiemClasif.mantenimiento||0)+minutos;
  } else {
    var causaSel=G('tc-causa-'+rid);
    var causaId=causaSel?causaSel.value:'';
    var causaNombre=causaId?(S.causasMuerto.find(function(c){return c.id===causaId;})||{nombre:'Sin causa'}).nombre:'Sin causa';
    r.tiemClasif.muertos.push({causaId:causaId,causaNombre:causaNombre,min:minutos});
  }
