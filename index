  if(br)br.style.background=est==='rechazada'?'var(--erA)':'';
}
function _renderCalStars(){
  var c=G('cot-stars-input');if(!c)return;
  c.innerHTML='';
  for(var s=1;s<=5;s++){
    var sp=document.createElement('span');
    sp.textContent='★';
    sp.style.color=s<=_cotCalStars?'var(--or)':'var(--tx4)';
    sp.style.cursor='pointer';
    sp.setAttribute('data-s',s);
    sp.onclick=(function(val){return function(){_cotCalStars=val;_renderCalStars();};})(s);
    c.appendChild(sp);
  }
}
function saveCotCalificacion(){
  var id=G('cot-cal-id').value;
  var c=S.cotizaciones.find(function(x){return x.id===id;});if(!c)return;
  c.estado=_cotCalEstado==='pendiente'?'pendiente':_cotCalEstado;
  c.estrellas=_cotCalStars;
  saveCotizacionesDB();
  cmo('ov-cot-calificar');_renderCotKPIs();_renderCotTabla();
