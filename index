  // NIVEL 1: BLOQUEAR — las Auto-OTs de inspección SIEMPRE vienen de un check list
  var contenido='<div style="background:var(--bg2);border-radius:8px;padding:12px;margin-bottom:11px;border-left:3px solid var(--er)">';
  contenido+='<div style="font-family:var(--M);font-size:10px;color:var(--tx2);margin-bottom:6px">AUTO-OT GENERADA POR INSPECCIÓN:</div>';
  contenido+='<div style="font-size:13px;color:var(--tx1);font-weight:700">'+(ot.numero||'')+' · '+(ot.equipo||ot.comp||'')+'</div>';
  if(ot.punto)contenido+='<div style="font-family:var(--M);font-size:10px;color:var(--tx3);margin-top:4px">📍 '+ot.punto+'</div>';
  contenido+='<div style="font-family:var(--M);font-size:10px;color:var(--tx3);margin-top:4px">📅 '+(ot.fecha||'')+'</div>';
