  // NIVEL 3: confirmación simple
  var contenido='<div style="background:var(--bg2);border-radius:8px;padding:11px;margin-bottom:11px">';
  contenido+='<div style="font-family:var(--M);font-size:10px;color:var(--tx2);margin-bottom:6px">CONDUCTOR A ELIMINAR:</div>';
  contenido+='<div style="font-size:13px;color:var(--tx1);font-weight:700">👤 '+cond.nombre+(cond.placa?' · '+cond.placa:'')+'</div>';
  contenido+='</div>';
  contenido+='<div style="background:var(--okA);border-radius:7px;padding:10px;margin-bottom:11px">';
  contenido+='<div style="font-family:var(--M);font-size:10px;color:var(--ok);line-height:1.6">✓ Sin historial registrado, se puede eliminar sin riesgo.</div>';
  contenido+='</div>';
