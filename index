function _dashKPIs(){
  var c=G('dash-kpis-main');if(!c)return;
  var hoy=today();
  // Producción hoy — igual que updPKPI: suma r.dist[].m3
  var m3Hoy=0,nProd=0;
  (S.prod.records||[]).forEach(function(r){
    if(r.fecha!==hoy||r.pendienteClasif)return;
    var hasDist=false;
    (r.dist||[]).forEach(function(d){if(d.ptId&&d.m3>0){m3Hoy+=d.m3;hasDist=true;}});
    if(hasDist)nProd++;
  });
  // Extracción hoy — igual que updXKPI: suma r.tm directamente (cada rec es un alm distinto)
  var m3Exp=0,nExp=0;
  (S.exp.records||[]).forEach(function(r){
    if(r.fecha!==hoy||r.pp||r.provId==='sys_ini')return;
    m3Exp+=(r.tm||0); nExp++;
  });
  // Despacho hoy — igual que updDKPI: suma r.tm
  var m3Desp=0,nDesp=0;
  (S.desp.records||[]).forEach(function(r){
    if(r.fecha!==hoy)return;
    m3Desp+=(r.tm||0); nDesp++;
  });
  // OTs abiertas
  var otAbiertas=(S.mantOrdenes||[]).filter(function(o){return o.estado==='creada'||o.estado==='en_proceso';}).length;
  // Alertas activas
  var alertas=_lubGetAlertas().filter(function(a){return a.tipo==='er';}).length;
  // Disponibilidad turno actual
  var ultProd=(S.prod.records||[]).filter(function(r){return r.fecha===hoy;}).slice(-1)[0];
  var disp=ultProd&&ultProd.tiemClasif?_calcDisp(ultProd.tiemClasif):null;
  c.innerHTML=
    _dashKPI('Extracción Hoy',m3Exp.toFixed(1),'m³',nExp+' registros','or')
    +_dashKPI('Producción Hoy',m3Hoy.toFixed(1),'m³',nProd+' turnos','in')
    +_dashKPI('Despacho Hoy',m3Desp.toFixed(1),'m³',nDesp+' despachos','ok')
    +_dashKPI('OT Abiertas',otAbiertas,'',otAbiertas>0?'Requieren atención':'Todo al día',otAbiertas>0?'er':'ok')
    +_dashKPI('Alertas Activas',alertas,'',alertas>0?'Ver lubricación':'Sin alertas',alertas>0?'er':'ok')
    +_dashKPI('Disponibilidad',disp!==null?disp+'%':'—','',disp!==null?(disp>=80?'✅ Óptimo':disp>=70?'⚠️ Aceptable':'🔴 Bajo objetivo'):'Sin turno hoy',disp===null?'tx3':disp>=80?'ok':disp>=70?'wa':'er');

  // ── KPIs mensuales comparativos (mes actual vs mes anterior) ──
  var kc=G('dash-kpis-mes');if(!kc)return;
  var now=new Date();
  var yrAct=now.getFullYear(),moAct=String(now.getMonth()+1).padStart(2,'0');
  var prevDate=new Date(now.getFullYear(),now.getMonth()-1,1);
  var yrPrev=prevDate.getFullYear(),moPrev=String(prevDate.getMonth()+1).padStart(2,'0');
  var prefAct=yrAct+'-'+moAct, prefPrev=yrPrev+'-'+moPrev;
  var mesLbl=['','Ene','Feb','Mar','Abr','May','Jun','Jul','Ago','Sep','Oct','Nov','Dic'];
  var lblAct=mesLbl[parseInt(moAct)]+'-'+String(yrAct).slice(2);
  var lblPrev=mesLbl[parseInt(moPrev)]+'-'+String(yrPrev).slice(2);

  function sumMes(arr,prefix,field){
    return(arr||[]).filter(function(r){return r.fecha&&r.fecha.startsWith(prefix);})
      .reduce(function(a,r){return a+(parseFloat(r[field])||0);},0);
  }
  function sumProdMes(prefix){
    var tot=0;
    (S.prod.records||[]).filter(function(r){return r.fecha&&r.fecha.startsWith(prefix)&&!r.pendienteClasif;})
      .forEach(function(r){(r.dist||[]).forEach(function(d){if(d.ptId&&d.m3>0)tot+=d.m3;});});
    return tot;
  }
  var prodAct=sumProdMes(prefAct);
  var prodPrev=sumProdMes(prefPrev);
  // Explotación mensual — igual que updXKPI: suma r.tm directamente
  function sumExpMes(prefix){
    var tot=0;
    (S.exp.records||[]).forEach(function(r){
      if(r.fecha&&r.fecha.startsWith(prefix)&&!r.pp&&r.provId!=='sys_ini')tot+=(r.tm||0);
    });
    return tot;
  }
  var expAct=sumExpMes(prefAct);
  var expPrev=sumExpMes(prefPrev);
  var despAct=sumMes(S.desp.records,prefAct,'tm');
  var despPrev=sumMes(S.desp.records,prefPrev,'tm');

  function tendBadge(act,prev){
    if(!prev||!act)return'';
    var d=((act-prev)/prev*100);
    var col=d>=0?'var(--ok)':'var(--er)';
    var ico=d>=0?'▲':'▼';
    return'<span style="font-family:var(--M);font-size:9px;color:'+col+';margin-left:4px">'+ico+' '+Math.abs(d).toFixed(1)+'%</span>';
  }
  function kpiMes(label,act,prev,lAct,lPrev){
    var t=tendBadge(act,prev);
    return'<div style="background:var(--bg2);border:1px solid var(--bd2);border-radius:10px;padding:12px 14px;min-width:140px;flex:1">'
      +'<div style="font-family:var(--M);font-size:7px;color:var(--tx3);letter-spacing:1px;margin-bottom:6px">'+label+'</div>'
      +'<div style="display:flex;align-items:baseline;gap:4px">'
      +'<span style="font-family:var(--M);font-size:22px;font-weight:900;color:var(--tx1)">'+act.toFixed(0)+'</span>'
      +'<span style="font-family:var(--M);font-size:10px;color:var(--tx3)">m³</span>'
      +t
      +'</div>'
      +'<div style="margin-top:6px;padding-top:6px;border-top:1px solid var(--bd2);display:flex;justify-content:space-between">'
      +'<div style="font-family:var(--M);font-size:8px;color:var(--or)">'+(lAct||'')+'<br><span style="color:var(--tx1);font-size:10px">'+act.toFixed(0)+'</span></div>'
      +'<div style="font-family:var(--M);font-size:8px;color:var(--tx3);text-align:right">'+(lPrev||'')+'<br><span style="font-size:10px">'+prev.toFixed(0)+'</span></div>'
      +'</div>'
      +'</div>';
  }
  kc.innerHTML='<div style="font-family:var(--M);font-size:8px;color:var(--tx3);letter-spacing:1px;margin-bottom:8px">COMPARATIVO MENSUAL — <span style="color:var(--or)">'+lblAct+'</span> vs '+lblPrev+'</div>'
    +'<div style="display:flex;gap:10px;flex-wrap:wrap">'
    +kpiMes('EXPLOTACIÓN',expAct,expPrev,lblAct,lblPrev)
    +kpiMes('PRODUCCIÓN',prodAct,prodPrev,lblAct,lblPrev)
    +kpiMes('DESPACHO',despAct,despPrev,lblAct,lblPrev)
    +'</div>';
}
function _calcDisp(tc){
  var op=parseFloat(tc.operado)||0;var mu=parseFloat(tc.muertos)||0;var mn=parseFloat(tc.mantenimiento)||0;
  var total=op+mu+mn;return total>0?Math.round((op/total)*100):0;
}

