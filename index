function _renderCondHistorial(c){
  var html='<div style="font-size:15px;font-weight:700;margin-bottom:12px">Historial de Viajes por Conductor</div>';
  var conds=S.conductores||[];
  if(!conds.length){html+='<div style="color:var(--tx3);text-align:center;padding:30px">Sin conductores.</div>';c.innerHTML=html;return;}
  html+='<div class="tw"><table><thead><tr><th>Conductor</th><th>Tipo</th><th>Destino</th><th style="text-align:center">Viajes</th><th style="text-align:right">Valor est.</th></tr></thead><tbody>';
  conds.forEach(function(cond){
    var viajes=_getViajesConductor(cond.id);
    if(!viajes.length)return;
    var dests=S.conductoresConfig&&S.conductoresConfig.destinos||[];
    viajes.forEach(function(v){
      var dest=dests.find(function(d){return v.destino.includes(d.nombre)||d.nombre.includes(v.destino);});
      var valor=dest?(v.cantidad*dest.precio):0;
