function clasificarOrden(rid){
  var r=S.prod.records.find(function(x){return x.id===rid;});
  if(!r)return;
  var eqId=gv('pord-eq-'+rid);
  var opId=gv('pord-op-'+rid);
  var alertId='pord-alert-'+rid;
  if(!eqId){showAlert(alertId,'er','⚠️ Debe seleccionar el Equipo de Trituración para clasificar.');return;}
  if(!opId){showAlert(alertId,'er','⚠️ Debe seleccionar el Operador para clasificar.');return;}
  // FIX: Preservar fuenteId al reconstruir fuentes
  var fuentes=r.fuentes&&r.fuentes.length?r.fuentes:[{alm:'patio',m3:r.fuenteM3||0,fuenteId:r.fuenteId||'sys_patio'}];
  var almMax={patio:4,tolva:4,zaranda:2};
  var dist=[];
  fuentes.forEach(function(f){
    var maxT=almMax[f.alm]||4;
    for(var i=1;i<=maxT;i++){
      var ptId=gv('pord-pt-'+rid+'-'+f.alm+'-'+i);
      var pct=parseFloat(gv('pord-pct-'+rid+'-'+f.alm+'-'+i))||0;
      if(ptId&&pct>0)dist.push({key:f.alm+'-'+i,alm:f.alm,ptId:ptId,pct:pct,m3:f.m3*pct/100});
    }
  });
  var ini=gv('pord-hi-'+rid),fin=gv('pord-hf-'+rid);
  var dh=parseInt(gv('pord-dh-'+rid))||0,dm2=parseInt(gv('pord-dm-'+rid))||0;
  var desMin=dh*60+dm2;
  var netMin=ini&&fin?toMin(fin)-toMin(ini)-desMin:0;
  if(netMin<0)netMin+=1440;
  r.equipoId=eqId;r.operadorId=opId;
  r.ini=ini;r.fin=fin;r.des=pad(dh)+':'+pad(dm2);
  r.netMin=netMin;r.netas=mFmt(netMin);
  // FIX: NO resetear r.tm si dist está vacío
  if(dist.length>0)r.tm=dist.reduce(function(s,d){return s+d.m3;},0);
  // FIX: NO resetear r.dist si está vacío
  if(dist.length>0)r.dist=dist;
  r.pendienteClasif=false;
  // FIX: Preservar fuenteId original si no existía
  if(!r.fuenteId&&fuentes.length>0&&fuentes[0].fuenteId)r.fuenteId=fuentes[0].fuenteId;
  // Recalcular fuentes[] con los m3 REALES usados en esta orden (suma por alm desde dist)
  // SOLO si hay dist nuevo; si no, preservar las fuentes originales
  if(dist.length>0){
    var fuenteMap={};
    dist.forEach(function(d){
      if(!fuenteMap[d.alm])fuenteMap[d.alm]=0;
      fuenteMap[d.alm]+=d.m3;
    });
    // FIX: Mantener fuenteId, vj y m3v de la fuente original, actualizar m3 real
    r.fuentes=fuentes.map(function(f){
      var m3real=fuenteMap[f.alm]||0;
      return{alm:f.alm,vj:f.vj||0,m3v:f.m3v||14,m3:m3real,fuenteId:f.fuenteId||r.fuenteId};
    }).filter(function(f){return f.m3>0;});
    r.fuenteM3=r.fuentes.reduce(function(s,f){return s+f.m3;},0);
  }
  // FIX: Si no hay fuenteM3, recalcular desde las fuentes originales
  if(!r.fuenteM3||r.fuenteM3===0){
    r.fuenteM3=fuentes.reduce(function(s,f){return s+(f.m3||0);},0);
  }
  dbSaveProd(r);updPKPI();renderProdOrdenes();
  var al=G('pa');
  if(al){al.className='alert alert-ok on';al.textContent='✅ Orden clasificada: '+dist.length+' transformación(es) guardadas.';setTimeout(function(){al.className='alert';},3500);}
}

