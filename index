  // ES5 compatible: find index of manual product
  var manuals=S.prodTerm.filter(function(p){return!isSysId(p.id);});
  var idx=0;
  for(var i=0;i<manuals.length;i++){if(manuals[i].id===id){idx=i;break;}}
