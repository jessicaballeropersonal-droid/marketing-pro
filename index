function bitMCalc(){
  var ini=parseFloat(gv('bit-m-hini'))||0,fin=parseFloat(gv('bit-m-hfin'))||0;
  var acpm=parseFloat(gv('bit-m-acpm'))||0,vj=parseInt(gv('bit-m-vj'))||0;
