function renderDashboardEjecutivo(){
  var wrap=G('pg-dashboard-wrap');if(wrap)wrap.style.display='flex';
  var c=G('dash-content');if(!c)return;
  var now=new Date();
  var ts=G('dash-last-update');
  if(ts)ts.textContent='Actualizado: '+now.toLocaleTimeString('es-CO',{hour:'2-digit',minute:'2-digit'});

  // ── Calcular KPIs ──
  var hoy=today();
  // Producción hoy
  // Producción hoy — igual que updPKPI: suma dist[].m3
  var m3Hoy=0,nProd=0;
  (S.prod.records||[]).forEach(function(r){
    if(r.fecha!==hoy||r.pendienteClasif)return;
    var ok=false;
    (r.dist||[]).forEach(function(d){if(d.ptId&&d.m3>0){m3Hoy+=d.m3;ok=true;}});
    if(ok)nProd++;
  });
  // Extracción hoy — igual que updXKPI: suma r.tm
  var expM3Hoy=0,nExp=0;
  (S.exp.records||[]).forEach(function(r){
    if(r.fecha!==hoy||r.pp||r.provId==='sys_ini')return;
    expM3Hoy+=(r.tm||0); nExp++;
  });
  // Despacho hoy — igual que updDKPI: suma r.tm
  var despM3Hoy=0,nDesp=0;
  (S.desp.records||[]).forEach(function(r){
    if(r.fecha!==hoy)return;
    despM3Hoy+=(r.tm||0); nDesp++;
  });
  // OT abiertas
  var otAbiertas=(S.mantOrdenes||[]).filter(function(o){return o.estado==='creada'||o.estado==='en_proceso';}).length;
  var otCriticas=(S.mantOrdenes||[]).filter(function(o){return (o.estado==='creada'||o.estado==='en_proceso')&&o.sev==='critica';}).length;
  // Disponibilidad hoy — igual que _dashKPIs: usa tiemClasif de prod_records
  var dispProm=null;
  var prodConTiem=(S.prod.records||[]).filter(function(r){return r.fecha===hoy&&r.tiemClasif;});
  if(prodConTiem.length){
    var dispSum=0;
    prodConTiem.forEach(function(r){dispSum+=_calcDisp(r.tiemClasif);});
    dispProm=Math.round(dispSum/prodConTiem.length);
  }
  // Alertas lubricación
  var lubAlertas=typeof _lubGetAlertas==='function'?_lubGetAlertas().filter(function(a){return a.tipo==='er';}).length:0;
  // Planes vencidos
  var planesVenc=(S.mantPlanes||[]).filter(function(p){return p.proximaFecha&&p.proximaFecha<hoy&&p.estado!=='completado';}).length;
  // Inventario bajo mínimo
  var invBajo=0;
  // Tareas vencidas
  var tareasVenc=(S.tareas||[]).filter(function(t){return t.fecha_vencimiento&&t.fecha_vencimiento<hoy;}).length
    +(S.tareasOficina||[]).filter(function(t){return t.fecha_vencimiento&&t.fecha_vencimiento<hoy;}).length;

  // ── HTML ──
  var html='';

  // KPI row 1 — Operación
  html+='<div style="font-family:var(--M);font-size:8px;color:var(--tx3);letter-spacing:1px;margin-bottom:8px">OPERACIÓN HOY — '+fd(hoy)+'</div>';
