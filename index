// ── Helpers ────────────────────────────────────────────────────────
// === Modelo 2 columnas de gasto (v172.58) ===
// mes.costos[sec][id] puede ser número (legado) o {a,b}. Valor = a+b.
function _iadmAB(mes,sec,id){
  var v=(mes.costos&&mes.costos[sec])?mes.costos[sec][id]:null;
  if(v&&typeof v==='object')return {a:parseFloat(v.a)||0,b:parseFloat(v.b)||0};
  return {a:parseFloat(v)||0,b:0};
}
function _iadmCostoVal(mes,sec,id){var ab=_iadmAB(mes,sec,id);return ab.a+ab.b;}
function _iadmColNames(sec){
