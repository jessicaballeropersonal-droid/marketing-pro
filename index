function renderProdOrdenes(){
  var fecha=gv('prod-ord-fecha')||today();
  var el=G('prod-ord-body');if(!el)return;
  var pendientes=S.prod.records.filter(function(r){
    if(r.fecha!==fecha)return false;
    if(r.pendienteClasif)return true;
    // Also show records that have no equipo and no real dist (never classified)
    var hasRealDist=r.dist&&r.dist.some(function(d){return d.ptId&&d.m3>0;});
    if(!r.equipoId&&!hasRealDist&&r.fuenteM3>0)return true;
    return false;
  });
