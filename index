  dbSaveAlertasCfg();renderAlertasCfg();
}
function editAlertaCustom(id){
  var ca=(S.alertasCfg._custom||[]).find(function(a){return a.id===id;});if(!ca)return;
  var nombre=prompt('Nombre:',ca.nombre);if(!nombre)return;
  var desc=prompt('Descripción:',ca.desc);if(!desc)return;
  var umbralStr=prompt('Umbral:',ca.umbral||'');
  ca.nombre=nombre;ca.desc=desc;
  ca.umbral=umbralStr?parseFloat(umbralStr):0;
