function confirmarLiquidacion(condId,total,totalViajes){
  var desde=G('liq-desde')?G('liq-desde').value:_addDays(today(),-30);
  var hasta=G('liq-hasta')?G('liq-hasta').value:today();
  cc('¿Confirmar liquidación por $'+Math.round(total).toLocaleString('es-CO')+'? El período quedará registrado.',function(){
    if(!S.conductoresLiq)S.conductoresLiq=[];
    S.conductoresLiq.push({
      id:uid(),conductorId:condId,desde:desde,hasta:hasta,
      total:total,totalViajes:totalViajes,fechaLiq:today(),
      creadoPor:SESION?SESION.nombre:'—',editado:false,
    });
    dbSaveConductores();cmo('ov-cond-liq');_renderCondLiquidaciones(G('cond-content'));
  });
}

