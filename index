  // Verificar dependencias
  var viajes=(S.ctrlViajes||[]).filter(function(v){return v.condId===id||v.conductorId===id;});
  var liqs=(S.liquidacionesCond||[]).filter(function(l){return l.condId===id||l.conductorId===id;});
  var bitsAsoc=(S.mantBitacoras||[]).filter(function(b){return b.conductorTurno===id;});
