    return'<div style="display:flex;align-items:center;gap:12px;padding:11px 13px;background:var(--bg2);border:1px solid var(--bd2);border-radius:8px">'      +'<span style="font-size:20px">'+d.ico+'</span>'      +'<div style="flex:1;font-size:13px;font-weight:700">'+d.nombre+'</div>'      +'<div style="display:flex;align-items:center;gap:7px">'      +'<input type="number" value="'+precio+'" min="0" style="width:130px;height:32px;border:1px solid var(--bd2);border-radius:6px;padding:0 10px;font-size:13px;font-weight:700;color:var(--ok);text-align:right" onchange="_savePrecioFijo(\''+d.key+'\',this.value)">'      +'<span style="font-family:var(--M);font-size:9px;color:var(--tx3)">$/viaje</span>'      +'</div>'      +'</div>';
  }).join('');
}
function _savePrecioFijo(key,val){
  if(!S.conductoresConfig)S.conductoresConfig={};
  if(!S.conductoresConfig.preciosFijos)S.conductoresConfig.preciosFijos={};
  S.conductoresConfig.preciosFijos[key]=parseFloat(val)||0;
  dbSaveConductores();
  var al=G('dest-alert');
  if(al){al.className='alert alert-ok on';al.textContent='✅ Precio guardado.';setTimeout(function(){al.className='alert';},2000);}
}

