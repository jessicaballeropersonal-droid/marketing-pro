// v172.13: Cuando cambia el material en una fila, buscar el PT y poner el precio correspondiente
function _cotAutofillPrecio(i){
  var sel=G('cf-mat-'+i);var precInp=G('cf-precio-'+i);
  if(!sel||!precInp)return;
  var nombreMat=sel.value;
  if(!nombreMat)return; // material custom o vacío → no tocar
  var pt=S.prodTerm.find(function(p){return p.nombre===nombreMat;});
  if(!pt)return;
  var ivaMode=G('cot-iva')?G('cot-iva').value:'con_iva';
  var pref=S.preciosRef||{};
  var precio=ivaMode==='sin_iva'
    ? (pref[pt.id+'_sin']||0)
    : (pref[pt.id+'_con']||pref[pt.id]||0);
  if(precio>0)precInp.value=precio;
  // v172.14: recalcular subtotal y totales después de actualizar precio
  onCotCantChange();
}
// v172.13: Cuando cambia el modo IVA, recalcular precios de TODAS las filas
// que tengan material seleccionado (preserva precios custom de filas sin material PT)
function onCotIvaChange(){
  var i=0;
  while(G('cot-fila-'+i)){
    var sel=G('cf-mat-'+i);
    if(sel&&sel.value){
      // Es material PT — recalcular precio según nuevo modo IVA
      _cotAutofillPrecio(i);
    }
    // Si es custom (sel.value vacío), no tocar el precio escrito manualmente
    i++;
  }
  // v172.14: Recalcular totales (cambia rótulo según IVA y suma IVA)
  _cotRecalcTotales();
}
