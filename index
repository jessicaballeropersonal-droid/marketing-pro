function saveFungEqCambio(){
  var al=G('feq-cambio-alert');
  var fecha=gv('feq-c-fecha');var eqId=gv('feq-c-eq');var piezaId=gv('feq-c-pieza');
  var precio=parseFloat(G('feq-c-precio').value)||0;
  var causa='—';
  if(!fecha||!eqId||!piezaId){al.className='alert alert-er on';al.textContent='⚠️ Complete fecha, equipo y pieza.';return;}
  var info=feqGetLastHoroOdo(eqId,fecha);
  // Find previous cambio of same pieza+equipo to calculate duration
  var prevCambios=S.fungCambiosEq.filter(function(c){return c.piezaId===piezaId&&c.eqId===eqId;});
  prevCambios.sort(function(a,b){return b.fecha.localeCompare(a.fecha);});
  var prev=prevCambios[0]||null;
  var durHoras=null,durKm=null;
  if(prev&&info.horom!=null&&prev.horom!=null)durHoras=Math.max(0,parseFloat(info.horom)-parseFloat(prev.horom));
  if(prev&&info.odo!=null&&prev.odo!=null)durKm=Math.max(0,parseFloat(info.odo)-parseFloat(prev.odo));
  // Close previous cambio with duration
  if(prev){prev.durHoras=durHoras;prev.durKm=durKm;prev.fechaFin=fecha;}
  var cambio={id:uid(),fecha:fecha,eqId:eqId,piezaId:piezaId,horom:info.horom,odo:info.odo,
    precio:precio,causa:'—',obs:G('feq-c-obs').value.trim(),
    durHoras:null,durKm:null,fechaFin:null,pausas:[],estadoPieza:'activo'};
  if(!S.fungCambiosEq)S.fungCambiosEq=[];
  S.fungCambiosEq.push(cambio);dbSaveFungCambioEq(cambio);if(prev)dbSaveFungCambioEq(prev);
  al.className='alert alert-ok on';al.textContent='✅ Cambio registrado correctamente.';
  G('feq-c-pieza').value='';G('feq-c-precio').value='';G('feq-c-obs').value='';
  G('feq-pieza-info').style.display='none';
  setTimeout(function(){al.className='alert';},2500);
}

