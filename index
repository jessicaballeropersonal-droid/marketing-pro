      if(q.transporte_viajes)html+='• Transporte: <b style="color:var(--ok)">'+_rastEsc(q.transporte_viajes)+' viajes</b>';
      html+='</div>';
      if(q.metodo)html+='<div style="font-size:8px;color:var(--tx3);font-style:italic;margin-top:3px;font-family:var(--M)">Método: '+_rastEsc(q.metodo)+'</div>';
      html+='</div>';
    }
    // Materiales probables (mapa fijo + IA) — sin cantidad exacta
    if(a.materiales_estimados&&a.materiales_estimados.lista&&a.materiales_estimados.lista.length){
      var me=a.materiales_estimados;
      var bandaTxt=me.banda==='grande'?'Grande':(me.banda==='mediana'?'Mediana':(me.banda==='chica'?'Chica':'—'));
      html+='<div style="background:#FFF8F3;border-radius:6px;padding:7px 9px;margin-top:7px;border-left:2px solid var(--or)">';
      html+='<div style="font-size:8px;color:var(--wa);font-weight:700;letter-spacing:.5px;font-family:var(--M);margin-bottom:4px">🧱 MATERIALES PROBABLES · OBRA '+bandaTxt.toUpperCase()+'</div>';
      html+='<div style="font-size:11px;color:var(--tx1);font-family:var(--M);line-height:1.6">'+me.lista.map(function(x){return'<span style="display:inline-block;background:#fff;border:0.5px solid #F0A867;border-radius:8px;padding:1px 7px;margin:1px">'+_rastEsc(x)+'</span>';}).join(' ')+'</div>';
      html+='<div style="font-size:8px;color:var(--tx3);font-style:italic;margin-top:4px;font-family:var(--M)">'+(me.metodo==='ia'?'Deducido por IA':'Deducido por palabras')+' · sin cantidad exacta (mírala en el Detalle)</div>';
      html+='</div>';
    }
  }else{
    // Modo Licitar
    html+='<div style="background:linear-gradient(135deg,#FBEAF0,#FFD9E6);border:1px solid #E89BB7;border-radius:7px;padding:9px 10px;margin-bottom:8px">';
    html+='<div style="font-size:8px;color:#72243E;font-weight:700;letter-spacing:1px;font-family:var(--M);margin-bottom:3px">🎯 PROCESO ABIERTO PARA OFERTAR</div>';
    html+='<div style="font-size:13px;font-weight:700;color:#4B1528;line-height:1.25">'+_rastEsc(a.titulo||'?')+'</div>';
    if(a.id_proceso||a.modalidad)html+='<div style="font-size:10px;color:var(--tx2);margin-top:3px;font-family:var(--M)">'+(a.id_proceso?'Proceso: '+_rastEsc(a.id_proceso):'')+(a.id_proceso&&a.modalidad?' · ':'')+(a.modalidad?_rastEsc(a.modalidad):'')+'</div>';
    html+='</div>';
    if(a.fecha_cierre)html+='<div style="background:#FCEBEB;color:#791F1F;font-size:10px;padding:5px 9px;border-radius:6px;margin:7px 0;display:flex;justify-content:space-between;align-items:center;font-family:var(--M);font-weight:600"><span>⏰ Cierre:</span><b>'+_rastEsc(a.fecha_cierre)+'</b></div>';
    html+='<div style="font-size:10px;color:var(--tx2);margin-bottom:3px"><b>Entidad:</b> '+_rastEsc(a.entidad||'?')+'</div>';
    html+='<div style="font-size:10px;color:var(--tx2);margin-bottom:3px"><b>Municipio:</b> '+_rastEsc(a.municipio||'?')+'</div>';
    if(a.valor_estimado)html+='<div style="font-size:10px;color:var(--tx2);margin-bottom:3px"><b>Valor estimado:</b> <span style="color:var(--ok);font-weight:700;font-family:var(--M)">'+_rastFmt$(a.valor_estimado)+'</span></div>';
    // Requisitos
    if(a.requisitos){
      var r=a.requisitos;
      html+='<div style="background:#EFF6FC;border-radius:6px;padding:7px 9px;margin-top:7px;border-left:2px solid var(--in)">';
      html+='<div style="font-size:8px;color:var(--in);font-weight:700;letter-spacing:.5px;font-family:var(--M);margin-bottom:3px">📋 REQUISITOS CLAVE</div>';
      html+='<div style="font-size:10px;color:var(--tx1);font-family:var(--M);line-height:1.5">';
      if(r.rup_unspsc&&r.rup_unspsc.length)html+='• RUP UNSPSC: <b>'+r.rup_unspsc.join(', ')+'</b><br>';
      if(r.experiencia)html+='• Experiencia: '+_rastEsc(r.experiencia)+'<br>';
      if(r.capacidad_K)html+='• Capacidad K: <b>'+_rastEsc(r.capacidad_K)+'</b><br>';
      if(r.garantia_pct)html+='• Garantía: <b>'+_rastEsc(r.garantia_pct)+'%</b>';
      html+='</div></div>';
