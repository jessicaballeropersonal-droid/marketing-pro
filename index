  dbSaveAlertasCfg();renderAlertasCfg();
}
function delAlertaCustom(id){
  cc('¿Eliminar esta alerta personalizada?',function(){
    S.alertasCfg._custom=(S.alertasCfg._custom||[]).filter(function(a){return a.id!==id;});
    delete S.alertasCfg[id];
    dbSaveAlertasCfg();renderAlertasCfg();
  });
}

function saveWAConfig(){
  if(!S.alertasCfg)S.alertasCfg={};
  S.alertasCfg._api={
    instancia:G('wa-instancia').value.trim(),
