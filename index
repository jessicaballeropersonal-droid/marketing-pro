function _iadmTotalCostos(mes,seccion){
  var items=S.informeAdm.items[seccion]||[];
  var total=0;
  items.forEach(function(it){if(!it.archivado)total+=_iadmCostoVal(mes,seccion,it.id);});
  return total;
}
function _iadmTotalVentas(mes,key){
  // mes: el objeto del mes; key: 'YYYY-MM' para auto-calcular m³ desde despachos
  if(!key){
    // Compatibilidad: si no se pasa key, intentar deducirla
    for(var k in (S.informeAdm.meses||{})){if(S.informeAdm.meses[k]===mes){key=k;break;}}
  }
  if(!key)return 0;
  var autoVentas=_iadmAutoVentas(key);
  // Mapa rápido: ptId → {clienteId → m3}
  var autoMap={};
  autoVentas.forEach(function(a){autoMap[a.ptId]=a.m3PorCliente;});
  var total=0;
  (mes.ventas||[]).forEach(function(v){
    if(!v.ptId||!v.precios)return;
    var m3Cli=autoMap[v.ptId]||{};
    Object.keys(v.precios).forEach(function(clId){
      var pu=v.precios[clId]&&v.precios[clId].precioU||0;
      var m3=m3Cli[clId]||0;
      total+=m3*pu;
    });
  });
  return total;
}
function _fmn(v){return v?'$'+Math.round(v).toLocaleString('es-CO'):'—';}
function _fmm3(v){return v?Math.round(v).toLocaleString('es-CO')+' m³':'0 m³';}
function _fcpp(v,m3){return m3>0?'$'+(v/m3).toLocaleString('es-CO',{minimumFractionDigits:0,maximumFractionDigits:0})+'/m³':'—';}
// v172.66: formatea un $/m³ ya calculado (no divide)
function _fcppV(v){return v>0?'$'+v.toLocaleString('es-CO',{minimumFractionDigits:0,maximumFractionDigits:0})+'/m³':'—';}
// v172.66: $/m³ consolidado = SUMA de los $/m³ reales de cada ventana
// (Explotación ÷ m³ extraídos, Planta ÷ Total Producido, Adm ÷ Total Producido)
function _iadmCppConsol(tE,tP,tA,me,mp){
  var cE=me>0?tE/me:0, cP=mp>0?tP/mp:0, cA=mp>0?tA/mp:0;
  return cE+cP+cA;
}
// v172.67: formatea $/m³ con signo (permite negativos, p.ej. margen de contribución)
function _fcppS(v){var n=Math.round(v);return (n<0?'-$'+(-n).toLocaleString('es-CO'):'$'+n.toLocaleString('es-CO'))+'/m³';}
// v172.67: m³ VENDIDOS (despacho) de un mes 'YYYY-MM'
function _iadmM3Vendidos(key){
  if(!key)return 0;var s=0;
  (S.desp.records||[]).forEach(function(r){if(r.fecha&&r.fecha.indexOf(key)===0)s+=(r.tm||0);});
  return Math.round(s*100)/100;
}
// v172.67: promedio de m³ producidos entre los meses con datos (para detectar meses "raros")
function _iadmAvgProd(){
  var meses=(S.informeAdm&&S.informeAdm.meses)||{};var tot=0,n=0;
  Object.keys(meses).forEach(function(k){var info=_iadmGetM3(meses[k],k);if(info.total>0){tot+=info.total;n++;}});
  return n>0?tot/n:0;
}
// v172.67: cálculo central del Punto de Equilibrio del MES (modelo unitario por ventana)
//  - Precio/m³ = Ingresos ÷ m³ VENDIDOS (despacho del mes)
//  - Costo Variable/m³ = (var Explotación ÷ extraídos)+(var Planta ÷ producidos)+(var Adm ÷ producidos)
//  - Costos Fijos = monto total del mes (causado)
//  - PE = Fijos ÷ (Precio/m³ − CostoVar/m³)
function _iadmCalcPE(mes,key){
  var m3info=_iadmGetM3(mes,key);var mp=m3info.total,me=m3info.me;
  var varExpl=0,varPlanta=0,varAdm=0,fijos=0;
  ['expl','planta','adm'].forEach(function(sec){
    (S.informeAdm.items[sec]||[]).forEach(function(it){
      if(it.archivado)return;var v=_iadmCostoVal(mes,sec,it.id);
      if(it.tipo==='fijo'){fijos+=v;return;}
      if(sec==='expl')varExpl+=v;else if(sec==='planta')varPlanta+=v;else varAdm+=v;
    });
  });
  var varM3=(me>0?varExpl/me:0)+(mp>0?varPlanta/mp:0)+(mp>0?varAdm/mp:0);
  var m3vend=_iadmM3Vendidos(key);
  var tV=_iadmTotalVentas(mes,key);
  var precioM3=m3vend>0?tV/m3vend:0;
  var mc=precioM3-varM3;
  var pe=mc>0?Math.ceil(fijos/mc):0;
  var avg=_iadmAvgProd();
  var lowProd=(avg>0&&mp>0&&mp<0.3*avg);
  var noData=(m3vend<=0||mp<=0);
  return{mp:mp,me:me,fijos:fijos,varExpl:varExpl,varPlanta:varPlanta,varAdm:varAdm,
    variables:varExpl+varPlanta+varAdm,varM3:varM3,m3vend:m3vend,tV:tV,
    precioM3:precioM3,mc:mc,pe:pe,lowProd:lowProd,noData:noData};
}
// v172.67: Punto de Equilibrio ANUAL (acumulado del año) — promedia los meses
function _iadmCalcPEAnual(year){
  var meses=(S.informeAdm&&S.informeAdm.meses)||{};
  var fijos=0,varExpl=0,varPlanta=0,varAdm=0,meSum=0,mpSum=0,vendSum=0,ventas=0;
  Object.keys(meses).forEach(function(k){
    if(k.indexOf(year+'-')!==0)return;var mes=meses[k];var info=_iadmGetM3(mes,k);
    meSum+=info.me;mpSum+=info.total;vendSum+=_iadmM3Vendidos(k);ventas+=_iadmTotalVentas(mes,k);
    ['expl','planta','adm'].forEach(function(sec){
      (S.informeAdm.items[sec]||[]).forEach(function(it){
        if(it.archivado)return;var v=_iadmCostoVal(mes,sec,it.id);
        if(it.tipo==='fijo'){fijos+=v;return;}
        if(sec==='expl')varExpl+=v;else if(sec==='planta')varPlanta+=v;else varAdm+=v;
      });
    });
  });
  var varM3=(meSum>0?varExpl/meSum:0)+(mpSum>0?varPlanta/mpSum:0)+(mpSum>0?varAdm/mpSum:0);
  var precioM3=vendSum>0?ventas/vendSum:0;var mc=precioM3-varM3;
  var pe=mc>0?Math.ceil(fijos/mc):0;
  return{fijos:fijos,varM3:varM3,precioM3:precioM3,mc:mc,pe:pe,vend:vendSum,mp:mpSum,me:meSum,ventas:ventas,
    varExpl:varExpl,varPlanta:varPlanta,varAdm:varAdm};
}
