// Migración one-time: corrige fuentes[] en registros ya clasificados donde
// fuentes[] tenía los m3 del día completo en lugar de los m3 reales de la orden.
// Se reconstruye sumando dist[] por almacén y se persiste en Supabase.
function migrarFuentesDesdeDistClassificados(){
  S.prod.records.forEach(function(r){
    if(r.pendienteClasif)return;
    if(!r.equipoId)return;
    var distHasAlm=r.dist&&r.dist.some(function(d){return d.alm&&d.m3>0;});
    if(!distHasAlm)return;
    var fuenteMap={};
    r.dist.forEach(function(d){if(d.alm&&d.m3>0)fuenteMap[d.alm]=(fuenteMap[d.alm]||0)+d.m3;});
    var needsFix=false;
    (r.fuentes||[]).forEach(function(f){if(Math.abs(f.m3-(fuenteMap[f.alm]||0))>0.01)needsFix=true;});
    // También necesita fix si fuentes[] está vacío pero dist tiene alm
    if(!r.fuentes||!r.fuentes.length)needsFix=true;
    if(needsFix){
      r.fuentes=Object.keys(fuenteMap).map(function(alm){
        var orig=(r.fuentes||[]).find(function(f){return f.alm===alm;})||{};
        return{alm:alm,vj:orig.vj||0,m3v:orig.m3v||14,m3:fuenteMap[alm]};
      });
      r.fuenteM3=r.fuentes.reduce(function(s,f){return s+f.m3;},0);
      dbSaveProd(r);
    }
  });
}

