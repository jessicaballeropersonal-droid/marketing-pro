// Eliminar Componente de Mantenimiento — con verificación de uso
function delMantComp(tipo,comp){
  // Contar usos
  var anomalias=0,trabajos=0,ots=0,planes=0;
  (S.mantBitacoras||[]).forEach(function(b){
    (b.anomalias||[]).forEach(function(a){if(a.comp===comp)anomalias++;});
    (b.trabajos||[]).forEach(function(t){if(t.comp===comp)trabajos++;});
  });
  (S.mantOrdenes||[]).forEach(function(o){if(o.comp===comp)ots++;});
  (S.mantPlanes||[]).forEach(function(p){if(p.comp===comp)planes++;});
  var total=anomalias+trabajos+ots+planes;
  var tipoLbl={volqueta:'Volqueta',excavadora:'Excavadora',cargador:'Cargador',planta:'Planta'}[tipo]||tipo;
  // NIVEL 1: BLOQUEAR si tiene uso
  if(total>0){
    var contenido='<div style="background:var(--bg2);border-radius:8px;padding:12px;margin-bottom:11px;border-left:3px solid var(--er)">';
    contenido+='<div style="font-family:var(--M);font-size:10px;color:var(--tx2);margin-bottom:6px">COMPONENTE:</div>';
    contenido+='<div style="font-size:13px;color:var(--tx1);font-weight:700">🔧 '+comp+' <span style="color:var(--tx3);font-size:11px">('+tipoLbl+')</span></div>';
    contenido+='</div>';
    contenido+='<div style="background:var(--erA);border-radius:7px;padding:11px;margin-bottom:11px">';
    contenido+='<div style="font-family:var(--M);font-size:9px;color:var(--er);margin-bottom:6px;font-weight:700">⚠️ ESTE COMPONENTE TIENE USO REGISTRADO:</div>';
    contenido+='<div style="font-family:var(--M);font-size:10px;color:var(--tx1);line-height:1.8">';
    if(anomalias>0)contenido+='<div>• '+anomalias+' anomalía(s) reportada(s)</div>';
    if(trabajos>0)contenido+='<div>• '+trabajos+' trabajo(s) ejecutado(s)</div>';
    if(ots>0)contenido+='<div>• '+ots+' Orden(es) de Trabajo</div>';
    if(planes>0)contenido+='<div>• '+planes+' Plan(es) de Mantenimiento Preventivo</div>';
    contenido+='</div></div>';
    contenido+='<div style="background:var(--inA);border-radius:7px;padding:10px">';
    contenido+='<div style="font-family:var(--M);font-size:10px;color:var(--in);line-height:1.6">Si elimina, los registros relacionados quedarían huérfanos con referencias rotas. Mejor renómbrelo o déjelo como está.</div>';
    contenido+='</div>';
    modalAviso({tipo:'danger',titulo:'No se puede eliminar el componente',subtitulo:'Está en uso',contenidoHtml:contenido,botonSecundario:'Entendido'});
    return;
  }
  // NIVEL 3: confirmación simple
  var contenido='<div style="background:var(--bg2);border-radius:8px;padding:11px;margin-bottom:11px">';
  contenido+='<div style="font-family:var(--M);font-size:10px;color:var(--tx2);margin-bottom:6px">COMPONENTE A ELIMINAR:</div>';
  contenido+='<div style="font-size:13px;color:var(--tx1);font-weight:700">🔧 '+comp+' <span style="color:var(--tx3);font-size:11px">('+tipoLbl+')</span></div>';
  contenido+='</div>';
  contenido+='<div style="background:var(--okA);border-radius:7px;padding:10px;margin-bottom:11px">';
  contenido+='<div style="font-family:var(--M);font-size:10px;color:var(--ok);line-height:1.6">✓ Sin uso registrado, se puede eliminar sin riesgo.</div>';
  contenido+='</div>';
  modalAviso({tipo:'warn',titulo:'Eliminar Componente',contenidoHtml:contenido,
    botonPrincipal:'🗑️ Eliminar',onPrincipal:function(){
      S.mantComponentes[tipo]=S.mantComponentes[tipo].filter(function(c){return c!==comp;});
      dbSaveMantComponentes();
      try{renderCompsMant();}catch(e){}
      modalAvisoClose();
    }});
}
