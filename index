    <div class="mo-body">
      <div class="fg ca" style="margin-bottom:11px">
        <div class="ff"><div class="fl">Nombre de la Pieza</div><input type="text" class="fi" id="feq-p-nombre" placeholder="Ej: Filtro de aire, Correa principal..."></div>
        <div class="ff"><div class="fl">Equipo(s) que aplica</div><select class="fs" id="feq-p-eq"><option value="">— Todos los equipos —</option></select></div>
      </div>
      <div class="fg c2" style="margin-bottom:11px">
