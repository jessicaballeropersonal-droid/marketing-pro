// Estado temporal de creación de ítems (no se guarda en S hasta confirmar)
var _IADM_NEW_ITEM_EXPL_PLACEHOLDER=null; // (variable dummy para mantener formato)
var _IADM_NEW_ITEM=null; // {seccion, nombre, tipo} mientras se está creando

function _iadmAddItem(seccion){
  // Si ya hay una fila nueva sin guardar, no hacer nada (evitar duplicados)
  if(_IADM_NEW_ITEM)return;
  _IADM_NEW_ITEM={seccion:seccion,nombre:'',tipo:'variable'};
  _renderIAdmTab(seccion);
  // Dar foco al input recién creado
  setTimeout(function(){
    var inp=document.getElementById('iadm-new-item-name');
    if(inp)inp.focus();
  },50);
}

function _iadmCancelNewItem(){
  _IADM_NEW_ITEM=null;
  var tab=document.querySelector('#pg-informe-adm-wrap .insp-tab.on');
  var tabId=tab?tab.id.replace('iadm-tab-',''):'planta';
  _renderIAdmTab(tabId);
}

function _iadmSaveNewItem(){
  if(!_IADM_NEW_ITEM)return;
  var nombreInput=document.getElementById('iadm-new-item-name');
  var valorInput=document.getElementById('iadm-new-item-valor');
  if(!nombreInput)return;
  var nombre=(nombreInput.value||'').trim();
  if(!nombre){
    nombreInput.focus();
    nombreInput.style.borderColor='var(--er)';
    return;
  }
  var seccion=_IADM_NEW_ITEM.seccion;
  var tipo=_IADM_NEW_ITEM.tipo||'variable';
  var valor=valorInput?(parseFloat(valorInput.value)||0):0;
  var valorBInput=document.getElementById('iadm-new-item-valorb');
  var valorB=valorBInput?(parseFloat(valorBInput.value)||0):0;
  _iadmEnsure();
  if(!S.informeAdm.items[seccion])S.informeAdm.items[seccion]=[];
  var newId=uid();
  S.informeAdm.items[seccion].push({id:newId,nombre:nombre,tipo:tipo,visible:true,archivado:false});
  // Si hay valor, guardarlo en el mes actual
  if(valor>0||valorB>0){
    var key=_iadmMesKey();
    var mes=_iadmGetMes(key);
    if(!mes.costos[seccion])mes.costos[seccion]={};
    mes.costos[seccion][newId]={a:valor,b:valorB};
  }
  _IADM_NEW_ITEM=null;
  _iadmSave();
  _renderIAdmTab(seccion);
}

// Toggle tipo Variable/Fijo del ítem nuevo (no persistido aún)
function _iadmToggleNewItemTipo(tipo){
  if(!_IADM_NEW_ITEM)return;
  _IADM_NEW_ITEM.tipo=tipo;
  // Re-render solo del toggle sin perder lo escrito
  var togFijo=document.getElementById('iadm-new-tog-fijo');
  var togVar=document.getElementById('iadm-new-tog-var');
  if(togFijo&&togVar){
    if(tipo==='fijo'){
      togFijo.className='iadm-tog-btn on fijo';
      togVar.className='iadm-tog-btn';
    }else{
      togVar.className='iadm-tog-btn on var';
      togFijo.className='iadm-tog-btn';
    }
  }
}

