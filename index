function delX(id){
  var r=S.exp.records.find(function(x){return x.id===id;});
  if(!r){return;}
  // NIVEL 1: BLOQUEO si vino de bitácora
  if(esExtDeBitacora(r)){
    var bitFechaTxt=r.fecha||'';
    var almName={patio:'Grava',tolva:'Tolva',zaranda:'Zaranda',arena_rio:'Arena Río',arena:'Arena Río'}[r.alm]||r.alm;
    var contenido='<div style="background:var(--bg2);border-radius:8px;padding:12px;margin-bottom:11px;border-left:3px solid var(--er)">';
    contenido+='<div style="font-family:var(--M);font-size:10px;color:var(--tx2);margin-bottom:6px">Este registro fue generado desde:</div>';
    contenido+='<div style="font-size:13px;color:var(--in);display:flex;align-items:center;gap:6px"><span>🔗</span><strong>Bitácora Operacional del '+bitFechaTxt+'</strong></div>';
    if(r.bitEqNombre)contenido+='<div style="font-family:var(--M);font-size:9px;color:var(--tx3);margin-top:4px">Equipo: '+r.bitEqNombre+'</div>';
    contenido+='</div>';
    contenido+='<div style="background:var(--erA);border-radius:7px;padding:10px;margin-bottom:11px">';
    contenido+='<div style="font-family:var(--M);font-size:9px;color:var(--er);margin-bottom:6px;font-weight:700">⚠️ SI ELIMINA AQUÍ SE DESCUADRA:</div>';
    contenido+='<div style="font-family:var(--M);font-size:10px;color:var(--tx1);line-height:1.6">';
    contenido+='• '+almName+': se devolvería '+(r.tm||0).toFixed(2)+' m³ al stock<br>';
    contenido+='• La Bitácora origen seguiría diciendo "se hicieron esos viajes"<br>';
    contenido+='• Las clasificaciones de producción quedarían sin origen';
    contenido+='</div></div>';
    contenido+='<div style="background:var(--inA);border-radius:7px;padding:10px">';
    contenido+='<div style="font-family:var(--M);font-size:10px;color:var(--in);line-height:1.6">Para eliminar correctamente, vaya a <strong>Bitácora Operacional</strong> y elimine el registro completo desde allí (cascada total).</div>';
    contenido+='</div>';
    modalAviso({tipo:'danger',titulo:'No se puede eliminar',subtitulo:'Registro vinculado a Bitácora',contenidoHtml:contenido,
      botonPrincipal:'🔗 Ir a Bitácora',onPrincipal:function(){irABitacoraDia(r.fecha);},botonSecundario:'Entendido'});
    return;
  }
  // NIVEL MANUAL: verificar si tiene clasificación asociada
  var infoOrdenes=extraccionManualTieneOrdenes(r);
  var tieneClasif=infoOrdenes.clasificadas.length>0;
  var tieneOrdenes=infoOrdenes.ordenes.length>0;

  // NIVEL 3: confirmación + revertir (manual)
  var contenido='<div style="background:var(--bg2);border-radius:8px;padding:11px;margin-bottom:11px">';
  contenido+='<div style="font-family:var(--M);font-size:10px;color:var(--tx2);margin-bottom:6px">REVERTIRÁ:</div>';
  contenido+=resumenRevExtraccion(r);
  contenido+='</div>';

  // ⚠️ AVISO DE CASCADA si la extracción manual tiene clasificación
  if(tieneClasif){
    var totalClasifM3=infoOrdenes.clasificadas.reduce(function(s,p){return s+(p.tm||0);},0);
    contenido+='<div style="background:var(--erA);border-radius:7px;padding:11px;margin-bottom:11px;border:1px solid var(--er)">';
    contenido+='<div style="font-family:var(--M);font-size:9px;color:var(--er);margin-bottom:8px;font-weight:700">⚠️ TAMBIÉN SE PERDERÁ EN CASCADA:</div>';
    contenido+='<div style="font-family:var(--M);font-size:10px;color:var(--tx1);line-height:1.7">';
    contenido+='• <strong>'+infoOrdenes.clasificadas.length+' clasificación(es) ya hechas</strong> en Historial Producción<br>';
    contenido+='• Total clasificado: <strong>'+totalClasifM3.toFixed(2)+' m³</strong><br>';
    contenido+='• Los Productos Terminados volverán al stock';
    contenido+='</div></div>';
  } else if(tieneOrdenes){
    contenido+='<div style="background:var(--waA);border-radius:7px;padding:10px;margin-bottom:11px;border:1px solid var(--wa)">';
    contenido+='<div style="font-family:var(--M);font-size:9px;color:var(--wa);margin-bottom:6px;font-weight:700">⚠️ También se cancelarán:</div>';
    contenido+='<div style="font-family:var(--M);font-size:10px;color:var(--tx1);line-height:1.6">';
    contenido+='• '+infoOrdenes.ordenes.length+' Orden(es) pendiente(s) en Producción';
    contenido+='</div></div>';
  }
  contenido+='<div style="font-size:12px;color:var(--tx2)">¿Confirma eliminar este registro de extracción manual?</div>';
  modalAviso({tipo:tieneClasif?'danger':'warn',titulo:'Eliminar Extracción Manual',contenidoHtml:contenido,
    botonPrincipal:'🗑️ Eliminar todo en cascada',onPrincipal:function(){
      // Capturar info antes
      var antes={fecha:r.fecha,proveedor:pn(r.provId),alm:r.alm,m3:r.tm,viajes:r.tv,ordenesAfectadas:infoOrdenes.ordenes.length,clasificacionesAfectadas:infoOrdenes.clasificadas.length};
      // Revertir extracción
      revertirExtraccion(r);
      // CASCADA: eliminar órdenes y clasificaciones manuales del mismo día+turno
      infoOrdenes.ordenes.forEach(function(p){
        // Si tenía clasificación, revertir PT al stock
        if(!p.pendienteClasif&&p.dist&&p.dist.length){
          try{revertirProduccion(p);}catch(e){}
        }
        S.prod.records=S.prod.records.filter(function(x){return x.id!==p.id;});
        try{dbDelProd(p.id);}catch(e){}
      });
      logActividad({accion:'eliminar',modulo:'extraccion',descripcion:'Eliminó Extracción Manual '+r.fecha+' · '+r.tm.toFixed(2)+' m³ (+ '+infoOrdenes.ordenes.length+' órdenes en cascada)',registroId:r.id,antes:antes});
      saveS();updXKPI();updPKPI();updDKPI();renderXH();renderPH();
      try{renderProdOrdenes();}catch(e){}
      modalAvisoClose();
    }});
}
