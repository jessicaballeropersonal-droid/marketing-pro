  if(!SESION||SESION.rol==='admin'){goTo('kanban');return;}
  // No-admin: abrir el primer módulo NORMAL permitido (no-overlay), para que el sidebar quede visible
  var perms=(S.permisos&&S.permisos[SESION.id])||{};
  for(var i=0;i<MODULOS_PERMISOS.length;i++){
    var mid=MODULOS_PERMISOS[i].id,p=perms[mid];
    if((p==='ver'||p==='todo'||p===true)&&_KG_OVERLAYS.indexOf(mid)<0){goTo(mid);return;}
  }
  // Solo tiene módulos de pantalla completa (ej. Calendario+Kanban): abrir el primero permitido
  for(var j=0;j<MODULOS_PERMISOS.length;j++){
    var oid=MODULOS_PERMISOS[j].id,po=perms[oid];
    if((po==='ver'||po==='todo'||po===true)&&_KG_OVERLAYS.indexOf(oid)>=0){goTo(oid);return;}
  }
  // Sin nada permitido: dejar el menú visible
  document.querySelectorAll('.nl').forEach(function(n){n.classList.remove('on');});
  document.querySelectorAll('.nl-m').forEach(function(n){n.classList.remove('on');});
}
