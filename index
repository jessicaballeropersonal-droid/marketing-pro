var _notFilter='all';
var _notNum=1;
function saveNotificacionesDB(){supaUpsert('config',{key:'notificaciones',value:JSON.stringify(S.notificaciones)});}

function _renderNotKPIs(){
  var c=G('not-kpis');if(!c)return;
  var total=S.notificaciones.length;
  var firm=S.notificaciones.filter(function(n){return n.firmada;}).length;
  var pend=total-firm;
  c.innerHTML='<div class="kpi wa"><div class="kpi-lbl">Pendientes firma</div><div class="kpi-val" style="color:var(--wa)">'+pend+'</div></div>'
    +'<div class="kpi ok"><div class="kpi-lbl">Firmadas</div><div class="kpi-val" style="color:var(--ok)">'+firm+'</div></div>'
    +'<div class="kpi in"><div class="kpi-lbl">Total</div><div class="kpi-val" style="color:var(--in)">'+total+'</div></div>';
}
function _renderNotLista(){
  var c=G('not-lista');if(!c)return;
  var q=(G('not-search')||{value:''}).value.toLowerCase();
  var list=S.notificaciones.slice().sort(function(a,b){return b.fecha.localeCompare(a.fecha);});
  if(_notFilter==='pendiente')list=list.filter(function(n){return!n.firmada;});
  if(_notFilter==='firmada')list=list.filter(function(n){return n.firmada;});
  if(q)list=list.filter(function(n){return(n.genera+n.notificado+n.instruccion).toLowerCase().includes(q);});
  if(!list.length){c.innerHTML='<div style="text-align:center;padding:32px;color:var(--tx3);font-size:13px">Sin notificaciones.</div>';return;}
  var isAdmin=puedeEditar('notificaciones');
  c.innerHTML=list.map(function(n){
    var estadoBdg=n.firmada
      ?'<span class="bdg bdg-ok">✅ Firmada</span>'
      :'<span class="bdg bdg-wa">⏳ Pendiente firma</span>';
    return'<div class="card" style="margin-bottom:10px;cursor:pointer" onclick="openNotDetalle(\''+n.id+'\')">'
      +'<div style="display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:8px">'
      +'<div>'
      +'<div style="font-family:var(--M);font-size:8px;color:var(--tx3);margin-bottom:3px">NOT-'+n.num+' · '+fd(n.fecha)+'</div>'
      +'<div style="font-weight:700;font-size:13px;color:var(--tx1)">'+n.genera+' → '+n.notificado+'</div>'
      +'</div>'
      +estadoBdg
      +'</div>'
      +'<div style="font-size:12px;color:var(--tx2);line-height:1.5;max-height:40px;overflow:hidden">'+n.instruccion+'</div>'
      +'</div>';
  }).join('');
}
function limpiarFirmaNew(){
  var c=G('not-firma-canvas');
  if(c){var ctx=c.getContext('2d');ctx.clearRect(0,0,c.width,c.height);}
}
function saveNotificacion(){
  var genera=G('not-genera').value;var notif=G('not-notificado').value;
  var instruccion=G('not-instruccion').value.trim();
  var respuesta=G('not-respuesta').value.trim();
  var al=G('not-alert');
  if(!genera){al.className='alert alert-er on';al.textContent='Seleccione quién genera.';return;}
  if(!notif){al.className='alert alert-er on';al.textContent='Seleccione el notificado.';return;}
  if(!instruccion){al.className='alert alert-er on';al.textContent='Escribe la instrucción.';return;}
  // Capturar firma
  var canvas=G('not-firma-canvas');
  var firmaData='';var firmada=false;
  if(canvas){
    var blank=document.createElement('canvas');blank.width=canvas.width;blank.height=canvas.height;
    firmaData=canvas.toDataURL('image/png');
