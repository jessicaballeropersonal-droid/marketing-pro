function setSem(tipo,filaId,sem){
  if(!_inspSession[tipo])_inspSession[tipo]={};
  var prev=(_inspSession[tipo][filaId]||{}).sem;
  _inspSession[tipo][filaId]=_inspSession[tipo][filaId]||{};
  _inspSession[tipo][filaId].sem=sem;
  // Re-render if sem changed (to show/hide obs row)
  if(prev!==sem)_renderInspTab(tipo);
}
function _inspSetObs(tipo,filaId,val){
  if(!_inspSession[tipo])_inspSession[tipo]={};
  if(!_inspSession[tipo][filaId])_inspSession[tipo][filaId]={};
  _inspSession[tipo][filaId].obs=val;
}
function _inspSetFoto(tipo,filaId,input){
  var file=input.files[0];if(!file)return;
  // Compress to WebP 80%
  var reader=new FileReader();
  reader.onload=function(e){
    var img=new Image();
    img.onload=function(){
      var canvas=document.createElement('canvas');
      var maxW=800,maxH=600;
      var w=img.width,h=img.height;
      if(w>maxW){h=Math.round(h*maxW/w);w=maxW;}
      if(h>maxH){w=Math.round(w*maxH/h);h=maxH;}
      canvas.width=w;canvas.height=h;
      canvas.getContext('2d').drawImage(img,0,0,w,h);
      var webp=canvas.toDataURL('image/webp',0.8);
      if(!_inspSession[tipo])_inspSession[tipo]={};
      if(!_inspSession[tipo][filaId])_inspSession[tipo][filaId]={};
      _inspSession[tipo][filaId].foto=webp;
      _renderInspTab(tipo);
    };
    img.src=e.target.result;
  };
  reader.readAsDataURL(file);
}

function guardarInspeccion(tipo){
  var sess=_inspSession[tipo]||{};
  var filas=S.inspeccionPlantillas[tipo]||[];
  // Validate: rojo needs obs and foto
  var errFila=null;
  filas.forEach(function(f){
    var s=sess[f.id]||{};
    if(s.sem==='er'){
      if(!s.obs){errFila='El punto "'+f.equipo+' — '+f.punto+'" marcado 🔴 requiere observación.';}
      if(!s.foto&&!errFila){errFila='El punto "'+f.equipo+' — '+f.punto+'" marcado 🔴 requiere foto.';}
    }
  });
  if(errFila){
    modalAviso({tipo:'warn',titulo:'Validación de inspección',contenidoHtml:'<div style="font-size:12px;color:var(--tx2);line-height:1.6">'+errFila+'</div>',botonSecundario:'Entendido'});
    return;
  }

  var now=new Date();
  var hora=now.toLocaleTimeString('es-CO',{hour:'2-digit',minute:'2-digit'});
  var registro={
    id:uid(),tipo:tipo,fecha:today(),hora:hora,timestamp:Date.now(),
    tecnico:SESION?SESION.nombre:'',tecnicoId:SESION?SESION.id:'',
    puntos:filas.map(function(f){
      var s=sess[f.id]||{};
      return{filaId:f.id,equipo:f.equipo,punto:f.punto,sem:s.sem||'',obs:s.obs||'',foto:s.foto||''};
    })
  };
  if(!S.inspeccionHistorial)S.inspeccionHistorial=[];
  S.inspeccionHistorial.push(registro);

  // Generate Auto-OTs for amarillo and rojo
  var otGeneradas=0;
  filas.forEach(function(f){
    var s=sess[f.id]||{};
    if(s.sem==='wa'||s.sem==='er'){
      var otNum=(S.mantOtPlantaNum||1);
      if(!S.mantOrdenes)S.mantOrdenes=[];
      var ot={
        id:uid(),
        numero:'OT-INS-'+String(otNum).padStart(4,'0'),
        tipo:'inspeccion',
        origen:'Check List '+tipo.charAt(0).toUpperCase()+tipo.slice(1),
        origenId:registro.id,
        equipo:f.equipo,
        punto:f.punto,
        desc:f.desc+(s.obs?' | Obs: '+s.obs:''),
        foto:s.foto||'',
        semaforo:s.sem,
        fecha:today(),hora:hora,
        estado:S.inspeccionOTEstados[0]?S.inspeccionOTEstados[0].id:'iots_rep',
        historialEstados:[{
          fecha:today(),hora:hora,
          estadoNuevo:S.inspeccionOTEstados[0]?S.inspeccionOTEstados[0].id:'iots_rep',
          obs:'Generada automáticamente desde Check List '+tipo,
          usuario:SESION?SESION.nombre:'Sistema'
        }],
        creadoPor:SESION?SESION.nombre:'',
      };
      S.mantOrdenes.push(ot);
      S.mantOtPlantaNum=(otNum+1);
      otGeneradas++;
    }
  });

  dbSaveInsp();
  if(otGeneradas>0){
    supaUpsert('config',{key:'mantOrdenes',value:JSON.stringify(S.mantOrdenes)});
    supaUpsert('config',{key:'mantOtPlantaNum',value:String(S.mantOtPlantaNum||1)});
  }
  _inspSession[tipo]={};
  _updateInspBadge();
  modalAviso({tipo:'success',titulo:'Inspección guardada',contenidoHtml:'<div style="font-size:12px;color:var(--tx2);line-height:1.6">La inspección fue guardada correctamente.'+(otGeneradas>0?' Se generaron <strong>'+otGeneradas+' Auto-OT</strong> para las anomalías detectadas.':'')+'</div>',botonSecundario:'Cerrar'});
  _renderInspTab(tipo);
}

