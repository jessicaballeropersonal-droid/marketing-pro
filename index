<body>
<!-- ═══ PANTALLA DE LOGIN ═══ -->
<div id="login-screen" style="display:flex;position:fixed;inset:0;z-index:99999;background:var(--bg0);align-items:center;justify-content:center;flex-direction:column">
  <div style="width:100%;max-width:380px;padding:20px">
    <div style="text-align:center;margin-bottom:28px">
      <div style="background:var(--or);display:inline-block;padding:10px 22px;border-radius:8px;margin-bottom:10px">
        <div style="font-size:28px;font-weight:900;letter-spacing:5px;color:#fff;font-family:var(--H)">🎯 MARKETING PRO</div>
      </div>
      <div style="font-family:var(--M);font-size:9px;color:var(--tx3);letter-spacing:3px;margin-top:4px">SISTEMA DE GESTIÓN INDUSTRIAL</div>
    </div>
    <div style="background:var(--bg1);border:1.5px solid var(--bd2);border-radius:14px;padding:22px;box-shadow:0 4px 20px rgba(0,0,0,.12)">
      <div id="login-alert" style="display:none;padding:8px 12px;border-radius:6px;margin-bottom:12px;font-family:var(--M);font-size:9px;background:var(--erA);border:1px solid var(--erB);color:var(--er)"></div>
      <div style="font-family:var(--M);font-size:8px;letter-spacing:2px;color:var(--tx3);text-transform:uppercase;margin-bottom:5px">Seleccionar Usuario</div>
      <select class="fs" id="login-user" style="margin-bottom:13px;width:100%" onchange="loginUserChange()">
        <option value="">— Seleccionar —</option>
      </select>
      <div style="font-family:var(--M);font-size:8px;letter-spacing:2px;color:var(--tx3);text-transform:uppercase;margin-bottom:5px">PIN de Acceso</div>
      <input type="password" class="fi" id="login-pin" placeholder="••••" maxlength="8" style="margin-bottom:16px;width:100%;font-size:20px;letter-spacing:8px;text-align:center" onkeydown="if(event.key==='Enter')doLogin()">
      <div id="login-role-badge" style="text-align:center;margin-bottom:13px;font-family:var(--M);font-size:9px;color:var(--tx3)"></div>
      <button class="btn btn-or" style="width:100%;justify-content:center;font-size:14px;padding:10px" onclick="doLogin()">Entrar →</button>
    </div>
    <div style="text-align:center;margin-top:14px;font-family:var(--M);font-size:8px;color:var(--tx4)">MARKETING PRO v1.0 · Solo personal autorizado</div>
  </div>
</div>

<div class="shell">
<aside class="sb">
  <div class="sb-logo"><div class="sb-logo-top"><div class="sb-brand">🎯 MARKETING<em> PRO</em></div><div class="sb-sub">Sistema de Gestión Industrial</div></div></div>
  <nav class="sb-nav">
    <div class="sb-dept">Marketing</div>
    <div class="nl on" id="nl-calendario" onclick="goTo('calendario')"><span class="nl-ico">📅</span><span>Calendario</span></div>
    <div class="nl" id="nl-kanban" onclick="goTo('kanban')"><span class="nl-ico">🗂️</span><span>Kanban</span></div>
    <div class="sb-dept">Sistema</div>
    <div class="nl" id="nl-usuarios" onclick="goTo('usuarios')"><span class="nl-ico">👥</span><span>Usuarios</span></div>
  </nav>
  <div class="sb-foot">Marketing Pro v1.0 · Supabase Cloud</div>
</aside>
<div class="main">
  <div class="sb-mobile" style="background:var(--bg1);border-bottom:1px solid var(--bd1);overflow-x:auto;flex-shrink:0;position:sticky;top:0;z-index:100;-webkit-overflow-scrolling:touch;scrollbar-width:none"><div style="display:flex;min-width:max-content;padding:0 4px"><div class="nl-m on" id="nlm-calendario" onclick="goTo('calendario')" style="display:flex;flex-direction:column;align-items:center;padding:8px 14px;cursor:pointer;border-bottom:2px solid var(--or);color:var(--or);font-family:var(--M);font-size:8px;letter-spacing:1px;white-space:nowrap;min-width:60px;user-select:none"><span style="font-size:16px;margin-bottom:3px">📅</span>CALEND.</div><div class="nl-m" id="nlm-kanban" onclick="goTo('kanban')" style="display:flex;flex-direction:column;align-items:center;padding:8px 14px;cursor:pointer;border-bottom:2px solid transparent;color:var(--tx3);font-family:var(--M);font-size:8px;letter-spacing:1px;white-space:nowrap;min-width:60px;user-select:none"><span style="font-size:16px;margin-bottom:3px">🗂️</span>KANBAN</div><div class="nl-m" id="nlm-usuarios" onclick="goTo('usuarios')" style="display:flex;flex-direction:column;align-items:center;padding:8px 14px;cursor:pointer;border-bottom:2px solid transparent;color:var(--tx3);font-family:var(--M);font-size:8px;letter-spacing:1px;white-space:nowrap;min-width:60px;user-select:none"><span style="font-size:16px;margin-bottom:3px">👥</span>USERS</div></div></div>
  <div class="topbar">
    <div class="tb-l"><div class="tb-ico" id="tb-ico">🪨</div><div><div class="tb-title" id="tb-ttl">EXPLOTACIÓN</div><div class="tb-sub2" id="tb-sub">Extracción de material del río</div></div></div>
    <div style="display:flex;align-items:center;gap:8px">
      <div id="tb-backup-badge" onclick="openBackupModal()" style="display:none;cursor:pointer;font-family:var(--M);font-size:9px;padding:5px 9px;border-radius:5px;font-weight:700;letter-spacing:.3px" title="Click para hacer backup"></div>
      <div id="tb-user" style="font-family:var(--M);font-size:9px;color:var(--tx2);text-align:right"></div>
      <button id="btn-dark-mode" onclick="toggleDarkMode()" style="background:none;border:1px solid var(--bd2);border-radius:6px;padding:4px 10px;cursor:pointer;font-size:13px;margin-right:6px" title="Modo oscuro/claro">🌙</button>
      <button class="btn btn-gh btn-sm" onclick="doLogout()" style="font-size:10px">⏏ Salir</button>
    </div>
  </div>
  <div class="content">

  <!-- EXPLOTACIÓN -->
  <div id="pg-exp" class="pg">
    <div class="slbl">Resumen Acumulado — m³ por Almacenamiento</div>
    <div class="kg">
      <div class="kpi">   <div class="kpi-lbl">Patio (Grava)</div><div class="kpi-val" style="color:var(--or)" id="kx-p">0.0</div><div class="kpi-unit">m³</div><div class="kpi-sub" id="kx-pv">0 viajes</div></div>
      <div class="kpi in"><div class="kpi-lbl">Tolva</div>         <div class="kpi-val" id="kx-t">0.0</div><div class="kpi-unit">m³</div><div class="kpi-sub" id="kx-tv2">0 viajes</div></div>
      <div class="kpi pu"><div class="kpi-lbl">Zaranda</div>       <div class="kpi-val" id="kx-z">0.0</div><div class="kpi-unit">m³</div><div class="kpi-sub" id="kx-zv">0 viajes</div></div>
      <div class="kpi cy"><div class="kpi-lbl">Arena Río</div>     <div class="kpi-val" id="kx-a">0.0</div><div class="kpi-unit">m³</div><div class="kpi-sub" id="kx-av">0 viajes</div></div>
      <div class="kpi ok"><div class="kpi-lbl">Total General</div> <div class="kpi-val" id="kx-tot">0.0</div><div class="kpi-unit">m³</div><div class="kpi-sub" id="kx-totv">0 viajes</div></div>
    </div>
    <div class="tabs">
      <div class="tab on" onclick="swT(this,'exp','reg')">➕ Registro Manual</div>
      <div class="tab"    onclick="swT(this,'exp','fil')">Filtros &amp; Gráfica</div>
      <div class="tab"    onclick="swT(this,'exp','his')">Historial</div>
    </div>
    <div id="exp-reg" class="tp on">
      <div class="card">
        <div class="card-hd"><div><div class="card-ttl">Registro Manual — Extracción</div><div class="card-sub">Múltiples fuentes · La clasificación se hace en Órdenes del Día</div></div></div>
        <div id="pa" class="alert"></div>
        <div style="background:var(--inA);border:1px solid var(--inB);border-radius:8px;padding:10px 14px;margin-bottom:13px;font-family:var(--M);font-size:8px;color:#60a5fa;line-height:1.8">
          📋 Aquí registras lo que se <strong>extrajo manualmente</strong> (sin Bitácora). Al guardar:<br>
          • Las cards de extracción → aparecen en <strong>Historial de Extracción</strong><br>
          • Tolva, Zaranda, PG→Tolva y Transformación → generan <strong>Orden del Día pendiente</strong> en Producción
        </div>

        <!-- Cabecera: Fecha, Turno, Proveedor (Equipo/Operador se definen en la Orden de Producción) -->
        <div class="fg ca" style="margin-bottom:11px">
          <div class="ff"><div class="fl">Fecha</div><input type="date" class="fi" id="pf"></div>
          <div class="ff"><div class="fl">Turno</div><select class="fs" id="ptu"><option value="dia">☀️ Día</option><option value="noche">🌙 Noche</option></select></div>
          <div class="ff"><div class="fl">Proveedor</div><select class="fs" id="prm-prov"><option value="">— Sin proveedor —</option></select></div>
        </div>

        <!-- ══ SECCIÓN 1: EXTRACCIONES (4 cards) ══ -->
        <div style="display:flex;align-items:center;gap:8px;margin:14px 0 8px">
          <div style="width:24px;height:24px;background:var(--orA);border-radius:6px;display:flex;align-items:center;justify-content:center;color:var(--or);font-size:14px">🪨</div>
          <div style="font-family:var(--M);font-size:9px;font-weight:700;letter-spacing:1.5px;color:var(--tx2)">EXTRACCIONES — ENTRA MATERIAL AL SISTEMA</div>
        </div>
        <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:7px;margin-bottom:9px">

          <!-- 1. PATIO -->
          <div style="background:var(--orA);border:1.5px solid var(--or);border-radius:10px;padding:10px">
            <div style="font-family:var(--M);font-size:7px;color:var(--or);letter-spacing:1px;font-weight:700;margin-bottom:2px">🪨 PATIO</div>
            <div style="font-family:var(--M);font-size:6px;color:var(--tx3);font-style:italic;margin-bottom:8px">Solo apila Grava</div>
            <div class="ff" style="margin-bottom:6px"><div class="fl">Viajes</div><input type="number" class="fi" id="rm-patio-vj" min="0" value="0" oninput="rmCalc()"></div>
            <div class="ff" style="margin-bottom:6px"><div class="fl">m³/Viaje</div><input type="number" class="fi" id="rm-patio-m3v" min="0" step="0.5" value="14" oninput="rmCalc()"></div>
            <div class="ff"><div class="fl">Subtotal m³</div><input class="fi" id="rm-patio-tot" readonly style="color:var(--or);font-weight:700"></div>
          </div>

          <!-- 2. TOLVA -->
          <div style="background:rgba(96,165,250,.08);border:1.5px solid #60a5fa;border-radius:10px;padding:10px">
            <div style="font-family:var(--M);font-size:7px;color:#60a5fa;letter-spacing:1px;font-weight:700;margin-bottom:2px">🏗️ TOLVA</div>
            <div style="font-family:var(--M);font-size:6px;color:var(--tx3);font-style:italic;margin-bottom:8px">Se clasificará en Órdenes</div>
            <div class="ff" style="margin-bottom:6px"><div class="fl">Viajes</div><input type="number" class="fi" id="rm-tolva-vj" min="0" value="0" oninput="rmCalc()"></div>
            <div class="ff" style="margin-bottom:6px"><div class="fl">m³/Viaje</div><input type="number" class="fi" id="rm-tolva-m3v" min="0" step="0.5" value="14" oninput="rmCalc()"></div>
            <div class="ff"><div class="fl">Subtotal m³</div><input class="fi" id="rm-tolva-tot" readonly style="color:#60a5fa;font-weight:700"></div>
          </div>

          <!-- 3. ZARANDA -->
          <div style="background:rgba(192,132,252,.08);border:1.5px solid #c084fc;border-radius:10px;padding:10px">
            <div style="font-family:var(--M);font-size:7px;color:#c084fc;letter-spacing:1px;font-weight:700;margin-bottom:2px">🔮 ZARANDA</div>
            <div style="font-family:var(--M);font-size:6px;color:var(--tx3);font-style:italic;margin-bottom:8px">Se clasificará en Órdenes</div>
            <div class="ff" style="margin-bottom:6px"><div class="fl">Viajes</div><input type="number" class="fi" id="rm-zaranda-vj" min="0" value="0" oninput="rmCalc()"></div>
            <div class="ff" style="margin-bottom:6px"><div class="fl">m³/Viaje</div><input type="number" class="fi" id="rm-zaranda-m3v" min="0" step="0.5" value="14" oninput="rmCalc()"></div>
            <div class="ff"><div class="fl">Subtotal m³</div><input class="fi" id="rm-zaranda-tot" readonly style="color:#c084fc;font-weight:700"></div>
          </div>

          <!-- 4. ARENA RÍO -->
          <div style="background:var(--cyA);border:1.5px solid var(--cy);border-radius:10px;padding:10px">
            <div style="font-family:var(--M);font-size:7px;color:var(--cy);letter-spacing:1px;font-weight:700;margin-bottom:2px">💧 ARENA RÍO</div>
            <div style="font-family:var(--M);font-size:6px;color:var(--tx3);font-style:italic;margin-bottom:8px">Solo apila Arena Río</div>
            <div class="ff" style="margin-bottom:6px"><div class="fl">Viajes</div><input type="number" class="fi" id="rm-arena-vj" min="0" value="0" oninput="rmCalc()"></div>
            <div class="ff" style="margin-bottom:6px"><div class="fl">m³/Viaje</div><input type="number" class="fi" id="rm-arena-m3v" min="0" step="0.5" value="14" oninput="rmCalc()"></div>
            <div class="ff"><div class="fl">Subtotal m³</div><input class="fi" id="rm-arena-tot" readonly style="color:var(--cy);font-weight:700"></div>
          </div>

        </div>

        <!-- ══ SECCIÓN 2: MOVIMIENTOS INTERNOS (2 cards) ══ -->
        <div style="display:flex;align-items:center;gap:8px;margin:14px 0 8px">
          <div style="width:24px;height:24px;background:var(--bg3);border-radius:6px;display:flex;align-items:center;justify-content:center;color:var(--tx2);font-size:14px">🔄</div>
          <div style="font-family:var(--M);font-size:9px;font-weight:700;letter-spacing:1.5px;color:var(--tx2)">MOVIMIENTOS INTERNOS — NO ENTRA NI SALE MATERIAL</div>
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:7px;margin-bottom:9px">

          <!-- 5. PATIO A PATIO -->
          <div style="background:rgba(192,132,252,.08);border:1.5px solid #c084fc;border-radius:10px;padding:10px">
            <div style="font-family:var(--M);font-size:7px;color:#c084fc;letter-spacing:1px;font-weight:700;margin-bottom:2px">🔄 PATIO A PATIO</div>
            <div style="font-family:var(--M);font-size:6px;color:var(--tx3);font-style:italic;margin-bottom:8px">No afecta inventario</div>
            <div class="fg c2">
              <div class="ff"><div class="fl">Viajes</div><input type="number" class="fi" id="rm-pp-vj" min="0" value="0" oninput="rmCalc()"></div>
              <div class="ff"><div class="fl">m³/Viaje</div><input type="number" class="fi" id="rm-pp-m3v" min="0" step="0.5" value="14" oninput="rmCalc()"></div>
            </div>
            <div class="ff" style="margin-top:6px"><div class="fl">Subtotal m³</div><input class="fi" id="rm-pp-tot" readonly style="color:#c084fc;font-weight:700"></div>
          </div>

          <!-- 6. PG → TOLVA -->
          <div style="background:var(--okA);border:1.5px solid var(--ok);border-radius:10px;padding:10px">
            <div style="font-family:var(--M);font-size:7px;color:var(--ok);letter-spacing:1px;font-weight:700;margin-bottom:2px">🪨 PG → TOLVA</div>
            <div style="font-family:var(--M);font-size:6px;color:var(--tx3);font-style:italic;margin-bottom:8px">Descuenta Grava · Se clasificará en Órdenes</div>
            <div style="background:var(--bg1);border:1px solid var(--okB);border-radius:5px;padding:4px 7px;margin-bottom:6px;font-family:var(--M);font-size:8px">
              <span style="color:var(--tx3)">STOCK GRAVA: </span>
              <span style="font-weight:700;color:var(--ok)" id="rm-pgtolva-stock">—</span>
            </div>
            <div class="fg c2">
              <div class="ff"><div class="fl">Viajes</div><input type="number" class="fi" id="rm-pgtolva-vj" min="0" value="0" oninput="rmCalc()"></div>
              <div class="ff"><div class="fl">m³/Viaje</div><input type="number" class="fi" id="rm-pgtolva-m3v" min="0" step="0.5" value="14" oninput="rmCalc()"></div>
            </div>
            <div class="ff" style="margin-top:6px"><div class="fl">Subtotal m³</div><input class="fi" id="rm-pgtolva-tot" readonly style="color:var(--ok);font-weight:700"></div>
          </div>

        </div>

        <!-- ══ SECCIÓN 3: TRANSFORMACIÓN (1 card) ══ -->
        <div style="display:flex;align-items:center;gap:8px;margin:14px 0 8px">
          <div style="width:24px;height:24px;background:var(--cyA);border-radius:6px;display:flex;align-items:center;justify-content:center;color:var(--cy);font-size:14px">🔀</div>
          <div style="font-family:var(--M);font-size:9px;font-weight:700;letter-spacing:1.5px;color:var(--tx2)">TRANSFORMACIÓN — CONVIERTE UN PT EN OTRO PT</div>
        </div>
        <div style="background:var(--cyA);border:1.5px solid var(--cy);border-radius:10px;padding:10px;margin-bottom:9px">
          <div style="font-family:var(--M);font-size:7px;color:var(--cy);letter-spacing:1px;font-weight:700;margin-bottom:2px">🔀 PT → PT</div>
          <div style="font-family:var(--M);font-size:6px;color:var(--tx3);font-style:italic;margin-bottom:8px">No toca Grava · Se clasificará en Órdenes</div>
          <div class="fg c3" style="align-items:end">
            <div class="ff"><div class="fl">PT Origen</div><select class="fs" id="rm-trans-origen" onchange="rmCalc()"><option value="">— Sin transformación —</option></select></div>
            <div class="ff"><div class="fl">Viajes</div><input type="number" class="fi" id="rm-trans-vj" min="0" value="0" oninput="rmCalc()"></div>
            <div class="ff"><div class="fl">m³/Viaje</div><input type="number" class="fi" id="rm-trans-m3v" min="0" step="0.5" value="14" oninput="rmCalc()"></div>
          </div>
          <div class="fg c2" style="margin-top:6px">
            <div class="ff"><div class="fl">Stock disponible PT</div><input class="fi" id="rm-trans-stock" readonly style="font-size:11px;color:var(--tx2)"></div>
            <div class="ff"><div class="fl">Subtotal m³</div><input class="fi" id="rm-trans-tot" readonly style="color:var(--cy);font-weight:700"></div>
          </div>
        </div>

        <!-- ══ TOGGLE HORARIO ══ -->
