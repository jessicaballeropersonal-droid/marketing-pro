function getInv(){
  var inv={};
  S.prodTerm.forEach(function(p){inv[p.id]=0;});
  S.exp.records.forEach(function(r){
    if(r.pp)return; // Patio a Patio no afecta inventario
    var pid=r.ptId||ptIdBySrc(r.alm);
    if(pid&&r.tm)inv[pid]=(inv[pid]||0)+r.tm;
  });
  S.prod.records.forEach(function(r){
    if(r.pendienteClasif)return;
    // LÓGICA:
    // Grava(sys_patio) acumula Patio+Tolva+Zaranda desde exp.records
    // Al clasificar producción: descontar de cada fuente (patio, tolva, zaranda)
    // Arena Río: nunca toca producción
    var esTransfRec=r.esTransformacion||(r.fuenteId&&!isSysId(r.fuenteId)&&r.origenBit);
    if(r.fuentes&&r.fuentes.length){
      // Nuevo sistema: fuentes[] con alm y m3 exactos
      r.fuentes.forEach(function(f){
        if(f.alm==='arena_rio')return;
        if(f.alm==='transformacion'){
          if(f.origenId&&f.m3>0)inv[f.origenId]=(inv[f.origenId]||0)-f.m3;
          return;
        }
        var fid=ptIdBySrc(f.alm);
        if(fid&&f.m3>0)inv[fid]=(inv[fid]||0)-f.m3;
      });
    } else if(esTransfRec&&r.fuenteId&&r.fuenteM3){
      // Transformacion sin fuentes[]: descontar del fuenteId directamente
      inv[r.fuenteId]=(inv[r.fuenteId]||0)-r.fuenteM3;
    } else if(!r.origenBit&&r.fuenteId&&r.fuenteM3){
      // Registro manual: descontar de su fuente declarada
      inv[r.fuenteId]=(inv[r.fuenteId]||0)-r.fuenteM3;
    }
    // origenBit sin fuentes[]: intentar descontar por alm desde dist[], sino todo de sys_patio
    if(!r.fuentes||!r.fuentes.length){
      if(r.origenBit){
        // Si dist[] tiene campo alm, descontar por fuente correcta
        var distHasAlm=r.dist&&r.dist.some(function(d){return d.alm;});
        if(distHasAlm){
          var almTotals={};
          (r.dist||[]).forEach(function(d){
            if(d.alm&&d.m3>0){almTotals[d.alm]=(almTotals[d.alm]||0)+d.m3;}
          });
          Object.keys(almTotals).forEach(function(alm){
            if(alm==='arena_rio')return;
            var fid=ptIdBySrc(alm);
            if(fid)inv[fid]=(inv[fid]||0)-almTotals[alm];
          });
        } else {
          // Fallback legacy: descontar total de sys_patio
          var totalDist=0;
          (r.dist||[]).forEach(function(d){totalDist+=d.m3||0;});
          if(totalDist>0){
            var gravId=ptIdBySrc('patio');
            if(gravId)inv[gravId]=(inv[gravId]||0)-totalDist;
          }
        }
      }
    }
    // Sumar productos clasificados
    (r.dist||[]).forEach(function(d){if(d.ptId&&d.m3)inv[d.ptId]=(inv[d.ptId]||0)+d.m3;});
  });
  S.desp.records.forEach(function(r){
    (r.items||[]).forEach(function(it){if(it.ptId&&it.m3)inv[it.ptId]=(inv[it.ptId]||0)-it.m3;});
  });
  return inv;
}
