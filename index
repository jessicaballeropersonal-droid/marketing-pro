function _iadmAddEmpresa(){
  var n=prompt('Nombre de la empresa/cliente:');
  if(!n)return;
  _iadmEnsure();
  S.informeAdm.empresas.push({id:uid(),nombre:n.toUpperCase(),color:'#'+Math.floor(Math.random()*0xffffff).toString(16).padStart(6,'0'),activa:true});
  _iadmSave();
  _iadmRenderConfig(G('iadm-content'));
}

function _iadmEditEmpresa(id){
  var e=(S.informeAdm.empresas||[]).find(function(x){return x.id===id;});
  if(!e)return;
  var n=prompt('Nombre de la empresa:',e.nombre);
  if(n)e.nombre=n.toUpperCase();
  _iadmSave();
  _iadmRenderConfig(G('iadm-content'));
}

function _iadmToggleEmpresa(id){
  var e=(S.informeAdm.empresas||[]).find(function(x){return x.id===id;});
  if(e)e.activa=!e.activa;
  _iadmSave();
  _iadmRenderConfig(G('iadm-content'));
}

function _iadmDelEmpresa(id){
  cc('¿Eliminar esta empresa? Se perderán los precios asociados en todos los meses.',function(){
    S.informeAdm.empresas=(S.informeAdm.empresas||[]).filter(function(e){return e.id!==id;});
    _iadmSave();
    _iadmRenderConfig(G('iadm-content'));
  });
}

function _iadmRestoreItem(seccion,itemId){
  var it=(S.informeAdm.items[seccion]||[]).find(function(x){return x.id===itemId;});
  if(it){it.archivado=false;}
  _iadmSave();
  _iadmRenderConfig(G('iadm-content'));
}


