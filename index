  if(a.estado==='nueva')html+='<span style="background:'+bgsoft+';color:'+txsoft+';font-size:8px;font-weight:700;padding:3px 7px;border-radius:5px;letter-spacing:.8px;font-family:var(--M)">⚡ NUEVA</span>';
