  var today=new Date().toISOString().slice(0,10);
  sv('feq-c-fecha',today);
  renderFungEqPiezas();
  feqFillHistSelects();
}

function feqGetLastHoroOdo(eqId, fecha){
  // Get latest bitacora up to given date for this equipo
  var bits=S.mantBitacoras.filter(function(b){return b.equipoId===eqId&&b.fecha<=fecha;});
  bits.sort(function(a,b){return b.fecha.localeCompare(a.fecha)||(b.turno||'').localeCompare(a.turno||'');});
  if(!bits.length)return{horom:null,odo:null};
  var last=bits[0];
  return{horom:last.horoFin!=null?last.horoFin:(last.horoIni||null),odo:last.odoFin!=null?last.odoFin:(last.odoIni||null)};
}

function feqLoadBitInfo(){
  var eqId=gv('feq-c-eq');
  var fecha=gv('feq-c-fecha')||new Date().toISOString().slice(0,10);
  if(!eqId){G('feq-c-horom').value='';G('feq-c-odo').value='';return;}
  var info=feqGetLastHoroOdo(eqId,fecha);
  G('feq-c-horom').value=info.horom!=null?info.horom+'h':'Sin datos';
  var odoWrap=G('feq-c-odo-wrap');
  if(info.odo!=null){if(odoWrap)odoWrap.style.display='block';G('feq-c-odo').value=info.odo+' km';}
  else{if(odoWrap)odoWrap.style.display='none';}
  // fill piezas for this equipo
  feqFillPiezasSel(eqId);
}

function feqFillPiezasSel(eqId){
  var sel=G('feq-c-pieza');if(!sel)return;
  var piezas=S.fungPiezasEq.filter(function(p){return!p.eqId||p.eqId===eqId;});
  sel.innerHTML='<option value="">— Seleccionar —</option>';
  piezas.forEach(function(p){sel.innerHTML+='<option value="'+p.id+'">'+p.nombre+'</option>';});
