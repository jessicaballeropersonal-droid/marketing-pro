}
function _rastCrearAutoTarea(a){
  if(!S.tareas)S.tareas=[];
  var modoB2B=a.modo==='b2b';
  var titulo,descripcion,fechaVenc;
  var hoy=new Date();
  if(modoB2B){
    var nombre=(a.adjudicatario&&a.adjudicatario.nombre)||'contratista';
    titulo='📞 Llamar a '+nombre+' · ofrecer materiales';
    descripcion='Obra: '+(a.titulo||'?')+' · '+(a.municipio||'')+(a.valor?' · '+_rastFmt$(a.valor):'')+(a.adjudicatario&&a.adjudicatario.nit?'\nNIT: '+a.adjudicatario.nit:'')+(a.contacto&&a.contacto.telefono?'\nTel: '+a.contacto.telefono:'')+(a.contacto&&a.contacto.correo?'\nCorreo: '+a.contacto.correo:'');
    hoy.setDate(hoy.getDate()+3);
  }else{
    titulo='📋 Preparar oferta '+(a.municipio||'')+' · '+(a.titulo||'').substring(0,40);
    descripcion='Proceso: '+(a.id_proceso||'?')+' · '+(a.modalidad||'')+(a.fecha_cierre?'\nCierre: '+a.fecha_cierre:'')+(a.requisitos&&a.requisitos.rup_unspsc?'\nRUP UNSPSC: '+a.requisitos.rup_unspsc.join(', '):'');
    // Vencimiento = 5 días antes del cierre
    if(a.fecha_cierre){var fc=new Date(a.fecha_cierre);if(!isNaN(fc.getTime())){fc.setDate(fc.getDate()-5);hoy=fc;}else{hoy.setDate(hoy.getDate()+7);}}
    else hoy.setDate(hoy.getDate()+7);
  }
  var prioridad=(a.valor||a.valor_estimado||0)>=1000000000?'alta':'media';
  var tarea={
    id:(typeof uid==='function'?uid():'tar_'+Date.now()),
    titulo:titulo,
    descripcion:descripcion,
    tipo:'operativa',
    prioridad:prioridad,
    fecha_vencimiento:hoy.toISOString().substring(0,10),
    estado:'todo',
    responsables:[],
    gestionadas:[],
    creado_por:(SESION&&SESION.id)||'rastreador',
    creado_en:(new Date()).toISOString().substring(0,10),
    comentarios:[{texto:'Auto-tarea creada por Rastreador AI · alerta '+a.id,fecha:(new Date()).toISOString(),autor:'rastreador'}],
    origen:'rastreador',
    rasUid:a.id,
    rasModo:a.modo
  };
  S.tareas.push(tarea);
  a.tareaId=tarea.id;
}
