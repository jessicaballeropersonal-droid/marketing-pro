  html+='<div>− Producción consumida: <strong style="color:var(--er)">'+R.prodConsumo.toFixed(2)+' m³</strong></div>';
  html+='<div>− Transformaciones desde Grava: <strong style="color:var(--er)">'+R.transfDesdeGrava.toFixed(2)+' m³</strong></div>';
  html+='<div>− Despachos de Grava: <strong style="color:var(--er)">'+despGrava.toFixed(2)+' m³</strong></div>';
  html+='<hr style="border:none;border-top:1px dashed var(--bd2);margin:7px 0">';
  html+='<div style="color:var(--or);font-size:14px"><strong>= Stock Grava esperado: '+stockGravaCalc.toFixed(2)+' m³</strong></div>';
