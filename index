      html+='<span class="bdg bdg-er" style="display:inline-flex;align-items:center;gap:5px">⏸ '+(m.causaNombre||'Tiempo muerto')+': '+mToHM(m.min)+'<span class="tag-x" data-tid="'+r.id+'" data-mi="'+mi+'" style="cursor:pointer;margin-left:2px">×</span></span>';
