    +'<input type="checkbox" id="alt-act-'+id+'" '+(activa?'checked':'')+' '+(isAdmin?'':'disabled')+' onchange="saveAlertaToggle(\''+id+'\')">'
    +'<span style="font-family:var(--M);font-size:8px;color:'+(activa?'var(--ok)':'var(--tx3)')+'">'+( activa?'Activa':'Inactiva')+'</span>'
    +'</label>'
    +'</div></div>'
    // Umbral
    +(unidad&&isAdmin?'<div style="display:flex;align-items:center;gap:8px;margin-bottom:8px">'
      +'<span style="font-family:var(--M);font-size:8px;color:var(--tx3)">Umbral:</span>'
      +'<input type="number" id="alt-umb-'+id+'" value="'+(cfg.umbral!==undefined?cfg.umbral:defUmbral)+'" style="width:70px;height:26px;font-size:11px;text-align:center;border:1px solid var(--bd2);border-radius:5px;background:var(--bg3)" onchange="saveAlertaUmbral(\''+id+'\')">'
      +'<span style="font-size:11px;color:var(--tx3)">'+unidad+'</span>'
      +'</div>':'')
    // Destinatarios
    +'<div style="font-family:var(--M);font-size:7.5px;color:var(--tx3);margin-bottom:5px">QUIÉN RECIBE ESTA ALERTA:</div>'
    +'<div style="display:flex;flex-wrap:wrap;gap:5px">'
    +(S.usuarios||[]).map(function(u){
      var sel=(cfg.destinatarios||[]).indexOf(u.id)>-1;
      return'<label style="display:flex;align-items:center;gap:4px;padding:4px 10px;border-radius:20px;border:1px solid '+(sel?'var(--or)':'var(--bd2)')+';background:'+(sel?'var(--orA)':'var(--bg3)')+';cursor:pointer;font-size:11px;'+(isAdmin?'':'pointer-events:none')+'">'
        +'<input type="checkbox" '+(sel?'checked':'')+' '+(isAdmin?'':'disabled')+' style="margin:0" onchange="toggleAlertaDest(\''+id+'\',\''+u.id+'\')">'
        +'<span>'+u.nombre+'</span>'
        +(u.whatsapp?'<span style="font-size:10px">📱</span>':'<span style="font-size:10px;color:var(--wa)" title="Sin WhatsApp">⚠️</span>')
        +'</label>';
    }).join('')
    +(!(S.usuarios||[]).length?'<span style="font-size:11px;color:var(--tx3)">Sin usuarios creados.</span>':'')
