      if(a.contacto&&(a.contacto.telefono||a.contacto.correo)){
        html+='<div style="font-size:10px;color:var(--or);margin-top:4px;font-family:var(--M)">';
        if(a.contacto.telefono)html+='📞 '+_rastEsc(a.contacto.telefono);
        if(a.contacto.telefono&&a.contacto.correo)html+=' · ';
        if(a.contacto.correo)html+='✉ '+_rastEsc(a.contacto.correo);
        if(a.contacto.fuente_contacto)html+='<br><span style="font-size:8px;color:var(--tx3);font-style:italic">↑ '+_rastEsc(a.contacto.fuente_contacto)+'</span>';
        html+='</div>';
      }
      html+='</div>';
    }
    html+='<div style="font-size:11px;font-weight:500;color:var(--tx1);line-height:1.3;margin-bottom:6px"><b>Obra:</b> '+_rastEsc(a.titulo||'?')+'</div>';
    html+='<div style="font-size:10px;color:var(--tx2);margin-bottom:3px"><b>Entidad:</b> '+_rastEsc(a.entidad||'?')+'</div>';
