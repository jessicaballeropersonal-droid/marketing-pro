// S.actividad guarda todos los eventos: crear/editar/eliminar
// Persistencia: Supabase tabla 'actividad' o config como fallback
if(!S.actividad)S.actividad=[];

function logActividad(opts){
  // opts: {accion: 'crear'|'editar'|'eliminar', modulo: 'extraccion'|'produccion'|..., descripcion, registroId, antes, despues}
  try{
    if(!SESION)return; // No registrar acciones sin sesión activa
    var evt={
      id:uid(),
      ts:new Date().toISOString(),
      usuarioId:SESION.id||'',
      usuarioNombre:SESION.nombre||'?',
      usuarioRol:SESION.rol||'',
      accion:opts.accion||'crear',
      modulo:opts.modulo||'general',
      descripcion:opts.descripcion||'',
      registroId:opts.registroId||'',
      antes:opts.antes||null,
      despues:opts.despues||null
    };
    if(!S.actividad)S.actividad=[];
    S.actividad.unshift(evt); // Más reciente primero
    // Mantener máximo 5000 eventos en memoria (suficiente para varios meses)
    if(S.actividad.length>5000)S.actividad=S.actividad.slice(0,5000);
    // Guardar en Supabase (tabla actividad, con fallback a config)
    try{
      supaUpsert('actividad',{
        id:evt.id,ts:evt.ts,usuario_id:evt.usuarioId,usuario_nombre:evt.usuarioNombre,usuario_rol:evt.usuarioRol,
        accion:evt.accion,modulo:evt.modulo,descripcion:evt.descripcion,registro_id:evt.registroId,
        antes:evt.antes?JSON.stringify(evt.antes):null,
        despues:evt.despues?JSON.stringify(evt.despues):null
      });
    }catch(e){
      // Si falla Supabase (tabla no existe), guardar últimos 500 en config como fallback
      try{_dbSaveCfg('actividad',S.actividad.slice(0,500));}catch(e2){}
    }
    saveS();
  }catch(e){console.warn('logActividad error:',e);}
}

// Helper: comparar dos objetos y obtener solo los campos que cambiaron
function diffActividad(antes,despues,campos){
  // campos: array de nombres a comparar. Si no se pasa, compara todos los keys de despues
  var d={};
  var keys=campos||Object.keys(despues||{});
  keys.forEach(function(k){
    var a=antes?antes[k]:undefined;
    var n=despues?despues[k]:undefined;
    if(JSON.stringify(a)!==JSON.stringify(n)){
      d[k]={antes:a,despues:n};
    }
  });
  return Object.keys(d).length>0?d:null;
}

// Cargar historial desde Supabase al inicio
function syncActividadFromSupabase(){
  return supaFetch('GET','actividad',null,'order=ts.desc&limit=2000').then(function(r){
    if(r&&r.ok)return r.json();
    return [];
  }).then(function(rows){
    if(!Array.isArray(rows))return;
    S.actividad=rows.map(function(r){return {
      id:r.id,ts:r.ts,
      usuarioId:r.usuario_id,usuarioNombre:r.usuario_nombre,usuarioRol:r.usuario_rol,
      accion:r.accion,modulo:r.modulo,descripcion:r.descripcion,registroId:r.registro_id,
      antes:r.antes?(typeof r.antes==='string'?JSON.parse(r.antes):r.antes):null,
      despues:r.despues?(typeof r.despues==='string'?JSON.parse(r.despues):r.despues):null
    };});
  }).catch(function(){
    // Fallback: leer de config
    try{
      var stored=S.actividad;
      if(!Array.isArray(stored))S.actividad=[];
    }catch(e){S.actividad=[];}
  });
}

// ═══ UI HISTORIAL DE ACTIVIDAD ═══
function initActividadUI(){
  // Llenar select de usuarios deduplicado POR NOMBRE (v172.64): antes mostraba un ítem por
  // cada id del historial, así que un usuario recreado/borrado aparecía repetido. Ahora se
  // agrupa por nombre y el filtro trae toda su actividad (de cualquier id viejo).
  var sel=G('act-fu');if(!sel)return;
  var nombres={};
  (S.actividad||[]).forEach(function(e){if(e.usuarioNombre)nombres[e.usuarioNombre]=1;});
  (S.usuarios||[]).forEach(function(u){if(u.nombre)nombres[u.nombre]=1;});
  var opts='<option value="">Todos</option>';
  Object.keys(nombres).sort().forEach(function(n){opts+='<option value="'+(''+n).replace(/"/g,'&quot;')+'">'+n+'</option>';});
  sel.innerHTML=opts;
}

function actLimpiarFiltros(){
  ['act-fu','act-fm','act-fa','act-fd','act-fq'].forEach(function(id){var el=G(id);if(el)el.value='';});
  renderActividad();
}

function renderActividad(){
  var lista=G('act-lista');if(!lista)return;
  var fu=gv('act-fu'),fm=gv('act-fm'),fa=gv('act-fa'),fd2=gv('act-fd'),fq=(gv('act-fq')||'').toLowerCase();
  var eventos=(S.actividad||[]).slice();
  // Aplicar filtros
  if(fu)eventos=eventos.filter(function(e){return e.usuarioNombre===fu;});
  if(fm)eventos=eventos.filter(function(e){return e.modulo===fm;});
  if(fa)eventos=eventos.filter(function(e){return e.accion===fa;});
  if(fd2)eventos=eventos.filter(function(e){return e.ts&&e.ts>=fd2;});
  if(fq)eventos=eventos.filter(function(e){
    var txt=(e.descripcion||'')+' '+(e.usuarioNombre||'')+' '+(e.modulo||'');
    return txt.toLowerCase().indexOf(fq)>=0;
  });
  // Resumen
  var resumen=G('act-resumen');
  if(resumen){
    var usuariosUnicos={};eventos.forEach(function(e){usuariosUnicos[e.usuarioId]=1;});
    var nUsuarios=Object.keys(usuariosUnicos).length;
    resumen.innerHTML='📊 <strong>'+eventos.length+'</strong> eventos · 👥 <strong>'+nUsuarios+'</strong> usuario(s) distintos';
  }
  if(!eventos.length){
    lista.innerHTML='<div style="padding:30px;text-align:center;color:var(--tx3);font-family:var(--M);font-size:10px;font-style:italic">Sin eventos que mostrar.<br><br>Si recién activaste la auditoría, comienza a usar el sistema y los eventos aparecerán aquí.</div>';
    return;
  }
  // Mostrar máximo 200 más recientes
  var mostrar=eventos.slice(0,200);
  var html='';
  var iconos={crear:'➕',editar:'✏️',eliminar:'🗑️'};
  var colorAccion={crear:{bg:'var(--okA)',col:'var(--ok)'},editar:{bg:'var(--orA)',col:'var(--or)'},eliminar:{bg:'var(--erA)',col:'var(--er)'}};
  var modLbl={extraccion:'EXTRACCIÓN',produccion:'PRODUCCIÓN',despacho:'DESPACHO',bitacora:'BITÁCORA',mantenimiento:'MANTENIMIENTO',sesion:'SESIÓN',parametros:'PARÁMETROS',general:'GENERAL'};
  var modCol={extraccion:'var(--or)',produccion:'var(--in)',despacho:'var(--pu)',bitacora:'var(--cy)',mantenimiento:'var(--wa)',sesion:'var(--tx3)',parametros:'var(--ok)',general:'var(--tx2)'};
  mostrar.forEach(function(e,idx){
    var ic=iconos[e.accion]||'•';
    var clr=colorAccion[e.accion]||{bg:'var(--bg3)',col:'var(--tx2)'};
    var modL=modLbl[e.modulo]||(e.modulo||'').toUpperCase();
    var mCol=modCol[e.modulo]||'var(--tx2)';
    var fechaTs='';
    if(e.ts){
      try{
        var dt=new Date(e.ts);
        fechaTs=dt.toLocaleString('es-CO',{year:'numeric',month:'2-digit',day:'2-digit',hour:'2-digit',minute:'2-digit'});
      }catch(_){fechaTs=e.ts;}
    }
    var bgRow=idx%2===0?'var(--bg2)':'var(--bg1)';
    html+='<div style="padding:11px 14px;border-bottom:1px solid var(--bd2);background:'+bgRow+'">';
    html+='<div style="display:flex;align-items:flex-start;gap:11px">';
    html+='<div style="width:30px;height:30px;background:'+clr.bg+';border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:14px;flex-shrink:0">'+ic+'</div>';
    html+='<div style="flex:1;min-width:0">';
    html+='<div style="display:flex;flex-wrap:wrap;gap:6px;align-items:center;margin-bottom:4px">';
    html+='<span style="font-size:12px;font-weight:700;color:var(--tx1)">'+(e.usuarioNombre||'?')+'</span>';
    html+='<span style="background:'+clr.bg+';color:'+clr.col+';font-family:var(--M);font-size:8px;padding:2px 7px;border-radius:8px;font-weight:700;letter-spacing:.5px">'+(e.accion||'').toUpperCase()+'</span>';
    html+='<span style="background:var(--bg3);color:'+mCol+';font-family:var(--M);font-size:8px;padding:2px 7px;border-radius:8px;font-weight:700;letter-spacing:.5px;border:1px solid '+mCol+'">'+modL+'</span>';
    html+='</div>';
    html+='<div style="font-size:11px;color:var(--tx2);line-height:1.5;margin-bottom:4px">'+(e.descripcion||'(sin descripción)')+'</div>';
    // Mostrar antes/después si existen
    if(e.antes||e.despues){
      var cambios=[];
      if(e.accion==='editar'&&e.antes&&e.despues){
        // Comparar campos
        Object.keys(e.despues).forEach(function(k){
          var a=e.antes[k],n=e.despues[k];
          if(JSON.stringify(a)!==JSON.stringify(n)){
            cambios.push('<strong>'+k+':</strong> <s style="color:var(--er)">'+JSON.stringify(a)+'</s> → <span style="color:var(--ok)">'+JSON.stringify(n)+'</span>');
          }
        });
      } else if(e.accion==='crear'&&e.despues){
        Object.keys(e.despues).forEach(function(k){
          cambios.push('<strong>'+k+':</strong> '+JSON.stringify(e.despues[k]));
        });
      } else if(e.accion==='eliminar'&&e.antes){
        Object.keys(e.antes).forEach(function(k){
          cambios.push('<strong>'+k+':</strong> '+JSON.stringify(e.antes[k]));
        });
      }
      if(cambios.length){
        html+='<details style="margin-top:4px"><summary style="font-family:var(--M);font-size:8px;color:var(--tx3);cursor:pointer;letter-spacing:.5px">VER DETALLES ▾</summary>';
        html+='<div style="background:var(--bg3);border-left:2px solid '+clr.col+';padding:7px 9px;margin-top:5px;border-radius:0 5px 5px 0;font-family:var(--M);font-size:9px;color:var(--tx2);line-height:1.7">';
        html+=cambios.join('<br>');
        html+='</div></details>';
      }
    }
    html+='<div style="font-family:var(--M);font-size:8px;color:var(--tx3);margin-top:5px">⏰ '+fechaTs+'</div>';
    html+='</div></div></div>';
  });
  if(eventos.length>200){
    html+='<div style="padding:14px;text-align:center;font-family:var(--M);font-size:9px;color:var(--tx3);font-style:italic">Mostrando los 200 más recientes de '+eventos.length+'. Use filtros para acotar la búsqueda.</div>';
  }
  lista.innerHTML=html;
}

function actExportar(){
  var fu=gv('act-fu'),fm=gv('act-fm'),fa=gv('act-fa'),fd2=gv('act-fd'),fq=(gv('act-fq')||'').toLowerCase();
  var eventos=(S.actividad||[]).slice();
  if(fu)eventos=eventos.filter(function(e){return e.usuarioNombre===fu;});
  if(fm)eventos=eventos.filter(function(e){return e.modulo===fm;});
  if(fa)eventos=eventos.filter(function(e){return e.accion===fa;});
  if(fd2)eventos=eventos.filter(function(e){return e.ts&&e.ts>=fd2;});
  if(fq)eventos=eventos.filter(function(e){var txt=(e.descripcion||'')+' '+(e.usuarioNombre||'');return txt.toLowerCase().indexOf(fq)>=0;});
  if(!eventos.length){
    modalAviso({tipo:'info',titulo:'Sin eventos',contenidoHtml:'<div style="font-size:12px;color:var(--tx2);line-height:1.6">No hay eventos para exportar con los filtros actuales. Pruebe ajustando los filtros o limpiándolos.</div>',botonSecundario:'Entendido'});
    return;
  }
  var csv='Fecha,Hora,Usuario,Rol,Accion,Modulo,Descripcion,Antes,Despues\n';
  eventos.forEach(function(e){
    var dt=new Date(e.ts||0);
    var fechaStr=dt.toISOString().slice(0,10);
    var horaStr=dt.toISOString().slice(11,16);
    var antesStr=e.antes?JSON.stringify(e.antes).replace(/"/g,'""'):'';
    var despuesStr=e.despues?JSON.stringify(e.despues).replace(/"/g,'""'):'';
    var descStr=(e.descripcion||'').replace(/"/g,'""');
    csv+='"'+fechaStr+'","'+horaStr+'","'+(e.usuarioNombre||'')+'","'+(e.usuarioRol||'')+'","'+(e.accion||'')+'","'+(e.modulo||'')+'","'+descStr+'","'+antesStr+'","'+despuesStr+'"\n';
  });
  var blob=new Blob(['\ufeff'+csv],{type:'text/csv;charset=utf-8;'});
  var url=URL.createObjectURL(blob);
  var a=document.createElement('a');
  a.href=url;a.download='actividad_'+new Date().toISOString().slice(0,10)+'.csv';
  document.body.appendChild(a);a.click();document.body.removeChild(a);URL.revokeObjectURL(url);
}

