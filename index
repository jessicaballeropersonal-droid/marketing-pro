function saveProdManual(){
  if(!canWrite("prod")){showAlert('pa','er','Sin permisos.');return;}
  var f=gv('pf'),tu=gv('ptu'),provIdSel=gv('prm-prov');
  if(!f){showAlert('pa','er','Seleccione la fecha.');return;}
  // Nota: Equipo y Operador NO se piden aquí; se asignan en la Orden de Producción (Órdenes del Día)
  var cards=rmCardData();
  // Validar al menos una card con viajes
  var cardsActivas=cards.filter(function(c){return c.m3>0;});
  if(!cardsActivas.length){showAlert('pa','er','Debe llenar al menos una card con viajes.');return;}
  // Validar transformación tenga origen si tiene viajes
  var transC=cards[6];
  if(transC.m3>0&&!transC.origenId){showAlert('pa','er','Transformación: seleccione el PT Origen.');return;}
  // Validar stock para Transformación
  if(transC.m3>0&&transC.origenId){
    var stkO=invStock(transC.origenId);
    if(transC.m3>stkO+0.001){showAlert('pa','er','Stock insuficiente para Transformación. Disponible: '+stkO.toFixed(2)+' m³');return;}
  }
  // Validar stock Grava para PG→Tolva
  if(cards[5].m3>0){
    var stkG=invStock('sys_patio');
    if(cards[5].m3>stkG+0.001){showAlert('pa','er','Stock insuficiente de Grava para PG→Tolva. Disponible: '+stkG.toFixed(2)+' m³');return;}
  }
  // Horario (opcional)
  var horarioActivo=G('ph-toggle')?G('ph-toggle').checked:true;
  var ini='',fin='',des='00:00',netMin=0;
  if(horarioActivo){
    ini=gv('phi');fin=gv('phf');
    var desH=parseInt(gv('phd-h'))||0,desM=parseInt(gv('phd-m'))||0,desMin=desH*60+desM;
    des=pad(desH)+':'+pad(desM);
    if(ini&&fin){netMin=toMin(fin)-toMin(ini)-desMin;if(netMin<0)netMin+=1440;}
  }

  // ═══ 1) EXTRACCIONES (Patio, Tolva, Zaranda, Arena Río) → van a S.exp.records ═══
  ['patio','tolva','zaranda','arena'].forEach(function(k){
    var c=cards.find(function(x){return x.key===k;});
    if(!c||c.m3<=0)return;
    var almMap={patio:'patio',tolva:'tolva',zaranda:'zaranda',arena:'arena_rio'};
    var ptIdMap={patio:'sys_patio',tolva:'sys_tolva',zaranda:'sys_zaranda',arena:'sys_arena_rio'};
    var ptId=ptIdMap[k];
    var rec={id:uid(),fecha:f,provId:provIdSel,alm:almMap[k],turno:tu,
      dc:0,dm:0,dt:0,vc:c.vj,vm:c.m3v,vt:c.m3,tv:c.vj,tm:c.m3,
      ptId:ptId,origenBit:false};
    S.exp.records.push(rec);dbSaveExp(rec);
  });

  // ═══ 2) PATIO A PATIO → registro de extracción especial (no afecta inventario) ═══
  var ppC=cards[4];
  if(ppC.m3>0){
    var rPP={id:uid(),fecha:f,provId:provIdSel,alm:'patio',pp:true,turno:tu,
      dc:0,dm:0,dt:0,vc:ppC.vj,vm:ppC.m3v,vt:ppC.m3,tv:ppC.vj,tm:ppC.m3,
      ptId:'sys_patio',origenBit:false};
    S.exp.records.push(rPP);dbSaveExp(rPP);
  }

  // ═══ 3) CARDS que generan ORDEN PENDIENTE (Tolva, Zaranda, PG→Tolva, Transformación) ═══
  // NUEVO: NO se clasifica aquí — solo se crea registro con pendienteClasif:true
  // La clasificación se hace en Producción → Órdenes del Día
  var fuentesProd=[];var fuenteM3Tot=0;
  ['tolva','zaranda','pgtolva','trans'].forEach(function(k){
    var c=cards.find(function(x){return x.key===k;});
    if(!c||c.m3<=0)return;
    var almReal=k==='pgtolva'?'patio':(k==='trans'?'transformacion':c.alm);
    var fuenteObj={alm:almReal,vj:c.vj,m3v:c.m3v,m3:c.m3};
    if(k==='trans')fuenteObj.origenId=c.origenId;
    fuentesProd.push(fuenteObj);
    fuenteM3Tot+=c.m3;
  });

  if(fuentesProd.length>0){
    var totVjProd=fuentesProd.reduce(function(s,fu){return s+(fu.vj||0);},0);
    var esTransf=cards[6].m3>0;
    var recProd={id:uid(),fecha:f,turno:tu,equipoId:'',operadorId:'',
      fuentes:fuentesProd,fuenteM3:fuenteM3Tot,
      fuenteId:esTransf?cards[6].origenId:'sys_patio',
      dc:0,dm:0,dt:0,vc:totVjProd,vm:14,vt:0,tv:totVjProd,tm:0,
      ini:ini,des:des,fin:fin,netMin:netMin,netas:mFmt(netMin),
      dist:[],sinHorario:!horarioActivo,
      esTransformacion:esTransf,origenBit:false,pendienteClasif:true};
    S.prod.records.push(recProd);dbSaveProd(recProd);
  }

  // Log de actividad — Registro Manual
  var totM3Manual=cards.reduce(function(s,c){return s+c.m3;},0);
  var totVjManual=cards.reduce(function(s,c){return s+c.vj;},0);
  var detalleCards=cards.filter(function(c){return c.m3>0;}).map(function(c){return c.key+':'+c.m3.toFixed(1)+'m³';}).join(', ');
  logActividad({accion:'crear',modulo:'extraccion',descripcion:'Registro Manual '+f+' '+(tu==='dia'?'DÍA':'NOCHE')+' · '+totM3Manual.toFixed(1)+' m³ · '+totVjManual+' viajes ('+detalleCards+')',despues:{fecha:f,turno:tu,m3:totM3Manual,viajes:totVjManual,cards:detalleCards}});

  saveS();
  var msgExtra=fuentesProd.length>0?' Las cards de Tolva/Zaranda/PG→Tolva/Transformación quedaron pendientes en Producción → Órdenes del Día.':'';
  showAlert('pa','ok','✓ Registro guardado correctamente.'+msgExtra);
  // Limpiar formulario
  ['rm-patio-vj','rm-tolva-vj','rm-zaranda-vj','rm-arena-vj','rm-pp-vj','rm-pgtolva-vj','rm-trans-vj'].forEach(function(id){sv(id,'0');});
  sv('rm-trans-origen','');
  sv('pf',today());sv('prm-prov','');
  if(G('ph-toggle')){G('ph-toggle').checked=true;toggleHorario();}
  rmCalc();updPKPI();updDKPI();updXKPI();
  try{renderXH();renderPH();renderProdOrdenes();}catch(e){}
}
