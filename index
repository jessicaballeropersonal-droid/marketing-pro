function pordGuardarTurno(btn){
  var tk=btn.getAttribute('data-tk')||btn.getAttribute('data-turno');
  var turno=btn.getAttribute('data-turno');
  var rids=btn.getAttribute('data-rids').split(',');
  var alertId='pord-alert-'+tk;
  var eqId=gv('pord-eq-'+tk);
  var opId=gv('pord-op-'+tk);
  if(!eqId){showAlert(alertId,'er','⚠️ Debe seleccionar el Equipo de Trituración.');return;}
  if(!opId){showAlert(alertId,'er','⚠️ Debe seleccionar el Operador.');return;}
  var maxTransf2={patio:4,tolva:4,zaranda:2,transformacion:4};
  var ini=gv('pord-hi-'+tk),fin=gv('pord-hf-'+tk);
  var dh=parseInt(gv('pord-dh-'+tk))||0,dm=parseInt(gv('pord-dm-'+tk))||0;
  var desMin=dh*60+dm;
  var netMin=ini&&fin?toMin(fin)-toMin(ini)-desMin:0;if(netMin<0)netMin+=1440;

  // Calcular inventario base (actual)
  var invBase=getInv();

  // Calcular lo que se va a producir en este turno (de las otras fuentes: tolva, zaranda, patio)
  // para sumarlo al stock disponible al validar transformacion
  var prodEsteturno={};
  rids.forEach(function(rid){
    var r=S.prod.records.find(function(x){return x.id===rid;});
    if(!r||r.esTransformacion)return;
    var fuentes=r.fuentes&&r.fuentes.length?r.fuentes:[{alm:'patio',m3:r.fuenteM3||0,fuenteId:r.fuenteId||'sys_patio'}];
    fuentes.forEach(function(f){
      var maxT=maxTransf2[f.alm]||4;
      for(var i=1;i<=maxT;i++){
        var ptId=gv('pord-pt-'+tk+'-'+f.alm+'-'+i);
        var pct=parseFloat(gv('pord-pct-'+tk+'-'+f.alm+'-'+i))||0;
        if(ptId&&pct>0){
          var m3=f.m3*pct/100;
          prodEsteturno[ptId]=(prodEsteturno[ptId]||0)+m3;
        }
      }
    });
  });

  // Validar stock para transformacion — bloquear si inventario quedaría negativo
  var transRec=rids.map(function(rid){return S.prod.records.find(function(x){return x.id===rid;});})
    .find(function(r){return r&&(r.esTransformacion||(r.fuenteId&&!isSysId(r.fuenteId)));});
  if(transRec&&transRec.fuentes&&transRec.fuentes.length){
    var transF=transRec.fuentes.find(function(f){return f.alm==='transformacion';});
    if(transF&&transF.origenId){
      var stockActual=invBase[transF.origenId]||0;
      var stockConProd=stockActual+(prodEsteturno[transF.origenId]||0);
      if(stockConProd<transF.m3){
        var ptNombre=ptn(transF.origenId);
        showAlert(alertId,'er','⚠️ Stock insuficiente de "'+ptNombre+'" para Transformación. Disponible: '+stockConProd.toFixed(1)+' m³, requerido: '+transF.m3.toFixed(1)+' m³. Ajuste los porcentajes o el producto origen.');
        return;
      }
    }
  }
  rids.forEach(function(rid){
    var r=S.prod.records.find(function(x){return x.id===rid;});if(!r)return;
    var fuentes=r.fuentes&&r.fuentes.length?r.fuentes:[{alm:'patio',m3:r.fuenteM3||0,fuenteId:r.fuenteId||'sys_patio'}];
    var dist=[];
    fuentes.forEach(function(f){
      var maxT=maxTransf2[f.alm]||4;
      for(var i=1;i<=maxT;i++){
        var ptId=gv('pord-pt-'+tk+'-'+f.alm+'-'+i);
        var pct=parseFloat(gv('pord-pct-'+tk+'-'+f.alm+'-'+i))||0;
        if(ptId&&pct>0)dist.push({key:f.alm+'-'+i,alm:f.alm,ptId:ptId,pct:pct,m3:f.m3*pct/100});
      }
    });
    r.equipoId=eqId;r.operadorId=opId;
    r.ini=ini;r.fin=fin;r.des=pad(dh)+':'+pad(dm);
    r.netMin=netMin;r.netas=mFmt(netMin);
    // FIX: NO resetear r.tm si dist está vacío (preservar valor original)
    if(dist.length>0)r.tm=dist.reduce(function(s,d){return s+d.m3;},0);
    // FIX: NO resetear r.dist si está vacío (preservar valor original)
    if(dist.length>0)r.dist=dist;
    r.pendienteClasif=false;
    // FIX: Preservar fuenteId original si no existía en r.fuentes
    if(!r.fuenteId&&fuentes.length>0&&fuentes[0].fuenteId)r.fuenteId=fuentes[0].fuenteId;
    if(!r.fuenteM3||r.fuenteM3===0){
      r.fuenteM3=fuentes.reduce(function(s,f){return s+(f.m3||0);},0);
    }
    // Preservar fuentes originales — NO sobreescribir m3 con dist
    // (las fuentes representan lo que entró desde bitácora, no lo clasificado)
    dbSaveProd(r);
  });
  // Log actividad — clasificación
  var registrosLog=rids.map(function(rid){return S.prod.records.find(function(x){return x.id===rid;});}).filter(function(r){return r;});
  var rid0=registrosLog[0]&&registrosLog[0].id;
  var fechaLog=registrosLog[0]&&registrosLog[0].fecha;
  var totClasif=0;
  registrosLog.forEach(function(r){(r.dist||[]).forEach(function(d){totClasif+=d.m3||0;});});
  var ptsClasif=[];
  registrosLog.forEach(function(r){(r.dist||[]).forEach(function(d){if(d.ptId&&d.m3>0)ptsClasif.push(ptn(d.ptId)+':'+d.m3.toFixed(1)+'m³');});});
  logActividad({accion:'editar',modulo:'produccion',descripcion:'Clasificó orden '+fechaLog+' '+(turno==='dia'?'DÍA':'NOCHE')+' · '+totClasif.toFixed(2)+' m³ ('+ptsClasif.join(', ')+')',registroId:rid0,despues:{turno:turno,m3Total:totClasif,clasificaciones:ptsClasif}});
  updPKPI();renderProdOrdenes();
  var al=G('pa');if(al){al.className='alert alert-ok on';al.textContent='✅ Turno '+turno+' clasificado y guardado.';setTimeout(function(){al.className='alert';},3500);}
}
