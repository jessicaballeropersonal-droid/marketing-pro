  var eqId=gv('bit-m-equipo'),eq=S.mantEquipos.find(function(e){return e.id===eqId;});
  var ad=G('bit-m-alerta-cons'),msgs=[];
  if(eq&&cnh>0&&eq.acpmRefH>0){var varH=(cnh-eq.acpmRefH)/eq.acpmRefH*100;if(varH>(eq.alertaPct||15))msgs.push('⚠️ Consumo/hora '+cnh.toFixed(1)+' gal/h supera ref. '+eq.acpmRefH+' gal/h en '+varH.toFixed(0)+'%');}
