function iaEnviar(){
  var pregunta=(gv('ia-input')||'').trim();
  if(!pregunta){
    modalAviso({tipo:'info',titulo:'Pregunta vacía',contenidoHtml:'<div style="font-size:12px;color:var(--tx2);line-height:1.6">Escribe una pregunta antes de enviar.</div>',botonSecundario:'Entendido'});
    return;
  }
  // Ocultar welcome
  var wel=G('ia-welcome');if(wel)wel.style.display='none';
  // Agregar mensaje usuario en UI
  iaAgregarMensaje('user',pregunta);
  sv('ia-input','');
  // Agregar al historial conversacional
  _iaHistorial.push({role:'user',content:pregunta});
  // Mostrar "Analizando..."
  iaAgregarMensaje('thinking','');
  // Deshabilitar botón mientras procesa
  var btnEnv=document.querySelector('button[onclick="iaEnviar()"]');
  if(btnEnv){btnEnv.disabled=true;btnEnv.style.opacity='0.5';btnEnv.style.cursor='wait';}

  // Construir contexto de datos (resumen para no gastar tokens)
  var contexto=iaConstruirContexto();

  // Llamar al backend
  fetch('/api/chat',{
    method:'POST',
    headers:{'Content-Type':'application/json'},
    body:JSON.stringify({
      mensajes:_iaHistorial,
      contexto:contexto,
      modelo:'claude-sonnet-4-5-20250929'
    })
  })
  .then(function(r){return r.json().then(function(d){return{status:r.status,data:d};});})
  .then(function(res){
    iaQuitarThinking();
    if(btnEnv){btnEnv.disabled=false;btnEnv.style.opacity='';btnEnv.style.cursor='';}
    if(res.status!==200){
      // Error del backend
      var msg=res.data&&res.data.detalle?res.data.detalle:(res.data&&res.data.error?res.data.error:'Error desconocido');
      iaAgregarMensaje('ai','⚠️ <strong>No pude procesar tu pregunta.</strong><br><br><span style="color:var(--tx3);font-size:11px">'+msg+'</span><br><br>Verifica tu conexión a internet e inténtalo de nuevo.');
      // No agregar respuesta fallida al historial
      return;
    }
    var respuesta=(res.data&&res.data.respuesta)||'(respuesta vacía)';
    iaAgregarMensaje('ai',iaFormatearRespuesta(respuesta));
    // Agregar respuesta al historial conversacional
    _iaHistorial.push({role:'assistant',content:respuesta});
    // Limitar historial a 20 últimos mensajes (10 turnos) para no inflar tokens
    if(_iaHistorial.length>20){_iaHistorial=_iaHistorial.slice(-20);}
  })
  .catch(function(err){
    iaQuitarThinking();
    if(btnEnv){btnEnv.disabled=false;btnEnv.style.opacity='';btnEnv.style.cursor='';}
    iaAgregarMensaje('ai','⚠️ <strong>No pude conectar con el servicio.</strong><br><br><span style="color:var(--tx3);font-size:11px">'+(err.message||'Error de red')+'</span><br><br>Verifica tu conexión a internet e inténtalo de nuevo.');
  });
}

// Construye un resumen de datos del usuario para enviar como contexto
// IMPORTANTE: no enviamos TODOS los registros (gastaría muchos tokens), solo sumarios
// v171.8: Alcance = año actual completo (1 enero - 31 diciembre)
function iaConstruirContexto(){
  try{
    var ano=new Date().getFullYear();
    var desde=ano+'-01-01';
    var hasta=ano+'-12-31';

    // ═══ Inventario actual ═══
    var inv=getInv();
    var invStr=[];
    S.prodTerm.forEach(function(p){
      var stk=inv[p.id]||0;
      if(Math.abs(stk)>0.01)invStr.push(p.nombre+': '+stk.toFixed(1)+' m³');
    });

    // ═══ Producción año actual ═══
    var prodAno=S.prod.records.filter(function(r){return r.fecha>=desde&&r.fecha<=hasta&&!r.pendienteClasif;});
    var prodM3=0,prodViajes=0,transM3=0;
    var prodPorProducto={};
    var prodPorMes={};
    var prodPorEquipo={};
    prodAno.forEach(function(r){
      var esT=r.esTransformacion||(r.fuenteId&&!isSysId(r.fuenteId)&&r.origenBit);
      prodViajes+=r.tv||0;
      if(esT)transM3+=r.tm||0;else prodM3+=r.tm||0;
      (r.dist||[]).forEach(function(d){
        if(d.ptId&&d.m3>0){
          var pt=S.prodTerm.find(function(p){return p.id===d.ptId;});
          var pn=pt?pt.nombre:d.ptId;
          prodPorProducto[pn]=(prodPorProducto[pn]||0)+d.m3;
        }
      });
      var mes=r.fecha.substring(0,7);
      prodPorMes[mes]=(prodPorMes[mes]||0)+(r.tm||0);
      if(r.equipoId){
        var eq=S.equipos.find(function(e){return e.id===r.equipoId;});
        if(eq)prodPorEquipo[eq.nombre]=(prodPorEquipo[eq.nombre]||0)+(r.tm||0);
      }
    });

    // ═══ Despachos año actual ═══
    var despAno=S.desp.records.filter(function(r){return r.fecha>=desde&&r.fecha<=hasta;});
    var despM3=0;
    var despPorCliente={};
    var despPorProducto={};
    var despPorMes={};
    despAno.forEach(function(r){
      var mesD=r.fecha.substring(0,7);
      (r.items||[]).forEach(function(it){
        var m3=it.m3||0;
        despM3+=m3;
        var cli=r.cliente||'Sin cliente';
        despPorCliente[cli]=(despPorCliente[cli]||0)+m3;
        var pt=S.prodTerm.find(function(p){return p.id===it.ptId;});
        var pn=pt?pt.nombre:it.ptId;
        despPorProducto[pn]=(despPorProducto[pn]||0)+m3;
        despPorMes[mesD]=(despPorMes[mesD]||0)+m3;
      });
    });

    // Top clientes y productos
    var topCli=Object.keys(despPorCliente).map(function(k){return{n:k,m:despPorCliente[k]};})
      .sort(function(a,b){return b.m-a.m;}).slice(0,10);
    var topProdDesp=Object.keys(despPorProducto).map(function(k){return{n:k,m:despPorProducto[k]};})
      .sort(function(a,b){return b.m-a.m;});
    var topProdProd=Object.keys(prodPorProducto).map(function(k){return{n:k,m:prodPorProducto[k]};})
      .sort(function(a,b){return b.m-a.m;});

    // ═══ Extracción año actual ═══
    var extAno=S.exp.records.filter(function(r){return r.fecha>=desde&&r.fecha<=hasta&&r.provId!=='sys_ini'&&!r.pp;});
    var extM3=0;
    var extPorAlm={};
    var extPorMes={};
    extAno.forEach(function(r){
      extM3+=r.tm||0;
      extPorAlm[r.alm]=(extPorAlm[r.alm]||0)+(r.tm||0);
      var mesE=r.fecha.substring(0,7);
      extPorMes[mesE]=(extPorMes[mesE]||0)+(r.tm||0);
    });

    // ═══ Tiempos de operación año actual ═══
    var totOpMin=0,totMaMin=0,totMuMin=0;
    var causasMuerto={};
    S.prod.records.forEach(function(r){
      if(r.sinHorario||!r.netMin||r.netMin<=0)return;
      if(r.fecha<desde||r.fecha>hasta)return;
      var c=r.tiemClasif;if(!c)return;
      totOpMin+=c.operado||0;
      totMaMin+=c.mantenimiento||0;
      (c.muertos||[]).forEach(function(m){
        totMuMin+=m.min||0;
        var nom=(m.causaNombre||m.causa||'Sin causa').trim();
        causasMuerto[nom]=(causasMuerto[nom]||0)+(m.min||0);
      });
    });
    var topCausas=Object.keys(causasMuerto).map(function(k){return{n:k,m:causasMuerto[k]};})
      .sort(function(a,b){return b.m-a.m;}).slice(0,8);

    // ═══ Equipos y operadores ═══
    var equiposStr=(S.equipos||[]).map(function(e){return e.nombre;}).join(', ')||'(sin equipos)';

    // ═══ Mantenimiento ═══
    var otAbiertas=(S.mantOrdenes||[]).filter(function(o){return o.estado!=='cerrada'&&o.estado!=='completada';}).length;

    // ═══ Armar texto final ═══
    var ctx='';
    ctx+='# AÑO ANALIZADO: '+ano+'\n';
    ctx+='Rango: 1 enero '+ano+' al 31 diciembre '+ano+'\n\n';

    ctx+='## INVENTARIO ACTUAL (al día de hoy)\n';
    ctx+=invStr.length?invStr.join('\n'):'(sin stock registrado)';

    ctx+='\n\n## EXTRACCIÓN '+ano+'\n';
    ctx+='Total: '+extM3.toFixed(1)+' m³ ('+extAno.length+' registros)\n';
    Object.keys(extPorAlm).forEach(function(a){ctx+='  - '+a+': '+extPorAlm[a].toFixed(1)+' m³\n';});
    if(Object.keys(extPorMes).length){
      ctx+='Por mes:\n';
      Object.keys(extPorMes).sort().forEach(function(m){ctx+='  - '+m+': '+extPorMes[m].toFixed(1)+' m³\n';});
    }

    ctx+='\n## PRODUCCIÓN '+ano+'\n';
    ctx+='Total trituración: '+prodM3.toFixed(1)+' m³\n';
    ctx+='Total transformación: '+transM3.toFixed(1)+' m³\n';
    ctx+='Viajes totales: '+prodViajes+'\n';
    if(topProdProd.length){
      ctx+='Por producto (m³ producidos):\n';
      topProdProd.forEach(function(p){ctx+='  - '+p.n+': '+p.m.toFixed(1)+' m³\n';});
    }
    if(Object.keys(prodPorMes).length){
      ctx+='Por mes:\n';
      Object.keys(prodPorMes).sort().forEach(function(m){ctx+='  - '+m+': '+prodPorMes[m].toFixed(1)+' m³\n';});
    }
    if(Object.keys(prodPorEquipo).length){
      ctx+='Por equipo:\n';
      Object.keys(prodPorEquipo).sort(function(a,b){return prodPorEquipo[b]-prodPorEquipo[a];}).forEach(function(e){
        ctx+='  - '+e+': '+prodPorEquipo[e].toFixed(1)+' m³\n';
      });
    }

    ctx+='\n## DESPACHOS '+ano+'\n';
    ctx+='Total despachado: '+despM3.toFixed(1)+' m³ ('+despAno.length+' registros)\n';
    if(topProdDesp.length){
      ctx+='Por producto despachado:\n';
      topProdDesp.forEach(function(p){ctx+='  - '+p.n+': '+p.m.toFixed(1)+' m³\n';});
    }
    if(topCli.length){
      ctx+='Top 10 clientes:\n';
      topCli.forEach(function(c){ctx+='  - '+c.n+': '+c.m.toFixed(1)+' m³\n';});
    }
    if(Object.keys(despPorMes).length){
      ctx+='Por mes:\n';
      Object.keys(despPorMes).sort().forEach(function(m){ctx+='  - '+m+': '+despPorMes[m].toFixed(1)+' m³\n';});
    }

    var totMin=totOpMin+totMaMin+totMuMin;
    if(totMin>0){
      ctx+='\n## TIEMPOS DE OPERACIÓN '+ano+'\n';
      ctx+='Total horas: '+(totMin/60).toFixed(1)+' h\n';
      ctx+='  - Operado: '+(totOpMin/60).toFixed(1)+' h ('+(totOpMin/totMin*100).toFixed(1)+'%)\n';
      ctx+='  - Mantenimiento: '+(totMaMin/60).toFixed(1)+' h ('+(totMaMin/totMin*100).toFixed(1)+'%)\n';
      ctx+='  - Tiempo muerto: '+(totMuMin/60).toFixed(1)+' h ('+(totMuMin/totMin*100).toFixed(1)+'%)\n';
      if(topCausas.length){
        ctx+='Top causas de tiempo muerto:\n';
        topCausas.forEach(function(c){ctx+='  - '+c.n+': '+(c.m/60).toFixed(1)+' h\n';});
      }
    }

    ctx+='\n## OPERACIÓN GENERAL\n';
    ctx+='Equipos: '+equiposStr+'\n';
    ctx+='Operadores: '+(S.operadores||[]).length+'\n';
    ctx+='Conductores: '+(S.conductores||[]).length+'\n';
    ctx+='Clientes: '+(S.clientes||[]).length+'\n';
    ctx+='Proveedores: '+(S.proveedores||[]).length+'\n';
    ctx+='OT mantenimiento abiertas: '+otAbiertas+'\n';

    ctx+='\n## TOTALES HISTÓRICOS (todos los años)\n';
    ctx+='Extracciones: '+S.exp.records.length+' registros\n';
    ctx+='Producciones: '+S.prod.records.length+' registros\n';
    ctx+='Despachos: '+S.desp.records.length+' registros\n';

    return ctx;
  }catch(e){
    console.error('Error construyendo contexto IA:',e);
    return '(Error al construir contexto: '+e.message+')';
  }
}

// Formatea respuesta markdown a HTML simple
function iaFormatearRespuesta(texto){
  if(!texto)return '';
  var h=texto;
  // Escapar HTML primero (para que <script> u otros no se ejecuten)
  h=h.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  // Negrita: **texto** → <strong>texto</strong>
  h=h.replace(/\*\*([^*]+)\*\*/g,'<strong>$1</strong>');
  // Cursiva: *texto* → <em>texto</em>
  h=h.replace(/(^|[^*])\*([^*]+)\*([^*]|$)/g,'$1<em>$2</em>$3');
  // Código inline: `código` → <code>código</code>
  h=h.replace(/`([^`]+)`/g,'<code style="background:var(--bg3);padding:1px 5px;border-radius:3px;font-family:var(--M);font-size:11px">$1</code>');
  // Listas con guion o asterisco
  h=h.replace(/^[\s]*[-*]\s+(.+)$/gm,'<li style="margin-left:18px;list-style:disc">$1</li>');
  // Encabezados ### → bold con tamaño
  h=h.replace(/^### (.+)$/gm,'<div style="font-weight:700;color:var(--or);margin:8px 0 4px 0;font-size:13px">$1</div>');
  h=h.replace(/^## (.+)$/gm,'<div style="font-weight:700;color:var(--or);margin:10px 0 5px 0;font-size:14px">$1</div>');
  h=h.replace(/^# (.+)$/gm,'<div style="font-weight:700;color:var(--or);margin:12px 0 6px 0;font-size:15px">$1</div>');
  // Saltos de línea: \n → <br>
  h=h.replace(/\n/g,'<br>');
  return h;
}

