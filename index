  // Guardar historial de cambio de estado
  if(!ot.historialEstados)ot.historialEstados=[];
  var estadoLbl={creada:'Abierta',en_proceso:'En Proceso',completada:'Completada'};
  if(estadoAnterior!==nuevoEstado||ot.obsEstado){
    ot.historialEstados.push({
      fecha:today(),
      hora:new Date().toLocaleTimeString('es-CO',{hour:'2-digit',minute:'2-digit'}),
      estadoAnterior:estadoAnterior,
      estadoNuevo:nuevoEstado,
      obs:ot.obsEstado||'',
      usuario:SESION?SESION.nombre:'—'
    });
  }
  dbSaveMantOT(ot);cmo('ov-mant-ot-det');renderOTKpisMant();renderOTMant();renderMantDash();
}

