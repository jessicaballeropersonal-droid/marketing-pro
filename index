  var cnh=h>0&&acpm>0?parseFloat((acpm/h).toFixed(2)):0;sv('bit-m-cnh',cnh>0?cnh.toFixed(2):'');
  var cnv=vj>0&&acpm>0?parseFloat((acpm/vj).toFixed(2)):0;sv('bit-m-cnv',cnv>0?cnv.toFixed(2):'');
  bitMExtCalc();
  var oini=parseFloat(gv('bit-m-oini'))||0,ofin=parseFloat(gv('bit-m-ofin'))||0;
  var km=ofin>oini?Math.round(ofin-oini):0;
